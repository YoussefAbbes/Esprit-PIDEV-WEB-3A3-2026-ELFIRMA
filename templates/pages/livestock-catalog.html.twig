{% extends 'base.html.twig' %}

{% block title %}Livestock Catalog - EL FIRMA{% endblock %}
{% block body_class %}livestock-catalog-page{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
  <style>
    /* ═══════════════════════════════════════════════
       ROOT & RESET
    ═══════════════════════════════════════════════ */
    .livestock-catalog-page {
      --c-forest:   #0d3320;
      --c-moss:     #1a5c37;
      --c-fern:     #2d8653;
      --c-sage:     #86c49a;
      --c-mist:     #eaf4ed;
      --c-cream:    #faf8f3;
      --c-gold:     #c8a84b;
      --c-gold-lt:  #f0e0a0;
      --c-ink:      #111a14;
      --c-smoke:    #6b7c71;
      --shadow-sm:  0 4px 16px rgba(13,51,32,.09);
      --shadow-md:  0 14px 40px rgba(13,51,32,.14);
      --shadow-lg:  0 28px 72px rgba(13,51,32,.20);
      --r-card:     20px;
      --r-pill:     999px;
      font-family: 'DM Sans', sans-serif;
      background: var(--c-cream);
      color: var(--c-ink);
    }

    .livestock-catalog-page *,
    .livestock-catalog-page *::before,
    .livestock-catalog-page *::after { box-sizing: border-box; }

    /* ═══════════════════════════════════════════════
       PAGE HERO TITLE
    ═══════════════════════════════════════════════ */
    .livestock-catalog-page .page-title {
      padding-top: 110px;
      padding-bottom: 110px;
      position: relative;
      overflow: hidden;
    }

    .livestock-catalog-page .page-title::after {
      content: '🐄 🐑 🐔 🐖';
      position: absolute;
      right: 8%;
      bottom: -12px;
      font-size: 5rem;
      opacity: .12;
      letter-spacing: .4em;
      pointer-events: none;
      animation: float-icons 6s ease-in-out infinite alternate;
    }

    @keyframes float-icons {
      from { transform: translateY(0) rotate(-2deg); }
      to   { transform: translateY(-18px) rotate(2deg); }
    }

    /* ═══════════════════════════════════════════════
       MARQUEE TICKER
    ═══════════════════════════════════════════════ */
    .catalog-ticker {
      background: var(--c-forest);
      color: var(--c-gold-lt);
      overflow: hidden;
      white-space: nowrap;
      padding: 10px 0;
    }

    .catalog-ticker-track {
      display: inline-block;
      animation: ticker 28s linear infinite;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    @keyframes ticker {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    .catalog-ticker-track span { margin: 0 2.4rem; }
    .catalog-ticker-track .dot { color: var(--c-gold); opacity: .7; }

    /* ═══════════════════════════════════════════════
       INTRO SECTION
    ═══════════════════════════════════════════════ */
    .catalog-intro-section {
      padding: 80px 0 60px;
      background: var(--c-cream);
      position: relative;
      overflow: hidden;
    }

    .catalog-intro-section::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 60% at 85% 40%, rgba(45,134,83,.07) 0%, transparent 70%),
        radial-gradient(ellipse 50% 80% at 10% 70%, rgba(200,168,75,.06) 0%, transparent 60%);
      pointer-events: none;
    }

    /* floating leaf ornaments */
    .leaf-ornament {
      position: absolute;
      font-size: 2.4rem;
      opacity: .07;
      pointer-events: none;
      animation: leaf-drift 8s ease-in-out infinite alternate;
    }
    .leaf-ornament:nth-child(1) { top: 8%;  left: 3%;  animation-delay: 0s;   }
    .leaf-ornament:nth-child(2) { top: 60%; left: 6%;  animation-delay: 1.5s; font-size: 1.8rem; }
    .leaf-ornament:nth-child(3) { top: 20%; right: 4%; animation-delay: 3s;   }
    .leaf-ornament:nth-child(4) { top: 75%; right: 6%; animation-delay: 2s;   font-size: 1.6rem; }

    @keyframes leaf-drift {
      from { transform: translateY(0) rotate(-5deg) scale(1);   }
      to   { transform: translateY(-20px) rotate(8deg) scale(1.05); }
    }

    .intro-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, var(--c-forest) 0%, var(--c-moss) 100%);
      color: var(--c-gold-lt);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 7px 18px;
      border-radius: var(--r-pill);
      margin-bottom: 20px;
    }

    .intro-headline {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.4rem, 4.5vw, 4rem);
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -.02em;
      color: var(--c-forest);
      margin-bottom: 18px;
    }

    .intro-headline em {
      font-style: italic;
      color: var(--c-fern);
    }

    .intro-headline em {
      font-style: italic;
      color: var(--c-fern);
    }

    .intro-body {
      color: var(--c-smoke);
      font-size: 16px;
      line-height: 1.7;
      max-width: 420px;
      margin-bottom: 28px;
    }

    /* ── Feature pills ── */
    .feature-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 32px;
    }

    .feature-pill {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: #ffffff;
      border: 1.5px solid rgba(45,134,83,.18);
      border-radius: var(--r-pill);
      padding: 8px 16px;
      font-size: 13px;
      font-weight: 600;
      color: var(--c-moss);
      box-shadow: var(--shadow-sm);
      transition: transform .2s ease, box-shadow .2s ease;
    }

    .feature-pill:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    .feature-pill .pill-icon { font-size: 1rem; }

    /* ── KPI band ── */
    .kpi-band {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }

    .kpi-card {
      background: linear-gradient(160deg, #ffffff 0%, var(--c-mist) 100%);
      border: 1px solid rgba(45,134,83,.15);
      border-radius: var(--r-card);
      padding: 20px 18px;
      box-shadow: var(--shadow-sm);
      position: relative;
      overflow: hidden;
      transition: transform .25s ease, box-shadow .25s ease;
    }

    .kpi-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }

    .kpi-card::after {
      content: attr(data-icon);
      position: absolute;
      right: 10px; bottom: 6px;
      font-size: 2.4rem;
      opacity: .12;
      pointer-events: none;
    }

    .kpi-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .07em;
      color: var(--c-smoke);
      margin-bottom: 6px;
    }

    .kpi-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem;
      font-weight: 700;
      color: var(--c-forest);
      line-height: 1;
    }

    /* ── Intro visual ── */
    .intro-visual-wrap {
      border-radius: 28px;
      overflow: hidden;
      border: 2px solid rgba(45,134,83,.15);
      box-shadow: var(--shadow-lg);
      position: relative;
    }

    .intro-visual-wrap img {
      width: 100%;
      height: 100%;
      min-height: 480px;
      object-fit: cover;
      object-position: center;
      display: block;
      transition: transform 6s ease;
    }

    .intro-visual-wrap:hover img { transform: scale(1.04); }

    .intro-visual-badge {
      position: absolute;
      bottom: 20px;
      left: 20px;
      background: rgba(13,51,32,.85);
      backdrop-filter: blur(8px);
      color: #fff;
      border-radius: 14px;
      padding: 12px 18px;
      font-size: 13px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(255,255,255,.12);
    }

    .intro-visual-badge .badge-emoji { font-size: 1.5rem; }

    /* ═══════════════════════════════════════════════
       ANIMAL SHOWCASE STRIP
    ═══════════════════════════════════════════════ */
    .animal-strip {
      background: linear-gradient(135deg, var(--c-forest) 0%, var(--c-moss) 100%);
      padding: 36px 0;
    }

    .animal-strip-inner {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .animal-card {
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.14);
      border-radius: 18px;
      padding: 18px 22px;
      text-align: center;
      min-width: 110px;
      transition: transform .25s ease, background .25s ease;
      animation: pop-in .5s cubic-bezier(.34,1.56,.64,1) both;
    }

    .animal-card:hover {
      background: rgba(255,255,255,.16);
      transform: translateY(-6px) scale(1.04);
    }

    @keyframes pop-in {
      from { opacity: 0; transform: scale(.7) translateY(20px); }
      to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    .animal-card:nth-child(1) { animation-delay: .05s; }
    .animal-card:nth-child(2) { animation-delay: .12s; }
    .animal-card:nth-child(3) { animation-delay: .19s; }
    .animal-card:nth-child(4) { animation-delay: .26s; }
    .animal-card:nth-child(5) { animation-delay: .33s; }
    .animal-card:nth-child(6) { animation-delay: .40s; }

    .animal-card-emoji { font-size: 2.6rem; display: block; margin-bottom: 6px; }
    .animal-card-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .07em;
      color: var(--c-sage);
    }

    /* ═══════════════════════════════════════════════
       WORKBENCH SECTION
    ═══════════════════════════════════════════════ */
    .catalog-workbench {
      padding: 64px 0 80px;
      background: var(--c-cream);
    }

    .workbench-eyebrow {
      text-align: center;
      margin-bottom: 8px;
    }

    .workbench-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 3.5vw, 3rem);
      font-weight: 700;
      color: var(--c-forest);
      text-align: center;
      margin-bottom: 6px;
    }

    .workbench-sub {
      text-align: center;
      color: var(--c-smoke);
      font-size: 15px;
      margin-bottom: 44px;
    }

    /* ── Sidebar ── */
    .catalog-sidebar {
      background: #ffffff;
      border: 1.5px solid rgba(45,134,83,.13);
      border-radius: var(--r-card);
      padding: 28px 24px;
      box-shadow: var(--shadow-sm);
      position: sticky;
      top: 24px;
    }

    .sidebar-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.9rem;
      font-weight: 700;
      color: var(--c-forest);
      margin: 0 0 20px;
    }

    .catalog-input-label {
      display: block;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--c-smoke);
      margin-bottom: 6px;
    }

    .catalog-input, .catalog-select {
      width: 100%;
      border: 1.5px solid rgba(13,51,32,.12);
      border-radius: 10px;
      padding: 10px 14px;
      font-size: 14px;
      font-family: 'DM Sans', sans-serif;
      color: var(--c-ink);
      background: var(--c-mist);
      transition: border-color .2s ease, box-shadow .2s ease;
    }

    .catalog-input:focus, .catalog-select:focus {
      outline: none;
      border-color: var(--c-fern);
      box-shadow: 0 0 0 3px rgba(45,134,83,.15);
      background: #fff;
    }

    .catalog-error {
      margin-top: 6px;
      color: #c0392b;
      font-size: 12px;
      font-weight: 700;
      display: none;
    }
    .catalog-error.is-visible { display: block; }

    .catalog-list-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin: 20px 0 10px;
    }

    .catalog-list-head h4 {
      font-size: 15px;
      font-weight: 700;
      color: var(--c-forest);
      margin: 0;
    }

    .catalog-list-head span {
      font-size: 12px;
      font-weight: 700;
      color: var(--c-smoke);
      background: var(--c-mist);
      padding: 3px 10px;
      border-radius: var(--r-pill);
    }

    .catalog-list {
      display: grid;
      gap: 8px;
      max-height: 520px;
      overflow-y: auto;
      padding-right: 2px;
    }

    /* ── Entry card ── */
    .catalog-entry {
      width: 100%;
      background: var(--c-cream);
      border: 1.5px solid rgba(13,51,32,.09);
      border-radius: 12px;
      padding: 12px 14px;
      text-align: left;
      cursor: pointer;
      transition: all .22s ease;
      position: relative;
      overflow: hidden;
    }

    .catalog-entry::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: var(--c-fern);
      transform: scaleY(0);
      border-radius: 0 2px 2px 0;
      transition: transform .22s cubic-bezier(.34,1.56,.64,1);
    }

    .catalog-entry:hover {
      border-color: rgba(45,134,83,.35);
      background: #fff;
      transform: translateX(4px);
      box-shadow: var(--shadow-sm);
    }

    .catalog-entry:hover::before { transform: scaleY(1); }

    .catalog-entry.is-active {
      border-color: var(--c-fern);
      background: #fff;
      transform: translateX(6px);
      box-shadow: var(--shadow-md);
    }
    .catalog-entry.is-active::before { transform: scaleY(1); }

    .entry-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }

    .entry-left {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    .entry-emoji { font-size: 1.4rem; flex-shrink: 0; }

    .entry-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--c-ink);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .entry-chip {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: var(--c-mist);
      border: 1px solid rgba(45,134,83,.2);
      border-radius: var(--r-pill);
      padding: 3px 10px;
      font-size: 11px;
      font-weight: 700;
      color: var(--c-moss);
      white-space: nowrap;
      flex-shrink: 0;
    }

    .entry-sub {
      display: block;
      margin-top: 5px;
      font-size: 12px;
      color: var(--c-smoke);
    }

    .catalog-empty {
      display: none;
      padding: 16px;
      border: 1.5px dashed rgba(13,51,32,.15);
      border-radius: 10px;
      text-align: center;
      color: var(--c-smoke);
      font-size: 14px;
      margin-top: 8px;
    }
    .catalog-empty.is-visible { display: block; }

    /* ── Detail panel ── */
    .catalog-detail {
      background: #ffffff;
      border: 1.5px solid rgba(45,134,83,.13);
      border-radius: var(--r-card);
      padding: 32px 30px;
      box-shadow: var(--shadow-sm);
      position: relative;
      overflow: hidden;
    }

    .catalog-detail::before {
      content: '';
      position: absolute;
      top: -40px; right: -40px;
      width: 200px; height: 200px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(45,134,83,.07), transparent 70%);
      pointer-events: none;
    }

    .detail-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 24px;
    }

    .detail-header-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .detail-animal-icon {
      width: 4.5rem;
      height: 4.5rem;
      border-radius: 18px;
      background: var(--c-mist);
      border: 2px solid rgba(45,134,83,.18);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.4rem;
      flex-shrink: 0;
      transition: transform .3s cubic-bezier(.34,1.56,.64,1);
    }

    .catalog-detail:hover .detail-animal-icon { transform: scale(1.1) rotate(-4deg); }

    .detail-overline {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--c-smoke);
      margin-bottom: 4px;
    }

    .detail-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.2rem;
      font-weight: 700;
      color: var(--c-forest);
      margin: 0 0 4px;
      line-height: 1.1;
    }

    .detail-state {
      font-size: 14px;
      color: var(--c-smoke);
      margin: 0;
    }

    .detail-production-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, var(--c-forest) 0%, var(--c-moss) 100%);
      color: var(--c-gold-lt);
      border-radius: var(--r-pill);
      padding: 10px 20px;
      font-size: 14px;
      font-weight: 700;
      white-space: nowrap;
      flex-shrink: 0;
      box-shadow: 0 6px 20px rgba(13,51,32,.25);
    }

    .detail-production-chip .prod-emoji { font-size: 1.3rem; }

    /* ── KPI row ── */
    .detail-kpis {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-bottom: 28px;
    }

    .detail-kpi {
      background: var(--c-mist);
      border: 1px solid rgba(45,134,83,.12);
      border-radius: 14px;
      padding: 16px 14px;
      text-align: center;
      transition: transform .2s ease, box-shadow .2s ease;
    }

    .detail-kpi:hover { transform: translateY(-3px); box-shadow: var(--shadow-sm); }

    .detail-kpi-icon { font-size: 1.6rem; margin-bottom: 6px; }

    .detail-kpi-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .07em;
      color: var(--c-smoke);
      margin-bottom: 4px;
    }

    .detail-kpi-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.4rem;
      font-weight: 700;
      color: var(--c-forest);
      line-height: 1;
    }

    /* ── Occupancy bar ── */
    .occupancy-track {
      height: 8px;
      background: rgba(13,51,32,.1);
      border-radius: var(--r-pill);
      overflow: hidden;
      margin-top: 8px;
    }

    .occupancy-fill {
      height: 100%;
      border-radius: var(--r-pill);
      background: linear-gradient(90deg, var(--c-fern) 0%, var(--c-sage) 100%);
      transition: width .8s cubic-bezier(.34,1.2,.64,1);
    }

    /* ── Production strip ── */
    .production-strip-title {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--c-smoke);
      margin: 0 0 12px;
    }

    .production-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 28px;
    }

    .prod-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: #fff;
      border: 1.5px solid rgba(45,134,83,.18);
      border-radius: 12px;
      padding: 8px 14px;
      font-size: 13px;
      font-weight: 700;
      color: var(--c-moss);
      box-shadow: var(--shadow-sm);
      transition: transform .2s ease;
    }

    .prod-badge:hover { transform: scale(1.05); }
    .prod-badge .prod-emoji { font-size: 1.25rem; }

    /* ── Season grid ── */
    .season-strip-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .season-strip-title {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--c-smoke);
    }

    .season-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

    .season-card {
      border-radius: 16px;
      padding: 20px;
      position: relative;
      overflow: hidden;
      transition: transform .25s ease, box-shadow .25s ease;
    }

    .season-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }

    .season-card.autumn { background: linear-gradient(135deg, #fff8f0 0%, #fdecd5 100%); border: 1.5px solid rgba(194,100,14,.2); }
    .season-card.winter { background: linear-gradient(135deg, #f0f7ff 0%, #daeeff 100%); border: 1.5px solid rgba(3,105,161,.2); }
    .season-card.spring { background: linear-gradient(135deg, #f0fdf5 0%, #d4f5e2 100%); border: 1.5px solid rgba(21,128,61,.22); }
    .season-card.summer { background: linear-gradient(135deg, #fffcf0 0%, #fef3c5 100%); border: 1.5px solid rgba(180,83,9,.2); }

    .season-card-bg {
      position: absolute;
      right: 12px; bottom: 8px;
      font-size: 3.5rem;
      opacity: .12;
      pointer-events: none;
      transform: rotate(-10deg);
    }

    .season-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .08em;
      padding: 4px 12px;
      border-radius: var(--r-pill);
      margin-bottom: 10px;
    }

    .season-tag.autumn { background: #fff0df; color: #9a3412; }
    .season-tag.winter { background: #dbeafe; color: #0369a1; }
    .season-tag.spring { background: #dcfce7; color: #166534; }
    .season-tag.summer { background: #fef3c7; color: #b45309; }

    .season-card h5 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.35rem;
      font-weight: 700;
      margin: 0 0 8px;
    }

    .season-card.autumn h5 { color: #7c2d12; }
    .season-card.winter h5 { color: #0c4a6e; }
    .season-card.spring h5 { color: #14532d; }
    .season-card.summer h5 { color: #78350f; }

    .season-card p {
      font-size: 13px;
      line-height: 1.6;
      margin: 0;
    }
    .season-card.autumn p { color: #9a3412; }
    .season-card.winter p { color: #0369a1; }
    .season-card.spring p { color: #166534; }
    .season-card.summer p { color: #b45309; }

    .catalog-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 18px;
      margin-bottom: 26px;
      flex-wrap: wrap;
    }

    .catalog-toolbar .tool-copy {
      max-width: 42rem;
      color: var(--c-smoke);
      font-size: 15px;
      line-height: 1.65;
      margin: 0;
    }

    .catalog-toolbar .tool-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 3.2vw, 3rem);
      color: var(--c-forest);
      margin: 0;
      line-height: 1.05;
    }

    .catalog-toolbar .tool-title em {
      color: var(--c-fern);
      font-style: italic;
    }

    .season-strip-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    /* ═══════════════════════════════════════════════
       PRODUCTION SHOWCASE
    ═══════════════════════════════════════════════ */
    .production-showcase {
      background: linear-gradient(180deg, var(--c-forest) 0%, #0a2819 100%);
      padding: 64px 0;
      position: relative;
      overflow: hidden;
    }

    .production-showcase::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 70% at 20% 40%, rgba(45,134,83,.18) 0%, transparent 65%),
        radial-gradient(ellipse 40% 60% at 80% 70%, rgba(200,168,75,.1) 0%, transparent 60%);
      pointer-events: none;
    }

    .showcase-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 3.2vw, 2.8rem);
      font-weight: 700;
      color: #fff;
      text-align: center;
      margin-bottom: 8px;
    }

    .showcase-sub {
      text-align: center;
      color: var(--c-sage);
      font-size: 14px;
      margin-bottom: 44px;
    }

    .prod-showcase-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 16px;
    }

    .prod-showcase-card {
      background: rgba(255,255,255,.07);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 18px;
      padding: 24px 18px;
      text-align: center;
      transition: all .25s ease;
      animation: pop-in .5s cubic-bezier(.34,1.56,.64,1) both;
    }

    .prod-showcase-card:hover {
      background: rgba(255,255,255,.14);
      transform: translateY(-6px);
      box-shadow: 0 20px 40px rgba(0,0,0,.3);
    }

    .prod-showcase-emoji { font-size: 2.8rem; display: block; margin-bottom: 10px; }
    .prod-showcase-label {
      font-size: 13px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 4px;
    }
    .prod-showcase-desc { font-size: 11px; color: var(--c-sage); }

    /* delay cascade */
    .prod-showcase-card:nth-child(1) { animation-delay: .05s; }
    .prod-showcase-card:nth-child(2) { animation-delay: .10s; }
    .prod-showcase-card:nth-child(3) { animation-delay: .15s; }
    .prod-showcase-card:nth-child(4) { animation-delay: .20s; }
    .prod-showcase-card:nth-child(5) { animation-delay: .25s; }
    .prod-showcase-card:nth-child(6) { animation-delay: .30s; }
    .prod-showcase-card:nth-child(7) { animation-delay: .35s; }
    .prod-showcase-card:nth-child(8) { animation-delay: .40s; }
    .prod-showcase-card:nth-child(9) { animation-delay: .45s; }

    /* ═══════════════════════════════════════════════
       AOS-LIKE REVEAL
    ═══════════════════════════════════════════════ */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity .65s ease, transform .65s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: none;
    }
    .reveal-delay-1 { transition-delay: .1s; }
    .reveal-delay-2 { transition-delay: .2s; }
    .reveal-delay-3 { transition-delay: .3s; }

    /* ═══════════════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════════════ */
    @media (max-width: 991px) {
      .kpi-band,
      .detail-kpis { grid-template-columns: repeat(2, 1fr); }
      .detail-header { flex-direction: column; }
      .season-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 575px) {
      .kpi-band,
      .detail-kpis { grid-template-columns: 1fr; }
      .catalog-sidebar,
      .catalog-detail { padding: 20px 16px; }
    }
  </style>
{% endblock %}

