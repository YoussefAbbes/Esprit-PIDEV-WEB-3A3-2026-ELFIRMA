{% block javascripts %}
  {{ parent() }}
  <script>
  (function () {
    /* ══════════════════════════════════════════════
       ICON MAPS
    ══════════════════════════════════════════════ */
    const ANIMAL_ICONS = {
      // bovine
      'bovin': '<i class="fa-solid fa-piggy-bank"></i>', 'bovine': '<i class="fa-solid fa-piggy-bank"></i>', 'cattle': '<i class="fa-solid fa-piggy-bank"></i>', 'vache': '<i class="fa-solid fa-piggy-bank"></i>', 'cow': '<i class="fa-solid fa-piggy-bank"></i>',
      'bovin farm': '<i class="fa-solid fa-piggy-bank"></i>', 'bovine farm': '<i class="fa-solid fa-piggy-bank"></i>', 'cattle farm': '<i class="fa-solid fa-piggy-bank"></i>', 'cattlefarm': '<i class="fa-solid fa-piggy-bank"></i>',
      // sheep
      'mouton': '🐑', 'sheep': '🐑', 'sheep farm': '🐑', 'sheepfarm': '🐑',
      // poultry
      'poule': '🐔', 'poulet': '🐔', 'poultry': '🐔', 'volaille': '🐔',
      'poultry farm': '🐔', 'poultryfarm': '🐔',
      // goat
      'chèvre': '🐐', 'chevre': '🐐', 'goat': '🐐', 'goat farm': '🐐',
      // pig
      'porc': '🐖', 'cochon': '🐖', 'pig': '🐖', 'pig farm': '🐖',
      // horse
      'cheval': '🐴', 'horse': '🐴', 'horse farm': '🐴',
      // bee
      'abeille': '🐝', 'bee': '🐝', 'apiary': '🐝', 'ruche': '🐝',
      // duck
      'canard': '🦆', 'duck': '🦆',
      // rabbit
      'lapin': '🐇', 'rabbit': '🐇',
    };

    const PRODUCTION_ICONS = {
      'milk':    { emoji: '🥛', label: 'Milk' },
      'lait':    { emoji: '🥛', label: 'Lait' },
      'eggs':    { emoji: '🥚', label: 'Eggs' },
      'oeufs':   { emoji: '🥚', label: 'Œufs' },
      'œufs':    { emoji: '🥚', label: 'Œufs' },
      'meat':    { emoji: '🥩', label: 'Meat' },
      'viande':  { emoji: '🥩', label: 'Viande' },
      'wool':    { emoji: '🧶', label: 'Wool' },
      'laine':   { emoji: '🧶', label: 'Laine' },
      'honey':   { emoji: '🍯', label: 'Honey' },
      'miel':    { emoji: '🍯', label: 'Miel' },
      'cheese':  { emoji: '🧀', label: 'Cheese' },
      'fromage': { emoji: '🧀', label: 'Fromage' },
      'feathers':{ emoji: '🪶', label: 'Feathers' },
      'plumes':  { emoji: '🪶', label: 'Plumes' },
    };

    const resolveAnimal = (type) => {
      const t = (type || '').trim().toLowerCase();
      return ANIMAL_ICONS[t] || '🐾';
    };

    const resolveProduction = (prod) => {
      const words = (prod || '').toLowerCase().split(/[\s,;/&+]+/);
      const found = [];
      for (const w of words) {
        if (PRODUCTION_ICONS[w]) found.push(PRODUCTION_ICONS[w]);
      }
      if (found.length === 0) {
        return [{ emoji: '🥚', label: prod || 'N/A' }];
      }
      return found;
    };

    /* ══════════════════════════════════════════════
       DATA
    ══════════════════════════════════════════════ */
    const livestockData = {{ livestocks|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }};
    if (!Array.isArray(livestockData)) return;

    /* ══════════════════════════════════════════════
       DOM REFS
    ══════════════════════════════════════════════ */
    const searchInput     = document.getElementById('livestock-search');
    const searchError     = document.getElementById('livestock-search-error');
    const typeFilter      = document.getElementById('livestock-type');
    const stateFilter     = document.getElementById('livestock-state');
    const listNode        = document.getElementById('livestock-list');
    const countNode       = document.getElementById('livestock-count');
    const emptyNode       = document.getElementById('livestock-empty');

    const detailIcon      = document.getElementById('detail-animal-icon');
    const detailTitle     = document.getElementById('detail-title');
    const detailState     = document.getElementById('detail-state');
    const detailProd      = document.getElementById('detail-production');
    const detailProdStrip = document.getElementById('detail-production-strip');
    const detailCapacity  = document.getElementById('detail-capacity');
    const detailAnimals   = document.getElementById('detail-animals');
    const detailOccupancy = document.getElementById('detail-occupancy');
    const detailOccBar    = document.getElementById('detail-occ-bar');
    const seasonAutumn    = document.getElementById('season-autumn');
    const seasonWinter    = document.getElementById('season-winter');
    const seasonSpring    = document.getElementById('season-spring');
    const seasonSummer    = document.getElementById('season-summer');

    const searchPattern = /^[A-Za-z0-9À-ÖØ-öø-ÿ\s'\-]*$/;
    let activeId = livestockData.length > 0 ? Number(livestockData[0].id_elevage || 0) : null;

    const normalize = (v) => String(v || '').trim().toLowerCase();

    const occupancyRate = (item) => {
      const cap = Number(item.capacite || 0);
      const ani = Number(item.nombre_animaux || 0);
      return cap > 0 ? (ani / cap) * 100 : 0;
    };

    const seasonMsg = (season, item, pct) => {
      const type  = item.type_elevage || 'Livestock';
      const prod  = item.production   || 'production';
      const state = item.etat_elevage || 'Unknown';
      const msgs = {
        autumn: `🍂 Autumn reserves for ${type} are optimised to secure ${prod} output while occupancy stands at ${pct}. Current state: ${state}. Prepare shelter and stock feed for the cold months ahead.`,
        winter: `❄️ Winter protocol keeps ${type} stable with controlled ventilation, thermal bedding, and continuity of ${prod} output. Health monitoring and heating plans are critical this season.`,
        spring: `🌸 Spring cycle boosts resilience through selective nutrition and paddock rotation. A prime window for expansion and renewal of ${type} breeding lines.`,
        summer: `☀️ Summer plan optimises hydration and heat protection so ${prod} output stays predictable through peak temperatures. Shade structures and fresh water access are top priorities.`,
      };
      return msgs[season] || '';
    };

    /* ══════════════════════════════════════════════
       RENDER DETAIL
    ══════════════════════════════════════════════ */
    const renderDetail = (item) => {
      if (!item) {
        detailIcon.innerHTML         = '🥚';
        detailTitle.textContent     = 'Select a livestock';
        detailState.textContent     = 'State: —';
        detailProd.innerHTML        = '<span class="prod-emoji">🥚</span><span>Production: —</span>';
        detailProdStrip.innerHTML   = '<div class="prod-badge"><span class="prod-emoji">🥚</span> Select a livestock</div>';
        detailCapacity.textContent  = '—';
        detailAnimals.textContent   = '—';
        detailOccupancy.textContent = '—';
        detailOccBar.style.width    = '0%';
        seasonAutumn.textContent    = 'Select a livestock to display the strategic autumn planning.';
        seasonWinter.textContent    = 'Select a livestock to display winter resilience strategy.';
        seasonSpring.textContent    = 'Select a livestock to display spring growth strategy.';
        seasonSummer.textContent    = 'Select a livestock to display summer productivity strategy.';
        return;
      }

      const cap  = Number(item.capacite || 0);
      const ani  = Number(item.nombre_animaux || 0);
      const occ  = occupancyRate(item);
      const pct  = occ.toFixed(1) + '%';
      const anim = resolveAnimal(item.type_elevage);
      const prods = resolveProduction(item.production);

      // header
      detailIcon.innerHTML  = anim;
      detailTitle.textContent = item.type_elevage || 'Livestock';
      detailState.textContent = 'State: ' + (item.etat_elevage || 'Unknown');

      // production chip
      detailProd.innerHTML = `<span class="prod-emoji">${prods[0].emoji}</span><span>${item.production || 'N/A'}</span>`;

      // production strip
      detailProdStrip.innerHTML = prods.map(p =>
        `<div class="prod-badge"><span class="prod-emoji">${p.emoji}</span>${p.label}</div>`
      ).join('');

      // kpis
      detailCapacity.textContent  = String(cap);
      detailAnimals.textContent   = String(ani);
      detailOccupancy.textContent = pct;
      detailOccBar.style.width    = Math.min(occ, 100).toFixed(1) + '%';

      // seasons
      seasonAutumn.textContent = seasonMsg('autumn', item, pct);
      seasonWinter.textContent = seasonMsg('winter', item, pct);
      seasonSpring.textContent = seasonMsg('spring', item, pct);
      seasonSummer.textContent = seasonMsg('summer', item, pct);
    };

    /* ══════════════════════════════════════════════
       FILTER + LIST
    ══════════════════════════════════════════════ */
    const filteredData = () => {
      const term  = normalize(searchInput.value);
      const type  = normalize(typeFilter.value);
      const state = normalize(stateFilter.value);
      return livestockData.filter((item) => {
        const searchable = [
          normalize(item.type_elevage),
          normalize(item.etat_elevage),
          normalize(item.production),
          normalize(item.id_elevage),
        ].join(' ');
        return (term  === '' || searchable.includes(term))
            && (type  === '' || normalize(item.type_elevage) === type)
            && (state === '' || normalize(item.etat_elevage) === state);
      });
    };

    const validateSearch = () => {
      const valid = searchPattern.test(String(searchInput.value || '').trim());
      searchError.classList.toggle('is-visible', !valid);
      return valid;
    };

    const createEntry = (item, index) => {
      const id     = Number(item.id_elevage || 0);
      const emoji  = resolveAnimal(item.type_elevage);
      const prods  = resolveProduction(item.production);

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'catalog-entry' + (id === Number(activeId || 0) ? ' is-active' : '');

      btn.innerHTML = `
        <span class="entry-top">
          <span class="entry-left">
            <span class="entry-emoji">${emoji}</span>
            <span class="entry-title">${item.type_elevage || 'Livestock'}</span>
          </span>
          <span class="entry-chip"><span>${prods[0].emoji}</span> ${prods[0].label}</span>
        </span>
        <span class="entry-sub">State: ${item.etat_elevage || 'Unknown'} · ${Number(item.nombre_animaux||0)}/${Number(item.capacite||0)} animals</span>
      `;

      btn.addEventListener('click', () => { activeId = id; renderList(); });
      return btn;
    };

    const renderList = () => {
      if (!validateSearch()) return;
      const rows = filteredData();
      listNode.innerHTML = '';
      countNode.textContent = rows.length + (rows.length === 1 ? ' item' : ' items');
      emptyNode.classList.toggle('is-visible', rows.length === 0);

      if (rows.length === 0) { activeId = null; renderDetail(null); return; }

      if (!rows.some(item => Number(item.id_elevage || 0) === Number(activeId || 0))) {
        activeId = Number(rows[0].id_elevage || 0);
      }

      rows.forEach((item, idx) => listNode.appendChild(createEntry(item, idx)));

      const active = rows.find(item => Number(item.id_elevage || 0) === Number(activeId || 0)) || rows[0];
      renderDetail(active);
    };

    const hydrateFilters = () => {
      [...new Set(livestockData.map(i => String(i.type_elevage||'').trim()).filter(Boolean))].sort()
        .forEach(v => { const o=document.createElement('option'); o.value=v; o.textContent=v; typeFilter.appendChild(o); });
      [...new Set(livestockData.map(i => String(i.etat_elevage||'').trim()).filter(Boolean))].sort()
        .forEach(v => { const o=document.createElement('option'); o.value=v; o.textContent=v; stateFilter.appendChild(o); });
    };

    hydrateFilters();
    renderList();

    searchInput.addEventListener('input', renderList);
    typeFilter.addEventListener('change', renderList);
    stateFilter.addEventListener('change', renderList);

    /* ══════════════════════════════════════════════
       SCROLL REVEAL
    ══════════════════════════════════════════════ */
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
    }, { threshold: 0.12 });
    revealEls.forEach(el => observer.observe(el));

  })();
  </script>
{% endblock %}
