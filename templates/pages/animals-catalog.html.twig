{% block javascripts %}
  {{ parent() }}
  <script>
    (function () {
      const animalsData = {{ animals|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }};
      if (!Array.isArray(animalsData)) {
        return;
      }

      const healthyCountNode = document.getElementById('catalog-healthy-count');
      if (healthyCountNode) {
        const healthyCount = animalsData.filter((item) => {
          const health = String(item && item.etat_sante ? item.etat_sante : '').trim().toLowerCase();
          return health.includes('healthy') || health.includes('sain');
        }).length;
        healthyCountNode.textContent = String(healthyCount);
      }

      const searchInput = document.getElementById('animal-search');
      const searchError = document.getElementById('animal-search-error');
      const typeFilter = document.getElementById('animal-type');
      const statusFilter = document.getElementById('animal-status');
      const listNode = document.getElementById('animal-list');
      const countNode = document.getElementById('animal-count');
      const emptyNode = document.getElementById('animal-empty');

      const detailTitle = document.getElementById('animal-detail-title');
      const detailLivestock = document.getElementById('animal-detail-livestock');
      const detailStatus = document.getElementById('animal-detail-status');
      const detailGender = document.getElementById('animal-detail-gender');
      const detailAge = document.getElementById('animal-detail-age');
      const detailHealth = document.getElementById('animal-detail-health');
      const detailLivestockName = document.getElementById('animal-detail-livestock-name');

      const storyCare = document.getElementById('story-care');
      const storyHealth = document.getElementById('story-health');
      const storyStatus = document.getElementById('story-status');
      const storyId = document.getElementById('story-id');

      const invalidSearchMessage = 'Please use letters and spaces only.';
      const searchPattern = /^[A-Za-zÀ-ÖØ-öø-ÿ\s]*$/;
      const sanitizeSearchValue = (value) => String(value || '').replace(/[^A-Za-zÀ-ÖØ-öø-ÿ\s]/g, '');
      let activeId = animalsData.length > 0 ? Number(animalsData[0].id_animal || 0) : null;

      const normalize = (value) => String(value || '').trim().toLowerCase();

      const normalizeStatusLabel = (value) => {
        const text = normalize(value);
        if (text.includes('sale') || text.includes('vente')) {
          return 'For Sale';
        }
        if (text.includes('retained') || text.includes('garde')) {
          return 'Retained';
        }
        return String(value || 'Unknown').trim() || 'Unknown';
      };

      const normalizeHealthLabel = (value) => {
        const text = normalize(value);
        if (text.includes('healthy') || text.includes('sain')) {
          return 'Healthy';
        }
        if (text.includes('treatment') || text.includes('traitement')) {
          return 'Under Treatment';
        }
        if (text.includes('sick') || text.includes('malade')) {
          return 'Sick';
        }
        return String(value || 'Unknown').trim() || 'Unknown';
      };

      const statusIconClass = (statusLabel) => {
        if (statusLabel === 'For Sale') {
          return 'bi-tag-fill';
        }
        if (statusLabel === 'Retained') {
          return 'bi-shield-check';
        }

        return 'bi-info-circle';
      };

      const buildStories = (item, statusLabel, healthLabel) => {
        const type = item.type_animal || 'Animal';
        const livestock = item.livestock_label || 'Livestock';
        const age = Number(item.age || 0);
        const ageLabel = age > 0 ? age + (age === 1 ? ' year' : ' years') : 'age not specified';
        const genderLabel = String(item.sexe || 'not specified').trim();

        return {
          care: 'This ' + type + ' (' + genderLabel + ') is part of ' + livestock + ' and currently recorded at ' + ageLabel + ', with a stable daily care routine.',
          health: healthLabel === 'Under Treatment' || healthLabel === 'Sick'
            ? 'Health supervision is currently intensified with closer veterinary checks, adaptive care actions, and daily follow-up until recovery improves.'
            : 'Health condition is stable with preventive monitoring, hygiene control, and regular observation of key biological indicators.',
          status: statusLabel === 'For Sale'
            ? 'Behavior and readiness profile indicate this animal is prepared for sale, supported by consistent records and clear condition tracking.'
            : 'Behavior profile supports retention in herd strategy, helping maintain long-term productivity balance and operational continuity.',
          id: 'Traceability records connect this animal to ' + livestock + ' with a complete lifecycle context available for operational review.'
        };
      };

      const renderDetail = (item) => {
        if (!item) {
          detailTitle.textContent = 'Select an animal';
          detailLivestock.textContent = 'Livestock: --';
          detailStatus.innerHTML = '<i class="bi bi-info-circle" aria-hidden="true"></i> Status: --';
          detailStatus.className = 'detail-status';
          detailGender.textContent = '--';
          detailAge.textContent = '--';
          detailHealth.textContent = '--';
          detailLivestockName.textContent = '--';
          storyCare.textContent = 'Select an animal to show its profile summary.';
          storyHealth.textContent = 'Select an animal to show its health monitoring focus.';
          storyStatus.textContent = 'Select an animal to show its behavior notes.';
          storyId.textContent = 'Select an animal to show its traceability context.';
          return;
        }

        const statusLabel = normalizeStatusLabel(item.statut);
        const healthLabel = normalizeHealthLabel(item.etat_sante);
        const stories = buildStories(item, statusLabel, healthLabel);

        detailTitle.textContent = item.type_animal || 'Animal';
        detailLivestock.textContent = 'Livestock: ' + (item.livestock_label || 'Unknown livestock');
  detailStatus.innerHTML = '<i class="bi ' + statusIconClass(statusLabel) + '" aria-hidden="true"></i> Status: ' + statusLabel;
        detailStatus.className = 'detail-status' + (statusLabel === 'For Sale' ? ' sale' : '');

        detailGender.textContent = item.sexe || 'Not specified';
        const ageValue = Number(item.age || 0);
        detailAge.textContent = ageValue > 0 ? String(ageValue) + (ageValue === 1 ? ' year' : ' years') : '--';
        detailHealth.textContent = healthLabel;
        detailLivestockName.textContent = item.livestock_label || 'Unknown livestock';

        storyCare.textContent = stories.care;
        storyHealth.textContent = stories.health;
        storyStatus.textContent = stories.status;
        storyId.textContent = stories.id;
      };

      const filteredData = () => {
        const term = normalize(searchInput.value);
        const type = normalize(typeFilter.value);
        const status = normalize(statusFilter.value);

        return animalsData.filter((item) => {
          const itemType = normalize(item.type_animal);
          const itemStatus = normalize(item.statut);
          const itemLivestock = normalize(item.livestock_label);
          const itemHealth = normalize(item.etat_sante);
          const itemId = normalize(item.id_animal);
          const searchable = [itemType, itemStatus, itemLivestock, itemHealth, itemId].join(' ');

          const matchesTerm = term === '' || searchable.includes(term);
          const matchesType = type === '' || itemType === type;
          const matchesStatus = status === '' || itemStatus === status;

          return matchesTerm && matchesType && matchesStatus;
        });
      };

      const validateSearch = () => {
        const rawValue = String(searchInput.value || '');
        const sanitizedValue = sanitizeSearchValue(rawValue);
        const hadInvalidCharacters = rawValue !== sanitizedValue;

        console.assert(!hadInvalidCharacters, 'Animal search accepts letters and spaces only.');

        if (hadInvalidCharacters) {
          searchInput.value = sanitizedValue;
          searchInput.setCustomValidity(invalidSearchMessage);
          searchError.classList.add('is-visible');
          return true;
        }

        const isValid = searchPattern.test(rawValue);
        searchInput.setCustomValidity(isValid ? '' : invalidSearchMessage);
        searchError.classList.toggle('is-visible', !isValid);
        return isValid;
      };

      const createEntry = (item, index) => {
        const id = Number(item.id_animal || 0);
        const statusLabel = normalizeStatusLabel(item.statut);

        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'animal-entry' + (id === Number(activeId || 0) ? ' is-active' : '');

        const top = document.createElement('span');
        top.className = 'entry-top';

        const left = document.createElement('span');
        left.className = 'entry-left';

        const number = document.createElement('span');
        number.className = 'entry-number';
        number.textContent = String(index + 1).padStart(2, '0');

        const title = document.createElement('span');
        title.className = 'entry-title';
        title.textContent = item.type_animal || 'Animal';

        const chip = document.createElement('span');
        chip.className = 'status-chip' + (statusLabel === 'For Sale' ? ' sale' : '');
        chip.innerHTML = '<i class="bi ' + statusIconClass(statusLabel) + '" aria-hidden="true"></i> ' + statusLabel;

        const sub = document.createElement('span');
        sub.className = 'entry-sub';
        sub.textContent = item.livestock_label || 'Unknown livestock';

        left.appendChild(number);
        left.appendChild(title);
        top.appendChild(left);
        top.appendChild(chip);

        button.appendChild(top);
        button.appendChild(sub);

        button.addEventListener('click', () => {
          activeId = id;
          renderList();
        });

        return button;
      };

      const renderList = () => {
        if (!validateSearch()) {
          return;
        }

        const rows = filteredData();
        listNode.innerHTML = '';

        countNode.textContent = rows.length + (rows.length === 1 ? ' item' : ' items');
        emptyNode.classList.toggle('is-visible', rows.length === 0);

        if (rows.length === 0) {
          activeId = null;
          renderDetail(null);
          return;
        }

        if (!rows.some((item) => Number(item.id_animal || 0) === Number(activeId || 0))) {
          activeId = Number(rows[0].id_animal || 0);
        }

        rows.forEach((item, index) => {
          listNode.appendChild(createEntry(item, index));
        });

        const activeItem = rows.find((item) => Number(item.id_animal || 0) === Number(activeId || 0)) || rows[0];
        renderDetail(activeItem);
      };

      const hydrateFilters = () => {
        const types = [...new Set(animalsData.map((item) => String(item.type_animal || '').trim()).filter(Boolean))].sort();
        const statuses = [...new Set(animalsData.map((item) => String(item.statut || '').trim()).filter(Boolean))].sort();

        types.forEach((value) => {
          const option = document.createElement('option');
          option.value = value;
          option.textContent = value;
          typeFilter.appendChild(option);
        });

        statuses.forEach((value) => {
          const option = document.createElement('option');
          option.value = value;
          option.textContent = normalizeStatusLabel(value);
          statusFilter.appendChild(option);
        });
      };

      hydrateFilters();
      renderList();

      searchInput.addEventListener('input', renderList);
      typeFilter.addEventListener('change', renderList);
      statusFilter.addEventListener('change', renderList);
    })();
  </script>

