{% extends 'base.html.twig' %}

{% block title %}Animal Storyboard - EL FIRMA{% endblock %}
{% block body_class %}animals-catalog-page{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    .animals-catalog-page {
      --animal-soft: #f6fbf8;
      --animal-cream: #fff7ec;
      --animal-mint: #eff7f0;
      --animal-sky: #eef5ff;
      --animal-line: color-mix(in srgb, var(--default-color), transparent 85%);
      --animal-shadow: 0 14px 34px color-mix(in srgb, #102f20, transparent 90%);
      --animal-sale: #8f1f3a;
    }

    .animal-intro {
      position: relative;
      padding-top: 128px;
      overflow: hidden;
      background:
        radial-gradient(440px 170px at 8% 0%, color-mix(in srgb, var(--accent-color), #ffffff 84%), transparent 72%),
        radial-gradient(380px 220px at 92% 6%, color-mix(in srgb, #2d7a55, #ffffff 88%), transparent 76%),
        #ffffff;
    }

    .animal-intro .intro-shell {
      background: linear-gradient(132deg, #ffffff, var(--animal-soft));
      border: 1px solid var(--animal-line);
      border-radius: 18px;
      padding: 28px;
      box-shadow: var(--animal-shadow);
      position: relative;
      overflow: hidden;
    }

    .animal-intro .intro-shell::after {
      content: '';
      position: absolute;
      width: 240px;
      height: 240px;
      right: -70px;
      top: -120px;
      border-radius: 50%;
      background: radial-gradient(circle, color-mix(in srgb, #2d7a55, #ffffff 70%), transparent 72%);
      pointer-events: none;
    }

    .animal-intro .intro-visual {
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--animal-line);
      box-shadow: var(--animal-shadow);
      min-height: 100%;
    }

    .animal-intro .intro-visual img {
      width: 100%;
      height: 100%;
      min-height: 320px;
      object-fit: cover;
      display: block;
    }

    .animal-intro .content-title {
      color: var(--accent-color);
    }

    .animal-intro .kpi-band {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      margin-top: 26px;
    }

    .animal-intro .kpi-card {
      border: 1px solid var(--animal-line);
      border-radius: 10px;
      background: #ffffff;
      padding: 12px 14px;
    }

    .animal-intro .kpi-card.sale {
      background: color-mix(in srgb, #c3264c, #ffffff 94%);
      border-color: color-mix(in srgb, #c3264c, #ffffff 75%);
    }

    .animal-intro .kpi-card.retained {
      background: color-mix(in srgb, var(--accent-color), #ffffff 94%);
      border-color: color-mix(in srgb, var(--accent-color), #ffffff 75%);
    }

    .animal-intro .kpi-card span {
      display: block;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 12px;
      color: color-mix(in srgb, var(--default-color), transparent 42%);
      font-weight: 700;
    }

    .animal-intro .kpi-card strong {
      display: block;
      font-family: var(--heading-font);
      font-size: 34px;
      line-height: 1;
      margin-top: 6px;
      color: var(--heading-color);
    }

    .animal-intro .animal-catalog-hero {
      position: relative;
      overflow: hidden;
      border-radius: 28px;
      border: 1px solid rgba(45, 134, 83, 0.14);
      background:
        radial-gradient(circle at top right, rgba(45, 134, 83, 0.08), transparent 36%),
        radial-gradient(circle at bottom left, rgba(200, 168, 75, 0.08), transparent 38%),
        linear-gradient(135deg, #ffffff 0%, #f7fbf8 100%);
      box-shadow: 0 28px 72px rgba(13, 51, 32, 0.18);
      padding: 24px;
    }

    .animal-intro .animal-catalog-hero::before {
      content: "";
      position: absolute;
      inset: auto -80px -80px auto;
      width: 260px;
      height: 260px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(45, 134, 83, 0.14) 0%, rgba(45, 134, 83, 0) 68%);
      pointer-events: none;
    }

    .animal-intro .animal-hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.4rem, 4.6vw, 4.3rem);
      line-height: 1.02;
      letter-spacing: -0.03em;
      color: #0d3320;
      margin: 0;
    }

    .animal-intro .animal-hero-title em {
      color: #2d8653;
      font-style: italic;
    }

    .animal-intro .animal-hero-copy {
      color: #6b7c71;
      line-height: 1.75;
      font-size: 15px;
      max-width: 44rem;
      margin-top: 16px;
    }

    .animal-intro .animal-pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 16px;
    }

    .animal-intro .animal-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border-radius: 999px;
      border: 1px solid rgba(45, 134, 83, 0.18);
      background: #ffffff;
      padding: 8px 14px;
      font-size: 13px;
      font-weight: 700;
      color: #1f5f3f;
      box-shadow: 0 6px 18px rgba(13, 51, 32, 0.08);
    }

    .animal-intro .animal-hero-image {
      position: relative;
      border-radius: 24px;
      overflow: hidden;
      min-height: 360px;
      border: 1px solid rgba(45, 134, 83, 0.16);
      box-shadow: 0 28px 72px rgba(13, 51, 32, 0.18);
    }

    .animal-intro .animal-hero-image img {
      width: 100%;
      height: 100%;
      min-height: 360px;
      object-fit: cover;
      object-position: center center;
      display: block;
    }

    .animal-intro .animal-hero-chip {
      position: absolute;
      left: 18px;
      bottom: 18px;
      background: rgba(13, 51, 32, 0.86);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 16px;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 10px;
      backdrop-filter: blur(8px);
      box-shadow: 0 18px 40px rgba(13, 51, 32, 0.12);
    }

    .animal-intro .animal-hero-chip .chip-emoji {
      font-size: 1.6rem;
      line-height: 1;
    }

    .animal-intro .animal-hero-kpis {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      margin-top: 16px;
    }

    .animal-intro .animal-mini-kpi {
      border-radius: 18px;
      border: 1px solid rgba(45, 134, 83, 0.14);
      background: linear-gradient(160deg, #ffffff 0%, #f2faf4 100%);
      padding: 16px 14px;
      box-shadow: 0 6px 18px rgba(13, 51, 32, 0.08);
    }

    .animal-intro .animal-mini-kpi span {
      display: block;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 800;
      color: #6b7c71;
    }

    .animal-intro .animal-mini-kpi strong {
      display: block;
      margin-top: 6px;
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.5rem;
      line-height: 1;
      color: #0d3320;
    }

    .animal-workbench {
      background:
        linear-gradient(180deg, #f8fcfa 0%, #f2f8f3 34%, #fff9f1 100%);
    }

    .animal-workbench .section-title {
      padding-bottom: 34px;
    }

    .animal-workbench .section-title h2 {
      color: var(--accent-color);
      font-size: 20px;
      letter-spacing: 0.04em;
    }

    .animal-workbench .content {
      padding: 0;
    }

    .animal-sidebar,
    .animal-detail {
      border: 1px solid var(--animal-line);
      border-radius: 18px;
      padding: 22px;
      box-shadow: var(--animal-shadow);
      height: 100%;
    }

    .animal-sidebar {
      background: linear-gradient(160deg, var(--animal-cream), var(--animal-mint));
    }

    .animal-detail {
      background: linear-gradient(168deg, #ffffff 0%, var(--animal-sky) 58%, var(--animal-mint) 100%);
    }

    .animal-detail {
      position: relative;
      overflow: hidden;
    }

    .animal-detail::before {
      content: '';
      position: absolute;
      width: 220px;
      height: 220px;
      right: -100px;
      bottom: -120px;
      border-radius: 50%;
      background: radial-gradient(circle, color-mix(in srgb, var(--accent-color), #ffffff 78%), transparent 72%);
      pointer-events: none;
    }

    .animal-sidebar h3,
    .animal-detail h3 {
      margin: 0;
      font-size: 31px;
      color: var(--heading-color);
    }

    .animal-overline {
      margin: 0 0 8px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 12px;
      color: color-mix(in srgb, var(--default-color), transparent 45%);
      font-weight: 700;
    }

    .animal-input-label {
      display: block;
      margin-bottom: 6px;
      font-size: 14px;
      font-weight: 700;
      color: var(--heading-color);
    }

    .animal-input,
    .animal-select {
      width: 100%;
      border: 1px solid color-mix(in srgb, var(--default-color), transparent 82%);
      border-radius: 9px;
      padding: 10px 12px;
      font-size: 15px;
      color: var(--default-color);
      background: color-mix(in srgb, #ffffff, var(--animal-cream) 28%);
      transition: border-color 0.25s ease, box-shadow 0.25s ease;
    }

    .animal-input:focus,
    .animal-select:focus {
      outline: none;
      border-color: color-mix(in srgb, var(--accent-color), transparent 35%);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color), transparent 85%);
    }

    .animal-error {
      margin-top: 8px;
      margin-bottom: 0;
      color: #bd2a2a;
      font-size: 13px;
      font-weight: 700;
      display: none;
    }

    .animal-error.is-visible {
      display: block;
    }

    .animal-list-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 18px;
      margin-bottom: 10px;
    }

    .animal-list-head h4 {
      margin: 0;
      font-size: 20px;
      color: var(--heading-color);
    }

    .animal-list-head span {
      font-size: 13px;
      font-weight: 700;
      color: color-mix(in srgb, var(--default-color), transparent 42%);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .animal-list {
      display: grid;
      gap: 10px;
      max-height: 520px;
      overflow: auto;
      padding: 8px;
      border: 1px solid color-mix(in srgb, var(--accent-color), transparent 86%);
      border-radius: 12px;
      background: linear-gradient(180deg, #ffffff, color-mix(in srgb, var(--accent-color), #ffffff 96%));
    }

    .animal-entry {
      width: 100%;
      border: 1px solid var(--animal-line);
      border-radius: 10px;
      background: linear-gradient(146deg, #ffffff, #f8fcf8);
      text-align: left;
      padding: 12px;
      transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .animal-entry:nth-child(even) {
      background: linear-gradient(146deg, #fffdf7, #f7fbf5);
    }

    .animal-entry:hover {
      transform: translateY(-2px);
      border-color: color-mix(in srgb, var(--accent-color), transparent 30%);
      box-shadow: 0 10px 20px color-mix(in srgb, #102f20, transparent 88%);
    }

    .animal-entry.is-active {
      border-color: color-mix(in srgb, var(--accent-color), transparent 20%);
      box-shadow: inset 3px 0 0 var(--accent-color);
      background: color-mix(in srgb, var(--accent-color), #ffffff 95%);
    }

    .entry-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }

    .entry-left {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    .entry-number {
      font-size: 13px;
      font-weight: 700;
      color: color-mix(in srgb, var(--default-color), transparent 55%);
      letter-spacing: 0.05em;
      flex-shrink: 0;
    }

    .entry-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--heading-color);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .entry-sub {
      display: block;
      margin-top: 6px;
      color: color-mix(in srgb, var(--default-color), transparent 30%);
      font-size: 14px;
    }

    .status-chip,
    .detail-status {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border: 1px solid color-mix(in srgb, var(--accent-color), transparent 75%);
      border-radius: 999px;
      padding: 5px 11px;
      font-size: 12px;
      font-weight: 700;
      color: color-mix(in srgb, var(--accent-color), #000000 22%);
      background: color-mix(in srgb, var(--accent-color), #ffffff 94%);
      white-space: nowrap;
    }

    .status-chip i,
    .detail-status i {
      font-size: 11px;
      line-height: 1;
    }

    .status-chip.sale,
    .detail-status.sale {
      border-color: color-mix(in srgb, #c3264c, #ffffff 70%);
      color: var(--animal-sale);
      background: color-mix(in srgb, #c3264c, #ffffff 92%);
    }

    .animal-empty {
      margin: 12px 0 0;
      border: 1px dashed var(--animal-line);
      border-radius: 10px;
      padding: 12px;
      color: color-mix(in srgb, var(--default-color), transparent 40%);
      font-weight: 600;
      display: none;
    }

    .animal-empty.is-visible {
      display: block;
    }

    .detail-header {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 12px;
      margin-bottom: 16px;
    }

    .detail-livestock {
      margin-top: 6px;
      margin-bottom: 0;
      color: color-mix(in srgb, var(--default-color), transparent 25%);
      font-size: 16px;
    }

    .detail-metrics {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-bottom: 18px;
    }

    .detail-metric {
      border: 1px solid var(--animal-line);
      border-radius: 12px;
      padding: 12px;
      background: linear-gradient(145deg, #ffffff, #f6faf8);
    }

    .detail-metrics .detail-metric:nth-child(1) {
      background: linear-gradient(145deg, #f6f9ff, #eef4ff);
    }

    .detail-metrics .detail-metric:nth-child(2) {
      background: linear-gradient(145deg, #fff9ee, #fff3df);
    }

    .detail-metrics .detail-metric:nth-child(3) {
      background: linear-gradient(145deg, #f2fbf5, #e9f8ee);
    }

    .detail-metrics .detail-metric:nth-child(4) {
      background: linear-gradient(145deg, #f1fbf8, #e9f7f2);
    }

    .detail-metric p {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 12px;
      color: color-mix(in srgb, var(--default-color), transparent 42%);
      font-weight: 700;
    }

    .detail-metric p i {
      font-size: 14px;
      line-height: 1;
    }

    .detail-metrics .detail-metric:nth-child(1) p i {
      color: #2f567d;
    }

    .detail-metrics .detail-metric:nth-child(2) p i {
      color: #8a6c30;
    }

    .detail-metrics .detail-metric:nth-child(3) p i {
      color: #1f7a51;
    }

    .detail-metrics .detail-metric:nth-child(4) p i {
      color: #2b8f64;
    }

    .detail-metric strong {
      display: block;
      margin-top: 6px;
      font-size: 30px;
      line-height: 1;
      color: var(--heading-color);
      font-family: var(--heading-font);
    }

    .story-grid .service-item {
      position: relative;
      border: 1px solid var(--animal-line);
      border-radius: 16px;
      padding: 24px 20px 18px;
      background: linear-gradient(145deg, #ffffff, #f7fbf9);
      height: 100%;
      overflow: hidden;
      isolation: isolate;
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }

    .story-grid .service-item::before {
      content: '';
      position: absolute;
      width: 170px;
      height: 170px;
      right: -58px;
      bottom: -92px;
      border-radius: 50%;
      background: radial-gradient(circle, color-mix(in srgb, var(--accent-color), #ffffff 86%), transparent 72%);
      z-index: -1;
    }

    .story-grid .service-item:hover {
      transform: translateY(-5px);
      box-shadow: 0 16px 30px color-mix(in srgb, #102f20, transparent 86%);
      border-color: color-mix(in srgb, var(--accent-color), transparent 40%);
    }

    .story-grid .col-md-6:nth-child(1) .service-item {
      border-top: 4px solid #1f7a51;
    }

    .story-grid .col-md-6:nth-child(2) .service-item {
      border-top: 4px solid #2b8f64;
    }

    .story-grid .col-md-6:nth-child(3) .service-item {
      border-top: 4px solid #a06a2f;
    }

    .story-grid .col-md-6:nth-child(4) .service-item {
      border-top: 4px solid #2f567d;
    }

    .story-grid .service-item .number {
      right: 14px;
      top: 10px;
      color: color-mix(in srgb, var(--accent-color), transparent 75%);
      font-family: var(--heading-font);
      font-size: 32px;
      font-weight: 700;
    }

    .story-grid .service-item .service-item-content .story-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 12px;
      margin-bottom: 10px;
      border: 1px solid color-mix(in srgb, var(--accent-color), #ffffff 65%);
      background: color-mix(in srgb, var(--accent-color), #ffffff 90%);
      color: color-mix(in srgb, var(--accent-color), #000000 16%);
    }

    .story-grid .service-item .service-item-content .story-icon i {
      font-size: 18px;
      line-height: 1;
    }

    .story-grid .col-md-6:nth-child(1) .story-icon {
      color: #1f7a51;
      background: color-mix(in srgb, #1f7a51, #ffffff 90%);
      border-color: color-mix(in srgb, #1f7a51, #ffffff 72%);
    }

    .story-grid .col-md-6:nth-child(2) .story-icon {
      color: #2b8f64;
      background: color-mix(in srgb, #2b8f64, #ffffff 90%);
      border-color: color-mix(in srgb, #2b8f64, #ffffff 72%);
    }

    .story-grid .col-md-6:nth-child(3) .story-icon {
      color: #a06a2f;
      background: color-mix(in srgb, #a06a2f, #ffffff 90%);
      border-color: color-mix(in srgb, #a06a2f, #ffffff 72%);
    }

    .story-grid .col-md-6:nth-child(4) .story-icon {
      color: #2f567d;
      background: color-mix(in srgb, #2f567d, #ffffff 90%);
      border-color: color-mix(in srgb, #2f567d, #ffffff 72%);
    }

    .story-grid .service-item .service-item-content .service-heading {
      font-size: 25px;
      margin-bottom: 8px;
      color: var(--heading-color);
    }

    .story-grid .service-item .service-item-content p {
      margin-bottom: 0;
      color: color-mix(in srgb, var(--default-color), transparent 20%);
      font-size: 15px;
      line-height: 1.5;
    }

    @media (max-width: 991px) {
      .animal-intro .intro-shell {
        padding: 20px;
      }

      .animal-intro {
        padding-top: 112px;
      }

      .animal-intro .kpi-band {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .animal-intro .animal-hero-kpis {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .detail-header {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (max-width: 575px) {
      .animal-intro .kpi-band,
      .detail-metrics {
        grid-template-columns: 1fr;
      }

      .animal-intro .animal-hero-kpis {
        grid-template-columns: 1fr;
      }

      .animal-sidebar,
      .animal-detail {
        padding: 16px;
      }

      .animal-sidebar h3,
      .animal-detail h3 {
        font-size: 27px;
      }
    }
  </style>
{% endblock %}

{% block body %}
  <section class="about-3 section animal-intro">
    <div class="container">
      <div class="intro-shell">
        <section class="animal-catalog-hero">
          <div class="row gy-4 justify-content-between align-items-center">
            <div class="col-lg-6 order-lg-2" data-aos="zoom-out">
              <div class="animal-hero-image">
                <img src="{{ asset('assets/img/farm-animals-real.jpg') }}" alt="Livestock overview" class="img-fluid">
                <div class="animal-hero-chip">
                  <span class="chip-emoji">🌿</span>
                  <div>
                    <div style="font-size:12px;opacity:.72;font-weight:600;">EL FIRMA Certified</div>
                    <div style="font-size:14px;font-weight:800;">Premium Farm Network</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-lg-6 order-lg-1" data-aos="fade-up" data-aos-delay="120">
              <h2 class="animal-hero-title">Curated animal<br><em>intelligence</em> for clients</h2>
              <p class="animal-hero-copy">
                This catalog transforms animal records into a polished narrative: gender, health, age, status, and seasonal strategy in one coherent experience.
              </p>
              <div class="animal-pill-row">
                <span class="animal-pill">🔍 Smart filtering</span>
                <span class="animal-pill">📊 Live health</span>
                <span class="animal-pill">🌦️ Seasonal view</span>
                <span class="animal-pill">🧬 DNA clues</span>
              </div>
              <div class="animal-hero-kpis">
                <article class="animal-mini-kpi">
                  <span>Total animals</span>
                  <strong>{{ catalog_summary.total_animals }}</strong>
                </article>
                <article class="animal-mini-kpi">
                  <span>Healthy</span>
                  <strong id="catalog-healthy-count">0</strong>
                </article>
                <article class="animal-mini-kpi">
                  <span>For sale</span>
                  <strong>{{ catalog_summary.for_sale }}</strong>
                </article>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </section>

  <section class="section animal-workbench">
    <div class="container section-title" data-aos="fade-up">
      <h2>Animal Creative Explorer</h2>
      <p>An expressive and story-driven reading of each animal profile</p>
    </div>

    <div class="content">
      <div class="container">
        <div class="row g-4 align-items-start">
