{% extends 'base.html.twig' %}

{% block title %}Equipments - EL FIRMA{% endblock %}
{% block meta_description %}{% endblock %}
{% block meta_keywords %}{% endblock %}
{% block body_class %}Equipments-page{% endblock %}

{% block body %}
<style>
.btn-modern {
  padding:10px 20px;
  background:linear-gradient(135deg, #1e7e34, #218838);
  color:white;
  border-radius:25px;
  text-decoration:none;
  border:2px solid #1e7e34;
  transition:0.3s;
}

.btn-modern:hover {
  background:white;
  color:#1e7e34;
  transform:translateY(-3px);
}

@keyframes fadeIn {
  from { transform:scale(0.9); opacity:0; }
  to { transform:scale(1); opacity:1; }
}
</style>

<!-- SUCCESS MESSAGE -->
<div id="successMessage" style="
display:none;
position:fixed;
top:20px;
right:20px;
background:#1e7e34;
color:white;
padding:15px 20px;
border-radius:10px;
z-index:1000;">
✅ Order Done Successfully!
</div>

<!-- Page Title -->
    <div class="page-title dark-background" data-aos="fade" style="background-image: url({{ asset('assets/img/page-title-bg.webp') }});">
      <div class="container position-relative">
        <h1>Equipments</h1>
        <p>
          Home
          /
          Equipments</p>
        <nav class="breadcrumbs">
          <ol>
            <li><a href="{{ path('app_home') }}">Home</a></li>
            <li class="current">Equipments</li>
          </ol>
        </nav>
      </div>
    </div><!-- End Page Title -->

    <!-- Blog Posts 2 Section -->
    <section id="blog-posts-2" class="blog-posts-2 section">

      <div class="container">
  <div class="row gy-4">

    {% for equipement in equipements %}
      <div class="col-lg-4">
        <article class="position-relative h-100">

          <!-- IMAGE (remplace l'image statique) -->
          <div class="post-img position-relative overflow-hidden" 
     style="height:250px; display:flex; align-items:center; justify-content:center; background:#f5f5f5;">

  <img src="{{ asset('uploads/equipement/' ~ equipement.imageEq) }}" 
       style="max-height:100%; max-width:100%; object-fit:contain;" 
       class="img-fluid" 
       alt="">
</div>

          <div class="post-content d-flex flex-column">

            <!-- NOM -->
            <h3 class="post-title">
              {{ equipement.nomEq }}
            </h3>

            <!-- DESCRIPTION -->
            <p>
              {{ equipement.descriptionEq }}
            </p>

            <!-- PRIX -->
            {% set prixOriginal = equipement.coutAchat %}
            {% set prixPromo = prixOriginal * 0.7 %}

            <p>
              <span style="text-decoration:line-through; color:#888;">
                {{ prixOriginal }} DT
              </span>
            </p>

            <p style="color:#1e7e34; font-weight:bold; font-size:18px;">
              {{ prixPromo|number_format(2) }} DT
            </p>
            <a href="#" 
              class="btn-modern"
              onclick="openModal('{{ equipement.nomEq }}')"
              style="align-self:flex-end;">
              🛒 Order
            </a>

        </article>
      </div>
    {% else %}
      <p>Aucun équipement disponible.</p>
    {% endfor %}

  </div>
</div>

<!-- MODAL -->
<div id="orderModal" style="
display:none;
position:fixed;
top:0; left:0;
width:100%; height:100%;
background:rgba(0,0,0,0.6);
backdrop-filter:blur(5px);
z-index:999;
">

  <div style="
  background:white;
  width:450px;
  margin:80px auto;
  border-radius:20px;
  overflow:hidden;
  box-shadow:0 20px 50px rgba(0,0,0,0.3);
  animation:fadeIn 0.3s;
  ">

    <div style="
    background:linear-gradient(135deg, #1e7e34, #218838);
    color:white;
    padding:20px;
    display:flex;
    justify-content:space-between;">
      <h5>🛒 Place Order</h5>
      <span onclick="closeModal()" style="cursor:pointer;">✖</span>
    </div>

    <div style="padding:20px;">
      <p id="productName" style="background:#e6f4ea; padding:10px; border-radius:10px;"></p>

      <input type="text" id="clientName" placeholder="Your name"
             style="width:100%; padding:10px; margin-bottom:10px; border-radius:10px; border:1px solid #ccc;">

      <select id="paymentMethod"
              style="width:100%; padding:10px; border-radius:10px; border:1px solid #ccc;">
        <option>Cash</option>
        <option>Card</option>
        <option>Online</option>
      </select>
    </div>

    <div style="padding:20px; display:flex; justify-content:flex-end; gap:10px;">
      <button onclick="closeModal()">Cancel</button>

      <button onclick="submitOrder()" style="
      background:linear-gradient(135deg, #1e7e34, #218838);
      color:white;
      border:none;
      padding:10px 20px;
      border-radius:10px;">
      Confirm
      </button>
    </div>

  </div>
</div>

    </section><!-- /Blog Posts 2 Section -->

    <!-- Blog Pagination Section -->
    <section id="blog-pagination" class="blog-pagination section">

      <div class="container">
        <div class="d-flex justify-content-center">
          <ul>
            <li><a href="#"><i class="bi bi-chevron-left"></i></a></li>
            <li><a href="#">1</a></li>
            <li><a href="#" class="active">2</a></li>
            <li><a href="#">3</a></li>
            <li><a href="#">4</a></li>
            <li>...</li>
            <li><a href="#">10</a></li>
            <li><a href="#"><i class="bi bi-chevron-right"></i></a></li>
          </ul>
        </div>
      </div>

    </section><!-- /Blog Pagination Section -->

    <!-- Call To Action Section -->
    <section id="call-to-action" class="call-to-action section light-background">

      <div class="content">
        <div class="container">
          <div class="row align-items-center">
            <div class="col-lg-6">
              <h3>Subscribe To Our Newsletter</h3>
              <p class="opacity-50">
                Lorem ipsum dolor sit amet consectetur adipisicing elit.
                Nesciunt, reprehenderit!
              </p>
            </div>
            <div class="col-lg-6">
              <form action="{{ path('app_newsletter_submit') }}" class="form-subscribe php-email-form">
                <div class="form-group d-flex align-items-stretch">
                  <input type="email" name="email" class="form-control h-100" placeholder="Enter your e-mail">
                  <input type="submit" class="btn btn-secondary px-4" value="Subscribe">
                </div>
                <div class="loading">Loading</div>
                <div class="error-message"></div>
                <div class="sent-message">
                  Your subscription request has been sent. Thank you!
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section><!-- /Call To Action Section -->

    
<script>
function openModal(name) {
  document.getElementById('orderModal').style.display = 'block';
  document.getElementById('productName').innerText = "Product: " + name;
}

function closeModal() {
  document.getElementById('orderModal').style.display = 'none';
}

function submitOrder() {
  let name = document.getElementById('clientName').value;

  if (name === "") {
    alert("Enter your name");
    return;
  }

  closeModal();

  let msg = document.getElementById('successMessage');
  msg.style.display = 'block';

  setTimeout(() => {
    msg.style.display = 'none';
  }, 3000);
}
</script>
{% endblock %}