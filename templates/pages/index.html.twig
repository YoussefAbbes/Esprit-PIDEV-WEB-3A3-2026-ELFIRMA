{% extends 'base.html.twig' %}

{% block title %}Index - EL FIRMA{% endblock %}
{% block meta_description %}{% endblock %}
{% block meta_keywords %}{% endblock %}
{% block body_class %}index-page{% endblock %}

{% block body %}
<!-- Hero Section -->
    <section id="hero" class="hero section dark-background">

      <div id="hero-carousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="5000">

        <div class="carousel-item active">
          <img src="{{ asset('assets/img/hero_1.jpg') }}" alt="">
          <div class="carousel-container">
            <h2>EL FIRMA organizes all seasonal agricultural work</h2>
          </div>
        </div><!-- End Carousel Item -->

        <div class="carousel-item">
          <img src="{{ asset('assets/img/hero_2.jpg') }}" alt="">
          <div class="carousel-container">
            <h2>Healthy, traceable, high-quality agricultural production</h2>
          </div>
        </div><!-- End Carousel Item -->

        <div class="carousel-item">
          <img src="{{ asset('assets/img/hero_3.jpg') }}" alt="">
          <div class="carousel-container">
            <h2>Organized, productive, and sustainable agriculture</h2>
          </div>
        </div><!-- End Carousel Item -->

        <div class="carousel-item">
          <img src="{{ asset('assets/img/hero_4.jpg') }}" alt="">
          <div class="carousel-container">
            <h2>Planning, execution, and monitoring for every plot</h2>
          </div>
        </div><!-- End Carousel Item -->

        <div class="carousel-item">
          <img src="{{ asset('assets/img/hero_5.jpg') }}" alt="">
          <div class="carousel-container">
            <h2>Harvests that matter for everyone</h2>
          </div>
        </div><!-- End Carousel Item -->

        <a class="carousel-control-prev" href="#hero-carousel" role="button" data-bs-slide="prev">
          <span class="carousel-control-prev-icon bi bi-chevron-left" aria-hidden="true"></span>
        </a>

        <a class="carousel-control-next" href="#hero-carousel" role="button" data-bs-slide="next">
          <span class="carousel-control-next-icon bi bi-chevron-right" aria-hidden="true"></span>
        </a>

        <ol class="carousel-indicators"></ol>

      </div>

    </section><!-- /Hero Section -->

    <!-- Services Section -->
    <section id="services" class="services section">

