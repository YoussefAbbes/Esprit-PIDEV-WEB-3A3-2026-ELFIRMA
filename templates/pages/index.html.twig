    <section class="py-5" style="margin: 60px 0;">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-8 col-md-10">
            <!-- Header -->
            <div class="text-center mb-5">
              <h2 class="display-5 fw-bold mb-3" style="color: #1a3a3a;">Submit Your Feedback</h2>
              <p class="fs-5 text-muted">Help us improve our services by sharing your concerns and suggestions</p>
            </div>

            <!-- Form Card -->
            <div class="card border-0 shadow-lg">
              <div class="card-body p-5">
                <form id="complaintForm" class="needs-validation" novalidate>
                  <!-- Complaint Type -->
                  <div class="mb-4">
                    <label for="type" class="form-label fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                      Complaint Type *
                    </label>
                    <select name="type" id="type" class="form-select form-select-lg" required>
                      <option value="">Select a complaint type...</option>
                      <option value="Product Issue">Product Issue</option>
                      <option value="Service Issue">Service Issue</option>
                      <option value="Delivery Problem">Delivery Problem</option>
                      <option value="Quality Concern">Quality Concern</option>
                      <option value="Other">Other</option>
                    </select>
                    <div class="text-danger small mt-2" id="typeError"></div>
                  </div>

                  <!-- Complaint Title -->
                  <div class="mb-4">
                    <label for="title" class="form-label fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                      Complaint Title *
                    </label>
                    <input type="text" name="title" id="title" class="form-control form-control-lg" placeholder="Brief title of your complaint" maxlength="100" required>
                    <small class="text-muted d-block mt-1">Maximum 100 characters</small>
                    <div class="text-danger small mt-2" id="titleError"></div>
                  </div>

                  <!-- Complaint Description -->
                  <div class="mb-4">
                    <label for="description" class="form-label fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                      Description *
                    </label>
                    <textarea name="description" id="description" class="form-control form-control-lg" rows="6" placeholder="Describe your concern briefly..." maxlength="500" required></textarea>
                    <small class="text-muted d-block mt-1">Maximum 500 characters</small>
                    <div class="text-danger small mt-2" id="descriptionError"></div>
                  </div>

                  <!-- Submit Button -->
                  <div class="d-grid gap-2 pt-2">
                    <button type="submit" class="btn btn-lg fw-bold text-white" style="background-color: #116530; border: none; padding: 0.75rem 1.5rem;">
                      <i class="material-symbols-outlined" style="vertical-align: middle; margin-right: 8px; font-size: 1.25rem;">send</i>
                      SUBMIT COMPLAINT
                    </button>
                  </div>

                  <!-- Messages -->
                  <div class="alert alert-info mt-4 d-none" id="loadingMessage" role="alert">
                    <div class="spinner-border spinner-border-sm me-2" role="status">
                      <span class="visually-hidden">Loading...</span>
                    </div>
                    <span>Processing your complaint...</span>
                  </div>
                  <div class="alert alert-danger mt-4 d-none" id="formError" role="alert"></div>
                  <div class="alert alert-success mt-4 d-none d-flex align-items-center" id="sentMessage" role="alert">
                    <i class="material-symbols-outlined me-2" style="font-size: 1.5rem;">check_circle</i>
                    <span>Your complaint has been submitted successfully! Thank you for your feedback.</span>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>

      <style>
        #complaintForm .form-select:focus,
        #complaintForm .form-control:focus {
          border-color: #116530;
          box-shadow: 0 0 0 0.2rem rgba(17, 101, 48, 0.25);
        }

        #complaintForm .form-select.is-invalid,
        #complaintForm .form-control.is-invalid {
          border-color: #dc3545;
        }

        #complaintForm .form-select.is-invalid:focus,
        #complaintForm .form-control.is-invalid:focus {
          border-color: #dc3545;
          box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25);
        }

        .btn:hover {
          opacity: 0.9;
        }
      </style>

      <script>
        document.addEventListener('DOMContentLoaded', function() {
          const complaintForm = document.getElementById('complaintForm');
          const typeSelect = document.getElementById('type');
          const titleInput = document.getElementById('title');
          const descriptionTextarea = document.getElementById('description');
          const loadingMessage = document.getElementById('loadingMessage');
          const formError = document.getElementById('formError');
          const sentMessage = document.getElementById('sentMessage');

          function clearAllErrors() {
            document.getElementById('typeError').textContent = '';
            document.getElementById('titleError').textContent = '';
            document.getElementById('descriptionError').textContent = '';
            typeSelect.classList.remove('is-invalid');
            titleInput.classList.remove('is-invalid');
            descriptionTextarea.classList.remove('is-invalid');
            formError.classList.add('d-none');
            sentMessage.classList.add('d-none');
          }

          function showFieldError(fieldId, message) {
            const field = document.getElementById(fieldId);
            const errorEl = document.getElementById(fieldId + 'Error');
            field.classList.add('is-invalid');
            errorEl.textContent = message;
          }

          // Real-time validation
          typeSelect.addEventListener('change', function() {
            if (this.value) {
              this.classList.remove('is-invalid');
              document.getElementById('typeError').textContent = '';
            }
          });

          titleInput.addEventListener('blur', function() {
            if (this.value.trim()) {
              this.classList.remove('is-invalid');
              document.getElementById('titleError').textContent = '';
            }
          });

          descriptionTextarea.addEventListener('blur', function() {
            if (this.value.trim()) {
              this.classList.remove('is-invalid');
              document.getElementById('descriptionError').textContent = '';
            }
          });

          // Form submission
          complaintForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            clearAllErrors();

            let hasErrors = false;
            const type = typeSelect.value.trim();
            const title = titleInput.value.trim();
            const description = descriptionTextarea.value.trim();

            if (!type) {
              showFieldError('type', 'Please select a complaint type');
              hasErrors = true;
            }
            if (!title) {
              showFieldError('title', 'Title is required');
              hasErrors = true;
            } else if (title.length > 100) {
              showFieldError('title', 'Title must not exceed 100 characters');
              hasErrors = true;
            }
            if (!description) {
              showFieldError('description', 'Description is required');
              hasErrors = true;
            } else if (description.length > 500) {
              showFieldError('description', 'Description must not exceed 500 characters');
              hasErrors = true;
            }

            if (hasErrors) return;

            loadingMessage.classList.remove('d-none');

            const formData = new FormData();
            formData.append('type', type);
            formData.append('title', title);
            formData.append('description', description);

            try {
              const response = await fetch('{{ path("elfirma_create_complaint") }}', {
                method: 'POST',
                body: formData
              });

              const data = await response.json();
              loadingMessage.classList.add('d-none');

              if (data.success) {
                sentMessage.classList.remove('d-none');
                complaintForm.reset();
                setTimeout(() => sentMessage.classList.add('d-none'), 5000);
              } else {
                if (data.errors && typeof data.errors === 'object') {
                  for (const [field, message] of Object.entries(data.errors)) {
                    showFieldError(field, message);
                  }
                } else {
                  formError.textContent = data.message || 'An error occurred while submitting your complaint.';
                  formError.classList.remove('d-none');
                }
              }
            } catch (error) {
              loadingMessage.classList.add('d-none');
              console.error('Error:', error);
              formError.textContent = 'Network error: Unable to submit your complaint. Please try again.';
              formError.classList.remove('d-none');
            }
          });
        });
      </script>
    </section>
