{% extends 'base.html.twig' %}

{% block title %}Parcels – EL FIRMA{% endblock %}
{% block meta_description %}Explore our agricultural land parcels — soil profiles, availability status, crop history and GPS location data.{% endblock %}
{% block body_class %}pf-client-parcelles{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.css" crossorigin="anonymous">
<style>
/* ================================================================
   DESIGN TOKENS
================================================================ */
:root {
  --pf-primary:   #166534;
  --pf-secondary: #16a34a;
  --pf-light:     #dcfce7;
  --pf-dark:      #052e16;
  --pf-accent:    #4ade80;
  --pf-bg:        #f0fdf4;
}

/* ================================================================
   HERO
================================================================ */
.pf-hero {
  position: relative;
  min-height: 500px;
  background: linear-gradient(135deg, #052e16 0%, #14532d 45%, #166534 100%);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100px 0 0;
}

.pf-hero-bg {
  position: absolute;
  inset: 0;
  background: url('{{ asset('assets/img/hero_1.jpg') }}') center / cover no-repeat;
  opacity: 0.08;
  z-index: 0;
}

.pf-particles {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}

.pf-particle {
  position: absolute;
  border-radius: 50%;
  background: rgba(74, 222, 128, 0.18);
  animation: pfFloat linear infinite;
}

@keyframes pfFloat {
  0%   { transform: translateY(110vh) scale(0); opacity: 0; }
  8%   { opacity: 1; }
  92%  { opacity: 0.9; }
  100% { transform: translateY(-80px)  scale(1); opacity: 0; }
}

.pf-hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  color: #fff;
  padding: 0 16px;
  width: 100%;
}

.pf-badge-pill {
  display: inline-block;
  background: rgba(74, 222, 128, 0.18);
  border: 1px solid rgba(74, 222, 128, 0.42);
  color: #86efac;
  padding: 6px 20px;
  border-radius: 999px;
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .09em;
  text-transform: uppercase;
  margin-bottom: 20px;
}

.pf-hero-title {
  font-family: 'Marcellus', serif;
  font-size: clamp(2.3rem, 5.5vw, 4rem);
  font-weight: 400;
  color: #fff;
  line-height: 1.12;
  margin-bottom: 18px;
}

.pf-hero-title .highlight {
  color: var(--pf-accent);
  position: relative;
}

.pf-hero-subtitle {
  font-size: 1.05rem;
  color: #bbf7d0;
  max-width: 520px;
  margin: 0 auto 44px;
  line-height: 1.75;
  opacity: .9;
}

/* Stat strip */
.pf-stat-strip {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  justify-content: center;
  padding-bottom: 70px;
}

.pf-stat-card {
  background: rgba(255, 255, 255, 0.07);
  border: 1px solid rgba(255, 255, 255, 0.13);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-radius: 18px;
  padding: 18px 26px;
  text-align: center;
  min-width: 118px;
  transition: background .3s, transform .3s;
}

.pf-stat-card:hover {
  background: rgba(255, 255, 255, 0.13);
  transform: translateY(-4px);
}

.pf-stat-num {
  display: block;
  font-size: 2rem;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.pf-stat-num.c-green  { color: var(--pf-accent); }
.pf-stat-num.c-yellow { color: #fbbf24; }
.pf-stat-num.c-sky    { color: #38bdf8; }

.pf-stat-lbl {
  display: block;
  font-size: .69rem;
  font-weight: 700;
  color: #86efac;
  text-transform: uppercase;
  letter-spacing: .08em;
  margin-top: 5px;
}

/* Wave */
.pf-hero-wave {
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 100%;
  z-index: 3;
  line-height: 0;
}

/* ================================================================
   FILTER BAR
================================================================ */
.pf-filter-bar {
  position: static;
  top: unset;
  z-index: 1;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid #e2e8f0;
  box-shadow: 0 4px 22px rgba(0, 0, 0, 0.07);
  padding: 13px 0;
}

.pf-filter-inner {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.pf-search-wrap {
  position: relative;
  flex: 1;
  min-width: 200px;
}

.pf-search-wrap .search-icon {
  position: absolute;
  left: 13px;
  top: 50%;
  transform: translateY(-50%);
  color: #94a3b8;
  font-size: .95rem;
  pointer-events: none;
}

.pf-search-input {
  width: 100%;
  padding: 9px 14px 9px 39px;
  border: 1.5px solid #e2e8f0;
  border-radius: 10px;
  font-size: .88rem;
  outline: none;
  background: #f8fafc;
  transition: border-color .22s, box-shadow .22s, background .22s;
  color: #1e293b;
}

.pf-search-input:focus {
  border-color: var(--pf-secondary);
  box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.12);
  background: #fff;
}

.pf-filter-btns {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.pf-filter-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 7px 15px;
  border: 1.5px solid #e2e8f0;
  border-radius: 999px;
  background: #fff;
  font-size: .8rem;
  font-weight: 600;
  cursor: pointer;
  transition: all .22s;
  color: #475569;
  white-space: nowrap;
}

.pf-filter-btn .fdot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
  transition: transform .2s;
}

.pf-filter-btn:hover .fdot,
.pf-filter-btn.active .fdot {
  transform: scale(1.25);
}

.pf-filter-btn[data-filter="All"]       .fdot { background: #64748b; }
.pf-filter-btn[data-filter="Available"] .fdot { background: #16a34a; }
.pf-filter-btn[data-filter="Occupied"]  .fdot { background: #d97706; }
.pf-filter-btn[data-filter="Resting"]   .fdot { background: #0ea5e9; }

.pf-filter-btn:hover,
.pf-filter-btn.active {
  border-color: var(--pf-secondary);
  background: var(--pf-light);
  color: var(--pf-primary);
}

.pf-view-toggle {
  display: flex;
  gap: 3px;
  border: 1.5px solid #e2e8f0;
  border-radius: 10px;
  padding: 3px;
  background: #f8fafc;
  flex-shrink: 0;
}

.pf-view-btn {
  padding: 6px 10px;
  border: none;
  background: transparent;
  border-radius: 7px;
  color: #94a3b8;
  font-size: .95rem;
  cursor: pointer;
  transition: all .2s;
  line-height: 1;
}

.pf-view-btn.active {
  background: var(--pf-primary);
  color: #fff;
}

.pf-result-count {
  font-size: .78rem;
  color: #94a3b8;
  white-space: nowrap;
  font-weight: 500;
  margin-left: 4px;
}

/* ================================================================
   MAIN SECTION
================================================================ */
.pf-main {
  background: var(--pf-bg);
  padding: 44px 0 90px;
  min-height: 400px;
}

/* ── GRID ── */
.pf-grid        { display: none; }
.pf-grid.active { display: flex; flex-wrap: wrap; gap: 24px; }

.pf-card-col {
  flex: 0 0 calc(33.333% - 16px);
  max-width: calc(33.333% - 16px);
}

@media (max-width: 1199px) {
  .pf-card-col { flex: 0 0 calc(50% - 12px); max-width: calc(50% - 12px); }
}
@media (max-width: 767px) {
  .pf-card-col { flex: 0 0 100%; max-width: 100%; }
}

.pf-card {
  background: #fff;
  border-radius: 20px;
  border: 2px solid transparent;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  overflow: hidden;
  height: 100%;
  display: flex;
  flex-direction: column;
  cursor: pointer;
  transition: border-color .25s, transform .25s ease, box-shadow .25s;
}

.pf-card:hover {
  border-color: var(--pf-secondary);
  transform: translateY(-6px);
  box-shadow: 0 18px 44px rgba(22, 101, 52, 0.15);
}

.pf-card-img-wrap {
  position: relative;
  height: 210px;
  overflow: hidden;
  flex-shrink: 0;
}

.pf-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform .45s ease;
}

.pf-card:hover .pf-card-img { transform: scale(1.07); }

.pf-card-no-img {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #052e16 0%, #166534 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #86efac;
  gap: 10px;
}

.pf-card-no-img i    { font-size: 2.6rem; }
.pf-card-no-img span { font-size: .75rem; font-weight: 600; opacity: .65; letter-spacing: .05em; }

/* Image badges */
.pf-img-badge-tl,
.pf-img-badge-tr {
  position: absolute;
  top: 12px;
  padding: 4px 11px;
  border-radius: 999px;
  font-size: .7rem;
  font-weight: 700;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  letter-spacing: .04em;
  line-height: 1.5;
}

.pf-img-badge-tl { left: 12px;  background: rgba(5, 46, 22, 0.78); color: #86efac; }
.pf-img-badge-tr { right: 12px; }

.pf-badge-available { background: rgba(22, 163, 74, 0.84);  color: #fff; }
.pf-badge-occupied  { background: rgba(217, 119, 6, 0.84);  color: #fff; }
.pf-badge-resting   { background: rgba(14, 165, 233, 0.84); color: #fff; }
.pf-badge-default   { background: rgba(100, 116, 139, 0.84);color: #fff; }

/* Card body */
.pf-card-body {
  padding: 18px 18px 12px;
  flex: 1;
}

.pf-card-title {
  font-family: 'Marcellus', serif;
  font-size: 1.1rem;
  color: #1e293b;
  margin-bottom: 6px;
  line-height: 1.3;
}

.pf-card-loc {
  font-size: .8rem;
  color: #64748b;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 5px;
}

.pf-meta-pills { display: flex; flex-wrap: wrap; gap: 6px; }

.pf-meta-pill {
  background: var(--pf-bg);
  border: 1px solid #d1fae5;
  color: var(--pf-primary);
  border-radius: 999px;
  padding: 3px 11px;
  font-size: .72rem;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

/* Card footer */
.pf-card-footer {
  padding: 12px 18px 18px;
  display: flex;
  gap: 8px;
}

.pf-btn-view {
  flex: 1;
  padding: 10px 0;
  background: var(--pf-primary);
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: .84rem;
  font-weight: 600;
  cursor: pointer;
  transition: background .22s, transform .15s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
}

.pf-btn-view:hover { background: var(--pf-secondary); transform: translateY(-1px); }

.pf-btn-cultures {
  padding: 10px 13px;
  background: var(--pf-light);
  color: var(--pf-primary);
  border: 1.5px solid #bbf7d0;
  border-radius: 10px;
  font-size: .8rem;
  font-weight: 600;
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: background .2s;
  white-space: nowrap;
  flex-shrink: 0;
}

.pf-btn-cultures:hover { background: #bbf7d0; color: var(--pf-primary); }

/* ── LIST VIEW ── */
.pf-list        { display: none; flex-direction: column; gap: 16px; }
.pf-list.active { display: flex; }

.pf-list-card {
  background: #fff;
  border-radius: 16px;
  border: 2px solid transparent;
  box-shadow: 0 3px 16px rgba(0, 0, 0, 0.05);
  overflow: hidden;
  display: flex;
  align-items: stretch;
  cursor: pointer;
  transition: border-color .25s, transform .22s, box-shadow .25s;
}

.pf-list-card:hover {
  border-color: var(--pf-secondary);
  transform: translateX(5px);
  box-shadow: 0 8px 30px rgba(22, 101, 52, 0.12);
}

.pf-list-img-wrap {
  width: 180px;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.pf-list-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform .42s ease;
}

.pf-list-card:hover .pf-list-img-wrap img { transform: scale(1.06); }

.pf-list-no-img {
  width: 100%;
  height: 100%;
  min-height: 130px;
  background: linear-gradient(135deg, #052e16, #166534);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #86efac;
  font-size: 2rem;
}

.pf-list-body {
  flex: 1;
  padding: 16px 22px;
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}

.pf-list-info    { flex: 1; min-width: 180px; }

.pf-list-title {
  font-family: 'Marcellus', serif;
  font-size: 1.05rem;
  color: #1e293b;
  margin-bottom: 4px;
}

.pf-list-loc {
  font-size: .78rem;
  color: #64748b;
  display: flex;
  align-items: center;
  gap: 4px;
  margin-bottom: 10px;
}

.pf-list-actions {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.pf-list-status-badge {
  display: inline-block;
  padding: 5px 13px;
  border-radius: 999px;
  font-size: .72rem;
  font-weight: 700;
}

/* ── EMPTY / NO RESULTS ── */
.pf-empty {
  text-align: center;
  padding: 90px 20px;
}

.pf-icon-wrap {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: var(--pf-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
  font-size: 2.2rem;
  color: var(--pf-primary);
}

.pf-no-results              { display: none; text-align: center; padding: 70px 20px; }
.pf-no-results.pf-show      { display: block; }

/* ================================================================
   MODAL
================================================================ */
.pf-overlay {
  position: fixed;
  inset: 0;
  background: rgba(5, 46, 22, 0.52);
  backdrop-filter: blur(7px);
  -webkit-backdrop-filter: blur(7px);
  z-index: 1060;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity .3s, visibility .3s;
  padding: 16px;
}

.pf-overlay.pf-open {
  opacity: 1;
  visibility: visible;
}

.pf-modal {
  background: #fff;
  border-radius: 22px;
  width: 100%;
  max-width: 860px;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transform: scale(0.94) translateY(24px);
  transition: transform .32s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 32px 90px rgba(0, 0, 0, 0.26);
}

.pf-overlay.pf-open .pf-modal {
  transform: scale(1) translateY(0);
}

/* Banner */
.pf-modal-banner {
  height: 220px;
  position: relative;
  flex-shrink: 0;
  overflow: hidden;
  background: linear-gradient(135deg, #052e16, #166534);
}

.pf-modal-banner img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: .68;
}

.pf-modal-banner-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(5, 46, 22, .88) 0%, rgba(5, 46, 22, .18) 100%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 20px 26px;
  z-index: 2;
}

.pf-modal-close {
  position: absolute;
  top: 14px;
  right: 14px;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.17);
  border: 1px solid rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 1rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .2s;
  z-index: 5;
}

.pf-modal-close:hover { background: rgba(255, 255, 255, 0.3); }

.pf-modal-status {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 999px;
  font-size: .72rem;
  font-weight: 700;
  margin-bottom: 10px;
  letter-spacing: .04em;
}

.pf-modal-name {
  font-family: 'Marcellus', serif;
  font-size: 1.7rem;
  color: #fff;
  margin: 0 0 5px;
  text-shadow: 0 2px 10px rgba(0, 0, 0, .4);
  line-height: 1.2;
}

.pf-modal-loc-line {
  font-size: .84rem;
  color: #bbf7d0;
  display: flex;
  align-items: center;
  gap: 5px;
}

/* Stats strip */
.pf-stats-strip {
  background: var(--pf-dark);
  display: flex;
  justify-content: space-around;
  padding: 15px 20px;
  flex-shrink: 0;
  flex-wrap: wrap;
  gap: 10px;
}

.pf-strip-item { text-align: center; }

.pf-strip-val {
  display: block;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--pf-accent);
  line-height: 1;
}

.pf-strip-lbl {
  display: block;
  font-size: .66rem;
  font-weight: 700;
  color: #86efac;
  text-transform: uppercase;
  letter-spacing: .07em;
  margin-top: 4px;
}

/* Scrollable body */
.pf-modal-body {
  flex: 1;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: #d1fae5 transparent;
}

/* Tabs */
.pf-tab-nav {
  display: flex;
  border-bottom: 1px solid #e2e8f0;
  padding: 0 24px;
  position: sticky;
  top: 0;
  background: #fff;
  z-index: 10;
}

.pf-tab-btn {
  padding: 14px 18px;
  border: none;
  background: transparent;
  color: #94a3b8;
  font-size: .86rem;
  font-weight: 600;
  cursor: pointer;
  border-bottom: 2.5px solid transparent;
  transition: color .2s, border-color .2s;
  display: flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
}

.pf-tab-btn.active {
  color: var(--pf-primary);
  border-bottom-color: var(--pf-secondary);
}

.pf-tab-panel         { display: none; padding: 24px; }
.pf-tab-panel.active  { display: block; }

/* Info grid */
.pf-info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 18px;
}

@media (max-width: 575px) { .pf-info-grid { grid-template-columns: 1fr; } }

.pf-info-item {
  background: var(--pf-bg);
  border-radius: 10px;
  padding: 13px 15px;
  border: 1px solid #d1fae5;
}

.pf-info-lbl {
  font-size: .68rem;
  font-weight: 700;
  color: var(--pf-secondary);
  text-transform: uppercase;
  letter-spacing: .07em;
  margin-bottom: 4px;
}

.pf-info-val {
  font-size: .92rem;
  color: #1e293b;
  font-weight: 500;
}

.pf-gps-card {
  background: linear-gradient(135deg, #052e16, #166534);
  border-radius: 14px;
  padding: 16px 20px;
  color: #fff;
  display: flex;
  align-items: center;
  gap: 14px;
  margin-top: 6px;
}

.pf-gps-card .gps-icon { font-size: 1.8rem; color: var(--pf-accent); flex-shrink: 0; }
.pf-gps-label { font-weight: 700; font-size: .9rem; margin-bottom: 2px; }
.pf-gps-coords { font-size: .82rem; color: #bbf7d0; }

/* Map */
#pf-map {
  height: 320px;
  width: 100%;
  border-radius: 13px;
  position: relative;
  z-index: 0;
  isolation: isolate;
}

.pf-map-placeholder {
  height: 320px;
  border-radius: 13px;
  background: var(--pf-bg);
  border: 2px dashed #bbf7d0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #94a3b8;
  gap: 10px;
  font-size: .9rem;
  font-weight: 500;
}

/* Crops */
.pf-culture-item {
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 13px;
  padding: 15px 17px;
  margin-bottom: 12px;
  transition: border-color .2s, box-shadow .2s;
}

.pf-culture-item:hover {
  border-color: var(--pf-secondary);
  box-shadow: 0 4px 16px rgba(22, 101, 52, 0.08);
}

.pf-culture-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}

.pf-culture-icon {
  width: 42px;
  height: 42px;
  border-radius: 11px;
  background: var(--pf-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  flex-shrink: 0;
}

.pf-culture-name    { font-weight: 700; color: #1e293b; font-size: .9rem; }
.pf-culture-variety { font-size: .76rem; color: #64748b; margin-top: 1px; }

.pf-culture-dates {
  display: flex;
  gap: 18px;
  font-size: .76rem;
  color: #64748b;
  margin-bottom: 8px;
  flex-wrap: wrap;
}

.pf-progress-wrap {
  background: #f1f5f9;
  border-radius: 999px;
  height: 7px;
  overflow: hidden;
  flex: 1;
}

.pf-progress-bar {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--pf-secondary), var(--pf-accent));
  transition: width .65s ease;
}

/* Modal footer btn */
.pf-modal-footer-btn {
  display: flex;
  justify-content: center;
  padding: 6px 24px 30px;
}

/* ================================================================
   CTA SECTION
================================================================ */
.pf-cta {
  position: relative;
  background: linear-gradient(135deg, #052e16 0%, #166534 100%);
  overflow: hidden;
  padding: 88px 0;
  text-align: center;
}

.pf-cta-bg {
  position: absolute;
  inset: 0;
  background: url('{{ asset('assets/img/hero_1.jpg') }}') center / cover no-repeat;
  opacity: 0.06;
}

.pf-cta-content  { position: relative; z-index: 1; color: #fff; }

.pf-cta h2 {
  font-family: 'Marcellus', serif;
  font-size: clamp(1.9rem, 3.5vw, 2.9rem);
  margin-bottom: 14px;
}

.pf-cta p {
  color: #bbf7d0;
  max-width: 460px;
  margin: 0 auto 30px;
  font-size: 1.02rem;
  line-height: 1.7;
}

.pf-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 13px 34px;
  background: var(--pf-accent);
  color: var(--pf-dark);
  border-radius: 12px;
  font-weight: 700;
  font-size: .95rem;
  text-decoration: none;
  transition: background .22s, transform .2s, box-shadow .2s;
}

.pf-cta-btn:hover {
  background: #86efac;
  transform: translateY(-3px);
  box-shadow: 0 10px 28px rgba(74, 222, 128, 0.3);
  color: var(--pf-dark);
}

/* ================================================================
   TOAST
================================================================ */
.pf-toast-container {
  position: fixed;
  bottom: 26px;
  right: 26px;
  z-index: 2000;
  display: flex;
  flex-direction: column;
  gap: 10px;
  pointer-events: none;
}

.pf-toast {
  background: #1e293b;
  color: #fff;
  padding: 12px 18px;
  border-radius: 13px;
  font-size: .83rem;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 9px;
  box-shadow: 0 8px 28px rgba(0, 0, 0, 0.22);
  pointer-events: all;
  transform: translateX(130%);
  opacity: 0;
  transition: transform .38s cubic-bezier(0.34, 1.56, 0.64, 1), opacity .3s;
  max-width: 300px;
}

.pf-toast.pf-show {
  transform: translateX(0);
  opacity: 1;
}

.pf-toast .ti { font-size: 1rem; color: var(--pf-accent); }

/* ================================================================
   RESPONSIVE
================================================================ */
@media (max-width: 575px) {
  .pf-list-img-wrap { width: 110px; }
  .pf-stat-card     { min-width: 90px; padding: 14px 16px; }
  .pf-stat-num      { font-size: 1.5rem; }
  .pf-modal-name    { font-size: 1.3rem; }
}

/* ================================================================
   WEATHER TAB
================================================================ */
.pf-api-loading {
  text-align: center; padding: 40px 20px; color: #94a3b8;
}
.pf-api-loading i { font-size: 2rem; display: block; margin-bottom: 10px; animation: pf-spin 1.1s linear infinite; }
@keyframes pf-spin { to { transform: rotate(360deg); } }

.pf-api-no-coords {
  text-align: center; padding: 40px 20px; color: #94a3b8;
  border: 2px dashed #d1fae5; border-radius: 14px;
}
.pf-api-no-coords i { font-size: 2.5rem; display: block; margin-bottom: 10px; }

.pf-weather-alert {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 14px 18px; border-radius: 12px; margin-bottom: 16px;
  font-size: .86rem; font-weight: 600; line-height: 1.5;
}
.pf-alert-frost   { background: #eff6ff; border: 1.5px solid #bfdbfe; color: #1e40af; }
.pf-alert-drought { background: #fff7ed; border: 1.5px solid #fed7aa; color: #9a3412; }
.pf-alert-storm   { background: #fdf4ff; border: 1.5px solid #e9d5ff; color: #6b21a8; }
.pf-alert-good    { background: #f0fdf4; border: 1.5px solid #bbf7d0; color: #166534; }
.pf-alert-icon    { font-size: 1.3rem; flex-shrink: 0; margin-top: 1px; }

.pf-current-card {
  background: linear-gradient(135deg, #052e16 0%, #166534 55%, #15803d 100%);
  border-radius: 18px; padding: 22px 24px; color: white;
  display: flex; align-items: center; gap: 20px; margin-bottom: 16px;
  position: relative; overflow: hidden;
}
.pf-current-card::before {
  content: ''; position: absolute; top: -50px; right: -50px;
  width: 180px; height: 180px; background: rgba(255,255,255,0.06); border-radius: 50%;
}
.pf-current-card::after {
  content: ''; position: absolute; bottom: -40px; left: 30%;
  width: 120px; height: 120px; background: rgba(255,255,255,0.04); border-radius: 50%;
}
.pf-wx-icon-big  { font-size: 3.8rem; line-height: 1; flex-shrink: 0; z-index: 1; }
.pf-wx-info      { z-index: 1; }
.pf-wx-temp      { font-size: 2.6rem; font-weight: 800; line-height: 1; margin-bottom: 4px; }
.pf-wx-desc      { font-size: .88rem; color: rgba(255,255,255,.8); margin-bottom: 8px; }
.pf-wx-meta      { display: flex; gap: 14px; flex-wrap: wrap; }
.pf-wx-meta span { font-size: .76rem; color: rgba(255,255,255,.7); display: flex; align-items: center; gap: 5px; }

.pf-agro-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 18px;
}
.pf-agro-item {
  background: var(--pf-bg); border: 1px solid #d1fae5; border-radius: 13px;
  padding: 14px 10px; text-align: center;
}
.pf-agro-emoji { font-size: 1.6rem; margin-bottom: 6px; }
.pf-agro-val   { font-size: 1.05rem; font-weight: 800; color: var(--pf-primary); }
.pf-agro-lbl   { font-size: .65rem; color: #64748b; text-transform: uppercase; letter-spacing: .05em; font-weight: 700; margin-top: 2px; }

.pf-forecast-lbl { font-size: .75rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 10px; }
.pf-forecast-grid {
  display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px;
}
.pf-fc-day {
  background: var(--pf-bg); border: 1px solid #d1fae5; border-radius: 11px;
  padding: 9px 3px; text-align: center; font-size: .7rem;
}
.pf-fc-day.pf-fc-today { background: var(--pf-primary); border-color: var(--pf-primary); color: white; }
.pf-fc-name  { font-weight: 700; margin-bottom: 4px; }
.pf-fc-icon  { font-size: 1.2rem; margin: 3px 0; }
.pf-fc-max   { font-weight: 800; color: #dc2626; font-size: .75rem; }
.pf-fc-today .pf-fc-max { color: #fca5a5; }
.pf-fc-min   { color: #2563eb; font-size: .7rem; }
.pf-fc-today .pf-fc-min { color: #bfdbfe; }
.pf-fc-rain  { height: 4px; background: rgba(0,0,0,.1); border-radius: 2px; margin-top: 4px; }
.pf-fc-rain-fill { height: 100%; border-radius: 2px; background: #38bdf8; transition: width .5s; }

@media (max-width: 480px) {
  .pf-forecast-grid { grid-template-columns: repeat(4, 1fr); }
  .pf-agro-grid     { grid-template-columns: 1fr 1fr; }
}

/* ================================================================
   SOIL ANALYSIS TAB
================================================================ */
.pf-soil-source {
  font-size: .72rem; color: #9ca3af; text-align: right; margin-bottom: 14px;
}
.pf-soil-source a { color: #16a34a; text-decoration: none; font-weight: 600; }

.pf-ph-card {
  background: white; border: 1px solid #e5e7eb; border-radius: 16px; padding: 18px; margin-bottom: 14px;
}
.pf-ph-title { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #6b7280; margin-bottom: 12px; }
.pf-ph-scale { display: flex; border-radius: 8px; overflow: hidden; height: 14px; margin-bottom: 8px; }
.pf-ph-seg   { flex: 1; }
.pf-ph-pointer-row { position: relative; height: 22px; margin-bottom: 6px; }
.pf-ph-pointer {
  position: absolute; transform: translateX(-50%);
  background: #111827; color: white; font-size: .68rem; font-weight: 800;
  padding: 3px 8px; border-radius: 20px; white-space: nowrap; top: 0;
}
.pf-ph-interpret {
  font-size: .78rem; font-weight: 600; padding: 8px 12px; border-radius: 8px;
}

.pf-soil-props  { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }
.pf-prop-card   { background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 14px 16px; }
.pf-prop-head   { display: flex; justify-content: space-between; align-items: center; margin-bottom: 7px; }
.pf-prop-name   { font-size: .82rem; font-weight: 700; color: #374151; display: flex; align-items: center; gap: 6px; }
.pf-prop-pct    { font-size: .86rem; font-weight: 800; }
.pf-prop-bg     { height: 8px; background: #f3f4f6; border-radius: 4px; }
.pf-prop-fill   { height: 8px; border-radius: 4px; transition: width .9s cubic-bezier(.4,0,.2,1); width: 0; }
.pf-prop-hint   { font-size: .7rem; color: #6b7280; margin-top: 4px; }

.pf-soil-card {
  border-radius: 14px; padding: 16px 18px;
  display: flex; align-items: flex-start; gap: 14px; margin-top: 4px;
}
.pf-soil-card-icon { font-size: 1.8rem; flex-shrink: 0; margin-top: 2px; }
.pf-soil-card-body h5 { font-size: .92rem; font-weight: 800; margin-bottom: 4px; }
.pf-soil-card-body p  { font-size: .78rem; margin: 0; line-height: 1.55; }

/* Nominatim geocoded address */
.pf-geocode-row {
  background: linear-gradient(135deg, #f0fdf4, #dcfce7);
  border: 1px solid #bbf7d0; border-radius: 12px;
  padding: 12px 15px; margin-top: 10px;
  display: flex; align-items: flex-start; gap: 10px; font-size: .82rem;
}
.pf-geocode-row i { color: var(--pf-secondary); font-size: 1rem; flex-shrink: 0; margin-top: 2px; }
.pf-geocode-row span { color: #374151; font-weight: 500; line-height: 1.5; }
</style>
{% endblock %}

{% block body %}

{# ================================================================
   HERO
================================================================ #}
<section class="pf-hero">
  <div class="pf-hero-bg"></div>
  <div class="pf-particles" id="pfParticles"></div>

  <div class="pf-hero-content container">
    <div class="pf-badge-pill" data-aos="fade-down">
      <i class="bi bi-geo-alt-fill me-1"></i> Agricultural Land Registry
    </div>
    <h1 class="pf-hero-title" data-aos="fade-up" data-aos-delay="60">
      Our <span class="highlight">Parcels</span>
    </h1>
    <p class="pf-hero-subtitle" data-aos="fade-up" data-aos-delay="120">
      Explore our curated agricultural land parcels — detailed soil profiles,
      real-time availability, and full growing history.
    </p>

    <div class="pf-stat-strip" data-aos="fade-up" data-aos-delay="180">
      <div class="pf-stat-card">
        <span class="pf-stat-num" data-target="{{ stats.total }}">0</span>
        <span class="pf-stat-lbl">Total Parcels</span>
      </div>
      <div class="pf-stat-card">
        <span class="pf-stat-num c-green" data-target="{{ stats.available }}">0</span>
        <span class="pf-stat-lbl">Available</span>
      </div>
      <div class="pf-stat-card">
        <span class="pf-stat-num c-yellow" data-target="{{ stats.occupied }}">0</span>
        <span class="pf-stat-lbl">Occupied</span>
      </div>
      <div class="pf-stat-card">
        <span class="pf-stat-num c-sky" data-target="{{ stats.resting }}">0</span>
        <span class="pf-stat-lbl">Resting</span>
      </div>
      <div class="pf-stat-card">
        <span class="pf-stat-num c-green"
              data-target="{{ stats.totalArea|number_format(1, '.', '') }}"
              data-suffix=" ha">0</span>
        <span class="pf-stat-lbl">Total Area</span>
      </div>
    </div>
  </div>

  <div class="pf-hero-wave">
    <svg viewBox="0 0 1440 72" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,36 C240,72 480,0 720,36 C960,72 1200,0 1440,36 L1440,72 L0,72 Z"
            fill="var(--pf-bg)"/>
    </svg>
  </div>
</section>

{# ================================================================
   STICKY FILTER BAR
================================================================ #}
<div class="pf-filter-bar">
  <div class="container">
    <div class="pf-filter-inner">

      <div class="pf-search-wrap">
        <i class="bi bi-search search-icon"></i>
        <input type="text" id="pfSearch" class="pf-search-input"
               placeholder="Search parcel name or location…" autocomplete="off">
      </div>

      <div class="pf-filter-btns">
        <button class="pf-filter-btn active" data-filter="All">
          <span class="fdot"></span>All
        </button>
        <button class="pf-filter-btn" data-filter="Available">
          <span class="fdot"></span>Available
        </button>
        <button class="pf-filter-btn" data-filter="Occupied">
          <span class="fdot"></span>Occupied
        </button>
        <button class="pf-filter-btn" data-filter="Resting">
          <span class="fdot"></span>Resting
        </button>
      </div>

      <div class="pf-view-toggle">
        <button class="pf-view-btn active" id="pfGridBtn" title="Grid view">
          <i class="bi bi-grid-3x3-gap-fill"></i>
        </button>
        <button class="pf-view-btn" id="pfListBtn" title="List view">
          <i class="bi bi-list-ul"></i>
        </button>
      </div>

      <span class="pf-result-count" id="pfResultCount"></span>
    </div>
  </div>
</div>

{# ================================================================
   MAIN PARCELLES SECTION
================================================================ #}
<section class="pf-main">
  <div class="container">

    {% if parcelles is empty %}
    {# ── EMPTY STATE ── #}
    <div class="pf-empty" data-aos="fade-up">
      <div class="pf-icon-wrap"><i class="bi bi-map"></i></div>
      <h4 class="mb-2">No Parcels Available</h4>
      <p class="text-muted mb-0">
        Parcels will appear here once they are added to the registry.
      </p>
    </div>

    {% else %}

    {# ── NO RESULTS (JS-controlled) ── #}
    <div class="pf-no-results" id="pfNoResults">
      <div class="pf-icon-wrap" style="margin:0 auto 18px;">
        <i class="bi bi-search"></i>
      </div>
      <h5 class="mb-2">No results found</h5>
      <p class="text-muted mb-3">Try a different search term or reset your filters.</p>
      <button class="btn btn-outline-success btn-sm" id="pfClearFilters">
        <i class="bi bi-x-circle me-1"></i>Clear Filters
      </button>
    </div>

    {# ================================================================
       GRID VIEW
    ================================================================ #}
    <div class="pf-grid active" id="pfGrid">
      {% for parcelle in parcelles %}

      {% set badgeClass = 'pf-badge-default' %}
      {% if parcelle.statut == 'Available' %}{% set badgeClass = 'pf-badge-available' %}
      {% elseif parcelle.statut == 'Occupied' %}{% set badgeClass = 'pf-badge-occupied' %}
      {% elseif parcelle.statut == 'Resting'  %}{% set badgeClass = 'pf-badge-resting'  %}
      {% endif %}

      <div class="pf-card-col pf-parcel-item"
           data-status="{{ parcelle.statut }}"
           data-name="{{ parcelle.nom|lower }}"
           data-loc="{{ parcelle.localisation|lower }}"
           data-aos="fade-up"
           data-aos-delay="{{ (loop.index0 % 3) * 80 }}">

        <article class="pf-card"
                 data-id="{{ parcelle.id }}"
                 data-name="{{ parcelle.nom }}"
                 data-loc="{{ parcelle.localisation|default('—') }}"
                 data-area="{{ parcelle.superficie is not null ? parcelle.superficie|number_format(2, '.', '') : '0.00' }}"
                 data-soil="{{ parcelle.typeSol|default('N/A') }}"
                 data-statut="{{ parcelle.statut|default('Unknown') }}"
                 data-date="{{ parcelle.dateCreation ? parcelle.dateCreation|date('d/m/Y') : 'N/A' }}"
                 data-lat="{{ parcelle.latitude ?? '' }}"
                 data-lng="{{ parcelle.longitude ?? '' }}"
                 data-image-url="{{ parcelle.image ? path('parcelle_image', {id: parcelle.id}) : '' }}"
                 data-cultures="{{ parcelle.cultures|map(c => {
                   'id':             c.id,
                   'nom':            c.nomCulture,
                   'variete':        c.variete,
                   'statut':         c.statut,
                   'datePlantation': c.datePlantation ? c.datePlantation|date('d/m/Y') : 'N/A',
                   'dateRecolte':    c.dateRecoltePrevue ? c.dateRecoltePrevue|date('d/m/Y') : 'N/A',
                   'progress':       c.quantitePlantee > 0 ? ((c.quantiteRecoltee / c.quantitePlantee) * 100)|round : 0
                 })|json_encode|e('html_attr') }}"
                 onclick="PF.openModal(this)">

          {# Image area #}
          <div class="pf-card-img-wrap">
            {% if parcelle.image %}
              <img class="pf-card-img"
                   src="{{ path('parcelle_image', {id: parcelle.id}) }}"
                   alt="{{ parcelle.nom }}"
                   loading="lazy">
            {% else %}
              <div class="pf-card-no-img">
                <i class="bi bi-tree-fill"></i>
                <span>No Image</span>
              </div>
            {% endif %}
            <span class="pf-img-badge-tl">{{ parcelle.typeSol|default('N/A') }}</span>
            <span class="pf-img-badge-tr {{ badgeClass }}">{{ parcelle.statut|default('Unknown') }}</span>
          </div>

          {# Body #}
          <div class="pf-card-body">
            <h3 class="pf-card-title">{{ parcelle.nom }}</h3>
            <p class="pf-card-loc">
              <i class="bi bi-geo-alt-fill" style="color:var(--pf-secondary);"></i>
              {{ parcelle.localisation|default('Unknown location') }}
            </p>
            <div class="pf-meta-pills">
              <span class="pf-meta-pill">
                <i class="bi bi-rulers"></i>
                {{ parcelle.superficie is not null
                   ? parcelle.superficie|number_format(2, '.', '')
                   : '0.00' }} ha
              </span>
              <span class="pf-meta-pill">
                <i class="bi bi-flower2"></i>
                {{ parcelle.cultures|length }}
                crop{{ parcelle.cultures|length != 1 ? 's' : '' }}
              </span>
              {% if parcelle.dateCreation %}
              <span class="pf-meta-pill">
                <i class="bi bi-calendar3"></i>
                {{ parcelle.dateCreation|date('Y') }}
              </span>
              {% endif %}
            </div>
          </div>

          {# Footer #}
          <div class="pf-card-footer" onclick="event.stopPropagation()">
            <button class="pf-btn-view"
                    onclick="PF.openModal(this.closest('.pf-card'))">
              <i class="bi bi-eye"></i> View Details
            </button>
            <a href="{{ path('app_client_cultures') }}"
               class="pf-btn-cultures"
               title="Browse crops">
              Crops <i class="bi bi-arrow-right-short"></i>
            </a>
          </div>
        </article>
      </div>

      {% endfor %}
    </div>{# end pf-grid #}

    {# ================================================================
       LIST VIEW
    ================================================================ #}
    <div class="pf-list" id="pfList">
      {% for parcelle in parcelles %}

      {% set badgeClass = 'pf-badge-default' %}
      {% if parcelle.statut == 'Available' %}{% set badgeClass = 'pf-badge-available' %}
      {% elseif parcelle.statut == 'Occupied' %}{% set badgeClass = 'pf-badge-occupied' %}
      {% elseif parcelle.statut == 'Resting'  %}{% set badgeClass = 'pf-badge-resting'  %}
      {% endif %}

      <div class="pf-parcel-item"
           data-status="{{ parcelle.statut }}"
           data-name="{{ parcelle.nom|lower }}"
           data-loc="{{ parcelle.localisation|lower }}"
           data-aos="fade-right"
           data-aos-delay="{{ loop.index0 * 50 }}">

        <article class="pf-list-card"
                 data-id="{{ parcelle.id }}"
                 data-name="{{ parcelle.nom }}"
                 data-loc="{{ parcelle.localisation|default('—') }}"
                 data-area="{{ parcelle.superficie is not null ? parcelle.superficie|number_format(2, '.', '') : '0.00' }}"
                 data-soil="{{ parcelle.typeSol|default('N/A') }}"
                 data-statut="{{ parcelle.statut|default('Unknown') }}"
                 data-date="{{ parcelle.dateCreation ? parcelle.dateCreation|date('d/m/Y') : 'N/A' }}"
                 data-lat="{{ parcelle.latitude ?? '' }}"
                 data-lng="{{ parcelle.longitude ?? '' }}"
                 data-image-url="{{ parcelle.image ? path('parcelle_image', {id: parcelle.id}) : '' }}"
                 data-cultures="{{ parcelle.cultures|map(c => {
                   'id':             c.id,
                   'nom':            c.nomCulture,
                   'variete':        c.variete,
                   'statut':         c.statut,
                   'datePlantation': c.datePlantation ? c.datePlantation|date('d/m/Y') : 'N/A',
                   'dateRecolte':    c.dateRecoltePrevue ? c.dateRecoltePrevue|date('d/m/Y') : 'N/A',
                   'progress':       c.quantitePlantee > 0 ? ((c.quantiteRecoltee / c.quantitePlantee) * 100)|round : 0
                 })|json_encode|e('html_attr') }}"
                 onclick="PF.openModal(this)">

          <div class="pf-list-img-wrap">
            {% if parcelle.image %}
              <img src="{{ path('parcelle_image', {id: parcelle.id}) }}"
                   alt="{{ parcelle.nom }}" loading="lazy">
            {% else %}
              <div class="pf-list-no-img"><i class="bi bi-tree-fill"></i></div>
            {% endif %}
          </div>

          <div class="pf-list-body">
            <div class="pf-list-info">
              <h3 class="pf-list-title">{{ parcelle.nom }}</h3>
              <p class="pf-list-loc">
                <i class="bi bi-geo-alt-fill" style="color:var(--pf-secondary);"></i>
                {{ parcelle.localisation|default('Unknown') }}
              </p>
              <div class="pf-meta-pills">
                <span class="pf-meta-pill">
                  <i class="bi bi-rulers"></i>
                  {{ parcelle.superficie is not null
