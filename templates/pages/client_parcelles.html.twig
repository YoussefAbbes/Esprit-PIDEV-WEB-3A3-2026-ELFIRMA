{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.js" crossorigin="anonymous"></script>
<script>
/* ================================================================
   EL FIRMA — Client Parcelles Module
================================================================ */
var PF = (function () {
  'use strict';

  /* ──────────────────────────────────────────────────────────────
     PARTICLES
  ────────────────────────────────────────────────────────────── */
  function initParticles() {
    var c = document.getElementById('pfParticles');
    if (!c) return;
    for (var i = 0; i < 24; i++) {
      var el   = document.createElement('div');
      el.className = 'pf-particle';
      var sz   = (Math.random() * 14 + 5).toFixed(1);
      var dur  = (Math.random() * 13 + 10).toFixed(1);
      var del  = (Math.random() * -22).toFixed(1);
      var left = (Math.random() * 100).toFixed(1);
      el.style.cssText =
        'width:'              + sz   + 'px;' +
        'height:'             + sz   + 'px;' +
        'left:'               + left + '%;'  +
        'animation-duration:' + dur  + 's;'  +
        'animation-delay:'    + del  + 's;';
      c.appendChild(el);
    }
  }

  /* ──────────────────────────────────────────────────────────────
     COUNTER ANIMATION
  ────────────────────────────────────────────────────────────── */
  function animateCounter(el) {
    var raw    = el.dataset.target || '0';
    var target = parseFloat(raw);
    var suffix = el.dataset.suffix || '';
    var isFloat = raw.indexOf('.') !== -1;
    var duration = 1700;
    var start    = performance.now();

    function step(now) {
      var elapsed  = now - start;
      var progress = Math.min(elapsed / duration, 1);
      var ease     = 1 - Math.pow(1 - progress, 3);
      var current  = target * ease;
      el.textContent = (isFloat ? current.toFixed(1) : Math.floor(current)) + suffix;
      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        el.textContent = (isFloat ? target.toFixed(1) : Math.floor(target)) + suffix;
      }
    }
    requestAnimationFrame(step);
  }

  function initCounters() {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          animateCounter(e.target);
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.4 });

    document.querySelectorAll('[data-target]').forEach(function (el) {
      io.observe(el);
    });
  }

  /* ──────────────────────────────────────────────────────────────
     TOAST
  ────────────────────────────────────────────────────────────── */
  function toast(msg, icon) {
    icon = icon || 'check-circle-fill';
    var container = document.getElementById('pfToastContainer');
    var t = document.createElement('div');
    t.className = 'pf-toast';
    t.innerHTML = '<i class="bi bi-' + icon + ' ti"></i><span>' + msg + '</span>';
    container.appendChild(t);
    requestAnimationFrame(function () {
      requestAnimationFrame(function () { t.classList.add('pf-show'); });
    });
    setTimeout(function () {
      t.classList.remove('pf-show');
      setTimeout(function () { t.remove(); }, 420);
    }, 3000);
  }

  /* ──────────────────────────────────────────────────────────────
     FILTER / SEARCH
  ────────────────────────────────────────────────────────────── */
  var currentStatus = 'All';
  var currentSearch = '';

  function applyFilters() {
    var items   = document.querySelectorAll('.pf-parcel-item');
    var visible = 0;

    items.forEach(function (item) {
      var name    = item.dataset.name   || '';
      var loc     = item.dataset.loc    || '';
      var status  = item.dataset.status || '';

      var okStatus = currentStatus === 'All' || status === currentStatus;
      var okSearch = !currentSearch ||
                     name.indexOf(currentSearch) !== -1 ||
                     loc.indexOf(currentSearch)  !== -1;

      var show = okStatus && okSearch;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    var cnt = document.getElementById('pfResultCount');
    if (cnt) cnt.textContent = visible + ' parcel' + (visible !== 1 ? 's' : '');

    var noRes = document.getElementById('pfNoResults');
    if (noRes) {
      noRes.classList.toggle('pf-show', visible === 0 && items.length > 0);
    }
  }

  function initFilters() {
    var searchInput = document.getElementById('pfSearch');
    if (searchInput) {
      searchInput.addEventListener('input', function () {
        currentSearch = this.value.trim().toLowerCase();
        applyFilters();
        if (currentSearch) toast('Searching for "' + this.value.trim() + '"', 'search');
      });
    }

    document.querySelectorAll('.pf-filter-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        document.querySelectorAll('.pf-filter-btn').forEach(function (b) {
          b.classList.remove('active');
        });
        this.classList.add('active');
        currentStatus = this.dataset.filter;
        applyFilters();
        toast('Filter: ' + currentStatus, 'funnel-fill');
      });
    });

    var clearBtn = document.getElementById('pfClearFilters');
    if (clearBtn) {
      clearBtn.addEventListener('click', function () {
        currentSearch = '';
        currentStatus = 'All';
        var si = document.getElementById('pfSearch');
        if (si) si.value = '';
        document.querySelectorAll('.pf-filter-btn').forEach(function (b) {
          b.classList.remove('active');
        });
        var allBtn = document.querySelector('.pf-filter-btn[data-filter="All"]');
        if (allBtn) allBtn.classList.add('active');
        applyFilters();
        toast('Filters cleared', 'x-circle');
      });
    }

    applyFilters();
  }

  /* ──────────────────────────────────────────────────────────────
     VIEW TOGGLE
  ────────────────────────────────────────────────────────────── */
  function initViewToggle() {
    var grid    = document.getElementById('pfGrid');
    var list    = document.getElementById('pfList');
    var gridBtn = document.getElementById('pfGridBtn');
    var listBtn = document.getElementById('pfListBtn');

    if (!gridBtn || !listBtn) return;

    gridBtn.addEventListener('click', function () {
      if (grid) grid.classList.add('active');
      if (list) list.classList.remove('active');
      gridBtn.classList.add('active');
      listBtn.classList.remove('active');
      toast('Grid view', 'grid-3x3-gap-fill');
    });

    listBtn.addEventListener('click', function () {
      if (list) list.classList.add('active');
      if (grid) grid.classList.remove('active');
      listBtn.classList.add('active');
      gridBtn.classList.remove('active');
      toast('List view', 'list-ul');
    });
  }

  /* ──────────────────────────────────────────────────────────────
     MODAL
  ────────────────────────────────────────────────────────────── */
  var overlay  = document.getElementById('pfOverlay');
  var leaflet  = null;
  var pendLat  = NaN;
  var pendLng  = NaN;

  function openModal(card) {
    var name    = card.dataset.name    || '—';
    var loc     = card.dataset.loc     || '—';
    var area    = card.dataset.area    || '—';
    var soil    = card.dataset.soil    || '—';
    var statut  = card.dataset.statut  || '—';
    var date    = card.dataset.date    || '—';
    var imgUrl  = card.dataset.imageUrl || '';
    var lat     = parseFloat(card.dataset.lat);
    var lng     = parseFloat(card.dataset.lng);
    var cultRaw = card.dataset.cultures || '[]';
    var cultures = [];
    try { cultures = JSON.parse(cultRaw); } catch (e) { cultures = []; }

    /* Banner image */
    var img = document.getElementById('pfModalImg');
    if (imgUrl) {
      img.src = imgUrl;
      img.style.display = 'block';
    } else {
      img.style.display = 'none';
    }

    /* Status badge */
    var statusEl = document.getElementById('pfModalStatus');
    statusEl.textContent = statut;
    statusEl.className = 'pf-modal-status';
    var cls = 'pf-badge-default';
    if (statut === 'Available') cls = 'pf-badge-available';
    else if (statut === 'Occupied') cls = 'pf-badge-occupied';
    else if (statut === 'Resting')  cls = 'pf-badge-resting';
    statusEl.classList.add(cls);

    /* Header text */
    document.getElementById('pfModalName').textContent    = name;
    document.getElementById('pfModalLocSpan').textContent = loc;

    /* Stats strip */
    document.getElementById('pfStripArea').textContent  = area + ' ha';
    document.getElementById('pfStripSoil').textContent  = soil;
    document.getElementById('pfStripCrops').textContent = cultures.length;
    document.getElementById('pfStripDate').textContent  = date;

    /* Overview tab content */
    document.getElementById('pfInfoName').textContent   = name;
    document.getElementById('pfInfoLoc').textContent    = loc;
    document.getElementById('pfInfoArea').textContent   = area + ' ha';
    document.getElementById('pfInfoSoil').textContent   = soil;
    document.getElementById('pfInfoStatut').textContent = statut;
    document.getElementById('pfInfoDate').textContent   = date;

    var gpsCard = document.getElementById('pfGpsCard');
    if (!isNaN(lat) && !isNaN(lng)) {
      gpsCard.style.display = 'flex';
      document.getElementById('pfGpsCoords').textContent =
        lat.toFixed(6) + ',  ' + lng.toFixed(6);
    } else {
      gpsCard.style.display = 'none';
    }

    /* Crops tab */
    var cb = document.getElementById('pfCropsBadge');
    if (cb) cb.textContent = cultures.length;
    renderCrops(cultures);

    /* Store coords for map init */
    pendLat = lat;
    pendLng = lng;

    /* Reset tab – reset weather/soil panels to loading state */
    document.getElementById('pfWxLoading').style.display    = 'block';
    document.getElementById('pfWxNoCoords').style.display   = 'none';
    document.getElementById('pfWxContent').style.display    = 'none';
    document.getElementById('pfSoilLoading').style.display  = 'block';
    document.getElementById('pfSoilNoCoords').style.display = 'none';
    document.getElementById('pfSoilContent').style.display  = 'none';
    activateTab('overview');

    /* Nominatim reverse geocode (overview location enrichment) */
    if (!isNaN(lat) && !isNaN(lng)) {
      fetchNominatim(lat, lng).then(function (geo) {
        var addr = geo && geo.address;
        if (!addr) return;
        var parts = [
          addr.village || addr.town || addr.city || addr.county,
          addr.state || addr.region,
          addr.country
        ].filter(Boolean);
        var label = parts.join(', ');
        var geocodeRow = document.getElementById('pfGeocodeRow');
        var geocodeSpan = document.getElementById('pfGeocodeSpan');
        if (geocodeRow && geocodeSpan && label) {
          geocodeSpan.textContent = label;
          geocodeRow.style.display = 'flex';
        }
      }).catch(function () {});
    } else {
      var gcRow = document.getElementById('pfGeocodeRow');
      if (gcRow) gcRow.style.display = 'none';
    }

    /* Open */
    overlay.classList.add('pf-open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.classList.remove('pf-open');
    document.body.style.overflow = '';
    destroyMap();
  }

  function closeOnBackdrop(e) {
    if (e.target === overlay) closeModal();
  }

  /* ── TABS ── */
  function activateTab(name) {
    document.querySelectorAll('.pf-tab-btn').forEach(function (btn) {
      btn.classList.toggle('active', btn.dataset.tab === name);
    });
    var panels = {
      overview: 'pfTabOverview', map: 'pfTabMap',
      crops: 'pfTabCrops', weather: 'pfTabWeather', soil: 'pfTabSoil'
    };
    Object.keys(panels).forEach(function (k) {
      var p = document.getElementById(panels[k]);
      if (p) p.classList.toggle('active', k === name);
    });

    if (name === 'map') {
      destroyMap();
      /* Wait for the tab panel to become visible (CSS display:block + repaint)
         before Leaflet reads container dimensions. 400 ms covers the modal
         open animation (320 ms) plus a full repaint cycle. */
      setTimeout(function () { initMap(pendLat, pendLng); }, 400);
    } else {
      destroyMap();
    }
    if (name === 'weather' && !isNaN(pendLat) && !isNaN(pendLng)) {
      fetchAndRenderWeather(pendLat, pendLng);
    }
    if (name === 'soil' && !isNaN(pendLat) && !isNaN(pendLng)) {
      fetchAndRenderSoil(pendLat, pendLng);
    }
    if (name === 'weather' && (isNaN(pendLat) || isNaN(pendLng))) {
      document.getElementById('pfWxLoading').style.display  = 'none';
      document.getElementById('pfWxNoCoords').style.display = 'block';
      document.getElementById('pfWxContent').style.display  = 'none';
    }
    if (name === 'soil' && (isNaN(pendLat) || isNaN(pendLng))) {
      document.getElementById('pfSoilLoading').style.display  = 'none';
      document.getElementById('pfSoilNoCoords').style.display = 'block';
      document.getElementById('pfSoilContent').style.display  = 'none';
    }
  }

  /* ── LEAFLET MAP ── */
  function initMap(lat, lng) {
    var mapEl = document.getElementById('pf-map');
    var phEl  = document.getElementById('pfMapPlaceholder');
    if (!mapEl || !phEl) return;

    /* Guard: Leaflet must be loaded */
    if (typeof L === 'undefined') {
      console.error('Leaflet is not loaded. Map cannot be initialized.');
      mapEl.style.display = 'none';
      phEl.style.display  = 'flex';
      return;
    }

    /* Guard: must have valid coordinates */
    if (isNaN(lat) || isNaN(lng)) {
      mapEl.style.display = 'none';
      phEl.style.display  = 'flex';
      return;
    }

    mapEl.style.display = 'block';
    phEl.style.display  = 'none';

    /* Force a layout pass so Leaflet can read real dimensions */
    mapEl.offsetWidth;

    try {
      leaflet = L.map('pf-map', {
        zoomControl: true,
        attributionControl: true,
        preferCanvas: false
      }).setView([lat, lng], 14);

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
        maxZoom: 19,
        crossOrigin: true
      }).addTo(leaflet);

      var icon = L.divIcon({
        className: '',
        html: '<div style="' +
          'width:30px;height:30px;' +
          'background:linear-gradient(135deg,#166534,#16a34a);' +
          'border:3px solid #fff;' +
          'border-radius:50% 50% 50% 0;' +
          'transform:rotate(-45deg);' +
          'box-shadow:0 4px 14px rgba(22,101,52,.55)' +
          '"></div>',
        iconSize:    [30, 30],
        iconAnchor:  [15, 30],
        popupAnchor: [0, -34]
      });

      var label     = document.getElementById('pfModalName');
      var popupName = label ? label.textContent : 'Parcelle';

      L.marker([lat, lng], { icon: icon })
        .addTo(leaflet)
        .bindPopup(
          '<strong>' + popupName + '</strong><br>' +
          '<small style="color:#64748b">' + lat.toFixed(6) + ', ' + lng.toFixed(6) + '</small>'
        )
        .openPopup();

      /* Recalculate size after paint — critical inside modals */
      requestAnimationFrame(function () {
        leaflet.invalidateSize({ animate: false });
        setTimeout(function () { leaflet.invalidateSize({ animate: false }); }, 200);
        setTimeout(function () { leaflet.invalidateSize({ animate: false }); }, 500);
        setTimeout(function () { leaflet.invalidateSize({ animate: false }); }, 900);
      });

    } catch (err) {
      console.error('Leaflet map init error:', err);
      mapEl.style.display = 'none';
      phEl.style.display  = 'flex';
    }
  }

  function destroyMap() {
    if (leaflet) { leaflet.remove(); leaflet = null; }
  }

  /* ── CROPS RENDER ── */
  var cropIcons = ['🌾','🥦','🌽','🍅','🥬','🌿','🫑','🧅','🥕','🍆','🌻','🫐'];

  function statusColor(s) {
    var map = { Growing: '#16a34a', Harvested: '#d97706', Planned: '#0ea5e9', Failed: '#dc2626' };
    return map[s] || '#64748b';
  }

  function renderCrops(cultures) {
    var list  = document.getElementById('pfCropsList');
    var empty = document.getElementById('pfNoCrops');
    if (!list || !empty) return;

    if (!cultures || cultures.length === 0) {
      list.innerHTML    = '';
      empty.style.display = 'block';
      return;
    }
    empty.style.display = 'none';

    var html = cultures.map(function (c, i) {
      var prog = Math.min(100, Math.max(0, Number(c.progress) || 0));
      var col  = statusColor(c.statut);
      return (
        '<div class="pf-culture-item">' +
          '<div class="pf-culture-header">' +
            '<div class="pf-culture-icon">' + cropIcons[i % cropIcons.length] + '</div>' +
            '<div style="flex:1">' +
              '<div class="pf-culture-name">' + (c.nom || 'Unknown Crop') + '</div>' +
              '<div class="pf-culture-variety">' + (c.variete || '') + '</div>' +
            '</div>' +
            '<span style="background:' + col + ';color:#fff;padding:3px 11px;border-radius:999px;font-size:.69rem;font-weight:700;flex-shrink:0;">' +
              (c.statut || 'N/A') +
            '</span>' +
          '</div>' +
          '<div class="pf-culture-dates">' +
            '<span><i class="bi bi-calendar-check" style="color:var(--pf-secondary);margin-right:4px;"></i>Planted: ' + (c.datePlantation || 'N/A') + '</span>' +
            '<span><i class="bi bi-calendar2-x" style="color:#d97706;margin-right:4px;"></i>Harvest: ' + (c.dateRecolte || 'N/A') + '</span>' +
          '</div>' +
          '<div style="display:flex;align-items:center;gap:10px;">' +
            '<div class="pf-progress-wrap" style="flex:1">' +
              '<div class="pf-progress-bar" style="width:' + prog + '%"></div>' +
            '</div>' +
            '<span style="font-size:.74rem;font-weight:700;color:var(--pf-primary);min-width:36px;text-align:right;">' + prog + '%</span>' +
          '</div>' +
        '</div>'
      );
    }).join('');

    list.innerHTML = html;
  }

  /* ──────────────────────────────────────────────────────────────
     WMO WEATHER CODE LOOKUP
  ────────────────────────────────────────────────────────────── */
  var WMO_ICON = {
    0:'☀️', 1:'🌤️', 2:'⛅', 3:'☁️',
    45:'🌫️', 48:'🌫️',
    51:'🌦️', 53:'🌦️', 55:'🌧️',
    61:'🌧️', 63:'🌧️', 65:'🌧️',
    71:'❄️', 73:'❄️', 75:'❄️', 77:'🌨️',
    80:'🌦️', 81:'🌧️', 82:'⛈️',
    85:'🌨️', 86:'🌨️',
    95:'⛈️', 96:'⛈️', 99:'⛈️'
  };
  var WMO_DESC = {
    0:'Clear sky', 1:'Mainly clear', 2:'Partly cloudy', 3:'Overcast',
    45:'Foggy', 48:'Icy fog',
    51:'Light drizzle', 53:'Drizzle', 55:'Heavy drizzle',
    61:'Light rain', 63:'Moderate rain', 65:'Heavy rain',
    71:'Light snow', 73:'Moderate snow', 75:'Heavy snow', 77:'Snow grains',
    80:'Light showers', 81:'Showers', 82:'Violent showers',
    85:'Light snow showers', 86:'Heavy snow showers',
    95:'Thunderstorm', 96:'Thunderstorm + hail', 99:'Severe thunderstorm'
  };
  var DAY_NAMES = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

  /* ──────────────────────────────────────────────────────────────
     OPEN-METEO WEATHER + AGRO FETCH
  ────────────────────────────────────────────────────────────── */
  var wxFetchedFor = '';

  function fetchAndRenderWeather(lat, lng) {
    var key = lat.toFixed(4) + ',' + lng.toFixed(4);
    if (wxFetchedFor === key) return; /* already loaded */

    var url = 'https://api.open-meteo.com/v1/forecast' +
      '?latitude='  + lat + '&longitude=' + lng +
      '&current=temperature_2m,apparent_temperature,precipitation,weather_code,wind_speed_10m,relative_humidity_2m' +
      '&hourly=soil_temperature_0cm,soil_moisture_0_to_1cm,et0_fao_evapotranspiration' +
      '&daily=temperature_2m_max,temperature_2m_min,precipitation_sum,weather_code' +
      '&forecast_days=7&timezone=auto';

    fetch(url)
      .then(function (r) { return r.json(); })
      .then(function (data) {
        wxFetchedFor = key;
        renderWeather(data);
      })
      .catch(function () {
        document.getElementById('pfWxLoading').innerHTML =
          '<i class="bi bi-exclamation-circle" style="color:#ef4444;"></i>' +
          '<span style="color:#ef4444;">Could not load weather data.</span>';
      });
  }

  function renderWeather(d) {
    var cur  = d.current   || {};
    var daily = d.daily    || {};
    var hourly = d.hourly  || {};

    var temp  = cur.temperature_2m;
    var code  = cur.weather_code;
    var rain  = cur.precipitation;
    var wind  = cur.wind_speed_10m;
    var humid = cur.relative_humidity_2m;

    /* Show content */
    document.getElementById('pfWxLoading').style.display = 'none';
    document.getElementById('pfWxContent').style.display = 'block';

    /* Current card */
    document.getElementById('pfWxIcon').textContent  = WMO_ICON[code]  || '🌡️';
    document.getElementById('pfWxTemp').textContent  = (temp !== undefined ? temp.toFixed(1) : '—') + '°C';
    document.getElementById('pfWxDesc').textContent  = WMO_DESC[code]  || 'Unknown';
    document.getElementById('pfWxRain').textContent  = rain !== undefined ? rain.toFixed(1) : '—';
    document.getElementById('pfWxWind').textContent  = wind !== undefined ? wind.toFixed(1) : '—';
    document.getElementById('pfWxHumid').textContent = humid !== undefined ? humid : '—';

    /* Alert logic */
    var alertEl = document.getElementById('pfWxAlert');
    alertEl.innerHTML = '';
    if (temp !== undefined && temp <= 2) {
      alertEl.innerHTML = '<div class="pf-weather-alert pf-alert-frost"><span class="pf-alert-icon">🥶</span><div><strong>Frost Risk</strong> — Temperature is at or below 2°C. Protect sensitive crops from frost damage.</div></div>';
    } else if (rain !== undefined && rain === 0 && wind > 25) {
      alertEl.innerHTML = '<div class="pf-weather-alert pf-alert-drought"><span class="pf-alert-icon">🌵</span><div><strong>Drought Conditions</strong> — No precipitation and high winds detected. Consider irrigation for your crops.</div></div>';
    } else if (code >= 95) {
      alertEl.innerHTML = '<div class="pf-weather-alert pf-alert-storm"><span class="pf-alert-icon">⛈️</span><div><strong>Storm Alert</strong> — Thunderstorm conditions detected. Avoid field operations and secure equipment.</div></div>';
    } else {
      alertEl.innerHTML = '<div class="pf-weather-alert pf-alert-good"><span class="pf-alert-icon">✅</span><div><strong>Good Conditions</strong> — No extreme weather events detected for this parcel today.</div></div>';
    }

    /* Agro metrics — use first hourly value for today */
    var soilT  = hourly.soil_temperature_0cm  && hourly.soil_temperature_0cm[0];
    var soilM  = hourly.soil_moisture_0_to_1cm && hourly.soil_moisture_0_to_1cm[0];
    var eto    = hourly.et0_fao_evapotranspiration && hourly.et0_fao_evapotranspiration[0];

    document.getElementById('pfSoilTemp').textContent  = soilT !== undefined && soilT !== null ? soilT.toFixed(1) + '°C' : 'N/A';
    document.getElementById('pfSoilMoist').textContent = soilM !== undefined && soilM !== null ? (soilM * 100).toFixed(0) + '%' : 'N/A';
    document.getElementById('pfEtO').textContent       = eto   !== undefined && eto   !== null ? eto.toFixed(2) + ' mm' : 'N/A';

    /* 7-day forecast */
    var grid   = document.getElementById('pfForecastGrid');
    var dates  = daily.time             || [];
    var codes  = daily.weather_code     || [];
    var maxes  = daily.temperature_2m_max || [];
    var mins   = daily.temperature_2m_min || [];
    var rains  = daily.precipitation_sum  || [];
    var maxRain = Math.max.apply(null, rains.map(function(v){ return v||0; })) || 1;

    grid.innerHTML = dates.map(function (dt, i) {
      var d   = new Date(dt + 'T12:00:00');
      var isToday = i === 0;
      var icon    = WMO_ICON[codes[i]] || '🌡️';
      var mx      = maxes[i] !== undefined ? maxes[i].toFixed(0) : '—';
      var mn      = mins[i]  !== undefined ? mins[i].toFixed(0)  : '—';
      var rPct    = rains[i] ? Math.round((rains[i] / maxRain) * 100) : 0;
      return '<div class="pf-fc-day' + (isToday ? ' pf-fc-today' : '') + '">' +
        '<div class="pf-fc-name">' + (isToday ? 'Today' : DAY_NAMES[d.getDay()]) + '</div>' +
        '<div class="pf-fc-icon">' + icon + '</div>' +
        '<div class="pf-fc-max">' + mx + '°</div>' +
        '<div class="pf-fc-min">' + mn + '°</div>' +
        '<div class="pf-fc-rain"><div class="pf-fc-rain-fill" style="width:' + rPct + '%"></div></div>' +
      '</div>';
    }).join('');
  }

  /* ──────────────────────────────────────────────────────────────
     SOILGRIDS FETCH
  ────────────────────────────────────────────────────────────── */
  var soilFetchedFor = '';

  function fetchAndRenderSoil(lat, lng) {
    var key = lat.toFixed(4) + ',' + lng.toFixed(4);
    if (soilFetchedFor === key) return;

    var url = 'https://rest.isric.org/soilgrids/v2.0/properties/query' +
      '?lon=' + lng + '&lat=' + lat +
      '&property=phh2o&property=clay&property=sand&property=ocd' +
      '&depth=0-5cm&value=mean';

    fetch(url)
      .then(function (r) { return r.json(); })
      .then(function (data) {
        soilFetchedFor = key;
        renderSoil(data);
      })
      .catch(function () {
        document.getElementById('pfSoilLoading').innerHTML =
          '<i class="bi bi-exclamation-circle" style="color:#ef4444;"></i>' +
          '<span style="color:#ef4444;">Could not load soil data. Try again later.</span>';
      });
  }

  function renderSoil(data) {
    document.getElementById('pfSoilLoading').style.display  = 'none';
    document.getElementById('pfSoilContent').style.display  = 'block';

    /* Parse SoilGrids response */
    var props = {};
    if (data && data.properties && data.properties.layers) {
      data.properties.layers.forEach(function (layer) {
        var name  = layer.name;
        var depth = layer.depths && layer.depths[0];
        var val   = depth && depth.values && depth.values.mean;
        props[name] = val;
      });
    }

    /* pH: SoilGrids returns pH * 10 */
    var phRaw = props['phh2o'];
    var ph    = phRaw !== undefined && phRaw !== null ? phRaw / 10 : null;
    /* Clay: g/kg -> % */
    var clayRaw = props['clay'];
    var clay    = clayRaw !== undefined && clayRaw !== null ? clayRaw / 10 : null;
    /* Sand: g/kg -> % */
    var sandRaw = props['sand'];
    var sand    = sandRaw !== undefined && sandRaw !== null ? sandRaw / 10 : null;
    /* OCD: g/kg (organic carbon density) */
    var ocd  = props['ocd'];

    /* pH gauge */
    if (ph !== null) {
      var pct = Math.min(100, Math.max(0, (ph / 14) * 100));
      document.getElementById('pfPhPointer').style.left = pct + '%';
      document.getElementById('pfPhPointer').textContent = ph.toFixed(1);

      var phInterp, phColor;
      if      (ph < 4.5) { phInterp = '⚠️ Strongly acidic — most crops will struggle. Lime application recommended.'; phColor = '#fef2f2'; }
      else if (ph < 5.5) { phInterp = '⚠️ Acidic — suitable for blueberries, potatoes. Lime may help other crops.'; phColor = '#fff7ed'; }
      else if (ph < 6.5) { phInterp = '✅ Slightly acidic — ideal for most vegetables, fruits and cereals.'; phColor = '#f0fdf4'; }
      else if (ph < 7.5) { phInterp = '✅ Neutral — optimal range for the widest variety of crops.'; phColor = '#f0fdf4'; }
      else if (ph < 8.5) { phInterp = '⚠️ Alkaline — suitable for wheat, barley. May limit phosphorus availability.'; phColor = '#eff6ff'; }
      else               { phInterp = '⚠️ Strongly alkaline — limited crop options. Sulfur amendment may help.'; phColor = '#fdf4ff'; }

      var interpEl = document.getElementById('pfPhInterpret');
      interpEl.textContent = phInterp;
      interpEl.style.background = phColor;
      interpEl.style.color = '#374151';
    }

    /* Clay bar */
    if (clay !== null) {
      document.getElementById('pfClayStat').textContent = clay.toFixed(1) + '%';
      setTimeout(function () {
        document.getElementById('pfClayBar').style.width = Math.min(100, clay) + '%';
      }, 200);
      document.getElementById('pfClayHint').textContent =
        clay < 15  ? 'Low clay — sandy-loam texture, drains quickly' :
        clay < 35  ? 'Moderate clay — good water retention and structure' :
                     'High clay — may compact; needs good drainage management';
    }

    /* Sand bar */
    if (sand !== null) {
      document.getElementById('pfSandStat').textContent = sand.toFixed(1) + '%';
      setTimeout(function () {
        document.getElementById('pfSandBar').style.width = Math.min(100, sand) + '%';
      }, 200);
      document.getElementById('pfSandHint').textContent =
        sand > 70 ? 'Sandy soil — low water/nutrient retention, irrigate frequently' :
        sand > 40 ? 'Loamy sand — reasonable drainage and workability' :
                    'Low sand content — soil may be heavier and slower-draining';
    }

    /* Organic carbon */
    if (ocd !== null && ocd !== undefined) {
      document.getElementById('pfOcStat').textContent = ocd.toFixed(1) + ' g/kg';
      setTimeout(function () {
        document.getElementById('pfOcBar').style.width = Math.min(100, (ocd / 30) * 100) + '%';
      }, 200);
      document.getElementById('pfOcHint').textContent =
        ocd < 5  ? 'Very low organic matter — compost application strongly recommended' :
        ocd < 15 ? 'Moderate organic matter — suitable for most crops' :
                   'High organic matter — excellent soil health indicator';
    }

    /* Summary card */
    var summaryTitle, summaryText, summaryIcon, summaryBg;
    if (ph !== null && clay !== null && sand !== null) {
      if (ph >= 5.5 && ph <= 7.5 && clay >= 15 && clay <= 35) {
        summaryTitle = 'Good Agricultural Soil'; summaryIcon = '🌱';
        summaryText  = 'This parcel has a well-balanced soil profile suitable for a wide range of crops including cereals, vegetables, and legumes.';
        summaryBg    = 'linear-gradient(135deg,#f0fdf4,#dcfce7)';
      } else if (sand > 70) {
        summaryTitle = 'Sandy Soil'; summaryIcon = '🏖️';
        summaryText  = 'High sand content means good drainage but low water retention. Best suited for root vegetables. Consider drip irrigation and organic matter amendments.';
        summaryBg    = 'linear-gradient(135deg,#fffbeb,#fef3c7)';
      } else if (clay > 40) {
        summaryTitle = 'Heavy Clay Soil'; summaryIcon = '🪨';
        summaryText  = 'High clay content provides good nutrient retention but may cause waterlogging. Avoid working when wet. Benefits from organic matter and raised beds.';
        summaryBg    = 'linear-gradient(135deg,#fff7ed,#fed7aa)';
      } else {
        summaryTitle = 'Mixed Soil Profile'; summaryIcon = '🌿';
        summaryText  = 'Soil properties are mixed. Review pH and nutrient levels carefully before selecting crops. Amendments may improve productivity.';
        summaryBg    = 'linear-gradient(135deg,#f9fafb,#f3f4f6)';
      }
    } else {
      summaryTitle = 'Partial Data'; summaryIcon = '📊';
      summaryText  = 'Some soil properties could not be retrieved for this location. Try again or check the GPS coordinates.';
      summaryBg    = 'linear-gradient(135deg,#f9fafb,#f3f4f6)';
    }
    document.getElementById('pfSoilSummaryIcon').textContent  = summaryIcon;
    document.getElementById('pfSoilSummaryTitle').textContent = summaryTitle;
    document.getElementById('pfSoilSummaryText').textContent  = summaryText;
    document.getElementById('pfSoilSummaryCard').style.background = summaryBg;
    document.getElementById('pfSoilSummaryCard').style.border = '1px solid #e5e7eb';
  }

  /* ──────────────────────────────────────────────────────────────
     NOMINATIM REVERSE GEOCODING
  ────────────────────────────────────────────────────────────── */
  function fetchNominatim(lat, lng) {
    return fetch(
      'https://nominatim.openstreetmap.org/reverse?lat=' + lat + '&lon=' + lng + '&format=json',
      { headers: { 'Accept-Language': 'en' } }
    ).then(function (r) { return r.json(); });
  }

  /* ──────────────────────────────────────────────────────────────
     INIT
  ────────────────────────────────────────────────────────────── */
  function init() {
    initParticles();
    initCounters();
    initFilters();
    initViewToggle();

    /* Modal close button */
    var closeBtn = document.getElementById('pfModalClose');
    if (closeBtn) closeBtn.addEventListener('click', closeModal);

    /* Tab buttons */
    document.querySelectorAll('.pf-tab-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        activateTab(this.dataset.tab);
      });
    });

    /* Keyboard ESC */
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay && overlay.classList.contains('pf-open')) {
        closeModal();
      }
    });
  }

  /* ── Public API ── */
  return {
    openModal:       openModal,
    closeOnBackdrop: closeOnBackdrop,
    init:            init
  };

})();

document.addEventListener('DOMContentLoaded', PF.init);
</script>
{% endblock %}
