{% block javascripts %}
{{ parent() }}
<script>
/* ============================================================
   1 · PARTICLES
   ============================================================ */
(function () {
  const wrap = document.getElementById('ccParticles');
  if (!wrap) return;
  for (let i = 0; i < 30; i++) {
    const el = document.createElement('div');
    el.className = 'cc-particle';
    const size = 3 + Math.random() * 6;
    el.style.cssText = [
      `left:${Math.random() * 100}%`,
      `width:${size}px`,
      `height:${size}px`,
      `animation-duration:${7 + Math.random() * 14}s`,
      `animation-delay:${Math.random() * 12}s`,
      `opacity:${0.3 + Math.random() * 0.55}`
    ].join(';');
    wrap.appendChild(el);
  }
})();

/* ============================================================
   2 · HERO COUNTER ANIMATION
   ============================================================ */
function animateCounters() {
  document.querySelectorAll('[data-target]').forEach(function (el) {
    const target   = parseFloat(el.dataset.target) || 0;
    const duration = 1700;
    const step     = target / (duration / 16);
    let current    = 0;
    const tick = setInterval(function () {
      current = Math.min(current + step, target);
      el.textContent = Math.round(current).toLocaleString();
      if (current >= target) clearInterval(tick);
    }, 16);
  });
}

const heroEl = document.querySelector('.cc-hero');
if (heroEl) {
  const heroObs = new IntersectionObserver(function (entries) {
    if (entries[0].isIntersecting) { animateCounters(); heroObs.disconnect(); }
  }, { threshold: 0.25 });
  heroObs.observe(heroEl);
}



/* ============================================================
   4 · FILTERING — shared state
   ============================================================ */
var _filterStatus   = 'all';
var _filterParcelle = '';
var _filterSearch   = '';

function getColsForView(viewId) {
  if (viewId === 'grid')     return document.querySelectorAll('#gridContainer .cc-gcol');
  if (viewId === 'list')     return document.querySelectorAll('#listContainer .cc-lcol');
  if (viewId === 'timeline') return document.querySelectorAll('#timelineContainer .cc-tlcol');
  return [];
}

function applyFilters() {
  var search  = _filterSearch.toLowerCase().trim();
  var total   = 0;

  ['grid', 'list', 'timeline'].forEach(function (v) {
    var cols   = getColsForView(v);
    var hidden = 0;

    cols.forEach(function (col) {
      var nameOk    = !search || (col.dataset.cname    || '').includes(search)
                               || (col.dataset.cvariety || '').includes(search);
      var statusOk  = _filterStatus   === 'all' || col.dataset.cstatus   === _filterStatus;
      var parcelOk  = !_filterParcelle             || col.dataset.cparcelle === _filterParcelle;
      var visible   = nameOk && statusOk && parcelOk;

      col.classList.toggle('d-none-force', !visible);
      if (!visible) hidden++;
    });

    var noResId = v === 'grid' ? 'noResGrid' : v === 'list' ? 'noResList' : 'noResTl';
    var noResEl = document.getElementById(noResId);
    if (noResEl) noResEl.classList.toggle('d-none-force', !(cols.length > 0 && hidden === cols.length));

    if (v === 'grid') total = cols.length - hidden;
  });

  var lbl = document.getElementById('ccCountLbl');
  if (lbl) lbl.textContent = total + ' crop(s)';
}

/* Search */
var searchInput = document.getElementById('ccSearch');
if (searchInput) {
  searchInput.addEventListener('input', function () {
    _filterSearch = this.value;
    applyFilters();
  });
}

/* Status buttons */
document.querySelectorAll('.cc-fbtn[data-status]').forEach(function (btn) {
  btn.addEventListener('click', function () {
    document.querySelectorAll('.cc-fbtn[data-status]').forEach(function (b) {
      b.classList.remove('active');
    });
    btn.classList.add('active');
    _filterStatus = btn.dataset.status;
    applyFilters();
  });
});

/* Parcelle dropdown */
var parcelSel = document.getElementById('ccParcelleFilter');
if (parcelSel) {
  parcelSel.addEventListener('change', function () {
    _filterParcelle = this.value;
    applyFilters();
  });
}

/* ============================================================
   5 · VIEW TOGGLE
   ============================================================ */
var viewMap = { grid: 'viewGrid', list: 'viewList', timeline: 'viewTimeline' };
var btnMap  = { grid: 'btnGrid',  list: 'btnList',  timeline: 'btnTimeline'  };

function switchView(v) {
  Object.keys(viewMap).forEach(function (key) {
    var el  = document.getElementById(viewMap[key]);
    var btn = document.getElementById(btnMap[key]);
    if (el)  el.classList.toggle('d-none-force', key !== v);
    if (btn) btn.classList.toggle('active',       key === v);
  });
  /* Recalculate count for new view */
  var cols   = getColsForView(v);
  var visible = 0;
  cols.forEach(function (c) { if (!c.classList.contains('d-none-force')) visible++; });
  var lbl = document.getElementById('ccCountLbl');
  if (lbl) lbl.textContent = visible + ' crop(s)';
  showToast('View Changed', 'Switched to ' + v + ' view', 'info');
}

['grid', 'list', 'timeline'].forEach(function (v) {
  var btn = document.getElementById('btn' + v.charAt(0).toUpperCase() + v.slice(1));
  if (btn) btn.addEventListener('click', function () { switchView(v); });
});

/* ============================================================
   6 · MODAL
   ============================================================ */
var ccOverlay = document.getElementById('ccOverlay');
var ccModal   = document.getElementById('ccModal');

function openModal(card) {
  if (!card) return;
  var d = card.dataset;
  var name    = d.name    || 'Unknown Crop';
  var variete = d.variete || 'Not specified';
  var parcel  = d.parcelle|| 'Not linked';
  var statut  = d.statut  || '';
  var sk      = d.sk      || 'default';
  var dp      = d.datePlantation      || '';
  var drp     = d.dateRecoltePrevue   || '';
  var drr     = d.dateRecolteReelle   || '';
  var qp      = parseFloat(d.quantitePlantee)  || 0;
  var qr      = parseFloat(d.quantiteRecoltee) || 0;

  var obs     = d.observations || '';
  var imgUrl  = d.imageUrl     || '';
  var prog    = parseInt(d.progress)           || 0;

  /* Banner image */
  var mImg = document.getElementById('mBannerImg');
  if (imgUrl) { mImg.src = imgUrl; mImg.style.display = 'block'; }
  else          mImg.style.display = 'none';

  /* Header */
  document.getElementById('mCropName').textContent = name;
  document.getElementById('mCropSub').innerHTML =
    '<i class="bi bi-flower2 me-1"></i>' + variete +
    ' &bull; <i class="bi bi-map-fill ms-1 me-1"></i>' + parcel;

  var badge = document.getElementById('mStatusBadge');
  badge.textContent = statut;
  badge.className   = 'cc-status-pill s-' + sk + ' mb-2 d-inline-block';

  /* Strip */
  document.getElementById('mQtyP').textContent = qp.toLocaleString();
  document.getElementById('mQtyH').textContent = qr.toLocaleString();
  document.getElementById('mProg').textContent = prog + '%';


  /* Overview */
  document.getElementById('iName').textContent    = name;
  document.getElementById('iVariete').textContent = variete;
  document.getElementById('iParcelle').textContent= parcel;
  document.getElementById('iStatut').innerHTML    =
    '<span class="cc-status-pill s-' + sk + '">' + statut + '</span>';
  document.getElementById('iDp').textContent      = dp  || '—';
  document.getElementById('iDrp').textContent     = drp || '—';
  document.getElementById('iDrr').textContent     = drr || 'Not yet harvested';

  document.getElementById('iProgBar').innerHTML   =
    '<div class="cc-prog-track" style="margin-bottom:4px;">' +
      '<div class="cc-prog-fill" style="width:' + prog + '%"></div>' +
    '</div>' +
    '<small class="fw-800" style="color:#166534;">' + prog + '%</small>';

  /* Lifecycle */
  buildLifecycle(statut, dp, drp, drr);

  /* Observations */
  document.getElementById('obsContent').textContent = obs || 'No observations recorded.';

  /* Reset to first tab */
  activateTab('overview');

  /* Open */
  ccOverlay.classList.add('open');
  document.body.style.overflow = 'hidden';
  showToast('Crop Details', 'Viewing details for ' + name, 'success');
}

function buildLifecycle(statut, dp, drp, drr) {
  var phases = [
    { icon: 'bi-file-earmark-check', label: 'Planning',  desc: 'Crop planned for the season',            date: null },
    { icon: 'bi-seedling',            label: 'Planting',  desc: 'Seeds or seedlings placed in the field', date: dp },
    { icon: 'bi-flower1',             label: 'Growing',   desc: 'Crop actively grows and matures',        date: null },
    { icon: 'bi-basket2-fill',        label: 'Harvest',   desc: 'Crops collected from the field',         date: drr || drp }
  ];

  var states;
  if      (statut === 'Harvested')   states = ['lc-done','lc-done','lc-done','lc-done'];
  else if (statut === 'In Progress') states = ['lc-done','lc-done','lc-current','lc-pending'];
  else                               states = ['lc-current','lc-pending','lc-pending','lc-pending'];

  var stateIcons = { 'lc-done': '<i class="bi bi-check-lg"></i>', 'lc-current': '<i class="bi bi-play-fill"></i>', 'lc-pending': '<i class="bi bi-three-dots"></i>' };
  var stateLabelHtml = {
    'lc-done':    '<span class="badge ms-1" style="background:#dcfce7;color:#166534;font-size:0.62rem;">Done</span>',
    'lc-current': '<span class="badge ms-1" style="background:#fef3c7;color:#92400e;font-size:0.62rem;">Current</span>',
    'lc-pending': ''
  };
  var iconColors = { 'lc-done': '#166534', 'lc-current': '#ca8a04', 'lc-pending': '#9ca3af' };

  var html = phases.map(function (p, i) {
    var s    = states[i];
    var date = p.date ? ' &mdash; <strong>' + p.date + '</strong>' : '';
    return '<div class="cc-lc-phase">' +
      '<div class="cc-lc-dot ' + s + '">' + stateIcons[s] + '</div>' +
      '<div class="cc-lc-title">' +
        '<i class="' + p.icon + ' me-1" style="color:' + iconColors[s] + '"></i>' +
        p.label + stateLabelHtml[s] +
      '</div>' +
      '<p class="cc-lc-desc">' + p.desc + date + '</p>' +
    '</div>';
  }).join('');

  document.getElementById('lcTimeline').innerHTML = html;
}

function closeModal() {
  ccOverlay.classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('mCloseBtn').addEventListener('click', closeModal);
ccOverlay.addEventListener('click', function (e) { if (e.target === ccOverlay) closeModal(); });
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape' && ccOverlay.classList.contains('open')) closeModal();
});

/* Tabs */
function activateTab(name) {
  document.querySelectorAll('.cc-tab-btn').forEach(function (b) {
    b.classList.toggle('active', b.dataset.tab === name);
  });
  document.querySelectorAll('.cc-tab-pane').forEach(function (p) {
    p.classList.toggle('active', p.id === 'tab-' + name);
  });
}
document.querySelectorAll('.cc-tab-btn').forEach(function (btn) {
  btn.addEventListener('click', function () { activateTab(btn.dataset.tab); });
});

/* ============================================================
   7 · TOAST SYSTEM
   ============================================================ */
function showToast(title, message, type) {
  type = type || 'success';
  var icons  = { success:'✅', info:'ℹ️', warning:'⚠️', error:'❌' };
  var colors = { success:'#166534', info:'#1d4ed8', warning:'#ca8a04', error:'#dc2626' };
  var wrap   = document.getElementById('ccToasts');
  var el     = document.createElement('div');
  el.className = 'cc-toast';
  el.style.borderLeftColor = colors[type] || colors.success;
  el.innerHTML =
    '<span class="cc-toast-ico">' + (icons[type] || '✅') + '</span>' +
    '<div class="cc-toast-body">' +
      '<div class="tt">' + title   + '</div>' +
      '<div class="ts">' + message + '</div>' +
    '</div>';
  wrap.appendChild(el);
  setTimeout(function () {
    el.classList.add('removing');
    setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 340);
  }, 3400);
}

/* ============================================================
   8 · AOS + INITIAL FILTER PASS
   ============================================================ */
if (typeof AOS !== 'undefined') {
  AOS.init({ duration: 720, once: true, offset: 55 });
}

/* Run once to initialise count label */
applyFilters();

/* ============================================================
   CROP SEASONAL CALENDAR (FAO-based data for Tunisia / N.Africa)
   ============================================================ */
(function () {
  var CROP_DB = [
    { key:['wheat','blé','ble','triticum','hard wheat','soft wheat'], name:'Wheat', emoji:'🌾',
      phases:[{type:'plant',months:[9,10]},{type:'grow',months:[11,0,1,2,3]},{type:'harvest',months:[4,5]}] },
    { key:['barley','orge','hordeum'], name:'Barley', emoji:'🌾',
      phases:[{type:'plant',months:[9,10]},{type:'grow',months:[11,0,1,2]},{type:'harvest',months:[3,4]}] },
    { key:['tomato','tomate','lycopersicum'], name:'Tomato', emoji:'🍅',
      phases:[{type:'plant',months:[2,3,4]},{type:'grow',months:[4,5,6]},{type:'harvest',months:[6,7,8,9]}] },
    { key:['potato','pomme de terre','solanum'], name:'Potato', emoji:'🥔',
      phases:[{type:'plant',months:[1,2,3]},{type:'grow',months:[3,4]},{type:'harvest',months:[4,5,6]}] },
    { key:['pepper','poivron','capsicum','piment'], name:'Pepper', emoji:'🫑',
      phases:[{type:'plant',months:[2,3]},{type:'grow',months:[4,5,6]},{type:'harvest',months:[6,7,8,9]}] },
    { key:['watermelon','pastèque','pasteque','citrullus'], name:'Watermelon', emoji:'🍉',
      phases:[{type:'plant',months:[3,4]},{type:'grow',months:[4,5,6]},{type:'harvest',months:[6,7,8]}] },
    { key:['olive','olea','olivier'], name:'Olive', emoji:'🫒',
      phases:[{type:'grow',months:[0,1,2,3,4,5,6,7,8]},{type:'harvest',months:[9,10,11]}] },
    { key:['onion','oignon','allium'], name:'Onion', emoji:'🧅',
      phases:[{type:'plant',months:[9,10]},{type:'grow',months:[11,0,1,2]},{type:'harvest',months:[3,4,5]}] },
    { key:['carrot','carotte','daucus'], name:'Carrot', emoji:'🥕',
      phases:[{type:'plant',months:[8,9,10]},{type:'grow',months:[10,11,0,1]},{type:'harvest',months:[1,2,3]}] },
    { key:['corn','maize','maïs','mais','zea'], name:'Corn', emoji:'🌽',
      phases:[{type:'plant',months:[3,4]},{type:'grow',months:[4,5,6,7]},{type:'harvest',months:[7,8,9]}] },
    { key:['sunflower','tournesol','helianthus'], name:'Sunflower', emoji:'🌻',
      phases:[{type:'plant',months:[3,4]},{type:'grow',months:[4,5,6]},{type:'harvest',months:[7,8]}] },
    { key:['melon','cucumis'], name:'Melon', emoji:'🍈',
      phases:[{type:'plant',months:[3,4]},{type:'grow',months:[5,6]},{type:'harvest',months:[6,7,8]}] }
  ];

  var MONTH_NAMES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  var MONTH_FULL  = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  var currentMonth = new Date().getMonth();

  function matchCrop(cultureName) {
    if (!cultureName) return null;
    var n = cultureName.toLowerCase().trim();
    for (var i = 0; i < CROP_DB.length; i++) {
      for (var j = 0; j < CROP_DB[i].key.length; j++) {
        if (n.indexOf(CROP_DB[i].key[j]) !== -1) return CROP_DB[i];
      }
    }
    return null;
  }

  function buildCalendar() {
    var cards   = document.querySelectorAll('[data-name][data-statut]');
    var matched = [];
    var seen    = {};

    cards.forEach(function (card) {
      var crop = matchCrop(card.dataset.name);
      if (crop && !seen[crop.name]) { seen[crop.name] = true; matched.push(crop); }
    });
    if (matched.length === 0) { CROP_DB.forEach(function (c) { matched.push(c); }); }
    matched = matched.slice(0, 8);

    var badge = document.getElementById('ccCalBadge');
    if (badge) badge.textContent = matched.length + ' crop' + (matched.length !== 1 ? 's' : '');

    var lbl = document.getElementById('ccCalCurrentMonthLabel');
    if (lbl) lbl.textContent = 'Current month: ' + MONTH_FULL[currentMonth];

    var monthRow = document.getElementById('ccCalMonthRow');
    if (monthRow) {
      MONTH_NAMES.forEach(function (m, i) {
        var div = document.createElement('div');
        div.className = 'cc-cal-month-header' + (i === currentMonth ? ' current-month' : '');
        div.textContent = m;
        monthRow.appendChild(div);
      });
    }

    var body = document.getElementById('ccCalBody');
    if (!body) return;

    matched.forEach(function (crop) {
      var monthPhase = {};
      crop.phases.forEach(function (p) { p.months.forEach(function (m) { monthPhase[m] = p.type; }); });

      var row = document.createElement('div');
      row.className = 'cc-cal-row';

      var nameCell = document.createElement('div');
      nameCell.className = 'cc-cal-crop-name';
      nameCell.innerHTML = '<span class="cc-cal-crop-emoji">' + crop.emoji + '</span><div><div class="cc-cal-crop-txt">' + crop.name + '</div></div>';
      row.appendChild(nameCell);

      for (var m = 0; m < 12; m++) {
        var cell = document.createElement('div');
        cell.className = 'cc-cal-cell' + (m === currentMonth ? ' current-month-col' : '');
        var phase = monthPhase[m];
        if (phase) {
          var bar = document.createElement('div');
          bar.className = 'cc-cal-bar cc-bar-' + phase;
          if (phase !== monthPhase[m - 1]) {
            bar.textContent = phase === 'plant' ? 'Plant' : phase === 'grow' ? 'Grow' : 'Harvest';
          }
          cell.appendChild(bar);
        }
        row.appendChild(cell);
      }
      body.appendChild(row);
    });

    var chips = document.getElementById('ccRecommendChips');
    var panel = document.getElementById('ccRecommendPanel');
    if (chips && panel) {
      var plantable = CROP_DB.filter(function (c) {
        return c.phases.some(function (p) { return p.type === 'plant' && p.months.indexOf(currentMonth) !== -1; });
      });
      chips.innerHTML = plantable.length
        ? plantable.map(function (c) { return '<div class="cc-recommend-chip">' + c.emoji + ' ' + c.name + '</div>'; }).join('')
        : '<span style="color:#6b7280;font-size:.82rem;">No specific planting recommended this month.</span>';
      panel.style.display = 'block';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', buildCalendar);
  } else {
    buildCalendar();
  }
})();
</script>
{% endblock %}
