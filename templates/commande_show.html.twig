{% extends 'base.html.twig' %}

{% block title %}Commande #{{ commande.idCommande }} - EL FIRMA{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8">
            <div style="background: white; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); overflow: hidden;">
                <div style="background: linear-gradient(135deg, #2d5016 0%, #1e3a0f 100%); padding: 25px; color: white;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <h2 style="margin: 0; display: flex; align-items: center; gap: 15px;">
                            <span class="material-symbols-outlined" style="font-size: 32px;">receipt</span>
                            Commande #{{ commande.idCommande }}
                        </h2>
                        <div>
                            {% set statusColor = commande.statutCommande == 'En attente' ? '#f59e0b' : (commande.statutCommande == 'Confirmée' ? '#3b82f6' : (commande.statutCommande == 'Livrée' ? '#10b981' : '#ef4444')) %}
                            <span style="background: {{ statusColor }}; color: white; padding: 8px 16px; border-radius: 25px; font-size: 14px; font-weight: 700;">
                                {{ commande.statutCommande }}
                            </span>
                        </div>
                    </div>
                </div>

                <div style="padding: 30px;">
                    <!-- Informations de la commande -->
                    <div style="margin-bottom: 30px;">
                        <h4 style="color: #2d5016; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                            <span class="material-symbols-outlined">info</span>
                            Détails de la commande
                        </h4>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div style="background: #f9fafb; border-radius: 10px; padding: 20px; margin-bottom: 20px;">
                                    <h6 style="color: #374151; font-weight: 700; margin-bottom: 15px;">Informations client</h6>
                                    <div style="margin-bottom: 10px;">
                                        <strong style="color: #2d5016;">Client:</strong> {{ commande.nomClient }}
                                    </div>
                                    <div style="margin-bottom: 10px;">
                                        <strong style="color: #2d5016;">Date de commande:</strong> {{ commande.dateCommande|date('d/m/Y à H:i') }}
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div style="background: #f9fafb; border-radius: 10px; padding: 20px; margin-bottom: 20px;">
                                    <h6 style="color: #374151; font-weight: 700; margin-bottom: 15px;">Paiement</h6>
                                    <div style="margin-bottom: 10px;">
                                        <strong style="color: #2d5016;">Mode:</strong> {{ commande.modePaiement }}
                                    </div>
                                    <div style="margin-bottom: 10px;">
                                        <strong style="color: #2d5016;">Statut:</strong> 
                                        {% set paymentColor = commande.statutPaiement == 'Payé' ? '#10b981' : '#f59e0b' %}
                                        <span style="color: {{ paymentColor }}; font-weight: 600;">{{ commande.statutPaiement }}</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Produit commandé -->
                    <div style="margin-bottom: 30px;">
                        <h4 style="color: #2d5016; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                            <span class="material-symbols-outlined">shopping_bag</span>
                            Produit commandé
                        </h4>
                        
                        {% if commande.produit %}
                        <div style="background: #f9fafb; border-radius: 15px; padding: 25px;">
                            <div style="display: flex; align-items: center; gap: 20px;">
                                <div style="width: 120px; height: 120px; border-radius: 12px; overflow: hidden; background: linear-gradient(135deg, #2d5016 0%, #1e3a0f 100%);">
                                    {% if commande.produit.image %}
                                        <img src="{{ asset('uploads/produits/' ~ commande.produit.image) }}" alt="{{ commande.produit.nom }}" style="width: 100%; height: 100%; object-fit: cover;">
                                    {% else %}
                                        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                                            <span class="material-symbols-outlined" style="color: rgba(255,255,255,0.5); font-size: 48px;">package_2</span>
                                        </div>
                                    {% endif %}
                                </div>
                                <div style="flex: 1;">
                                    <h5 style="margin: 0 0 10px 0; color: #2d5016; font-weight: 800;">{{ commande.produit.nom }}</h5>
                                    <p style="margin: 0 0 8px 0; color: #6b7280;">{{ commande.produit.categorie ? commande.produit.categorie.nom : 'Non catégorisé' }}</p>
                                    <p style="margin: 0 0 8px 0; color: #6b7280;">Type: {{ commande.produit.type }}</p>
                                    {% if commande.produit.qualite %}
                                    <div style="margin-bottom: 10px;">
                                        <span style="background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%); color: white; padding: 4px 12px; border-radius: 15px; font-size: 12px; font-weight: 600;">
                                            <span class="material-symbols-outlined" style="font-size: 14px; vertical-align: middle;">star</span>
                                            {{ commande.produit.qualite }}
                                        </span>
                                    </div>
                                    {% endif %}
                                    <div style="display: flex; gap: 20px; margin-top: 15px;">
                                        <div>
                                            <span style="font-size: 14px; color: #6b7280;">Prix unitaire:</span><br>
                                            <span style="font-size: 18px; font-weight: 700; color: #16a34a;">{{ commande.produit.prixUnitaire }} DT</span>
                                        </div>
                                        <div>
                                            <span style="font-size: 14px; color: #6b7280;">Quantité:</span><br>
                                            <span style="font-size: 18px; font-weight: 700; color: #2d5016;">{{ commande.quantite }}</span>
                                        </div>
                                        <div>
                                            <span style="font-size: 14px; color: #6b7280;">Total:</span><br>
                                            <span style="font-size: 24px; font-weight: 900; color: #16a34a;">{{ commande.prixTotal }} DT</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {% else %}
                        <div style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 10px; padding: 20px; color: #ef4444;">
                            <span class="material-symbols-outlined" style="vertical-align: middle; margin-right: 8px;">warning</span>
                            Le produit associé à cette commande n'est plus disponible.
                        </div>
                        {% endif %}
                    </div>

                    <!-- Facture (si disponible) -->
                    {% if commande.facture %}
                    <div style="margin-bottom: 30px;">
                        <h4 style="color: #2d5016; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                            <span class="material-symbols-outlined">description</span>
                            Facture
                        </h4>
                        <div style="background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 10px; padding: 20px;">
                            <p style="margin: 0; color: #0369a1;">
                                <span class="material-symbols-outlined" style="vertical-align: middle; margin-right: 8px;">download</span>
                                <a href="{{ asset('uploads/factures/' ~ commande.facture) }}" target="_blank" style="color: #0369a1; font-weight: 600;">
                                    Télécharger la facture
                                </a>
                            </p>
                        </div>
                    </div>
                    {% endif %}

                    <!-- Actions -->
                    <div style="border-top: 2px solid #f3f4f6; padding-top: 20px;">
                        <div style="display: flex; gap: 15px; justify-content: space-between;">
                            <a href="{{ path('app_commandes_index') }}" style="background: #6b7280; color: white; padding: 12px 24px; border-radius: 10px; text-decoration: none; font-weight: 600;">
                                ← Retour aux commandes
                            </a>
                            
                            {% if commande.statutCommande == 'Livrée' %}
                            <a href="{{ path('app_pages_home') }}#products" style="background: linear-gradient(135deg, #16a34a 0%, #15803d 100%); color: white; padding: 12px 24px; border-radius: 10px; text-decoration: none; font-weight: 600;">
                                Commander à nouveau
                            </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div style="background: white; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); overflow: hidden; position: sticky; top: 20px;">
                <div style="background: linear-gradient(135deg, #16a34a 0%, #15803d 100%); padding: 25px; color: white;">
                    <h4 style="margin: 0; display: flex; align-items: center; gap: 10px;">
                        <span class="material-symbols-outlined">timeline</span>
                        Suivi de commande
                    </h4>
                </div>

                <div style="padding: 30px;">
                    <div style="position: relative;">
                        <!-- Timeline -->
                        <div style="position: absolute; left: 15px; top: 0; bottom: 0; width: 2px; background: #e5e7eb;"></div>
                        
                        <div style="margin-bottom: 30px; position: relative; padding-left: 40px;">
                            <div style="position: absolute; left: 6px; top: 2px; width: 20px; height: 20px; border-radius: 50%; background: #10b981; border: 3px solid white; box-shadow: 0 0 0 2px #10b981;"></div>
                            <div>
                                <h6 style="margin: 0 0 5px 0; color: #10b981; font-weight: 700;">Commande passée</h6>
                                <p style="margin: 0; font-size: 12px; color: #6b7280;">{{ commande.dateCommande|date('d/m/Y à H:i') }}</p>
                            </div>
                        </div>

                        <div style="margin-bottom: 30px; position: relative; padding-left: 40px;">
                            {% set isConfirmed = commande.statutCommande in ['Confirmée', 'En cours', 'Livrée'] %}
                            <div style="position: absolute; left: 6px; top: 2px; width: 20px; height: 20px; border-radius: 50%; background: {{ isConfirmed ? '#10b981' : '#e5e7eb' }}; border: 3px solid white; box-shadow: 0 0 0 2px {{ isConfirmed ? '#10b981' : '#e5e7eb' }};"></div>
                            <div>
                                <h6 style="margin: 0 0 5px 0; color: {{ isConfirmed ? '#10b981' : '#6b7280' }}; font-weight: 700;">Commande confirmée</h6>
                                <p style="margin: 0; font-size: 12px; color: #6b7280;">{{ isConfirmed ? 'Confirmé' : 'En attente' }}</p>
                            </div>
                        </div>

                        <div style="margin-bottom: 30px; position: relative; padding-left: 40px;">
                            {% set isProcessing = commande.statutCommande in ['En cours', 'Livrée'] %}
                            <div style="position: absolute; left: 6px; top: 2px; width: 20px; height: 20px; border-radius: 50%; background: {{ isProcessing ? '#10b981' : '#e5e7eb' }}; border: 3px solid white; box-shadow: 0 0 0 2px {{ isProcessing ? '#10b981' : '#e5e7eb' }};"></div>
                            <div>
                                <h6 style="margin: 0 0 5px 0; color: {{ isProcessing ? '#10b981' : '#6b7280' }}; font-weight: 700;">En préparation</h6>
                                <p style="margin: 0; font-size: 12px; color: #6b7280;">{{ isProcessing ? 'En cours' : 'En attente' }}</p>
                            </div>
                        </div>

                        <div style="position: relative; padding-left: 40px;">
                            {% set isDelivered = commande.statutCommande == 'Livrée' %}
                            <div style="position: absolute; left: 6px; top: 2px; width: 20px; height: 20px; border-radius: 50%; background: {{ isDelivered ? '#10b981' : '#e5e7eb' }}; border: 3px solid white; box-shadow: 0 0 0 2px {{ isDelivered ? '#10b981' : '#e5e7eb' }};"></div>
                            <div>
                                <h6 style="margin: 0 0 5px 0; color: {{ isDelivered ? '#10b981' : '#6b7280' }}; font-weight: 700;">Livraison</h6>
                                <p style="margin: 0; font-size: 12px; color: #6b7280;">{{ isDelivered ? 'Livrée' : 'En attente' }}</p>
                            </div>
                        </div>
                    </div>

                    <!-- Contact support -->
                    <div style="margin-top: 30px; padding: 20px; background: #f0f9ff; border-radius: 10px; text-align: center;">
                        <h6 style="color: #0369a1; margin-bottom: 10px;">Besoin d'aide ?</h6>
                        <p style="font-size: 12px; color: #0284c7; margin: 0 0 15px 0;">Contactez notre service client</p>
                        <a href="{{ path('app_contact') }}" style="background: #0284c7; color: white; padding: 8px 16px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 14px;">
                            Nous contacter
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}