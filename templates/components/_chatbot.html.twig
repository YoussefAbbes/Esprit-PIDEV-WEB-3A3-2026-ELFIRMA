{# ============================================================
   EL FIRMA — AI Chatbot Component
   Usage: {% include 'components/_chatbot.html.twig' with {
             'page': 'parcelles',
             'page_label': 'Agricultural Parcels'
           } %}
   ============================================================ #}

<style>
/* ── Chatbot floating button ── */
.elfirma-chat-fab {
  position: fixed;
  bottom: 28px;
  right: 28px;
  z-index: 9900;
  display: flex;
  align-items: center;
  gap: 10px;
  background: linear-gradient(135deg, #166534 0%, #16a34a 100%);
  color: #fff;
  border: none;
  border-radius: 50px;
  padding: 13px 22px 13px 16px;
  font-size: .93rem;
  font-weight: 700;
  cursor: pointer;
  box-shadow: 0 8px 28px rgba(22,101,52,.45);
  transition: transform .22s cubic-bezier(.34,1.56,.64,1), box-shadow .22s;
  letter-spacing: .01em;
}
.elfirma-chat-fab:hover {
  transform: translateY(-3px) scale(1.04);
  box-shadow: 0 14px 36px rgba(22,101,52,.55);
}
.elfirma-chat-fab .fab-icon {
  width: 34px; height: 34px;
  background: rgba(255,255,255,.18);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem;
  flex-shrink: 0;
}
.elfirma-chat-fab .fab-pulse {
  position: absolute;
  top: 6px; right: 6px;
  width: 10px; height: 10px;
  background: #4ade80;
  border-radius: 50%;
  border: 2px solid #166534;
  animation: fabPulse 2s infinite;
}
@keyframes fabPulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50%       { transform: scale(1.5); opacity: .6; }
}

/* ── Chat panel ── */
.elfirma-chat-panel {
  position: fixed;
  bottom: 100px;
  right: 28px;
  z-index: 9910;
  width: 390px;
  max-width: calc(100vw - 32px);
  height: 560px;
  max-height: calc(100vh - 130px);
  background: #fff;
  border-radius: 20px;
  box-shadow: 0 24px 80px rgba(5,46,22,.28), 0 4px 16px rgba(0,0,0,.12);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transform: translateY(20px) scale(.95);
  opacity: 0;
  pointer-events: none;
  transition: transform .3s cubic-bezier(.34,1.56,.64,1), opacity .25s;
}
.elfirma-chat-panel.chat-open {
  transform: translateY(0) scale(1);
  opacity: 1;
  pointer-events: all;
}

/* Panel header */
.chat-panel-header {
  background: linear-gradient(135deg, #052e16 0%, #166534 100%);
  padding: 16px 18px;
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}
.chat-header-avatar {
  width: 40px; height: 40px;
  background: rgba(74,222,128,.22);
  border: 2px solid rgba(74,222,128,.45);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.15rem;
  flex-shrink: 0;
}
.chat-header-info { flex: 1; min-width: 0; }
.chat-header-title {
  color: #fff;
  font-size: .92rem;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.chat-header-sub {
  color: #86efac;
  font-size: .69rem;
  font-weight: 500;
  margin-top: 1px;
}
.chat-header-right { display: flex; align-items: center; gap: 8px; }
.chat-status-badge {
  display: flex; align-items: center; gap: 5px;
  background: rgba(74,222,128,.18);
  border: 1px solid rgba(74,222,128,.35);
  border-radius: 999px;
  padding: 3px 10px;
  font-size: .68rem;
  font-weight: 700;
  color: #86efac;
  letter-spacing: .04em;
}
.chat-status-dot {
  width: 7px; height: 7px;
  background: #4ade80;
  border-radius: 50%;
  animation: fabPulse 2s infinite;
}
.chat-close-btn {
  width: 30px; height: 30px;
  border-radius: 50%;
  background: rgba(255,255,255,.14);
  border: 1px solid rgba(255,255,255,.2);
  color: #fff;
  font-size: .8rem;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background .18s;
  flex-shrink: 0;
}
.chat-close-btn:hover { background: rgba(255,255,255,.28); }

/* Context banner */
.chat-context-bar {
  background: #f0fdf4;
  border-bottom: 1px solid #bbf7d0;
  padding: 7px 16px;
  font-size: .72rem;
  color: #166534;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}
.chat-context-bar span.ctx-icon { font-size: .85rem; }

/* Messages area */
.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  scrollbar-width: thin;
  scrollbar-color: #d1fae5 transparent;
}
.chat-messages::-webkit-scrollbar { width: 5px; }
.chat-messages::-webkit-scrollbar-thumb { background: #bbf7d0; border-radius: 99px; }

/* Message bubbles */
.chat-msg { display: flex; flex-direction: column; max-width: 86%; }
.chat-msg--bot { align-self: flex-start; align-items: flex-start; }
.chat-msg--user { align-self: flex-end; align-items: flex-end; }

.chat-bubble {
  padding: 10px 14px;
  border-radius: 16px;
  font-size: .86rem;
  line-height: 1.55;
  word-break: break-word;
  white-space: pre-wrap;
}
.chat-msg--bot .chat-bubble {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-bottom-left-radius: 4px;
  color: #1e293b;
}
.chat-msg--user .chat-bubble {
  background: linear-gradient(135deg, #166534, #16a34a);
  color: #fff;
  border-bottom-right-radius: 4px;
}
.chat-msg-time {
  font-size: .65rem;
  color: #94a3b8;
  margin-top: 4px;
  padding: 0 4px;
}

/* Typing indicator */
.chat-typing {
  display: none;
  align-self: flex-start;
  padding: 11px 16px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 16px;
  border-bottom-left-radius: 4px;
  gap: 5px;
  align-items: center;
}
.chat-typing.typing-visible { display: flex; }
.chat-typing-dot {
  width: 7px; height: 7px;
  background: #94a3b8;
  border-radius: 50%;
  animation: typingBounce 1.2s infinite;
}
.chat-typing-dot:nth-child(2) { animation-delay: .2s; }
.chat-typing-dot:nth-child(3) { animation-delay: .4s; }
@keyframes typingBounce {
  0%, 60%, 100% { transform: translateY(0); }
  30%           { transform: translateY(-6px); }
}

/* Input area */
.chat-input-area {
  padding: 12px 14px;
  border-top: 1px solid #e2e8f0;
  display: flex;
  gap: 10px;
  align-items: flex-end;
  flex-shrink: 0;
  background: #fff;
}
.chat-textarea {
  flex: 1;
  border: 1.5px solid #e2e8f0;
  border-radius: 12px;
  padding: 10px 13px;
  font-size: .86rem;
  resize: none;
  outline: none;
  font-family: inherit;
  line-height: 1.5;
  max-height: 110px;
  overflow-y: auto;
  transition: border-color .18s;
  color: #1e293b;
}
.chat-textarea:focus { border-color: #16a34a; }
.chat-textarea::placeholder { color: #94a3b8; }
.chat-send-btn {
  width: 40px; height: 40px;
  background: linear-gradient(135deg, #166534, #16a34a);
  border: none;
  border-radius: 12px;
  color: #fff;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: opacity .18s, transform .18s;
}
.chat-send-btn:hover:not(:disabled) { opacity: .88; transform: scale(1.06); }
.chat-send-btn:disabled { opacity: .45; cursor: not-allowed; }
.chat-send-btn svg { width: 17px; height: 17px; }

/* Error message style */
.chat-bubble--error {
  background: #fef2f2 !important;
  border-color: #fecaca !important;
  color: #dc2626 !important;
}

/* Suggestions chips */
.chat-suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding: 0 0 4px;
}
.chat-chip {
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  color: #166534;
  border-radius: 999px;
  padding: 5px 13px;
  font-size: .74rem;
  font-weight: 600;
  cursor: pointer;
  transition: background .18s, transform .18s;
  white-space: nowrap;
}
.chat-chip:hover {
  background: #dcfce7;
  transform: translateY(-1px);
}

@media (max-width: 480px) {
  .elfirma-chat-panel { right: 10px; bottom: 90px; width: calc(100vw - 20px); }
  .elfirma-chat-fab   { right: 14px; bottom: 20px; padding: 11px 16px 11px 12px; font-size: .85rem; }
}
</style>

{# ── Floating button ── #}
<button class="elfirma-chat-fab" id="elfirmaChatFab" aria-label="Open AI Assistant" type="button">
  <span class="fab-pulse"></span>
  <span class="fab-icon">🌿</span>
  <span>AI Assistant</span>
</button>

{# ── Chat panel ── #}
<div class="elfirma-chat-panel" id="elfirmaChatPanel" aria-live="polite" aria-label="EL FIRMA AI Chat">

  {# Header #}
  <div class="chat-panel-header">
    <div class="chat-header-avatar">🌱</div>
    <div class="chat-header-info">
      <div class="chat-header-title">EL FIRMA Assistant</div>
      <div class="chat-header-sub">Your smart farming assistant</div>
    </div>
    <div class="chat-header-right">
      <div class="chat-status-badge" id="elfirmaChatStatus">
        <span class="chat-status-dot"></span>
        <span id="elfirmaChatStatusText">Online</span>
      </div>
      <button class="chat-close-btn" id="elfirmaChatClose" type="button" aria-label="Close chat">✕</button>
    </div>
  </div>

  {# Context bar #}
  <div class="chat-context-bar">
    <span class="ctx-icon">📋</span>
    Viewing: <strong>{{ page_label|default('Farm Data') }}</strong>
  </div>

  {# Messages #}
  <div class="chat-messages" id="elfirmaChatMessages">
    {# Welcome bot message with suggestion chips #}
    <div class="chat-msg chat-msg--bot">
      <div class="chat-bubble">
        👋 Hello! I'm your EL FIRMA agricultural assistant with live access to all <strong>parcel</strong> and <strong>crop</strong> data. How can I help you today?
      </div>
      <div class="chat-msg-time">just now</div>
    </div>
    <div class="chat-suggestions" id="elfirmaChatChips">
      {% if page == 'parcelles' %}
      <button class="chat-chip" type="button">How many parcels are available?</button>
      <button class="chat-chip" type="button">Which parcel has the largest area?</button>
      <button class="chat-chip" type="button">List all parcels and their soil types</button>
      <button class="chat-chip" type="button">Which parcels are currently resting?</button>
      {% else %}
      <button class="chat-chip" type="button">Which crops are overdue for harvest?</button>
      <button class="chat-chip" type="button">What is the average crop yield?</button>
      <button class="chat-chip" type="button">List all crops in progress</button>
      <button class="chat-chip" type="button">Which crop has the highest production cost?</button>
      {% endif %}
    </div>
  </div>

  {# Typing indicator #}
  <div class="chat-typing" id="elfirmaChatTyping">
    <div class="chat-typing-dot"></div>
    <div class="chat-typing-dot"></div>
    <div class="chat-typing-dot"></div>
  </div>

  {# Input area #}
  <div class="chat-input-area">
    <textarea
      id="elfirmaChatInput"
      class="chat-textarea"
      placeholder="Ask about parcels, crops, harvests…"
      rows="1"
      aria-label="Chat message input"
    ></textarea>
    <button id="elfirmaChatSend" class="chat-send-btn" type="button" aria-label="Send message" disabled>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </button>
  </div>
</div>

<script>
(function () {
  'use strict';

  var fab       = document.getElementById('elfirmaChatFab');
  var panel     = document.getElementById('elfirmaChatPanel');
  var closeBtn  = document.getElementById('elfirmaChatClose');
  var messages  = document.getElementById('elfirmaChatMessages');
  var typing    = document.getElementById('elfirmaChatTyping');
  var input     = document.getElementById('elfirmaChatInput');
  var sendBtn   = document.getElementById('elfirmaChatSend');
  var chips     = document.getElementById('elfirmaChatChips');
  var statusTxt = document.getElementById('elfirmaChatStatusText');

  var history   = [];   /* OpenAI-style message history */
  var isOpen    = false;
  var isLoading = false;

  /* ── Toggle panel ── */
  function openChat() {
    isOpen = true;
    panel.classList.add('chat-open');
    fab.style.display = 'none';
    input.focus();
  }
  function closeChat() {
    isOpen = false;
    panel.classList.remove('chat-open');
    fab.style.display = '';
  }

  fab.addEventListener('click', openChat);
  closeBtn.addEventListener('click', closeChat);

  /* ── Suggestion chips ── */
  if (chips) {
    chips.querySelectorAll('.chat-chip').forEach(function (chip) {
      chip.addEventListener('click', function () {
        input.value = chip.textContent.trim();
        autoResize();
        updateSendBtn();
        chips.style.display = 'none';
        sendMessage();
      });
    });
  }

  /* ── Input handling ── */
  function autoResize() {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 110) + 'px';
  }

  function updateSendBtn() {
    sendBtn.disabled = input.value.trim() === '' || isLoading;
  }

  input.addEventListener('input', function () {
    autoResize();
    updateSendBtn();
  });

  input.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (!sendBtn.disabled) sendMessage();
    }
  });

  sendBtn.addEventListener('click', sendMessage);

  /* ── Helpers ── */
  function timestamp() {
    var d = new Date();
    return d.getHours().toString().padStart(2,'0') + ':' + d.getMinutes().toString().padStart(2,'0');
  }

  function appendMessage(role, text, isError) {
    var wrapper = document.createElement('div');
    wrapper.className = 'chat-msg chat-msg--' + (role === 'user' ? 'user' : 'bot');

    var bubble = document.createElement('div');
    bubble.className = 'chat-bubble' + (isError ? ' chat-bubble--error' : '');
    bubble.textContent = text;

    var time = document.createElement('div');
    time.className = 'chat-msg-time';
    time.textContent = timestamp();

    wrapper.appendChild(bubble);
    wrapper.appendChild(time);
    messages.appendChild(wrapper);
    scrollToBottom();
    return wrapper;
  }

  function scrollToBottom() {
    messages.scrollTop = messages.scrollHeight;
  }

  function setLoading(val) {
    isLoading = val;
    sendBtn.disabled = val || input.value.trim() === '';
    if (val) {
      typing.classList.add('typing-visible');
      statusTxt.textContent = 'Thinking…';
    } else {
      typing.classList.remove('typing-visible');
      statusTxt.textContent = 'Online';
    }
    scrollToBottom();
  }

  /* ── Send message ── */
  function sendMessage() {
    var text = input.value.trim();
    if (!text || isLoading) return;

    /* Hide chips after first message */
    if (chips) chips.style.display = 'none';

    /* Add to UI and history */
    appendMessage('user', text);
    history.push({ role: 'user', content: text });

    /* Reset input */
    input.value = '';
    input.style.height = 'auto';
    updateSendBtn();

    setLoading(true);

    fetch('/api/chatbot/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: history }),
    })
    .then(function (res) { return res.json(); })
    .then(function (data) {
      setLoading(false);
      if (data.error) {
        console.error('[EL FIRMA Chatbot] LM Studio error response:', data);
        appendMessage('bot', '⚠️ ' + data.error, true);
      } else {
        var reply = data.reply || '(no response)';
        appendMessage('bot', reply);
        history.push({ role: 'assistant', content: reply });
      }
    })
    .catch(function (err) {
      setLoading(false);
      appendMessage('bot', '⚠️ Network error — please check that LM Studio is running.', true);
    });
  }

})();
</script>
