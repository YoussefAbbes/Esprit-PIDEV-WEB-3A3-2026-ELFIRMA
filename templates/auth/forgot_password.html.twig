{% extends 'auth_base.html.twig' %}

{% block title %}Forgot Password - EL FIRMA{% endblock %}

{% block content %}
  <div class="auth-brand">
    <div class="auth-logo-section">
      <h2>Password Recovery</h2>
      <p>Secure reset flow with your existing 2FA and email verification.</p>
    </div>

    <div class="auth-features">
      <div class="auth-feature">
        <i class="bi bi-envelope-check"></i>
        <span>Step 1: Confirm your account email</span>
      </div>
      <div class="auth-feature">
        <i class="bi bi-shield-lock"></i>
        <span>Step 2: Verify your authenticator 2FA code</span>
      </div>
      <div class="auth-feature">
        <i class="bi bi-key"></i>
        <span>Step 3: Verify email code and set a new password</span>
      </div>
    </div>
  </div>

  <div class="auth-form-section">
    <div class="auth-form-header">
      <h2>Forgot Password</h2>
      <p>
        {% if step == 'email' %}
          Enter your account email to start.
        {% elseif step == 'two_factor' %}
          Enter your 6-digit authenticator code.
        {% elseif step == 'email_code' %}
          Enter the code sent to {{ masked_email ?: 'your email' }}.
        {% elseif step == 'reset_password' %}
          Set your new password.
        {% endif %}
      </p>
    </div>

    {% if error is defined and error %}
      <div style="background-color: #ffebee; border: 1px solid #ef5350; border-radius: 8px; padding: 1rem; margin-bottom: 1.2rem; color: #d32f2f;">
        {{ error }}
      </div>
    {% endif %}

    {% if success is defined and success %}
      <div style="background-color: #e8f5e9; border: 1px solid #66bb6a; border-radius: 8px; padding: 1rem; margin-bottom: 1.2rem; color: #1b5e20;">
        {{ success }}
      </div>
    {% endif %}

    {% if step == 'email' %}
      <form method="POST" action="{{ path('app_forgot_password') }}" class="auth-form" style="max-width: 420px;">
        <input type="hidden" name="action" value="start">
        <input type="hidden" name="_token" value="{{ csrf_token('forgot_email') }}">

        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" class="form-control" placeholder="you@example.com" required>
          <small class="text-muted">We will first verify this account exists.</small>
        </div>

        <button type="submit" class="btn-auth"><span>Continue</span></button>
      </form>
    {% elseif step == 'two_factor' %}
      <form method="POST" action="{{ path('app_forgot_password') }}" class="auth-form" style="max-width: 420px;">
        <input type="hidden" name="action" value="verify_2fa">
        <input type="hidden" name="_token" value="{{ csrf_token('forgot_2fa') }}">

        <div class="form-group">
          <label for="code">Authenticator Code</label>
          <input type="text" id="code" name="code" class="form-control" placeholder="123456" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autocomplete="one-time-code">
          <small class="text-muted">Use the same 2FA authenticator flow already used in your project.</small>
        </div>

        <button type="submit" class="btn-auth"><span>Verify 2FA</span></button>
      </form>
    {% elseif step == 'email_code' %}
      <form method="POST" action="{{ path('app_forgot_password') }}" class="auth-form" style="max-width: 420px; margin-bottom: 0.8rem;">
        <input type="hidden" name="action" value="verify_email_code">
        <input type="hidden" name="_token" value="{{ csrf_token('forgot_email_code') }}">

        <div class="form-group">
          <label for="email_code">Email Verification Code</label>
          <input type="text" id="email_code" name="email_code" class="form-control" placeholder="123456" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autocomplete="one-time-code">
          <small class="text-muted">Check your inbox for the latest 6-digit code.</small>
        </div>

        <button type="submit" class="btn-auth"><span>Verify Email Code</span></button>
      </form>

      <form method="POST" action="{{ path('app_forgot_password') }}" class="auth-form" style="max-width: 420px;">
        <input type="hidden" name="action" value="resend_email_code">
        <input type="hidden" name="_token" value="{{ csrf_token('forgot_email_code') }}">
        <button type="submit" class="btn-auth" style="background: #f5f7f6; color: #183b2a; box-shadow: none; border: 1px solid rgba(17, 101, 48, 0.2);">
          <span>Resend Code</span>
        </button>
      </form>
    {% elseif step == 'reset_password' %}
      <form method="POST" action="{{ path('app_forgot_password') }}" class="auth-form" style="max-width: 420px;">
        <input type="hidden" name="action" value="reset_password">
        <input type="hidden" name="_token" value="{{ csrf_token('forgot_reset_password') }}">

        <div class="form-group">
          <label for="new_password">New Password</label>
          <input type="password" id="new_password" name="new_password" class="form-control" placeholder="••••••••" required>
          <small class="text-muted">At least 6 characters, with uppercase, lowercase and a number.</small>
        </div>

        <div class="form-group">
          <label for="confirm_password">Confirm Password</label>
          <input type="password" id="confirm_password" name="confirm_password" class="form-control" placeholder="••••••••" required>
        </div>

        <button type="submit" class="btn-auth"><span>Update Password</span></button>
      </form>
    {% endif %}

    <div class="form-divider" style="margin-top: 1.2rem;">
      <span>Remembered your password?</span>
    </div>

    <div class="auth-footer">
      <p><a href="{{ path('app_login') }}">Back to Sign In</a></p>
    </div>
  </div>
{% endblock %}
