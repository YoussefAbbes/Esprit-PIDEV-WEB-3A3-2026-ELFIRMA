    border: 2px solid rgba(16, 185, 129, 0.5);
    animation: slideInUp 0.8s ease-out 0.5s both, badge-pulse 2s ease-in-out 1.3s infinite;
    box-shadow: 0 0 20px rgba(16, 185, 129, 0.3);
