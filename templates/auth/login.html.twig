  @keyframes checkAnimation {
    0% {
      opacity: 0;
      transform: scale(0) rotate(-45deg);
    }
    50% {
      transform: scale(1.2);
    }
    100% {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }
    from {
      width: 0%;
    }
