</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Get errors from the data attribute
    const errorsData = document.getElementById('errors-data');
    let formErrors = {};

    if (errorsData) {
      const errorsJson = errorsData.getAttribute('data-errors');
      if (errorsJson) {
        try {
          formErrors = JSON.parse(errorsJson);
        } catch(e) {
          console.error('Error parsing errors:', e);
        }
      }
    }

    // Only apply red styles if there are errors
    if (Object.keys(formErrors).length > 0) {
      console.log('Applying error styles for fields:', Object.keys(formErrors));

      for (const [fieldName, errorMsg] of Object.entries(formErrors)) {
        const field = document.getElementById(fieldName);
        if (field) {
          // Add red border
          field.style.borderColor = '#dc3545';
          field.style.borderWidth = '2px';
          field.style.boxShadow = '0 0 0 3px rgba(220, 53, 69, 0.2)';

          // Create error message element
          const formGroup = field.parentElement;
          let errorElement = formGroup.querySelector('.error-message');

          if (!errorElement) {
            errorElement = document.createElement('div');
            errorElement.className = 'error-message';
          }

          errorElement.textContent = errorMsg;
          errorElement.style.color = '#dc3545';
          errorElement.style.fontSize = '0.875rem';
          errorElement.style.marginTop = '0.5rem';
          errorElement.style.marginBottom = '0.5rem';
          errorElement.style.fontWeight = '500';
          errorElement.style.display = 'block';

          // Insert after field if not already there
          if (!formGroup.querySelector('.error-message')) {
            formGroup.insertBefore(errorElement, field.nextElementSibling);
          }
        }
      }
    }
  });

  // Smooth form focus animation
  const inputs = document.querySelectorAll('.form-control');
  inputs.forEach(input => {
    input.addEventListener('focus', function() {
      this.parentElement.style.transform = 'scale(1.01)';
      this.parentElement.style.transition = 'transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1)';
    });
    input.addEventListener('blur', function() {
      this.parentElement.style.transform = 'scale(1)';
    });
  });

  // Parallax effect on mouse move
  const formSection = document.querySelector('.auth-form-section');
  document.addEventListener('mousemove', function(e) {
    const x = (window.innerWidth / 2 - e.clientX) / 100;
    const y = (window.innerHeight / 2 - e.clientY) / 100;

    if (formSection) {
      formSection.style.transform = `perspective(1000px) rotateY(${x}deg) rotateX(${y}deg)`;
    }
  });

  document.addEventListener('mouseleave', function() {
    if (formSection) {
      formSection.style.transform = 'perspective(1000px) rotateY(0deg) rotateX(0deg)';
    }
  });

  const loginDropdown = document.querySelector('.login-dropdown');
  const loginToggle = document.getElementById('loginToggle');
  const faceTrigger = document.getElementById('faceLoginTrigger');
  const faceModal = document.getElementById('loginFaceModal');
  const faceClose = document.getElementById('loginFaceClose');
  const faceVideo = document.getElementById('loginFaceVideo');
  const faceOverlay = document.getElementById('loginFaceOverlay');
  const faceStatus = document.getElementById('loginFaceStatus');
  const faceIdentity = document.getElementById('loginFaceIdentity');
  const faceCountdownEl = document.getElementById('loginFaceCountdown');
  const faceCtx = faceOverlay ? faceOverlay.getContext('2d') : null;

  let faceStream = null;
  let faceTimer = null;
  let faceStartedAt = 0;
  let recognizedHits = 0;
  let recognizedUserId = null;
  let lastRecognizedUserId = null;
  let isLoggingIn = false; // Flag pour éviter appels multiples

  const faceTimeoutMs = 25000; // 25s timeout for proper detection
  const requiredConsecutiveHits = 2; // 2 hits for stable recognition

  if (loginDropdown && loginToggle) {
    loginToggle.addEventListener('click', function(event) {
      event.stopPropagation();
      loginDropdown.classList.toggle('open');
    });

    document.addEventListener('click', function(event) {
      if (!loginDropdown.contains(event.target)) {
        loginDropdown.classList.remove('open');
      }
    });

    document.addEventListener('keydown', function(event) {
      if (event.key === 'Escape') {
        loginDropdown.classList.remove('open');
      }
    });
  }

  const stopFaceLoginCamera = () => {
    if (faceTimer) {
      clearInterval(faceTimer);
      faceTimer = null;
    }
    if (faceStream) {
      faceStream.getTracks().forEach(track => track.stop());
      faceStream = null;
    }
  };

  const closeFaceModal = () => {
    stopFaceLoginCamera();
    if (faceModal) {
      faceModal.classList.remove('active');
      faceModal.setAttribute('aria-hidden', 'true');
    }
    recognizedHits = 0;
    recognizedUserId = null;
  };

  const drawFaceBox = (bbox, color, label) => {
    if (!faceCtx || !faceOverlay || !faceVideo) return;

    faceOverlay.width = faceVideo.videoWidth || faceOverlay.clientWidth;
    faceOverlay.height = faceVideo.videoHeight || faceOverlay.clientHeight;
    faceCtx.clearRect(0, 0, faceOverlay.width, faceOverlay.height);

    if (!bbox) return;

    // Cadre plus gras et visible
    faceCtx.strokeStyle = color;
    faceCtx.lineWidth = 8; // Augmenté de 3 à 8 pour cadre bien visible
    faceCtx.strokeRect(bbox.x, bbox.y, bbox.w, bbox.h);

    // Texte du nom beaucoup plus gros et gras
    faceCtx.fillStyle = color;
    faceCtx.font = 'bold 36px Arial'; // Augmenté de 16px à 36px, plus gras
    faceCtx.fillText(label, bbox.x, Math.max(36, bbox.y - 12));
  };

  const grabFrame = () => {
    const tmpCanvas = document.createElement('canvas');
    tmpCanvas.width = faceVideo.videoWidth;
    tmpCanvas.height = faceVideo.videoHeight;
    const tmpCtx = tmpCanvas.getContext('2d');
    tmpCtx.drawImage(faceVideo, 0, 0, tmpCanvas.width, tmpCanvas.height);
    return tmpCanvas.toDataURL('image/jpeg', 0.76);
  };

  const updateFaceCountdown = () => {
    const elapsed = Date.now() - faceStartedAt;
    const left = Math.max(0, Math.ceil((faceTimeoutMs - elapsed) / 1000));
    if (faceCountdownEl) faceCountdownEl.textContent = `${left}s`;

    if (elapsed >= faceTimeoutMs) {
      closeFaceModal();
      Swal.fire({
        icon: 'info',
        title: 'Face detection timed out',
        text: 'Please use email and password to sign in.',
        confirmButtonColor: '#116530'
      });
    }
  };

  const loginByRecognizedFace = async (userId, firstName = '', lastName = '') => {
    // Close the face modal first
    closeFaceModal();

    // Show welcome animation
    const userName = `${firstName} ${lastName}`.trim() || 'User';

    Swal.fire({
      html: `
        <div class="welcome-container">
          <div class="welcome-animation">
            <div class="welcome-checkmark">✓</div>
            <div class="welcome-text">Welcome</div>
            <div class="user-info">
              <div class="user-name">${firstName}</div>
              <div class="user-lastname">${lastName}</div>
            </div>
            <div class="elfirma-badge">⭐ EL FIRMA ⭐</div>
          </div>
        </div>
      `,
      icon: null,
      showConfirmButton: false,
      allowOutsideClick: false,
      allowEscapeKey: false,
      customClass: {
        popup: 'welcome-popup'
      },
      timer: 5000,
      timerProgressBar: false,
      didOpen: async () => {
        // Animation de checkmark
        const checkmark = document.querySelector('.welcome-checkmark');
        if (checkmark) {
          checkmark.style.animation = 'checkAnimation 0.6s ease-out';
        }

        // Start the login process IMMEDIATELY (during the sweet display)
        try {
          const res = await fetch('{{ path('app_face_id_login') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId })
          });

          const data = await res.json();
          if (data.ok && data.redirect) {
            // Redirect happens during sweet display, no wait after
            setTimeout(() => {
              window.location.href = data.redirect;
            }, 1000); // Small delay to show sweet nicely
          }
        } catch (err) {
          console.error('Login failed:', err);
        }
      }
    });
  };

  const startFaceLogin = async () => {
    if (!faceModal || !faceVideo || !faceOverlay) return;

    // Reset login flag
    isLoggingIn = false;

    try {
      faceStream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: 'user', width: { ideal: 960 }, height: { ideal: 540 } },
        audio: false
      });
      faceVideo.srcObject = faceStream;
      await faceVideo.play();
    } catch (err) {
      Swal.fire({
        icon: 'error',
        title: 'Camera access denied',
        text: 'Please continue with your email and password.',
        confirmButtonColor: '#116530'
      });
      return;
    }

    faceStartedAt = Date.now();
    recognizedHits = 0;
    recognizedUserId = null;
    faceModal.classList.add('active');
    faceModal.setAttribute('aria-hidden', 'false');
    if (faceStatus) faceStatus.textContent = 'Detecting face...';
    if (faceIdentity) faceIdentity.textContent = 'Waiting for detection';

    faceTimer = setInterval(async () => {
      if (!faceVideo || faceVideo.readyState < 2) return;

      updateFaceCountdown();

      try {
        const image = grabFrame();
        const response = await fetch('{{ path('app_face_id_recognize') }}', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ image })
        });
        const data = await response.json();

        if (!data.ok) {
          drawFaceBox(null, '#ef4444', '');
          if (faceStatus) faceStatus.textContent = 'Face service unavailable';
          if (faceIdentity) faceIdentity.textContent = 'Try classic login';
          recognizedHits = 0;
          recognizedUserId = null;
          return;
        }

        if (!data.faceFound) {
          drawFaceBox(null, '#f59e0b', '');
          if (faceStatus) faceStatus.textContent = 'No face detected';
          if (faceIdentity) faceIdentity.textContent = 'Position your face in frame';
          recognizedHits = 0;
          recognizedUserId = null;
          return;
        }

        if (data.recognized && data.match) {
          drawFaceBox(data.bbox, '#22c55e', data.match.fullName || 'Recognized');
          if (faceStatus) faceStatus.textContent = 'User recognized';
          if (faceIdentity) {
            faceIdentity.textContent = `${data.match.firstName || ''} ${data.match.lastName || ''}`.trim();
          }

          // Check if this is the same user as last frame
          if (lastRecognizedUserId === data.match.userId) {
            recognizedHits += 1;
          } else {
            // Different user recognized, reset counter
            recognizedHits = 1;
            lastRecognizedUserId = data.match.userId;
          }

          // Require 2 consecutive frames with same user for confirmation
          if (recognizedHits >= requiredConsecutiveHits && !isLoggingIn) {
            isLoggingIn = true; // Marquer que le login est en cours
            closeFaceModal();
            await loginByRecognizedFace(data.match.userId, data.match.firstName, data.match.lastName);
          }
          return;
        }

        // No match found
        drawFaceBox(data.bbox, '#ef4444', 'Unknown user');
        if (faceStatus) faceStatus.textContent = 'Face not recognized';
        if (faceIdentity) faceIdentity.textContent = 'Unknown user';
        recognizedHits = 0;
        lastRecognizedUserId = null;
      } catch (err) {
        recognizedHits = 0;
        recognizedUserId = null;
      }
    }, 240);
  };

  if (faceTrigger) {
    faceTrigger.addEventListener('click', async function() {
      loginDropdown?.classList.remove('open');
      await startFaceLogin();
    });
  }

  if (faceClose) {
    faceClose.addEventListener('click', function() {
      closeFaceModal();
    });
  }



</script>

<script>
  (function () {
    const showTwoFaErrorAlert = function () {
      const params = new URLSearchParams(window.location.search);
      const twoFaError = params.get('twofa_error');

      if (twoFaError !== 'invalid_code') {
        return;
      }

      const title = 'Two-Factor Verification Failed';
      const message = 'Sorry, for security reasons, the code you entered is incorrect or has expired. You have been signed out. Please sign in again.';

      if (typeof Swal !== 'undefined') {
        Swal.fire({
          icon: 'error',
          title: title,
          text: message,
          confirmButtonColor: '#116530',
          confirmButtonText: 'Back to Sign In'
        }).then(function () {
          // Remove query string so alert does not reappear on refresh
          window.history.replaceState({}, document.title, window.location.pathname);
        });
      } else {
        // Fallback if SweetAlert is not loaded
        alert(message);
        window.history.replaceState({}, document.title, window.location.pathname);
      }
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', showTwoFaErrorAlert, { once: true });
    } else {
      showTwoFaErrorAlert();
    }
  })();
</script>

<!-- ══════════════════════════════════════════════════════════════
     FINGERPRINT RE-ENROLLMENT
     ══════════════════════════════════════════════════════════════ -->
<script>
(function () {
  'use strict';

  const FP_STATUS_URL       = '{{ path("app_fingerprint_status") }}';
  const FP_START_URL        = '{{ path("app_fingerprint_reenroll_start") }}';
  const FP_CAPTURE_URL      = '{{ path("app_fingerprint_reenroll_capture") }}';
  const FP_REENROLL_SAVE    = '{{ path("app_fingerprint_reenroll_save") }}';
  const LOGIN_URL           = '{{ path("app_login") }}';

  const modal         = document.getElementById('fingerprintReenrollModal');
  const trigger       = document.getElementById('fingerprintReenrollTrigger');
  const closeBtn      = document.getElementById('fpReenrollClose');
  const loginSection  = document.getElementById('fpReenrollLoginSection');
  const scanSection   = document.getElementById('fpReenrollScanSection');
  const emailEl       = document.getElementById('fpReenrollEmail');
  const passwordEl    = document.getElementById('fpReenrollPassword');
  const loginBtn      = document.getElementById('fpReenrollLoginBtn');
  const loginErrEl    = document.getElementById('fpReenrollLoginError');
  const iconEl        = document.getElementById('fpReenrollIcon');
  const statusEl      = document.getElementById('fpReenrollStatus');
  const progressEl    = document.getElementById('fpReenrollProgress');
  const scanBtn       = document.getElementById('fpReenrollScanBtn');
  const cancelScanBtn = document.getElementById('fpReenrollCancelScan');

  const steps = [
    document.getElementById('fpRStep1'),
    document.getElementById('fpRStep2'),
    document.getElementById('fpRStep3'),
  ];

  let loggedInUserId  = null;
  let currentStep     = 0;
  let captureInFlight = false;
  let enrolledTpl     = null;
  let enrolledLen     = 0;

  /* ── helpers ── */
  function openModal() {
    if (!modal) return;
    resetAll();
    modal.classList.add('active');
    modal.setAttribute('aria-hidden', 'false');
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.remove('active');
    modal.setAttribute('aria-hidden', 'true');
    captureInFlight = false;
  }

  function resetAll() {
    loggedInUserId  = null;
    currentStep     = 0;
    captureInFlight = false;
    enrolledTpl     = null;
    enrolledLen     = 0;

    if (loginSection)  { loginSection.style.display  = ''; }
    if (scanSection)   { scanSection.style.display   = 'none'; }
    if (emailEl)       emailEl.value    = '';
    if (passwordEl)    passwordEl.value = '';
    if (loginErrEl)    { loginErrEl.textContent = ''; loginErrEl.style.display = 'none'; }
    if (iconEl)        { iconEl.innerHTML = '<i class="bi bi-fingerprint"></i>'; iconEl.style.color = '#116530'; }
    if (statusEl)      statusEl.textContent = 'Click "Start Scan" to begin';
    if (progressEl)    progressEl.style.width = '0%';
    if (scanBtn)       { scanBtn.textContent = 'Start Scan'; scanBtn.disabled = false; }
    steps.forEach(s => { s.className = 'fp-step'; });
    if (steps[0]) steps[0].classList.add('fp-step-active');
  }

  function markStep(idx) {
    if (steps[idx]) { steps[idx].className = 'fp-step fp-step-done'; steps[idx].textContent = '✓'; }
    if (idx + 1 < steps.length) {
      steps[idx + 1].className = 'fp-step fp-step-active';
    }
  }

  function setStatus(msg, color) {
    if (statusEl) { statusEl.textContent = msg; statusEl.style.color = color || '#183b2a'; }
  }

  function setProgress(pct) {
    if (progressEl) progressEl.style.width = Math.min(100, pct) + '%';
  }

  /* ── step 1: login ── */
  if (loginBtn) {
    loginBtn.addEventListener('click', async function () {
      const email    = emailEl ? emailEl.value.trim() : '';
      const password = passwordEl ? passwordEl.value : '';

      if (!email || !password) {
        if (loginErrEl) { loginErrEl.textContent = 'Email and password are required.'; loginErrEl.style.display = ''; }
        return;
      }

      loginBtn.disabled = true;
      loginBtn.textContent = 'Signing in...';

      try {
        const fd = new FormData();
        fd.append('email', email);
        fd.append('password', password);

        const r = await fetch(LOGIN_URL, { method: 'POST', body: fd, redirect: 'manual' });

        // The login endpoint redirects on success. Do not treat HTTP 200 as success
        // because invalid credentials render the login page with status 200.
        const isLoginSuccess =
          r.type === 'opaqueredirect' ||
          r.redirected ||
          r.status === 301 ||
          r.status === 302 ||
          r.status === 303 ||
          r.status === 307 ||
          r.status === 308;

        if (isLoginSuccess) {
          // Try to get user_id from session via status endpoint
          const statusR = await fetch(FP_STATUS_URL, { method: 'POST' });
          const statusD = await statusR.json();

          if (!statusD.ok || !statusD.device_connected) {
            if (loginErrEl) {
              loginErrEl.textContent = 'Fingerprint scanner not connected. Start the bridge service first.';
              loginErrEl.style.display = '';
            }
            loginBtn.disabled = false;
            loginBtn.textContent = 'Sign In & Continue';
            return;
          }

          // Login succeeded — but we need the user_id from PHP session.
          // We'll get it by calling a lightweight endpoint that reads the session.
          // For now, trigger a real form login to establish session, then proceed.
          // The reenroll/save endpoint uses the PHP session user_id directly.
          loggedInUserId = true; // flag: logged in

          if (loginSection) loginSection.style.display = 'none';
          if (scanSection)  scanSection.style.display  = '';
        } else {
          if (loginErrEl) {
            loginErrEl.textContent = 'Invalid email or password.';
            loginErrEl.style.display = '';
          }
          loginBtn.disabled = false;
          loginBtn.textContent = 'Sign In & Continue';
        }
      } catch (e) {
        // Do a real form submit to create session, then show scan UI
        const realForm = document.createElement('form');
        realForm.method = 'POST';
        realForm.action = LOGIN_URL;
        realForm.style.display = 'none';
        const ef = document.createElement('input'); ef.type='hidden'; ef.name='email'; ef.value=email;
        const pf = document.createElement('input'); pf.type='hidden'; pf.name='password'; pf.value=password;
        realForm.appendChild(ef);
        realForm.appendChild(pf);
        document.body.appendChild(realForm);

        // Store intent to reenroll in sessionStorage, then submit
        sessionStorage.setItem('fp_reenroll_pending', '1');
        realForm.submit();
      }
    });
  }

  /* ── step 2: scan ── */
  async function doCapture() {
    if (captureInFlight) return;
    captureInFlight = true;
    if (scanBtn) { scanBtn.disabled = true; }

    if (currentStep === 0) {
      setStatus('Connecting to scanner...', '#116530');
      const startR = await fetch(FP_START_URL, { method: 'POST' });
      const startD = await startR.json();
      if (!startD.ok) {
        setStatus('Could not start enrollment: ' + (startD.error || 'Unknown error'), '#dc2626');
        if (scanBtn) { scanBtn.disabled = false; scanBtn.textContent = 'Retry'; }
        captureInFlight = false;
        return;
      }
      currentStep = 1;
    }

    setStatus('Place your finger on the scanner and hold...', '#116530');
    if (iconEl) { iconEl.innerHTML = '<i class="bi bi-fingerprint fp-scanning"></i>'; }

    try {
      const r    = await fetch(FP_CAPTURE_URL, { method: 'POST' });
      const data = await r.json();

      if (!data.ok) {
        setStatus('Capture failed: ' + (data.message || data.error || 'Try again'), '#dc2626');
        if (iconEl) { iconEl.innerHTML = '<i class="bi bi-fingerprint fp-error"></i>'; }
        if (scanBtn) { scanBtn.disabled = false; scanBtn.textContent = 'Retry Scan'; }
        captureInFlight = false;
        return;
      }

      markStep(currentStep - 1);
      setProgress((currentStep / 3) * 100);

      if (data.done) {
        enrolledTpl = data.template;
        enrolledLen = data.template_length || 0;
        setStatus('All 3 scans captured! Saving...', '#116530');
        if (iconEl) { iconEl.innerHTML = '<i class="bi bi-fingerprint fp-success"></i>'; }
        setProgress(100);

        // Save via the reenroll/save endpoint (uses PHP session user_id)
        try {
          const saveR = await fetch(FP_REENROLL_SAVE, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ template: enrolledTpl, template_length: enrolledLen }),
          });
          const saveD = await saveR.json();

          if (saveD.ok) {
            setTimeout(() => {
              closeModal();
              Swal.fire({
                icon: 'success',
                title: 'Fingerprint Updated!',
                text: 'You can now sign in using your fingerprint.',
                confirmButtonColor: '#116530',
              });
            }, 800);
          } else {
            setStatus('Save failed: ' + (saveD.error || 'Please try again'), '#dc2626');
            if (scanBtn) { scanBtn.style.display = 'none'; }
            captureInFlight = false;
          }
        } catch (e) {
          setStatus('Network error saving fingerprint. Try again.', '#dc2626');
          captureInFlight = false;
        }
      } else {
        currentStep++;
        setStatus('Scan ' + (currentStep - 1) + ' of 3 done. Lift finger and place again.', '#116530');
        if (iconEl) { iconEl.innerHTML = '<i class="bi bi-fingerprint"></i>'; iconEl.style.color = '#116530'; }
        if (scanBtn) { scanBtn.textContent = 'Capture Scan ' + currentStep; scanBtn.disabled = false; }
        captureInFlight = false;
      }
    } catch (e) {
      setStatus('Network error. Try again.', '#dc2626');
      if (scanBtn) { scanBtn.disabled = false; }
      captureInFlight = false;
    }
  }

  /* ── check if returning from a login redirect with reenroll intent ── */
  if (sessionStorage.getItem('fp_reenroll_pending') === '1') {
    sessionStorage.removeItem('fp_reenroll_pending');
    // Check if we have a session (device connected means bridge is up)
    setTimeout(() => {
      openModal();
      // Skip to scan section immediately since user just logged in
      if (loginSection) loginSection.style.display = 'none';
      if (scanSection)  scanSection.style.display  = '';
      loggedInUserId = true;
    }, 400);
  }

  /* ── listeners ── */
  if (trigger)       trigger.addEventListener('click', openModal);
  if (closeBtn)      closeBtn.addEventListener('click', closeModal);
  if (cancelScanBtn) cancelScanBtn.addEventListener('click', closeModal);
  if (scanBtn)       scanBtn.addEventListener('click', doCapture);

  if (modal) {
    modal.querySelector('.face-modal-backdrop')?.addEventListener('click', closeModal);
  }

  /* ── fp-step styles (needed on login page too) ── */
  const fpStyle = document.createElement('style');
  fpStyle.textContent = `
    .fp-step {
      width:36px;height:36px;border-radius:50%;border:2px solid #d1d5db;
      display:flex;align-items:center;justify-content:center;
      font-weight:700;font-size:0.85rem;color:#9ca3af;transition:all 0.3s ease;
    }
    .fp-step-active { border-color:#116530;color:#116530; }
    .fp-step-done   { border-color:#22c55e;background:#22c55e;color:#fff; }
    @keyframes fp-pulse { 0%,100%{transform:scale(1);opacity:1;} 50%{transform:scale(1.12);opacity:0.75;} }
    @keyframes fp-success-bounce { 0%{transform:scale(1);} 40%{transform:scale(1.3);} 100%{transform:scale(1);} }
    .fp-scanning { animation:fp-pulse 1.2s ease-in-out infinite;color:#116530; }
    .fp-success  { animation:fp-success-bounce 0.5s ease-out forwards;color:#22c55e; }
    .fp-error    { color:#dc2626; }
  `;
  document.head.appendChild(fpStyle);
})();
</script>

<!-- ══════════════════════════════════════════════════════════════
     FINGERPRINT LOGIN
     ══════════════════════════════════════════════════════════════ -->
<script>
(function () {
  'use strict';

  const TIMEOUT_MS     = 30000;
  const POLL_MS        = 500;
  const FP_STATUS_URL  = '{{ path("app_fingerprint_status") }}';
  const FP_LOGIN_URL   = '{{ path("app_fingerprint_login") }}';

  const modal       = document.getElementById('fingerprintLoginModal');
  const iconEl      = document.getElementById('fpLoginIcon');
  const statusEl    = document.getElementById('fpLoginStatus');
  const countdownEl = document.getElementById('fpLoginCountdown');
  const progressEl  = document.getElementById('fpLoginProgress');
  const trigger     = document.getElementById('fingerprintLoginTrigger');
  const closeBtn    = document.getElementById('fpLoginClose');
  const cancelBtn   = document.getElementById('fpLoginCancel');

  let countdownInterval = null;
  let loginInFlight     = false;

  function openModal() {
    if (!modal) return;
    modal.classList.add('active');
    modal.setAttribute('aria-hidden', 'false');
    resetUI();
    startLogin();
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.remove('active');
    modal.setAttribute('aria-hidden', 'true');
    stopCountdown();
    loginInFlight = false;
  }

  function resetUI() {
    if (iconEl)      { iconEl.className = 'bi bi-fingerprint fp-scanning'; iconEl.style.fontSize = '6rem'; }
    if (statusEl)    statusEl.textContent = 'Waiting for finger...';
    if (countdownEl) countdownEl.textContent = '30s';
    if (progressEl)  progressEl.style.width = '0%';
  }

  function setSuccess(msg) {
    if (iconEl)   { iconEl.className = 'bi bi-fingerprint fp-success'; }
    if (statusEl) statusEl.textContent = msg || 'Fingerprint recognised!';
    if (progressEl) progressEl.style.width = '100%';
  }

  function setError(msg) {
    if (iconEl)   { iconEl.className = 'bi bi-fingerprint fp-error'; }
    if (statusEl) statusEl.textContent = msg || 'Not recognised.';
  }

  function stopCountdown() {
    if (countdownInterval) {
      clearInterval(countdownInterval);
      countdownInterval = null;
    }
  }

  async function startLogin() {
    loginInFlight = true;
    const start = Date.now();

    // Countdown ticker
    countdownInterval = setInterval(() => {
      const elapsed = Date.now() - start;
      const left    = Math.max(0, Math.ceil((TIMEOUT_MS - elapsed) / 1000));
      if (countdownEl) countdownEl.textContent = left + 's';
      if (progressEl)  progressEl.style.width = Math.min(100, (elapsed / TIMEOUT_MS) * 100) + '%';

      if (elapsed >= TIMEOUT_MS) {
        stopCountdown();
        setError('Timed out. Please try again.');
        loginInFlight = false;
      }
    }, POLL_MS);

    // ── Check bridge is reachable ────────────────────────────────────────
    if (statusEl) statusEl.textContent = 'Connecting to fingerprint scanner...';
    try {
      const statusRes = await fetch(FP_STATUS_URL, { method: 'POST' });
      const statusData = await statusRes.json();

      if (!statusData.ok || !statusData.device_connected) {
        stopCountdown();
        setError('Scanner not connected. Start the fingerprint service and plug in the device.');
        loginInFlight = false;
        return;
      }
    } catch (e) {
      stopCountdown();
      setError('Fingerprint service unreachable. Is it running?');
      loginInFlight = false;
      return;
    }

    // ── Send identify request (Java bridge will capture live finger) ─────
    if (statusEl) statusEl.textContent = 'Place your finger on the scanner...';
    try {
      const loginRes  = await fetch(FP_LOGIN_URL, { method: 'POST' });
      const loginData = await loginRes.json();
      stopCountdown();

      if (!loginInFlight) return; // was cancelled

      if (loginData.ok) {
        setSuccess('Fingerprint recognised! Signing you in...');
        setTimeout(() => {
          window.location.href = loginData.redirect || '/home';
        }, 900);
      } else {
        setError(loginData.message || 'Fingerprint not recognised. Try again.');
        loginInFlight = false;
      }
    } catch (e) {
      stopCountdown();
      setError('Network error during fingerprint login.');
      loginInFlight = false;
    }
  }

  if (trigger)   trigger.addEventListener('click', openModal);
  if (closeBtn)  closeBtn.addEventListener('click', closeModal);
  if (cancelBtn) cancelBtn.addEventListener('click', closeModal);

  if (modal) {
    modal.querySelector('.face-modal-backdrop')?.addEventListener('click', closeModal);
  }
})();
</script>

