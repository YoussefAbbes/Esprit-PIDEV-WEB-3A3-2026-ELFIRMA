{% extends 'auth_base.html.twig' %}

{% block title %}Sign In - EL FIRMA{% endblock %}

{% block content %}
  <!-- Left Side -->
  <div class="auth-brand">
    <div class="auth-logo-section">
      <h2>Welcome Back</h2>
      <p>Manage your agricultural operations efficiently</p>
    </div>

    <div class="auth-features">
      <div class="auth-feature">
        <i class="bi bi-check-circle"></i>
        <span>Organize seasonal agricultural work</span>
      </div>
      <div class="auth-feature">
        <i class="bi bi-check-circle"></i>
        <span>Track production from plot to harvest</span>
      </div>
      <div class="auth-feature">
        <i class="bi bi-check-circle"></i>
        <span>Sustainable farming practices</span>
      </div>
    </div>
  </div>

  <!-- Right Side -->
  <div class="auth-form-section">
    <div class="auth-form-header">
      <h2>Sign In</h2>
      <p>Access your account</p>
    </div>

    <!-- Store errors data -->
    <div id="errors-data" data-errors="{{ (errors ?? {})|json_encode() }}"></div>

    {% if error is defined and error %}
      <div style="background-color: #ffebee; border: 1px solid #ef5350; border-radius: 6px; padding: 1rem; margin-bottom: 1.5rem; color: #d32f2f; display: flex; gap: 0.75rem; align-items: flex-start;">
        <i class="bi bi-exclamation-circle" style="font-size: 1.2rem; flex-shrink: 0; margin-top: 0.1rem;"></i>
        <span>{{ error }}</span>
      </div>
    {% endif %}

    <form method="POST" action="{{ path('app_login') }}" class="auth-form" id="loginForm">
      <!-- Email -->
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="text" id="email" name="email" class="form-control" placeholder="you@example.com" value="{{ app.request.request.get('email', '') }}">
        <small class="text-muted">Enter your registered email</small>
      </div>

      <!-- Password -->
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" class="form-control" placeholder="••••••••">
        <small class="text-muted">Enter your password</small>
        <div style="margin-top: 0.55rem; text-align: right;">
          <a href="{{ path('app_forgot_password') }}" style="font-size: 0.88rem; color: #116530; font-weight: 600; text-decoration: none;">Forgot password?</a>
        </div>
      </div>

      <div class="form-check">
        <input type="checkbox" id="remember" name="remember" class="form-check-input">
        <label class="form-check-label" for="remember">
          Remember me on this device
        </label>
      </div>

      <button type="submit" class="btn-auth"><span>Sign In</span></button>

      <!-- Sign in with Social Networks -->
      <div class="login-dropdown">
        <button type="button" class="login-btn" id="loginToggle">
          <span>Sign in with</span>
          <span class="arrow">▾</span>
        </button>

        <div class="login-menu" id="loginMenu">
          <a href="{{ path('connect_google') }}" class="login-item google">
            <svg class="login-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Google
          </a>

          <a href="{{ path('connect_github') }}" class="login-item github">
            <svg class="login-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" fill="#333"/>
            </svg>
            GitHub
          </a>

          <button type="button" class="login-item face" id="faceLoginTrigger">
            <i class="bi bi-person-bounding-box"></i>
            Face Recognition
          </button>

          <button type="button" class="login-item fingerprint" id="fingerprintLoginTrigger">
            <i class="bi bi-fingerprint"></i>
            Fingerprint
          </button>

         
        </div>
      </div>




    </form>

    <div class="form-divider">
      <span>New to EL FIRMA?</span>
    </div>

    <div class="auth-footer">
      <p><a href="{{ path('app_signup') }}">Create a new account</a></p>
    </div>
  </div>

  <!-- Fingerprint Login Modal -->
  <!-- Fingerprint Enrollment Modal -->
  <div class="face-modal" id="fingerprintEnrollModal" aria-hidden="true">
    <div class="face-modal-backdrop"></div>
    <div class="face-modal-card" role="dialog" aria-modal="true" aria-labelledby="fpEnrollTitle">
      <div class="face-modal-head">
        <h3 id="fpEnrollTitle" style="display:flex;align-items:center;gap:0.5rem;">
          <i class="bi bi-fingerprint" style="font-size:1.4rem;color:#116530;"></i>
          Register Fingerprint
        </h3>
        <button type="button" class="face-close-btn" id="fpEnrollClose" aria-label="Close">&times;</button>
      </div>
      <p class="face-helper-text">We will scan your finger 3 times to build your fingerprint profile.</p>

      <div style="display:flex;flex-direction:column;align-items:center;padding:1.5rem 0;">
        <div id="fpEnrollIcon" style="font-size:6rem;color:#116530;transition:all 0.4s ease;">
          <i class="bi bi-fingerprint"></i>
        </div>

        <!-- Step indicators -->
        <div style="display:flex;gap:0.75rem;margin-top:1rem;">
          <div id="fpStep1" style="width:36px;height:36px;border-radius:50%;border:2px solid #116530;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem;color:#116530;">1</div>
          <div id="fpStep2" style="width:36px;height:36px;border-radius:50%;border:2px solid #d1d5db;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem;color:#9ca3af;">2</div>
          <div id="fpStep3" style="width:36px;height:36px;border-radius:50%;border:2px solid #d1d5db;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem;color:#9ca3af;">3</div>
        </div>

        <div class="face-status" id="fpEnrollStatus" style="margin-top:1rem;text-align:center;">
          Place your finger on the scanner
        </div>
      </div>

      <!-- Progress bar -->
      <div style="width:100%;height:4px;background:#e5e7eb;border-radius:2px;overflow:hidden;margin-bottom:1rem;">
        <div id="fpEnrollProgress" style="height:100%;width:0%;background:linear-gradient(90deg,#116530,#22c55e);transition:width 0.5s ease;"></div>
      </div>

      <div class="face-actions" style="justify-content:space-between;">
        <button type="button" id="fpEnrollSkip" class="face-secondary-btn">Skip Fingerprint</button>
        <button type="button" id="fpEnrollNext" style="display:none;padding:0.52rem 1.2rem;background:#116530;color:#fff;border:none;border-radius:10px;font-weight:600;cursor:pointer;">
          Capture Next Scan
        </button>
      </div>
    </div>
  </div>

  <div class="face-modal" id="fingerprintLoginModal" aria-hidden="true">
    <div class="face-modal-backdrop"></div>
    <div class="face-modal-card" role="dialog" aria-modal="true" aria-labelledby="fpLoginTitle">
      <div class="face-modal-head">
        <h3 id="fpLoginTitle" style="display:flex;align-items:center;gap:0.5rem;">
          <i class="bi bi-fingerprint" style="font-size:1.4rem;color:#116530;"></i>
          Sign In with Fingerprint
        </h3>
        <button type="button" class="face-close-btn" id="fpLoginClose" aria-label="Close">&times;</button>
      </div>
      <p class="face-helper-text">Place your finger on the ZKTeco scanner and hold still.</p>

      <!-- Animated fingerprint indicator -->
      <div style="display:flex;flex-direction:column;align-items:center;padding:2rem 0;">
        <div id="fpLoginIcon" style="font-size:6rem;color:#116530;transition:all 0.4s ease;">
          <i class="bi bi-fingerprint"></i>
        </div>
        <div class="face-status" id="fpLoginStatus" style="margin-top:1rem;text-align:center;">
          Waiting for finger...
        </div>
        <div style="margin-top:0.5rem;display:flex;align-items:center;gap:0.5rem;">
          <span id="fpLoginCountdown" style="font-size:0.86rem;color:#6b7280;">30s</span>
        </div>
      </div>

      <!-- Progress bar -->
      <div style="width:100%;height:4px;background:#e5e7eb;border-radius:2px;overflow:hidden;margin-bottom:1rem;">
        <div id="fpLoginProgress" style="height:100%;width:0%;background:linear-gradient(90deg,#116530,#22c55e);transition:width 0.3s ease;"></div>
      </div>

      <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
        <button type="button" id="fpLoginCancel" class="face-secondary-btn">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Fingerprint Re-enrollment Modal -->
  <div class="face-modal" id="fingerprintReenrollModal" aria-hidden="true">
    <div class="face-modal-backdrop"></div>
    <div class="face-modal-card" role="dialog" aria-modal="true" aria-labelledby="fpReenrollTitle">
      <div class="face-modal-head">
        <h3 id="fpReenrollTitle" style="display:flex;align-items:center;gap:0.5rem;">
          <i class="bi bi-fingerprint" style="font-size:1.4rem;color:#116530;"></i>
          Re-enroll Fingerprint
        </h3>
        <button type="button" class="face-close-btn" id="fpReenrollClose" aria-label="Close">&times;</button>
      </div>
      <p class="face-helper-text">First sign in with email &amp; password, then scan your finger 3 times to update your fingerprint.</p>

      <!-- Login form inside modal -->
      <div id="fpReenrollLoginSection">
        <div style="margin-bottom:1rem;">
          <label style="font-weight:600;color:#183b2a;display:block;margin-bottom:0.4rem;">Email</label>
          <input type="email" id="fpReenrollEmail" class="form-control" placeholder="you@example.com" style="width:100%;box-sizing:border-box;">
        </div>
        <div style="margin-bottom:1.2rem;">
          <label style="font-weight:600;color:#183b2a;display:block;margin-bottom:0.4rem;">Password</label>
          <input type="password" id="fpReenrollPassword" class="form-control" placeholder="••••••" style="width:100%;box-sizing:border-box;">
        </div>
        <div id="fpReenrollLoginError" style="color:#dc2626;font-size:0.85rem;margin-bottom:0.8rem;display:none;"></div>
        <button type="button" id="fpReenrollLoginBtn" style="width:100%;padding:0.75rem;background:#116530;color:#fff;border:none;border-radius:10px;font-weight:700;cursor:pointer;font-size:1rem;">
          Sign In &amp; Continue
        </button>
      </div>

      <!-- Scan section (shown after login) -->
      <div id="fpReenrollScanSection" style="display:none;">
        <div style="display:flex;flex-direction:column;align-items:center;padding:1rem 0;">
          <div id="fpReenrollIcon" style="font-size:5rem;color:#116530;">
            <i class="bi bi-fingerprint"></i>
          </div>
          <div style="display:flex;gap:0.6rem;margin-top:0.8rem;">
            <div id="fpRStep1" class="fp-step fp-step-active">1</div>
            <div id="fpRStep2" class="fp-step">2</div>
            <div id="fpRStep3" class="fp-step">3</div>
          </div>
          <div id="fpReenrollStatus" class="face-status" style="margin-top:0.8rem;text-align:center;">
            Click "Start Scan" to begin
          </div>
        </div>
        <div style="width:100%;height:4px;background:#e5e7eb;border-radius:2px;overflow:hidden;margin-bottom:1rem;">
          <div id="fpReenrollProgress" style="height:100%;width:0%;background:linear-gradient(90deg,#116530,#22c55e);transition:width 0.5s ease;"></div>
        </div>
        <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
          <button type="button" id="fpReenrollCancelScan" class="face-secondary-btn">Cancel</button>
          <button type="button" id="fpReenrollScanBtn" style="padding:0.52rem 1.2rem;background:#116530;color:#fff;border:none;border-radius:10px;font-weight:600;cursor:pointer;">
            Start Scan
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="face-modal" id="loginFaceModal" aria-hidden="true">
    <div class="face-modal-backdrop"></div>
    <div class="face-modal-card" role="dialog" aria-modal="true" aria-labelledby="loginFaceTitle">
      <div class="face-modal-head">
        <h3 id="loginFaceTitle">Sign In With Face Recognition</h3>
        <button type="button" class="face-close-btn" id="loginFaceClose" aria-label="Close">&times;</button>
      </div>
      <p class="face-helper-text">Live camera is running. Align your face inside the frame.</p>
      <div class="face-stage">
        <video id="loginFaceVideo" autoplay playsinline muted></video>
        <canvas id="loginFaceOverlay"></canvas>
      </div>
      <div class="face-status" id="loginFaceStatus">Starting camera...</div>
      <div class="face-progress-row">
        <span id="loginFaceIdentity">Waiting for detection</span>
        <span id="loginFaceCountdown">25s</span>
      </div>
    </div>
  </div>

<style>
  .form-group {
    margin-bottom: 1.5rem;
  }

  .auth-form-section {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .auth-form-header,
  .form-divider,
  .auth-footer {
    width: 100%;
    max-width: 420px;
  }

  .auth-form-header {
    margin-bottom: 28px;
  }

  .auth-form-header h2 {
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.45rem;
    color: #183b2a;
  }

  .auth-form-header p {
    color: #6b7280;
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .auth-form {
    width: 100%;
    max-width: 420px;
  }

  .form-group label {
    font-weight: 600;
    color: #060606;
    margin-bottom: 0.5rem;
    display: block;
  }

  .form-control {
    width: 100%;
    border-radius: 6px;
    border: 1.5px solid #e0e0e0;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    box-sizing: border-box;
  }

  .form-control:focus {
    border-color: #116530 !important;
    box-shadow: 0 0 0 3px rgba(17, 101, 48, 0.1) !important;
    outline: none;
  }

  .form-control.is-invalid {
    border: 2px solid #dc3545 !important;
    box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.2) !important;
  }

  .form-control.is-invalid:focus {
    border: 2px solid #dc3545 !important;
    box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.3) !important;
  }

  .error-message {
    color: #dc3545;
    font-size: 0.875rem;
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    font-weight: 500;
    display: block;
  }

  small.text-muted {
    font-size: 0.8rem;
    display: block;
    margin-top: 0.3rem;
    color: #999;
  }

  .form-check {
    margin-bottom: 1.5rem;
  }

  .form-check-input {
    margin-top: 0.3rem;
  }

  .login-dropdown {
    position: relative;
    margin-top: 1rem;
    z-index: 60;
  }

  /* Allow dropdown panel to escape the auth card bounds */
  .auth-form-section {
    overflow: visible;
  }

  .login-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    border: 1px solid rgba(17, 101, 48, 0.15);
    border-radius: 14px;
    background: linear-gradient(180deg, #ffffff 0%, #f8fbf8 100%);
    color: #183b2a;
    padding: 0.95rem 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 10px 24px rgba(17, 101, 48, 0.08);
  }

  .login-btn:hover,
  .login-btn:focus {
    border-color: rgba(17, 101, 48, 0.35);
    box-shadow: 0 14px 28px rgba(17, 101, 48, 0.12);
    outline: none;
  }

  .login-btn .arrow {
    font-size: 0.9rem;
    transition: transform 0.2s ease;
  }

  .login-dropdown.open .login-btn .arrow {
    transform: rotate(180deg);
  }

  .login-menu {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: calc(100% + 0.5rem);
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid rgba(17, 101, 48, 0.12);
    border-radius: 16px;
    box-shadow: 0 18px 36px rgba(10, 20, 15, 0.12);
    padding: 0.5rem;
    width: max-content;
    min-width: 100%;
    max-width: min(420px, calc(100vw - 2rem));
    max-height: 340px;
    overflow-y: auto;
    display: none;
    z-index: 20;
  }

  .login-dropdown.open .login-menu {
    display: block;
  }

  .login-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.9rem 1rem;
    border-radius: 12px;
    color: #183b2a;
    text-decoration: none;
    font-weight: 600;
    white-space: nowrap;
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .login-item:hover {
    background: #f7faf7;
    transform: translateX(3px);
    box-shadow: 0 6px 14px rgba(17, 101, 48, 0.06);
  }

  .login-icon {
    width: 1.15rem;
    height: 1.15rem;
    flex-shrink: 0;
  }

  .login-item.google:hover {
    background: rgba(66, 133, 244, 0.08);
  }

  .login-item.github:hover {
    background: rgba(51, 51, 51, 0.08);
  }

  .login-item.face {
    width: 100%;
    border: none;
    background: transparent;
    text-align: left;
    cursor: pointer;
    font-size: 0.96rem;
  }

  .login-item.face:hover {
    background: rgba(17, 101, 48, 0.09);
  }

  .login-item.fingerprint {
    width: 100%;
    border: none;
    background: transparent;
    text-align: left;
    cursor: pointer;
    font-size: 0.96rem;
  }

  .login-item.fingerprint:hover {
    background: rgba(17, 101, 48, 0.09);
  }

  @keyframes fp-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.12); opacity: 0.75; }
  }

  @keyframes fp-success {
    0% { transform: scale(1); }
    40% { transform: scale(1.3); }
    100% { transform: scale(1); }
  }

  .fp-scanning { animation: fp-pulse 1.2s ease-in-out infinite; color: #116530 !important; }
  .fp-success  { animation: fp-success 0.5s ease-out forwards; color: #22c55e !important; }
  .fp-error    { color: #dc2626 !important; }

  .btn-auth {
    width: 100%;
    border: none;
    border-radius: 14px;
    padding: 0.95rem 1rem;
    background: linear-gradient(135deg, #116530 0%, #0f4f27 100%);
    color: #fff;
    font-weight: 700;
    letter-spacing: 0.01em;
    box-shadow: 0 16px 30px rgba(17, 101, 48, 0.24);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn-auth:hover {
    transform: translateY(-1px);
    box-shadow: 0 18px 36px rgba(17, 101, 48, 0.28);
  }

  .form-divider {
    margin-top: 1.5rem;
    margin-bottom: 0.9rem;
    text-align: center;
    color: #6b7280;
  }

  .form-divider span {
    position: relative;
    display: inline-block;
    padding: 0 0.8rem;
    font-size: 0.92rem;
  }

  .auth-footer {
    text-align: center;
  }

  .auth-footer a {
    color: #116530;
    font-weight: 700;
    text-decoration: none;
  }

  .auth-footer a:hover {
    text-decoration: underline;
  }

  .face-modal {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1200;
  }

  .face-modal.active {
    display: flex;
  }

  .face-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 16, 14, 0.72);
    backdrop-filter: blur(4px);
  }

  .face-modal-card {
    position: relative;
    width: min(92vw, 600px);
    background: #ffffff;
    border-radius: 18px;
    border: 1px solid rgba(17, 101, 48, 0.22);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.25);
    padding: 1rem;
    z-index: 1;
  }

  .face-modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .face-modal-head h3 {
    margin: 0;
    color: #183b2a;
    font-size: 1.2rem;
    font-weight: 700;
  }

  .face-close-btn {
    border: none;
    background: transparent;
    color: #52606d;
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
  }

  .face-helper-text {
    margin: 0.3rem 0 0.8rem;
    color: #617080;
