{% extends 'auth_base.html.twig' %}

{% block title %}Sign In - EL FIRMA{% endblock %}

{% block content %}
  <!-- Left Side -->
  <div class="auth-brand">
    <div class="auth-logo-section">
      <h2>Welcome Back</h2>
      <p>Manage your agricultural operations efficiently</p>
    </div>

    <div class="auth-features">
      <div class="auth-feature">
        <i class="bi bi-check-circle"></i>
        <span>Organize seasonal agricultural work</span>
      </div>
      <div class="auth-feature">
        <i class="bi bi-check-circle"></i>
        <span>Track production from plot to harvest</span>
      </div>
      <div class="auth-feature">
        <i class="bi bi-check-circle"></i>
        <span>Sustainable farming practices</span>
      </div>
    </div>
  </div>

  <!-- Right Side -->
  <div class="auth-form-section">
    <div class="auth-form-header">
      <h2>Sign In</h2>
      <p>Access your account</p>
    </div>

    <!-- Store errors data -->
    <div id="errors-data" data-errors="{{ (errors ?? {})|json_encode() }}"></div>

    {% if error is defined and error %}
      <div style="background-color: #ffebee; border: 1px solid #ef5350; border-radius: 6px; padding: 1rem; margin-bottom: 1.5rem; color: #d32f2f; display: flex; gap: 0.75rem; align-items: flex-start;">
        <i class="bi bi-exclamation-circle" style="font-size: 1.2rem; flex-shrink: 0; margin-top: 0.1rem;"></i>
        <span>{{ error }}</span>
      </div>
    {% endif %}

    <form method="POST" action="{{ path('app_login') }}" class="auth-form" id="loginForm">
      <!-- Email -->
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="text" id="email" name="email" class="form-control" placeholder="you@example.com" value="{{ app.request.request.get('email', '') }}">
        <small class="text-muted">Enter your registered email</small>
      </div>

      <!-- Password -->
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" class="form-control" placeholder="••••••••">
        <small class="text-muted">Enter your password</small>
      </div>

      <div class="form-check">
        <input type="checkbox" id="remember" name="remember" class="form-check-input">
        <label class="form-check-label" for="remember">
          Remember me on this device
        </label>
      </div>

      <button type="submit" class="btn-auth"><span>Sign In</span></button>      

      <!-- Sign in with Social Networks -->
      <div class="login-dropdown">
        <button type="button" class="login-btn" id="loginToggle">
          <span>Sign in with</span>
          <span class="arrow">▾</span>
        </button>

        <div class="login-menu" id="loginMenu">
          <a href="{{ path('connect_google') }}" class="login-item google">
            <svg class="login-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Google
          </a>

          <a href="{{ path('connect_github') }}" class="login-item github">
            <svg class="login-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" fill="#333"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>




    </form>

    <div class="form-divider">
      <span>New to EL FIRMA?</span>
    </div>

    <div class="auth-footer">
      <p><a href="{{ path('app_signup') }}">Create a new account</a></p>
    </div>
  </div>

<style>
  .form-group {
    margin-bottom: 1.5rem;
  }

  .auth-form-section {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .auth-form-header,
  .form-divider,
  .auth-footer {
    width: 100%;
    max-width: 420px;
  }

  .auth-form-header {
    margin-bottom: 28px;
  }

  .auth-form-header h2 {
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.45rem;
    color: #183b2a;
  }

  .auth-form-header p {
    color: #6b7280;
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .auth-form {
    width: 100%;
    max-width: 420px;
  }

  .form-group label {
    font-weight: 600;
    color: #060606;
    margin-bottom: 0.5rem;
    display: block;
  }

  .form-control {
    width: 100%;
    border-radius: 6px;
    border: 1.5px solid #e0e0e0;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    box-sizing: border-box;
  }

  .form-control:focus {
    border-color: #116530 !important;
    box-shadow: 0 0 0 3px rgba(17, 101, 48, 0.1) !important;
    outline: none;
  }

  .form-control.is-invalid {
    border: 2px solid #dc3545 !important;
    box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.2) !important;
  }

  .form-control.is-invalid:focus {
    border: 2px solid #dc3545 !important;
    box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.3) !important;
  }

  .error-message {
    color: #dc3545;
    font-size: 0.875rem;
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    font-weight: 500;
    display: block;
  }

  small.text-muted {
    font-size: 0.8rem;
    display: block;
    margin-top: 0.3rem;
    color: #999;
  }

  .form-check {
    margin-bottom: 1.5rem;
  }

  .form-check-input {
    margin-top: 0.3rem;
  }

  .login-dropdown {
    position: relative;
    margin-top: 1rem;
  }

  .login-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    border: 1px solid rgba(17, 101, 48, 0.15);
    border-radius: 14px;
    background: linear-gradient(180deg, #ffffff 0%, #f8fbf8 100%);
    color: #183b2a;
    padding: 0.95rem 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 10px 24px rgba(17, 101, 48, 0.08);
  }

  .login-btn:hover,
  .login-btn:focus {
    border-color: rgba(17, 101, 48, 0.35);
    box-shadow: 0 14px 28px rgba(17, 101, 48, 0.12);
    outline: none;
  }

  .login-btn .arrow {
    font-size: 0.9rem;
    transition: transform 0.2s ease;
  }

  .login-dropdown.open .login-btn .arrow {
    transform: rotate(180deg);
  }

  .login-menu {
    position: absolute;
    left: 0;
    right: 0;
    top: calc(100% + 0.5rem);
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid rgba(17, 101, 48, 0.12);
    border-radius: 16px;
    box-shadow: 0 18px 36px rgba(10, 20, 15, 0.12);
    padding: 0.5rem;
    display: none;
    z-index: 20;
  }

  .login-dropdown.open .login-menu {
    display: block;
  }

  .login-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.9rem 1rem;
    border-radius: 12px;
    color: #183b2a;
    text-decoration: none;
    font-weight: 600;
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .login-item:hover {
    background: #f7faf7;
    transform: translateX(3px);
    box-shadow: 0 6px 14px rgba(17, 101, 48, 0.06);
  }

  .login-icon {
    width: 1.15rem;
    height: 1.15rem;
    flex-shrink: 0;
  }

  .login-item.google:hover {
    background: rgba(66, 133, 244, 0.08);
  }

  .login-item.github:hover {
    background: rgba(51, 51, 51, 0.08);
  }

  .btn-auth {
    width: 100%;
    border: none;
    border-radius: 14px;
    padding: 0.95rem 1rem;
    background: linear-gradient(135deg, #116530 0%, #0f4f27 100%);
    color: #fff;
    font-weight: 700;
    letter-spacing: 0.01em;
    box-shadow: 0 16px 30px rgba(17, 101, 48, 0.24);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn-auth:hover {
    transform: translateY(-1px);
    box-shadow: 0 18px 36px rgba(17, 101, 48, 0.28);
  }

  .form-divider {
    margin-top: 1.5rem;
    margin-bottom: 0.9rem;
    text-align: center;
    color: #6b7280;
  }

  .form-divider span {
    position: relative;
    display: inline-block;
    padding: 0 0.8rem;
    font-size: 0.92rem;
  }

  .auth-footer {
    text-align: center;
  }

  .auth-footer a {
    color: #116530;
    font-weight: 700;
    text-decoration: none;
  }

  .auth-footer a:hover {
    text-decoration: underline;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Get errors from the data attribute
    const errorsData = document.getElementById('errors-data');
    let formErrors = {};

    if (errorsData) {
      const errorsJson = errorsData.getAttribute('data-errors');
      if (errorsJson) {
        try {
          formErrors = JSON.parse(errorsJson);
        } catch(e) {
          console.error('Error parsing errors:', e);
        }
      }
    }

    // Only apply red styles if there are errors
    if (Object.keys(formErrors).length > 0) {
      console.log('Applying error styles for fields:', Object.keys(formErrors));

      for (const [fieldName, errorMsg] of Object.entries(formErrors)) {
        const field = document.getElementById(fieldName);
        if (field) {
          // Add red border
          field.style.borderColor = '#dc3545';
          field.style.borderWidth = '2px';
          field.style.boxShadow = '0 0 0 3px rgba(220, 53, 69, 0.2)';

          // Create error message element
          const formGroup = field.parentElement;
          let errorElement = formGroup.querySelector('.error-message');

          if (!errorElement) {
            errorElement = document.createElement('div');
            errorElement.className = 'error-message';
          }

          errorElement.textContent = errorMsg;
          errorElement.style.color = '#dc3545';
          errorElement.style.fontSize = '0.875rem';
          errorElement.style.marginTop = '0.5rem';
          errorElement.style.marginBottom = '0.5rem';
          errorElement.style.fontWeight = '500';
          errorElement.style.display = 'block';

          // Insert after field if not already there
          if (!formGroup.querySelector('.error-message')) {
            formGroup.insertBefore(errorElement, field.nextElementSibling);
          }
        }
      }
    }
  });

  // Smooth form focus animation
  const inputs = document.querySelectorAll('.form-control');
  inputs.forEach(input => {
    input.addEventListener('focus', function() {
      this.parentElement.style.transform = 'scale(1.01)';
      this.parentElement.style.transition = 'transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1)';
    });
    input.addEventListener('blur', function() {
      this.parentElement.style.transform = 'scale(1)';
    });
  });

  // Parallax effect on mouse move
  const formSection = document.querySelector('.auth-form-section');
  document.addEventListener('mousemove', function(e) {
    const x = (window.innerWidth / 2 - e.clientX) / 100;
    const y = (window.innerHeight / 2 - e.clientY) / 100;

    if (formSection) {
      formSection.style.transform = `perspective(1000px) rotateY(${x}deg) rotateX(${y}deg)`;
    }
  });

  document.addEventListener('mouseleave', function() {
    if (formSection) {
      formSection.style.transform = 'perspective(1000px) rotateY(0deg) rotateX(0deg)';
    }
  });

  const loginDropdown = document.querySelector('.login-dropdown');
  const loginToggle = document.getElementById('loginToggle');

  if (loginDropdown && loginToggle) {
    loginToggle.addEventListener('click', function(event) {
      event.stopPropagation();
      loginDropdown.classList.toggle('open');
    });

    document.addEventListener('click', function(event) {
      if (!loginDropdown.contains(event.target)) {
        loginDropdown.classList.remove('open');
      }
    });

    document.addEventListener('keydown', function(event) {
      if (event.key === 'Escape') {
        loginDropdown.classList.remove('open');
      }
    });
  }
</script>
{% endblock %}
