<!DOCTYPE html>
<html class="light" lang="fr">
<head>
    <meta charset="UTF-8">

    <title>{% block title %}Elfirma{% endblock %}</title>

    <!-- ✅ TON CSS -->
    <link href="{{ asset('styles/elfirma-theme.css') }}" rel="stylesheet"/>

    <!-- ✅ TAILWIND -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- ✅ FONTS -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet"/>

    <!-- ✅ ICONS -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet"/>

    <!-- CONFIG TAILWIND -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#0a2200",
                        secondary: "#934b19",
                        background: "#fbfbe2"
                    }
                }
            }
        }
    </script>

</head>

<body class="min-h-screen bg-white">

{% include 'elfirma/_admin_sidebar.html.twig' with { 'current_module': current_module|default('') } %}

<!-- ✅ CONTENT -->
<main class="elfirma-admin-content min-h-screen" style="margin-left: 280px;">
    {% block body %}{% endblock %}
</main>

{{ include('elfirma/_nav_routes.html.twig') }}

<!-- ✅ Sidebar Collapse Handler -->
<script>
    (function() {
        const sidebar = document.querySelector('.elfirma-premium-sidebar');
        const mainContent = document.querySelector('.elfirma-admin-content');

        if (!sidebar || !mainContent) return;

        // Restore collapsed state from localStorage
        const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
        if (isCollapsed) {
            sidebar.classList.add('collapsed');
            updateMainContentMargin();
        }

        // Update main content margin when sidebar is toggled
        function updateMainContentMargin() {
            const collapsed = sidebar.classList.contains('collapsed');
            mainContent.style.marginLeft = collapsed ? '90px' : '280px';
        }

        // Watch for sidebar class changes
        const observer = new MutationObserver(() => {
            updateMainContentMargin();
        });

        observer.observe(sidebar, { attributes: true, attributeFilter: ['class'] });
    })();
</script>

<!-- ✅ STIMULUS & CHARTS -->
{{ importmap('app') }}

</body>

</html>
