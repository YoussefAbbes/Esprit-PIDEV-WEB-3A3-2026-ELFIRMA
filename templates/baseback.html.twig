<!DOCTYPE html>
<html class="light" lang="fr">
<head>
    <meta charset="UTF-8">

    <title>{% block title %}Elfirma{% endblock %}</title>

    <!-- ✅ TON CSS -->
    <link href="{{ asset('styles/elfirma-theme.css') }}" rel="stylesheet"/>

    <!-- ✅ TAILWIND -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- ✅ FONTS -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet"/>

    <!-- ✅ ICONS -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet"/>

    <!-- CONFIG TAILWIND -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#0a2200",
                        secondary: "#934b19",
                        background: "#fbfbe2"
                    }
                }
            }
        }
    </script>

</head>

<body class="text-on-surface bg-[#fbfbe2]">

<!-- ✅ SIDEBAR (TON CODE EXACT) -->
<aside class="hidden md:flex flex-col h-screen w-72 fixed left-0 top-0 bg-[#f5f5dc] dark:bg-[#173901] py-8 pr-4 z-50">

<div class="px-8">
<h1 class="text-3xl font-black text-[#0a2200] dark:text-[#fbfbe2] mb-8 tracking-tighter">Elfirma</h1>
<p class="text-[#0a2200] dark:text-[#fbfbe2] font-semibold opacity-60 -mt-6 mb-8">Gestion Agricole</p>
</div>

<nav class="flex-1 space-y-1">

<a class="flex items-center px-8 py-3 text-[#43493d] hover:bg-[#e4e4cc] rounded-r-full" href="#">
<span class="material-symbols-outlined mr-4">dashboard</span>
<span class="font-semibold">Tableau de Bord</span>
</a>

<a class="flex items-center px-8 py-3 text-[#43493d] hover:bg-[#e4e4cc] rounded-r-full" href="#">
<span class="material-symbols-outlined mr-4">group</span>
<span class="font-semibold">Utilisateurs</span>
</a>

<a class="flex items-center px-8 py-3 text-[#43493d] hover:bg-[#e4e4cc] rounded-r-full" href="#">
<span class="material-symbols-outlined mr-4">agriculture</span>
<span class="font-semibold">Parcelles & Cultures</span>
</a>

<a class="flex items-center px-8 py-3 text-[#43493d] hover:bg-[#e4e4cc] rounded-r-full" href="#">
<span class="material-symbols-outlined mr-4">handyman</span>
<span class="font-semibold">Équipements & Maintenance</span>
</a>

</nav>

</aside>

<!-- ✅ CONTENU -->
<div class="ml-72">
    {% block body %}{% endblock %}
</div>

</body>

</html>