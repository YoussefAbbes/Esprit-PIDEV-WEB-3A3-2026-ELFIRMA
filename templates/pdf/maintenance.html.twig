<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial; }
        h1 { text-align: center; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #000; padding: 8px; text-align: center; }
        th { background-color: #eee; }
    </style>
</head>
<body>

<h1>Rapport des Maintenances</h1>

<table>
    <thead>
        <tr>
            <th>Équipement</th>
            <th>Type</th>
            <th>Date</th>
            <th>Statut</th>
            <th>Coût</th>
        </tr>
    </thead>
    <tbody>
    {% for m in maintenances %}
        <tr>
            <td>{{ m.equipement.nomEq }}</td>
            <td>{{ m.typeM }}</td>
            <td>{{ m.dateM|date('Y-m-d') }}</td>
            <td>{{ m.statut.value }}</td>
            <td>{{ m.cout }} DT</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

</body>
</html>