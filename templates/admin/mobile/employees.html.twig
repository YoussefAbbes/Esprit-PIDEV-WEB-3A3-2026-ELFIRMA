{% extends 'baseback.html.twig' %}

{% block title %}Team Members - Elfirma{% endblock %}

{% block body %}
<main class="flex-1 min-h-screen md:ml-64 bg-[#fbfbe2]">
    <header class="sticky top-0 z-30 bg-[#fbfbe2]/80 backdrop-blur-xl border-b border-[#e4e4cc] px-8 py-5 flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-black text-[#0a2200]">Team Members</h2>
            <p class="text-sm text-[#5f6658]">Keep employee profiles and NFC cards up to date.</p>
        </div>
        <nav class="flex gap-2 text-sm font-semibold">
            <a href="{{ path('admin_mobile_employees') }}" class="px-4 py-2 rounded-full bg-[#0a2200] text-white">Employees</a>
            <a href="{{ path('admin_mobile_tasks') }}" class="px-4 py-2 rounded-full bg-[#e4e4cc] text-[#0a2200]">Tasks</a>
            <a href="{{ path('admin_mobile_reports') }}" class="px-4 py-2 rounded-full bg-[#e4e4cc] text-[#0a2200]">Reports</a>
        </nav>
    </header>

    <section class="p-8 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <article class="rounded-2xl bg-gradient-to-br from-[#0a2200] to-[#43682b] text-white p-5 shadow-lg">
                <p class="text-xs uppercase tracking-[0.15em] text-white/80">Total Team Members</p>
                <p class="text-3xl font-black mt-2">{{ employees|length }}</p>
            </article>
            <article class="rounded-2xl bg-white border border-[#d9dfcb] p-5 shadow-sm">
                <p class="text-xs uppercase tracking-[0.15em] text-[#5f6658]">Profiles Ready</p>
                <p class="text-3xl font-black text-[#0a2200] mt-2">{{ profiles_by_mysql_id|length }}</p>
            </article>
        </div>

        {% for message in app.flashes('success') %}
            <div class="p-4 rounded-lg border border-green-300 bg-green-100 text-green-800">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="p-4 rounded-lg border border-red-300 bg-red-100 text-red-800">{{ message }}</div>
        {% endfor %}

        <div class="bg-white rounded-2xl shadow p-6">
            <h3 class="text-xl font-bold text-[#0a2200] mb-3">Refresh Team Profiles</h3>
            <p class="text-sm text-[#5f6658] mb-4">Update all employee profiles so the mobile team list stays accurate.</p>
            <form method="post" action="{{ path('admin_mobile_employees') }}">
                <input type="hidden" name="action" value="sync_all">
                <button type="submit" class="px-5 py-3 rounded-xl bg-[#0a2200] text-white font-semibold hover:opacity-90">Refresh Team</button>
            </form>
        </div>

        <div class="bg-white rounded-2xl shadow p-6 overflow-x-auto">
            <h3 class="text-xl font-bold text-[#0a2200] mb-4">NFC Card Enrollment</h3>
            <table class="w-full text-sm border-collapse">
                <thead>
                    <tr class="border-b border-[#e4e4cc] text-left">
                        <th class="py-3">Employee</th>
                        <th class="py-3">Email</th>
                        <th class="py-3">Profile Status</th>
                        <th class="py-3">NFC Card</th>
                        <th class="py-3">Update Card</th>
                    </tr>
                </thead>
                <tbody>
                    {% for employee in employees %}
                        {% set profile = profiles_by_mysql_id[employee.idU ~ ''] ?? null %}
                        <tr class="border-b border-[#f0f0df]">
                            <td class="py-3 font-semibold">{{ employee.prenomU }} {{ employee.nomU }}</td>
                            <td class="py-3">{{ employee.emailU }}</td>
                            <td class="py-3">
                                {% if profile is not null %}
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700">Ready</span>
                                {% else %}
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-700">Pending</span>
                                {% endif %}
                            </td>
                            <td class="py-3">{{ profile is not null and profile.nfc_uid is defined and profile.nfc_uid ? profile.nfc_uid : 'Not assigned' }}</td>
                            <td class="py-3">
                                <form method="post" action="{{ path('admin_mobile_employees') }}" class="flex gap-2 items-center">
                                    <input type="hidden" name="action" value="enroll_nfc">
                                    <input type="hidden" name="user_id" value="{{ employee.idU }}">
                                    <input
                                        name="nfc_uid"
                                        type="text"
                                        required
                                        placeholder="Enter NFC card code"
                                        class="w-64 px-3 py-2 border border-[#c3c9b9] rounded-lg"
                                    >
                                    <button type="submit" class="px-4 py-2 rounded-lg bg-[#43682b] text-white font-semibold">Save NFC</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="py-6 text-center text-[#5f6658]">No employees found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
</main>
{% endblock %}
