{% extends 'base.html.twig' %}

{% block title %}Our Suppliers - EL FIRMA{% endblock %}
{% block meta_description %}Browse and rate our trusted suppliers{% endblock %}
{% block meta_keywords %}suppliers, agriculture, ratings{% endblock %}
{% block body_class %}suppliers-page{% endblock %}

{% block body %}
<!-- Notification Container -->
<div id="notification-container" style="position: fixed; top: 20px; right: 20px; z-index: 9999; max-width: 400px;"></div>

<!-- Page Title -->
<div class="page-title dark-background" data-aos="fade" style="background-image: url({{ asset('assets/img/page-title-bg.webp') }});">
  <div class="container position-relative">
    <h1>Our Suppliers</h1>
    <p>Home / Suppliers</p>
    <nav class="breadcrumbs">
      <ol>
        <li><a href="{{ path('app_home') }}">Home</a></li>
        <li class="current">Suppliers</li>
      </ol>
    </nav>
  </div>
</div>

<!-- Suppliers Section -->
<section id="suppliers" class="suppliers-section">
  <div class="container">
    <div class="section-header" data-aos="fade-up">
      <h2 class="section-title">Trusted Supplier Network</h2>
      <p class="section-subtitle">Discover quality suppliers. Rate and review to help us maintain excellence</p>
      <div class="header-divider"></div>
    </div>

    <div class="suppliers-grid" data-aos="fade-up" data-aos-delay="100">
      {% if suppliers %}
        {% for supplier in suppliers %}
          <div class="supplier-card" data-supplier-id="{{ supplier.idF }}" onclick="openSupplierModal({{ supplier.idF }})">
            <div class="card-content">
              <!-- Top Section with Status Badge -->
              <div class="card-top">
                <span class="status-badge {% if supplier.statutF == 'Active' %}active{% elseif supplier.statutF == 'Inactive' %}inactive{% else %}suspended{% endif %}">
                  {{ supplier.statutF }}
                </span>
              </div>

              <!-- Main Content -->
              <div class="card-main">
                <h3 class="supplier-name">{{ supplier.typeF }}</h3>
                <p class="supplier-description">{{ supplier.descriptionF|slice(0, 85) }}{% if supplier.descriptionF|length > 85 %}...{% endif %}</p>

                <!-- Rating Display -->
                <div class="supplier-rating" id="rating-{{ supplier.idF }}">
                  <div class="stars-container">
                    <span class="stars">★★★★★</span>
                    <span class="rating-value">0.0</span>
                  </div>
                  <span class="rating-count">(0 reviews)</span>
                </div>

                <!-- Contact Info -->
                <div class="contact-info">
                  <div class="info-item">
                    <i class="bi bi-envelope"></i>
                    <span>{{ supplier.emailF }}</span>
                  </div>
                  <div class="info-item">
                    <i class="bi bi-telephone"></i>
                    <span>{{ supplier.telF }}</span>
                  </div>
                </div>
              </div>

              <!-- Button -->
              <button class="view-btn" onclick="openSupplierModal({{ supplier.idF }})">
                View & Rate <i class="bi bi-arrow-right"></i>
              </button>
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div class="no-suppliers">
          <p>No suppliers available at this moment.</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<!-- Supplier Details Modal -->
<div class="modal fade" id="supplierModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content modern-modal">
      <div class="modal-header modern-header">
        <h5 class="modal-title" id="supplierModalLabel">Supplier Details</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body modern-body">
        <div id="supplier-details">
          <div class="supplier-header">
            <h2 id="modal-supplier-name" class="modal-supplier-title"></h2>
            <span id="modal-supplier-status" class="status-badge"></span>
          </div>

          <div class="supplier-info-grid">
            <div class="info-card">
              <label>Email</label>
              <p id="modal-supplier-email"></p>
            </div>
            <div class="info-card">
              <label>Phone</label>
              <p id="modal-supplier-phone"></p>
            </div>
            <div class="info-card full-width">
              <label>Address</label>
              <p id="modal-supplier-address"></p>
            </div>
          </div>

          <div class="description-section">
            <h4>About</h4>
            <p id="modal-supplier-description"></p>
          </div>

          <div class="ratings-section">
            <div class="ratings-header">
              <h4>Customer Reviews</h4>
              <div class="rating-stats">
                <div class="stat-item">
                  <span class="stat-value" id="modal-average-rating">0</span>
                  <span class="stat-label">Rating</span>
                </div>
                <div class="stat-item">
                  <span class="stat-value" id="modal-rating-count">0</span>
                  <span class="stat-label">Reviews</span>
                </div>
              </div>
            </div>

            <div class="average-rating-display">
              <div class="stars-large" id="modal-rating-stars">★★★★★</div>
            </div>

            <!-- Ratings List -->
            <div id="ratings-list" class="ratings-list">
              <p class="loading-text">Loading reviews...</p>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer modern-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-primary" id="add-rating-btn" data-supplier-id="">
          <i class="bi bi-star"></i> Add Review
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Add Rating Modal -->
<div class="modal fade" id="addRatingModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content modern-modal">
      <div class="modal-header modern-header">
        <h5 class="modal-title">Share Your Experience</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body modern-body">
        <form id="rating-form">
          <div class="rating-input-group">
            <label class="form-label">Your Rating</label>
            <div class="star-rating-picker" id="rating-stars">
              {% for i in 1..5 %}
                <span class="star-picker" data-value="{{ i }}">★</span>
              {% endfor %}
            </div>
            <input type="hidden" id="selected-stars" name="stars" value="5">
            <small id="stars-error" class="error-text d-none">Please select a rating</small>
          </div>

          <div class="mb-4">
            <label for="rating-comment" class="form-label">Your Review</label>
            <textarea class="form-control modern-textarea" id="rating-comment" name="comment" rows="5" placeholder="Share your honest feedback about this supplier..." maxlength="1000"></textarea>
            <div class="char-counter">
              <span id="char-count">0</span> / 1000
            </div>
            <small id="comment-error" class="error-text d-none">Please add a review</small>
          </div>

          <input type="hidden" id="supplier-id-input" name="supplier_id" value="">
          <input type="hidden" id="user-id-input" name="user_id" value="">
        </form>
      </div>
      <div class="modal-footer modern-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="submit-rating-btn">
          <i class="bi bi-check-circle"></i> Submit Review
        </button>
      </div>
    </div>
  </div>
</div>

<style>
