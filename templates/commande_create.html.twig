{% extends 'base.html.twig' %}

{% block title %}Créer une commande - EL FIRMA{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .stripe-zone { display: none; margin-top: 12px; border-radius: 14px; border: 1px solid #d1fae5; background: linear-gradient(145deg, #ecfdf5 0%, #f0fdf4 55%, #dcfce7 100%); padding: 18px; }
        .stripe-zone.active { display: block; animation: fadeInStripe 260ms ease-out; }
        .pay-card-preview { position: relative; border-radius: 16px; padding: 20px; color: #ecfeff; background: radial-gradient(circle at 15% 15%, rgba(16,185,129,.4), transparent 45%), linear-gradient(135deg, #052e16 0%, #064e3b 45%, #065f46 100%); box-shadow: 0 14px 26px rgba(6,95,70,.28); overflow: hidden; min-height: 170px; transform-style: preserve-3d; transition: transform .28s ease, box-shadow .28s ease; }
        .pay-card-preview::after { content: ''; position: absolute; top: -40%; right: -10%; width: 180px; height: 180px; background: rgba(255,255,255,.08); border-radius: 50%; }
        .pay-card-preview:hover { transform: translateY(-2px) rotateX(2deg); box-shadow: 0 20px 34px rgba(6,95,70,.35); }
        .pay-chip { width: 44px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, #fde68a 0%, #f59e0b 100%); margin-bottom: 18px; }
        .pay-card-number { letter-spacing: 2px; font-size: 20px; font-weight: 700; margin-bottom: 14px; }
        .pay-card-row { display: flex; justify-content: space-between; gap: 10px; font-size: 12px; text-transform: uppercase; opacity: .92; }
        .stripe-element-wrap { margin-top: 14px; border: 2px solid #bbf7d0; background: #fff; border-radius: 10px; padding: 12px; transition: border-color .2s ease, box-shadow .2s ease; }
        .stripe-element-wrap.focused { border-color: #16a34a; box-shadow: 0 0 0 3px rgba(34,197,94,.2); }
        @keyframes fadeInStripe { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
    </style>
{% endblock %}

{% block body %}
{% set formErrors = form_errors|default({}) %}
{% set oldInput = old|default({}) %}
<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8">
            <div style="background: white; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); overflow: hidden;">
                <div style="background: linear-gradient(135deg, #2d5016 0%, #1e3a0f 100%); padding: 25px; color: white;">
                    <h2 style="margin: 0; display: flex; align-items: center; gap: 15px;">
                        <span class="material-symbols-outlined" style="font-size: 32px;">shopping_bag</span>
                        Finaliser votre commande
                    </h2>
                </div>

                <form method="POST" id="checkoutForm" style="padding: 30px;">
                    <input type="hidden" id="stripe_payment_intent_id" name="stripe_payment_intent_id" value="{{ oldInput.stripe_payment_intent_id|default('') }}">
                    {% if formErrors._global is defined %}
                        <div class="alert alert-danger" role="alert" style="margin-bottom: 20px;">
                            {% for err in formErrors._global %}
                                <div>{{ err }}</div>
                            {% endfor %}
                        </div>
                    {% endif %}
                    <!-- Informations client -->
                    <div style="margin-bottom: 30px;">
                        <h4 style="color: #2d5016; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                            <span class="material-symbols-outlined">person</span>
                            Informations client
                        </h4>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="nom_client" style="font-weight: 600; color: #374151; margin-bottom: 8px;">Nom complet *</label>
                                <input type="text" id="nom_client" name="nom_client" value="{{ oldInput.nom_client|default('') }}"
                                       style="width: 100%; padding: 12px 15px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 16px;">
                                {% if formErrors.nom_client is defined %}
                                    {% for err in formErrors.nom_client %}
                                        <div style="color: #dc2626; font-size: 13px; margin-top: 6px;">{{ err }}</div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="mode_paiement" style="font-weight: 600; color: #374151; margin-bottom: 8px;">Mode de paiement *</label>
                                <select id="mode_paiement" name="mode_paiement" 
                                        style="width: 100%; padding: 12px 15px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 16px;">
                                    <option value="Cash" {% if oldInput.mode_paiement|default('Cash') == 'Cash' %}selected{% endif %}>Cash (à la livraison)</option>
                                    <option value="Carte bancaire" {% if oldInput.mode_paiement|default('Cash') == 'Carte bancaire' %}selected{% endif %}>Carte bancaire</option>
                                    <option value="Virement" {% if oldInput.mode_paiement|default('Cash') == 'Virement' %}selected{% endif %}>Virement bancaire</option>
                                </select>
                                {% if formErrors.mode_paiement is defined %}
                                    {% for err in formErrors.mode_paiement %}
                                        <div style="color: #dc2626; font-size: 13px; margin-top: 6px;">{{ err }}</div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            <div class="col-12 mb-3">
                                <div id="stripe-zone" class="stripe-zone {% if oldInput.mode_paiement|default('Cash') == 'Carte bancaire' %}active{% endif %}">
                                    <div class="pay-card-preview" id="pay-card-preview">
                                        <div class="pay-chip"></div>
                                        <div class="pay-card-number" id="card-preview-number">•••• •••• •••• ••••</div>
                                        <div class="pay-card-row">
                                            <div>
                                                <div>Nom porteur</div>
                                                <div id="card-preview-name" style="font-size: 15px; font-weight: 700; margin-top: 3px;">{{ oldInput.nom_client|default('Votre nom') }}</div>
                                            </div>
                                            <div style="text-align: right;">
                                                <div>Réseau</div>
                                                <div style="font-size: 16px; font-weight: 700; margin-top: 3px;">Stripe</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div style="margin-top: 14px; display: grid; gap: 10px;">
                                        <div>
                                            <label for="stripe_card_holder" style="font-weight: 600; color: #14532d; margin-bottom: 6px; display: block;">Nom du porteur de carte</label>
                                            <input type="text" id="stripe_card_holder" value="{{ oldInput.nom_client|default('') }}" placeholder="Nom et prénom"
                                                   style="width: 100%; padding: 10px 12px; border: 2px solid #bbf7d0; border-radius: 8px; font-size: 15px;">
                                        </div>
                                        <div>
                                            <label style="font-weight: 600; color: #14532d; margin-bottom: 6px; display: block;">Informations carte</label>
                                            <div id="stripe-element-wrap" class="stripe-element-wrap">
                                                <div id="stripe-card-element"></div>
                                            </div>
                                        </div>
                                        {% if not stripe_enabled %}
                                            <div style="color: #dc2626; font-size: 13px;">Paiement carte indisponible: configurez les cles Stripe (STRIPE_PUBLIC_KEY et STRIPE_SECRET_KEY).</div>
                                        {% endif %}
                                        <div id="stripe-client-error" style="display: none; color: #dc2626; font-size: 13px;"></div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 mb-3" style="background: #fffbeb; border: 1px solid #fde68a; border-radius: 10px; padding: 15px;">
                                <p style="margin: 0 0 10px 0; font-weight: 700; color: #92400e;">Code promo (valable 3 jours)</p>
                                <p style="margin: 0 0 12px 0; color: #78350f; font-size: 14px;">Génération disponible pour un panier à partir de {{ promo_min_total|number_format(0, '.', ' ') }} DT.</p>
                                <div style="display: flex; flex-wrap: wrap; gap: 10px; align-items: center;">
                                    <input type="text" id="promo_code" name="promo_code" value="{{ oldInput.promo_code|default('') }}" placeholder="Entrez votre code promo"
                                           style="flex: 1; min-width: 220px; padding: 10px 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 15px;">
                                    <button type="submit" name="checkout_action" value="generate_promo"
                                            style="background: #92400e; color: white; border: none; padding: 10px 14px; border-radius: 8px; font-weight: 600; cursor: pointer;">
                                        Générer code
                                    </button>
                                    <button type="submit" name="checkout_action" value="apply_promo"
                                            style="background: #b45309; color: white; border: none; padding: 10px 14px; border-radius: 8px; font-weight: 600; cursor: pointer;">
                                        Appliquer code
                                    </button>
                                </div>
                                {% if promo_generated_code %}
                                    <p style="margin: 10px 0 0 0; font-size: 14px; color: #065f46;">
                                        Code généré: <strong>{{ promo_generated_code }}</strong>
                                        {% if promo_expires_at %}
                                            (expire le {{ promo_expires_at|date('d/m/Y H:i') }})
                                        {% endif %}
                                    </p>
                                {% endif %}
                                {% if promo_is_applied %}
                                    <p style="margin: 8px 0 0 0; font-size: 14px; color: #166534; font-weight: 700;">
                                        Code promo appliqué: réduction de {{ promo_percent }}%
                                    </p>
                                {% endif %}
                                {% if formErrors.promo_code is defined %}
                                    {% for err in formErrors.promo_code %}
                                        <div style="color: #dc2626; font-size: 13px; margin-top: 6px;">{{ err }}</div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            <div class="col-12 mb-3" style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 10px; padding: 15px;">
                                <p style="margin: 0 0 10px 0; font-weight: 700; color: #2d5016;">Champs remplis automatiquement</p>
                                <ul style="margin: 0; padding-left: 18px; color: #4b5563; font-size: 14px;">
                                    <li>Date de commande: maintenant</li>
                                    <li>Statut commande: En attente</li>
                                    <li>Statut paiement: Non payé</li>
                                    <li>Prix total: calculé depuis le panier</li>
                                    <li>Produit et quantité: récupérés depuis le panier</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Récapitulatif de la commande -->
                    <div style="margin-bottom: 30px;">
                        <h4 style="color: #2d5016; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                            <span class="material-symbols-outlined">receipt</span>
                            Récapitulatif de votre commande
                        </h4>
                        
                        <div style="background: #f9fafb; border-radius: 10px; padding: 20px;">
                            {% for item in items %}
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px 0; {% if not loop.last %}border-bottom: 1px solid #e5e7eb;{% endif %}">
                                <div style="display: flex; align-items: center; gap: 15px;">
                                    <div style="width: 60px; height: 60px; border-radius: 8px; overflow: hidden; background: linear-gradient(135deg, #2d5016 0%, #1e3a0f 100%);">
                                        {% if item.produit.image %}
                                            <img src="{{ asset('uploads/produits/' ~ item.produit.image) }}" alt="{{ item.produit.nom }}" style="width: 100%; height: 100%; object-fit: cover;">
                                        {% else %}
                                            <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                                                <span class="material-symbols-outlined" style="color: rgba(255,255,255,0.5); font-size: 24px;">package_2</span>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div>
                                        <h6 style="margin: 0 0 5px 0; font-weight: 700;">{{ item.produit.nom }}</h6>
                                        <p style="margin: 0; font-size: 14px; color: #6b7280;">{{ item.produit.prixUnitaire }} DT x {{ item.quantite }}</p>
                                    </div>
                                </div>
                                <div style="text-align: right;">
                                    <span style="font-size: 18px; font-weight: 700; color: #16a34a;">{{ item.subtotal }} DT</span>
                                </div>
                            </div>
                            {% endfor %}
                            
                            <div style="border-top: 2px solid #e5e7eb; margin-top: 20px; padding-top: 20px;">
                                {% if promo_discount|default(0) > 0 %}
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                        <span style="font-size: 16px; font-weight: 600; color: #92400e;">Réduction promo ({{ promo_percent }}%) :</span>
                                        <span style="font-size: 18px; font-weight: 700; color: #b45309;">-{{ promo_discount|number_format(2, '.', ' ') }} DT</span>
                                    </div>
                                {% endif %}
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="font-size: 20px; font-weight: 700; color: #2d5016;">Total à payer:</span>
                                    <span style="font-size: 24px; font-weight: 900; color: #16a34a;">{{ final_total|default(total)|number_format(2, '.', ' ') }} DT</span>
                                </div>
                                {% if promo_discount|default(0) > 0 %}
                                    <div style="text-align: right; margin-top: 4px; color: #6b7280; font-size: 13px;">Sous-total avant réduction: {{ total|number_format(2, '.', ' ') }} DT</div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <!-- Boutons d'action -->
                    <div style="display: flex; gap: 15px; justify-content: space-between;">
                        <a href="{{ path('app_panier_index') }}" style="background: #6b7280; color: white; padding: 15px 30px; border-radius: 10px; text-decoration: none; font-weight: 600;">
                            Retour au panier
                        </a>
                        <button type="submit" id="confirm-order-btn" name="checkout_action" value="confirm_order" style="background: linear-gradient(135deg, #16a34a 0%, #15803d 100%); color: white; border: none; padding: 15px 30px; border-radius: 10px; font-weight: 700; cursor: pointer; flex: 1; max-width: 300px;">
                            Confirmer la commande
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-4">
            <div style="background: white; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); overflow: hidden; position: sticky; top: 20px;">
                <div style="background: linear-gradient(135deg, #16a34a 0%, #15803d 100%); padding: 25px; color: white;">
                    <h4 style="margin: 0; display: flex; align-items: center; gap: 10px;">
                        <span class="material-symbols-outlined">info</span>
                        Informations importantes
                    </h4>
                </div>

                <div style="padding: 30px;">
                    <div style="margin-bottom: 20px;">
                        <h6 style="color: #2d5016; font-weight: 700; margin-bottom: 10px;">
                            <span class="material-symbols-outlined" style="font-size: 18px; vertical-align: middle;">local_shipping</span>
                            Livraison
                        </h6>
                        <p style="font-size: 14px; color: #6b7280; margin: 0;">
                            Livraison gratuite pour toute commande. Délai de livraison : 2-3 jours ouvrables.
                        </p>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <h6 style="color: #2d5016; font-weight: 700; margin-bottom: 10px;">
                            <span class="material-symbols-outlined" style="font-size: 18px; vertical-align: middle;">payment</span>
                            Paiement
                        </h6>
                        <p style="font-size: 14px; color: #6b7280; margin: 0;">
                            Paiement sécurisé. Possibilité de payer à la livraison ou par virement.
                        </p>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <h6 style="color: #2d5016; font-weight: 700; margin-bottom: 10px;">
                            <span class="material-symbols-outlined" style="font-size: 18px; vertical-align: middle;">support_agent</span>
                            Support
                        </h6>
                        <p style="font-size: 14px; color: #6b7280; margin: 0;">
                            Notre équipe est disponible pour vous aider. Contactez-nous en cas de besoin.
                        </p>
                    </div>

                    <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 15px;">
                        <p style="font-size: 12px; color: #166534; margin: 0; text-align: center;">
                            <span class="material-symbols-outlined" style="font-size: 16px; vertical-align: middle;">verified</span>
                            Commande sécurisée et garantie
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="position: fixed; top: 20px; right: 20px; z-index: 9999;">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{% for message in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="position: fixed; top: 20px; right: 20px; z-index: 9999;">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://js.stripe.com/v3/"></script>
    <script>
        (function () {
            const modeSelect = document.getElementById('mode_paiement');
            const stripeZone = document.getElementById('stripe-zone');
            const checkoutForm = document.getElementById('checkoutForm');
            const confirmButton = document.getElementById('confirm-order-btn');
            const stripeErrorEl = document.getElementById('stripe-client-error');
            const stripeIntentInput = document.getElementById('stripe_payment_intent_id');
            const cardHolderInput = document.getElementById('stripe_card_holder');
            const nameInput = document.getElementById('nom_client');
            const cardPreviewName = document.getElementById('card-preview-name');
            const cardPreviewNumber = document.getElementById('card-preview-number');
            const elementWrap = document.getElementById('stripe-element-wrap');
            const stripeEnabled = {{ stripe_enabled ? 'true' : 'false' }};
            const stripePublicKey = '{{ stripe_public_key|e('js') }}';
            let stripe = null;
            let cardElement = null;
            let stripeValidated = false;

            function showStripeError(message) {
                if (!stripeErrorEl) return;
                stripeErrorEl.style.display = 'block';
                stripeErrorEl.textContent = message;
            }

            function clearStripeError() {
                if (!stripeErrorEl) return;
                stripeErrorEl.style.display = 'none';
                stripeErrorEl.textContent = '';
            }

            function refreshCardName() {
                if (!cardPreviewName) return;
                const value = (cardHolderInput && cardHolderInput.value.trim() !== '')
                    ? cardHolderInput.value.trim()
                    : ((nameInput && nameInput.value.trim() !== '') ? nameInput.value.trim() : 'Votre nom');
                cardPreviewName.textContent = value;
            }

            function refreshStripeVisibility() {
                if (!modeSelect || !stripeZone) return;
                const isCard = modeSelect.value === 'Carte bancaire';
                stripeZone.classList.toggle('active', isCard);
                if (!isCard) {
                    clearStripeError();
                }
            }

            function initStripe() {
                if (!stripeEnabled || !stripePublicKey || typeof Stripe === 'undefined') {
                    return;
                }
                stripe = Stripe(stripePublicKey);
                const elements = stripe.elements();
                cardElement = elements.create('card', {
                    style: {
                        base: {
                            color: '#111827',
                            fontSize: '16px',
                            fontFamily: 'Open Sans, sans-serif',
                            '::placeholder': { color: '#6b7280' }
                        },
                        invalid: { color: '#dc2626' }
                    }
                });

                cardElement.mount('#stripe-card-element');

                cardElement.on('focus', function () {
                    if (elementWrap) elementWrap.classList.add('focused');
                });
                cardElement.on('blur', function () {
                    if (elementWrap) elementWrap.classList.remove('focused');
                });
                cardElement.on('change', function (event) {
                    clearStripeError();
                    cardPreviewNumber.textContent = event.empty ? '•••• •••• •••• ••••' : '•••• •••• •••• ' + (event.brand ? event.brand.toUpperCase().slice(0, 4) : 'CARD');
                    if (event.error) {
                        showStripeError(event.error.message);
                    }
                });
            }

            async function createPaymentIntent() {
                const promoCode = document.getElementById('promo_code');
                const body = new URLSearchParams();
                body.set('promo_code', promoCode ? promoCode.value : '');
                const response = await fetch('{{ path('app_commande_stripe_create_intent') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                    },
                    body: body.toString()
                });

                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Erreur de creation du paiement Stripe.');
                }

                return data;
            }

            if (modeSelect) {
                modeSelect.addEventListener('change', refreshStripeVisibility);
            }

            if (cardHolderInput) {
                cardHolderInput.addEventListener('input', refreshCardName);
            }

            if (nameInput) {
                nameInput.addEventListener('input', refreshCardName);
            }

            refreshCardName();
            refreshStripeVisibility();
            initStripe();

            if (checkoutForm && confirmButton) {
                checkoutForm.addEventListener('submit', async function (event) {
                    const submitter = event.submitter;
                    const isConfirmAction = submitter && submitter.name === 'checkout_action' && submitter.value === 'confirm_order';

                    if (!isConfirmAction) {
                        return;
                    }

                    const isCardPayment = modeSelect && modeSelect.value === 'Carte bancaire';
                    if (!isCardPayment) {
                        stripeValidated = false;
                        stripeIntentInput.value = '';
                        return;
                    }

                    if (stripeValidated) {
                        return;
                    }

                    event.preventDefault();
                    clearStripeError();

                    if (!stripeEnabled) {
                        showStripeError('Paiement carte indisponible pour le moment.');
                        return;
                    }

                    if (!stripe || !cardElement) {
                        showStripeError('Stripe n\'est pas pret. Rechargez la page.');
                        return;
                    }

                    submitter.disabled = true;
                    submitter.textContent = 'Paiement en cours...';

                    try {
                        const intentData = await createPaymentIntent();
                        const holderName = (cardHolderInput && cardHolderInput.value.trim() !== '')
                            ? cardHolderInput.value.trim()
                            : (nameInput ? nameInput.value.trim() : '');

                        const result = await stripe.confirmCardPayment(intentData.clientSecret, {
                            payment_method: {
                                card: cardElement,
                                billing_details: {
                                    name: holderName
                                }
                            }
                        });

                        if (result.error) {
                            throw new Error(result.error.message || 'Paiement refuse.');
                        }

                        if (!result.paymentIntent || result.paymentIntent.status !== 'succeeded') {
                            throw new Error('Paiement carte non confirme.');
                        }

                        stripeIntentInput.value = result.paymentIntent.id;
                        stripeValidated = true;
                        submitter.textContent = 'Validation...';
                        submitter.disabled = false;
                        checkoutForm.requestSubmit(submitter);
                    } catch (err) {
                        showStripeError(err.message || 'Erreur lors du paiement carte.');
                        submitter.disabled = false;
                        submitter.textContent = 'Confirmer la commande';
                    }
                });
            }
        })();
    </script>
{% endblock %}