{% extends 'base.html.twig' %}

{% block title %}Create Order - EL FIRMA{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <style>
        .stripe-zone { display: none; margin-top: 12px; border-radius: 14px; border: 1px solid #d1fae5; background: linear-gradient(145deg, #ecfdf5 0%, #f0fdf4 55%, #dcfce7 100%); padding: 18px; }
        .stripe-zone.active { display: block; animation: fadeInStripe 260ms ease-out; }
        .pay-card-preview { position: relative; border-radius: 16px; padding: 20px; color: #ecfeff; background: radial-gradient(circle at 15% 15%, rgba(16,185,129,.4), transparent 45%), linear-gradient(135deg, #052e16 0%, #064e3b 45%, #065f46 100%); box-shadow: 0 14px 26px rgba(6,95,70,.28); overflow: hidden; min-height: 170px; transform-style: preserve-3d; transition: transform .28s ease, box-shadow .28s ease; }
        .pay-card-preview::after { content: ''; position: absolute; top: -40%; right: -10%; width: 180px; height: 180px; background: rgba(255,255,255,.08); border-radius: 50%; }
        .pay-card-preview:hover { transform: translateY(-2px) rotateX(2deg); box-shadow: 0 20px 34px rgba(6,95,70,.35); }
        .pay-chip { width: 44px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, #fde68a 0%, #f59e0b 100%); margin-bottom: 18px; }
        .pay-card-number { letter-spacing: 2px; font-size: 20px; font-weight: 700; margin-bottom: 14px; }
        .pay-card-row { display: flex; justify-content: space-between; gap: 10px; font-size: 12px; text-transform: uppercase; opacity: .92; }
        .stripe-element-wrap { margin-top: 14px; border: 2px solid #bbf7d0; background: #fff; border-radius: 10px; padding: 12px; transition: border-color .2s ease, box-shadow .2s ease; }
        .stripe-element-wrap.focused { border-color: #16a34a; box-shadow: 0 0 0 3px rgba(34,197,94,.2); }
        .assist-fab { position: fixed; right: 22px; bottom: 22px; z-index: 1100; width: 58px; height: 58px; border-radius: 50%; border: none; background: linear-gradient(135deg, #0f766e 0%, #0ea5a4 100%); color: #fff; box-shadow: 0 12px 22px rgba(15,118,110,.35); display: inline-flex; align-items: center; justify-content: center; cursor: pointer; }
        .assist-panel { position: fixed; right: 22px; bottom: 92px; width: min(92vw, 380px); max-height: 68vh; z-index: 1100; border-radius: 16px; overflow: hidden; box-shadow: 0 18px 38px rgba(15,23,42,.2); background: #fff; border: 1px solid #ccfbf1; transform: translateY(10px); opacity: 0; pointer-events: none; transition: .22s ease; }
        .assist-panel.active { transform: translateY(0); opacity: 1; pointer-events: auto; }
        .assist-head { padding: 14px 16px; background: linear-gradient(135deg, #0f766e 0%, #0d9488 100%); color: #f0fdfa; display: flex; justify-content: space-between; align-items: center; }
        .assist-body { padding: 12px; background: linear-gradient(180deg, #f8fafc 0%, #ecfeff 100%); height: 320px; overflow-y: auto; }
        .assist-msg { margin-bottom: 10px; display: flex; }
        .assist-msg .bubble { max-width: 86%; padding: 9px 11px; border-radius: 11px; font-size: 14px; line-height: 1.35; }
        .assist-msg.bot { justify-content: flex-start; }
        .assist-msg.bot .bubble { background: #fff; border: 1px solid #bae6fd; color: #0f172a; }
        .assist-msg.user { justify-content: flex-end; }
        .assist-msg.user .bubble { background: #0d9488; color: #fff; }
        .assist-quick { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 6px; }
        .assist-quick button { border: 1px solid #99f6e4; background: #f0fdfa; color: #134e4a; border-radius: 999px; padding: 5px 10px; font-size: 12px; }
        .assist-input { border-top: 1px solid #ccfbf1; padding: 10px; background: #fff; display: flex; gap: 8px; }
        .assist-input input { flex: 1; border: 1px solid #99f6e4; border-radius: 8px; padding: 9px 10px; font-size: 14px; }
        .assist-input button { border: none; background: #0f766e; color: #fff; border-radius: 8px; padding: 9px 12px; font-weight: 700; }
        .delivery-map-box { margin-top: 10px; border: 2px solid #e5e7eb; border-radius: 10px; overflow: hidden; background: #fff; }
        .delivery-map-head { padding: 8px 10px; display: flex; justify-content: space-between; align-items: center; gap: 10px; border-bottom: 1px solid #e5e7eb; }
        .delivery-map-head button { border: 1px solid #bbf7d0; background: #f0fdf4; color: #166534; border-radius: 7px; font-size: 12px; padding: 5px 8px; font-weight: 700; }
        #delivery-map { height: 240px; width: 100%; }
        #delivery-map-status { font-size: 12px; color: #6b7280; }
        @keyframes fadeInStripe { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
    </style>
{% endblock %}

{% block body %}
{% set formErrors = form_errors|default({}) %}
{% set oldInput = old|default({}) %}
<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8">
            <div style="background: white; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); overflow: hidden;">
                <div style="background: linear-gradient(135deg, #2d5016 0%, #1e3a0f 100%); padding: 25px; color: white;">
                    <h2 style="margin: 0; display: flex; align-items: center; gap: 15px;">
                        <span class="material-symbols-outlined" style="font-size: 32px;">shopping_bag</span>
                        Complete your order
                    </h2>
                </div>

                <form method="POST" id="checkoutForm" style="padding: 30px;">
                    <input type="hidden" id="stripe_payment_intent_id" name="stripe_payment_intent_id" value="{{ oldInput.stripe_payment_intent_id|default('') }}">
                    {% if formErrors._global is defined %}
                        <div class="alert alert-danger" role="alert" style="margin-bottom: 20px;">
                            {% for err in formErrors._global %}
                                <div>{{ err }}</div>
                            {% endfor %}
                        </div>
                    {% endif %}
                    <!-- Customer information -->
                    <div style="margin-bottom: 30px;">
                        <h4 style="color: #2d5016; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                            <span class="material-symbols-outlined">person</span>
                            Customer information
                        </h4>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="nom_client" style="font-weight: 600; color: #374151; margin-bottom: 8px;">Full name *</label>
                                <input type="text" id="nom_client" name="nom_client" value="{{ oldInput.nom_client|default('') }}"
                                       style="width: 100%; padding: 12px 15px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 16px;">
                                {% if formErrors.nom_client is defined %}
                                    {% for err in formErrors.nom_client %}
                                        <div style="color: #dc2626; font-size: 13px; margin-top: 6px;">{{ err }}</div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="adresse_livraison" style="font-weight: 600; color: #374151; margin-bottom: 8px;">Delivery address *</label>
                                <textarea id="adresse_livraison" name="adresse_livraison" rows="2"
                                          style="width: 100%; padding: 12px 15px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 16px; resize: vertical;">{{ oldInput.adresse_livraison|default('') }}</textarea>
                                <div class="delivery-map-box">
                                    <div class="delivery-map-head">
                                        <span style="font-size: 12px; font-weight: 700; color: #1f2937;">Choose on map (click to fill the address)</span>
                                        <button id="use-current-location" type="button">My location</button>
                                    </div>
                                    <div id="delivery-map"></div>
                                    <div id="delivery-map-status" style="padding: 8px 10px;">Tip: you can type manually or click on the map.</div>
                                </div>
                                {% if formErrors.adresse_livraison is defined %}
                                    {% for err in formErrors.adresse_livraison %}
                                        <div style="color: #dc2626; font-size: 13px; margin-top: 6px;">{{ err }}</div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="mode_paiement" style="font-weight: 600; color: #374151; margin-bottom: 8px;">Payment method *</label>
                                <select id="mode_paiement" name="mode_paiement" 
                                        style="width: 100%; padding: 12px 15px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 16px;">
                                    <option value="Cash" {% if oldInput.mode_paiement|default('Cash') == 'Cash' %}selected{% endif %}>Cash (on delivery)</option>
                                    <option value="Carte bancaire" {% if oldInput.mode_paiement|default('Cash') == 'Carte bancaire' %}selected{% endif %}>Credit card</option>
                                    <option value="Virement" {% if oldInput.mode_paiement|default('Cash') == 'Virement' %}selected{% endif %}>Bank transfer</option>
                                </select>
                                {% if formErrors.mode_paiement is defined %}
                                    {% for err in formErrors.mode_paiement %}
                                        <div style="color: #dc2626; font-size: 13px; margin-top: 6px;">{{ err }}</div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            <div class="col-12 mb-3">
                                <div id="stripe-zone" class="stripe-zone {% if oldInput.mode_paiement|default('Cash') == 'Carte bancaire' %}active{% endif %}">
                                    <div class="pay-card-preview" id="pay-card-preview">
                                        <div class="pay-chip"></div>
                                        <div class="pay-card-number" id="card-preview-number">•••• •••• •••• ••••</div>
                                        <div class="pay-card-row">
                                            <div>
                                                <div>Card holder</div>
                                                <div id="card-preview-name" style="font-size: 15px; font-weight: 700; margin-top: 3px;">{{ oldInput.nom_client|default('Votre nom') }}</div>
                                            </div>
                                            <div style="text-align: right;">
                                                <div>Network</div>
                                                <div style="font-size: 16px; font-weight: 700; margin-top: 3px;">Stripe</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div style="margin-top: 14px; display: grid; gap: 10px;">
                                        <div>
                                            <label for="stripe_card_holder" style="font-weight: 600; color: #14532d; margin-bottom: 6px; display: block;">Card holder name</label>
                                            <input type="text" id="stripe_card_holder" value="{{ oldInput.nom_client|default('') }}" placeholder="Full name"
                                                   style="width: 100%; padding: 10px 12px; border: 2px solid #bbf7d0; border-radius: 8px; font-size: 15px;">
                                        </div>
                                        <div>
                                            <label style="font-weight: 600; color: #14532d; margin-bottom: 6px; display: block;">Card information</label>
                                            <div id="stripe-element-wrap" class="stripe-element-wrap">
                                                <div id="stripe-card-element"></div>
                                            </div>
                                        </div>
                                        {% if not stripe_enabled %}
                                            <div style="color: #dc2626; font-size: 13px;">Card payment unavailable: configure Stripe keys (STRIPE_PUBLIC_KEY and STRIPE_SECRET_KEY).</div>
                                        {% endif %}
                                        <div id="stripe-client-error" style="display: none; color: #dc2626; font-size: 13px;"></div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 mb-3" style="background: #fffbeb; border: 1px solid #fde68a; border-radius: 10px; padding: 15px;">
                                <p style="margin: 0 0 10px 0; font-weight: 700; color: #92400e;">Promo code (valid for 3 days)</p>
                                <p style="margin: 0 0 12px 0; color: #78350f; font-size: 14px;">Generation available for carts starting from {{ promo_min_total|number_format(0, '.', ' ') }} DT.</p>
                                <div style="display: flex; flex-wrap: wrap; gap: 10px; align-items: center;">
                                    <input type="text" id="promo_code" name="promo_code" value="{{ oldInput.promo_code|default('') }}" placeholder="Enter your promo code"
                                           style="flex: 1; min-width: 220px; padding: 10px 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 15px;">
                                    <button type="submit" name="checkout_action" value="generate_promo"
                                            style="background: #92400e; color: white; border: none; padding: 10px 14px; border-radius: 8px; font-weight: 600; cursor: pointer;">
                                        Generate code
                                    </button>
                                    <button type="submit" name="checkout_action" value="apply_promo"
                                            style="background: #b45309; color: white; border: none; padding: 10px 14px; border-radius: 8px; font-weight: 600; cursor: pointer;">
                                        Apply code
                                    </button>
                                </div>
                                {% if promo_generated_code %}
                                    <p style="margin: 10px 0 0 0; font-size: 14px; color: #065f46;">
                                        Generated code: <strong>{{ promo_generated_code }}</strong>
                                        {% if promo_expires_at %}
                                            (expires on {{ promo_expires_at|date('d/m/Y H:i') }})
                                        {% endif %}
                                    </p>
                                {% endif %}
                                {% if promo_is_applied %}
                                    <p style="margin: 8px 0 0 0; font-size: 14px; color: #166534; font-weight: 700;">
                                        Promo code applied: {{ promo_percent }}% discount
                                    </p>
                                {% endif %}
                                {% if formErrors.promo_code is defined %}
                                    {% for err in formErrors.promo_code %}
                                        <div style="color: #dc2626; font-size: 13px; margin-top: 6px;">{{ err }}</div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            <div class="col-12 mb-3" style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 10px; padding: 15px;">
                                <p style="margin: 0 0 10px 0; font-weight: 700; color: #2d5016;">Automatically filled fields</p>
                                <ul style="margin: 0; padding-left: 18px; color: #4b5563; font-size: 14px;">
                                    <li>Order date: now</li>
                                    <li>Order status: Pending</li>
                                    <li>Payment status: Unpaid</li>
                                    <li>Total price: calculated from cart</li>
                                    <li>Product and quantity: retrieved from cart</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Order summary -->
                    <div style="margin-bottom: 30px;">
                        <h4 style="color: #2d5016; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                            <span class="material-symbols-outlined">receipt</span>
                            Your order summary
                        </h4>
                        
                        <div style="background: #f9fafb; border-radius: 10px; padding: 20px;">
                            {% for item in items %}
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px 0; {% if not loop.last %}border-bottom: 1px solid #e5e7eb;{% endif %}">
                                <div style="display: flex; align-items: center; gap: 15px;">
                                    <div style="width: 60px; height: 60px; border-radius: 8px; overflow: hidden; background: linear-gradient(135deg, #2d5016 0%, #1e3a0f 100%);">
                                        {% if item.produit.imageFilename %}
                                            <img src="{{ asset('uploads/produits/' ~ item.produit.imageFilename) }}" alt="{{ item.produit.nom }}" style="width: 100%; height: 100%; object-fit: cover;">
                                        {% else %}
                                            <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                                                <span class="material-symbols-outlined" style="color: rgba(255,255,255,0.5); font-size: 24px;">package_2</span>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div>
                                        <h6 style="margin: 0 0 5px 0; font-weight: 700;">{{ item.produit.nom }}</h6>
                                        <p style="margin: 0; font-size: 14px; color: #6b7280;">{{ item.produit.prixUnitaire|number_format(2, '.', ' ') }} DT x {{ item.quantite }}</p>
                                        {% if tnd_to_eur_rate is not null %}
                                            <p style="margin: 3px 0 0 0; font-size: 12px; color: #0f766e;">~ {{ (item.produit.prixUnitaire * tnd_to_eur_rate)|number_format(2, '.', ' ') }} EUR / unite</p>
                                        {% endif %}
                                    </div>
                                </div>
                                <div style="text-align: right;">
                                    <span style="font-size: 18px; font-weight: 700; color: #16a34a;">{{ item.subtotal|number_format(2, '.', ' ') }} DT</span>
                                    {% if tnd_to_eur_rate is not null %}
                                        <div style="font-size: 12px; color: #0f766e; font-weight: 600; margin-top: 4px;">~ {{ (item.subtotal * tnd_to_eur_rate)|number_format(2, '.', ' ') }} EUR</div>
                                    {% endif %}
                                </div>
                            </div>
                            {% endfor %}
                            
                            <div style="border-top: 2px solid #e5e7eb; margin-top: 20px; padding-top: 20px;">
                                {% if promo_discount|default(0) > 0 %}
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                        <span style="font-size: 16px; font-weight: 600; color: #92400e;">Promo discount ({{ promo_percent }}%):</span>
                                        <span style="font-size: 18px; font-weight: 700; color: #b45309;">-{{ promo_discount|number_format(2, '.', ' ') }} DT</span>
                                    </div>
                                    {% if tnd_to_eur_rate is not null %}
                                        <div style="text-align: right; margin: -4px 0 8px 0; color: #0f766e; font-size: 12px;">~ -{{ (promo_discount * tnd_to_eur_rate)|number_format(2, '.', ' ') }} EUR</div>
                                    {% endif %}
                                {% endif %}
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="font-size: 20px; font-weight: 700; color: #2d5016;">Total to pay:</span>
                                    <span style="font-size: 24px; font-weight: 900; color: #16a34a;">{{ final_total|default(total)|number_format(2, '.', ' ') }} DT</span>
                                </div>
                                {% if tnd_to_eur_rate is not null %}
                                    <div style="text-align: right; margin-top: 4px; color: #0f766e; font-size: 13px; font-weight: 700;">~ {{ (final_total|default(total) * tnd_to_eur_rate)|number_format(2, '.', ' ') }} EUR</div>
                                {% endif %}
                                {% if eur_estimate is not null %}
                                    <div style="text-align: right; margin-top: 4px; color: #0f766e; font-size: 13px; font-weight: 600;">Approx. {{ eur_estimate|number_format(2, '.', ' ') }} EUR (paiement carte)</div>
                                {% endif %}
                                {% if promo_discount|default(0) > 0 %}
                                    <div style="text-align: right; margin-top: 4px; color: #6b7280; font-size: 13px;">Subtotal before discount: {{ total|number_format(2, '.', ' ') }} DT</div>
                                    {% if tnd_to_eur_rate is not null %}
                                        <div style="text-align: right; margin-top: 2px; color: #6b7280; font-size: 12px;">~ {{ (total * tnd_to_eur_rate)|number_format(2, '.', ' ') }} EUR</div>
                                    {% endif %}
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <!-- Boutons d'action -->
                    <div style="display: flex; gap: 15px; justify-content: space-between;">
                        <a href="{{ path('app_panier_index') }}" style="background: #6b7280; color: white; padding: 15px 30px; border-radius: 10px; text-decoration: none; font-weight: 600;">
                            Back to cart
                        </a>
                        <button type="submit" id="confirm-order-btn" name="checkout_action" value="confirm_order" style="background: linear-gradient(135deg, #16a34a 0%, #15803d 100%); color: white; border: none; padding: 15px 30px; border-radius: 10px; font-weight: 700; cursor: pointer; flex: 1; max-width: 300px;">
                            Confirm order
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-4">
            <div style="background: white; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); overflow: hidden; position: sticky; top: 20px;">
                <div style="background: linear-gradient(135deg, #16a34a 0%, #15803d 100%); padding: 25px; color: white;">
                    <h4 style="margin: 0; display: flex; align-items: center; gap: 10px;">
                        <span class="material-symbols-outlined">info</span>
                        Informations importantes
                    </h4>
                </div>

                <div style="padding: 30px;">
                    <div style="margin-bottom: 20px;">
                        <h6 style="color: #2d5016; font-weight: 700; margin-bottom: 10px;">
                            <span class="material-symbols-outlined" style="font-size: 18px; vertical-align: middle;">local_shipping</span>
                            Delivery
                        </h6>
                        <p style="font-size: 14px; color: #6b7280; margin: 0;">
                            Free delivery for all orders. Delivery time: 2-3 business days.
                        </p>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <h6 style="color: #2d5016; font-weight: 700; margin-bottom: 10px;">
                            <span class="material-symbols-outlined" style="font-size: 18px; vertical-align: middle;">payment</span>
                            Paiement
                        </h6>
                        <p style="font-size: 14px; color: #6b7280; margin: 0;">
                            Secure payment. You can pay on delivery or via bank transfer.
                        </p>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <h6 style="color: #2d5016; font-weight: 700; margin-bottom: 10px;">
                            <span class="material-symbols-outlined" style="font-size: 18px; vertical-align: middle;">support_agent</span>
                            Support
                        </h6>
                        <p style="font-size: 14px; color: #6b7280; margin: 0;">
                            Our team is available to help you. Contact us if needed.
                        </p>
                    </div>

                    <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 15px;">
                        <p style="font-size: 12px; color: #166534; margin: 0; text-align: center;">
                            <span class="material-symbols-outlined" style="font-size: 16px; vertical-align: middle;">verified</span>
                            Secure and guaranteed order
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="position: fixed; top: 20px; right: 20px; z-index: 9999;">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{% for message in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="position: fixed; top: 20px; right: 20px; z-index: 9999;">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

<button id="assist-fab" class="assist-fab" type="button" aria-label="Open order assistant">
    <span class="material-symbols-outlined">forum</span>
</button>

<section id="assist-panel" class="assist-panel" aria-live="polite">
    <div class="assist-head">
        <strong>Order assistant</strong>
        <button id="assist-close" type="button" style="border:none;background:transparent;color:#fff;">✕</button>
    </div>
    <div id="assist-body" class="assist-body"></div>
    <div class="assist-input">
        <input id="assist-input" type="text" placeholder="Ex: how to use the promo code?">
        <button id="assist-send" type="button">Send</button>
    </div>
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://js.stripe.com/v3/"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js"></script>
