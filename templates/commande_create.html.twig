    <script>
        (function () {
            const addressInput = document.getElementById('adresse_livraison');
            const mapEl = document.getElementById('delivery-map');
            const statusEl = document.getElementById('delivery-map-status');
            const myLocationBtn = document.getElementById('use-current-location');

            if (!addressInput || !mapEl || typeof L === 'undefined') {
                if (statusEl) {
                    statusEl.textContent = 'Carte indisponible. Vous pouvez saisir l\'adresse manuellement.';
                }
                return;
            }

            const defaultCenter = [36.8065, 10.1815];
            const map = L.map('delivery-map', { zoomControl: true }).setView(defaultCenter, 12);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            let marker = null;

            function setStatus(message, isError) {
                if (!statusEl) return;
                statusEl.textContent = message;
                statusEl.style.color = isError ? '#b91c1c' : '#6b7280';
            }

            function placeMarker(lat, lng) {
                if (marker) {
                    marker.setLatLng([lat, lng]);
                    return;
                }
                marker = L.marker([lat, lng]).addTo(map);
            }

            async function reverseGeocode(lat, lng) {
                setStatus('Recherche de l\'adresse...', false);
                try {
                    const response = await fetch('{{ path('app_api_commande_reverse_geocode') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ lat: lat, lng: lng })
                    });

                    const data = await response.json();
                    const address = (response.ok && data && data.ok && data.address)
                        ? String(data.address).trim()
                        : '';

                    if (address !== '') {
                        addressInput.value = address;
                        addressInput.dispatchEvent(new Event('input', { bubbles: true }));
                        setStatus('Adresse remplie automatiquement depuis la carte.', false);
                    } else {
                        addressInput.value = `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
                        setStatus('Adresse exacte non trouvee, coordonnees remplies.', false);
                    }
                } catch (_error) {
                    addressInput.value = `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
                    setStatus('Impossible de recuperer l\'adresse exacte. Coordonnees remplies.', true);
                }
            }

            map.on('click', function (event) {
                const lat = event.latlng.lat;
                const lng = event.latlng.lng;
                placeMarker(lat, lng);
                reverseGeocode(lat, lng);
            });

            if (myLocationBtn) {
                myLocationBtn.addEventListener('click', function () {
                    if (!navigator.geolocation) {
                        setStatus('Geolocalisation non supportee par ce navigateur.', true);
                        return;
                    }

                    setStatus('Detection de votre position...', false);
                    navigator.geolocation.getCurrentPosition(function (position) {
                        const lat = position.coords.latitude;
                        const lng = position.coords.longitude;
                        map.setView([lat, lng], 16);
                        placeMarker(lat, lng);
                        reverseGeocode(lat, lng);
                    }, function () {
                        setStatus('Impossible d\'obtenir votre position.', true);
                    }, { enableHighAccuracy: true, timeout: 8000 });
                });
            }

            setTimeout(function () {
                map.invalidateSize();
            }, 120);
        })();
    </script>
    <script>
        (function () {
            const modeSelect = document.getElementById('mode_paiement');
            const stripeZone = document.getElementById('stripe-zone');
            const checkoutForm = document.getElementById('checkoutForm');
            const confirmButton = document.getElementById('confirm-order-btn');
            const stripeErrorEl = document.getElementById('stripe-client-error');
            const stripeIntentInput = document.getElementById('stripe_payment_intent_id');
            const cardHolderInput = document.getElementById('stripe_card_holder');
            const nameInput = document.getElementById('nom_client');
            const cardPreviewName = document.getElementById('card-preview-name');
            const cardPreviewNumber = document.getElementById('card-preview-number');
            const elementWrap = document.getElementById('stripe-element-wrap');
            const stripeEnabled = {{ stripe_enabled ? 'true' : 'false' }};
            const stripePublicKey = '{{ stripe_public_key|e('js') }}';
            let stripe = null;
            let cardElement = null;
            let stripeValidated = false;

            function showStripeError(message) {
                if (!stripeErrorEl) return;
                stripeErrorEl.style.display = 'block';
                stripeErrorEl.textContent = message;
            }

            function clearStripeError() {
                if (!stripeErrorEl) return;
                stripeErrorEl.style.display = 'none';
                stripeErrorEl.textContent = '';
            }

            function refreshCardName() {
                if (!cardPreviewName) return;
                const value = (cardHolderInput && cardHolderInput.value.trim() !== '')
                    ? cardHolderInput.value.trim()
                    : ((nameInput && nameInput.value.trim() !== '') ? nameInput.value.trim() : 'Votre nom');
                cardPreviewName.textContent = value;
            }

            function refreshStripeVisibility() {
                if (!modeSelect || !stripeZone) return;
                const isCard = modeSelect.value === 'Carte bancaire';
                stripeZone.classList.toggle('active', isCard);
                if (!isCard) {
                    clearStripeError();
                }
            }

            function initStripe() {
                if (!stripeEnabled || !stripePublicKey || typeof Stripe === 'undefined') {
                    return;
                }
                stripe = Stripe(stripePublicKey);
                const elements = stripe.elements();
                cardElement = elements.create('card', {
                    style: {
                        base: {
                            color: '#111827',
                            fontSize: '16px',
                            fontFamily: 'Open Sans, sans-serif',
                            '::placeholder': { color: '#6b7280' }
                        },
                        invalid: { color: '#dc2626' }
                    }
                });

                cardElement.mount('#stripe-card-element');

                cardElement.on('focus', function () {
                    if (elementWrap) elementWrap.classList.add('focused');
                });
                cardElement.on('blur', function () {
                    if (elementWrap) elementWrap.classList.remove('focused');
                });
                cardElement.on('change', function (event) {
                    clearStripeError();
                    cardPreviewNumber.textContent = event.empty ? '•••• •••• •••• ••••' : '•••• •••• •••• ' + (event.brand ? event.brand.toUpperCase().slice(0, 4) : 'CARD');
                    if (event.error) {
                        showStripeError(event.error.message);
                    }
                });
            }

            async function createPaymentIntent() {
                const promoCode = document.getElementById('promo_code');
                const adresseInput = document.getElementById('adresse_livraison');
                const body = new URLSearchParams();
                body.set('promo_code', promoCode ? promoCode.value : '');
                body.set('adresse_livraison', adresseInput ? adresseInput.value : '');
                const response = await fetch('{{ path('app_commande_stripe_create_intent') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                    },
                    body: body.toString()
                });

                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Error creating Stripe payment.');
                }

                return data;
            }

            if (modeSelect) {
                modeSelect.addEventListener('change', refreshStripeVisibility);
            }

            if (cardHolderInput) {
                cardHolderInput.addEventListener('input', refreshCardName);
            }

            if (nameInput) {
                nameInput.addEventListener('input', refreshCardName);
            }

            refreshCardName();
            refreshStripeVisibility();
            initStripe();

            if (checkoutForm && confirmButton) {
                checkoutForm.addEventListener('submit', async function (event) {
                    const submitter = event.submitter;
                    const isConfirmAction = submitter && submitter.name === 'checkout_action' && submitter.value === 'confirm_order';

                    if (!isConfirmAction) {
                        return;
                    }

                    const isCardPayment = modeSelect && modeSelect.value === 'Carte bancaire';
                    if (!isCardPayment) {
                        stripeValidated = false;
                        stripeIntentInput.value = '';
                        return;
                    }

                    if (stripeValidated) {
                        return;
                    }

                    event.preventDefault();
                    clearStripeError();

                    if (!stripeEnabled) {
                        showStripeError('Card payment is currently unavailable.');
                        return;
                    }

                    if (!stripe || !cardElement) {
                        showStripeError('Stripe is not ready. Reload the page.');
                        return;
                    }

                    submitter.disabled = true;
                    submitter.textContent = 'Processing payment...';

                    try {
                        const intentData = await createPaymentIntent();
                        const holderName = (cardHolderInput && cardHolderInput.value.trim() !== '')
                            ? cardHolderInput.value.trim()
                            : (nameInput ? nameInput.value.trim() : '');

                        const result = await stripe.confirmCardPayment(intentData.clientSecret, {
                            payment_method: {
                                card: cardElement,
                                billing_details: {
                                    name: holderName
                                }
                            }
                        });

                        if (result.error) {
                            throw new Error(result.error.message || 'Payment declined.');
                        }

                        if (!result.paymentIntent || result.paymentIntent.status !== 'succeeded') {
                            throw new Error('Card payment not confirmed.');
                        }

                        stripeIntentInput.value = result.paymentIntent.id;
                        stripeValidated = true;
                        submitter.textContent = 'Validation...';
                        submitter.disabled = false;
                        checkoutForm.requestSubmit(submitter);
                    } catch (err) {
                        showStripeError(err.message || 'Erreur lors du paiement carte.');
                        submitter.disabled = false;
                        submitter.textContent = 'Confirm order';
                    }
                });
            }
        })();
    </script>

    <script>
        (function () {
            const panel = document.getElementById('assist-panel');
            const fab = document.getElementById('assist-fab');
            const closeBtn = document.getElementById('assist-close');
            const body = document.getElementById('assist-body');
            const input = document.getElementById('assist-input');
            const send = document.getElementById('assist-send');

            if (!panel || !fab || !closeBtn || !body || !input || !send) {
                return;
            }

            function appendMessage(text, isUser, quickReplies) {
                const wrap = document.createElement('div');
                wrap.className = 'assist-msg ' + (isUser ? 'user' : 'bot');

                const bubble = document.createElement('div');
                bubble.className = 'bubble';
                bubble.textContent = text;
                wrap.appendChild(bubble);

                if (!isUser && Array.isArray(quickReplies) && quickReplies.length > 0) {
                    const quick = document.createElement('div');
                    quick.className = 'assist-quick';
                    quickReplies.slice(0, 4).forEach(function (label) {
                        const btn = document.createElement('button');
                        btn.type = 'button';
                        btn.textContent = label;
                        btn.addEventListener('click', function () {
                            askBot(label);
                        });
                        quick.appendChild(btn);
                    });
                    bubble.appendChild(quick);
                }

                body.appendChild(wrap);
                body.scrollTop = body.scrollHeight;
            }

            async function askBot(question) {
                const text = (question || input.value || '').trim();
                if (!text) {
                    return;
                }

                appendMessage(text, true, []);
                input.value = '';

                try {
                    const response = await fetch('{{ path('app_api_commande_chatbot') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ message: text })
                    });

                    const data = await response.json();
                    if (!response.ok) {
                        throw new Error(data.error || 'Chatbot error.');
                    }

                    appendMessage(data.reply || 'I am here to help you.', false, data.quick_replies || []);
                } catch (err) {
                    appendMessage(err.message || 'Error while getting assistant response.', false, []);
                }
            }

            fab.addEventListener('click', function () {
                panel.classList.add('active');
                if (body.children.length === 0) {
                    appendMessage('Hello! I am your order assistant. I can help with promo, Stripe payment, address, and total.', false, ['Promo code', 'Stripe card payment', 'Delivery address', 'Current total']);
                }
            });

            closeBtn.addEventListener('click', function () {
                panel.classList.remove('active');
            });

            send.addEventListener('click', function () {
                askBot('');
            });

            input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    askBot('');
                }
            });
        })();
    </script>

    <script>
        (function () {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            const synth = window.speechSynthesis;
            const hasVoice = !!SpeechRecognition && !!synth;
            let isListening = false;
            let networkRetryCount = 0;
            let isRecognitionStarting = false;
            let restartOnEnd = false;
            let manualStop = false;

            const fab = document.createElement('button');
            fab.type = 'button';
            fab.id = 'voice-checkout-fab';
            fab.style.cssText = 'position: fixed; left: 22px; bottom: 22px; z-index: 1100; width: 58px; height: 58px; border-radius: 50%; border: none; background: linear-gradient(135deg, #0f766e 0%, #0d9488 100%); color: #fff; box-shadow: 0 12px 22px rgba(15,118,110,.35); display: inline-flex; align-items: center; justify-content: center; cursor: pointer;';
            fab.innerHTML = '<span class="material-symbols-outlined">mic</span>';
            fab.title = hasVoice ? 'Voice assistant for checkout' : 'Voice assistant not supported on this browser';
            document.body.appendChild(fab);

            const form = document.getElementById('checkoutForm');
            const nameInput = document.getElementById('nom_client');
            const addressInput = document.getElementById('adresse_livraison');
            const paymentSelect = document.getElementById('mode_paiement');
            const promoInput = document.getElementById('promo_code');
            const totalEl = Array.from(document.querySelectorAll('span')).find((el) => el.textContent.includes('DT') && el.style.fontSize === '24px');
            const confirmBtn = document.getElementById('confirm-order-btn');

            const voiceStatus = document.createElement('div');
            voiceStatus.id = 'voice-checkout-status';
            voiceStatus.style.cssText = 'position: fixed; left: 22px; bottom: 90px; z-index: 1100; max-width: 320px; padding: 8px 12px; border-radius: 10px; background: rgba(15,23,42,.9); color: #fff; font-size: 13px; line-height: 1.35; display: none;';
            document.body.appendChild(voiceStatus);

            function showVoiceStatus(message, isError, withSpeech = true) {
                voiceStatus.textContent = message;
                voiceStatus.style.display = 'block';
                voiceStatus.style.background = isError ? 'rgba(185,28,28,.95)' : 'rgba(15,23,42,.9)';
                if (withSpeech) {
                    speak(message);
                }
                setTimeout(function () {
                    voiceStatus.style.display = 'none';
                }, 3600);
            }

            function openVoiceFallbackPrompt() {
                const typed = window.prompt('Voice recognition unavailable. Type a checkout command. Example: name ahmed');
                if (typeof typed === 'string' && typed.trim() !== '') {
                    handleVoiceCommand(typed.trim());
                }
            }

            function speak(message) {
                if (!synth) {
                    return;
                }
                synth.cancel();
                const utt = new SpeechSynthesisUtterance(message);
                utt.lang = 'fr-FR';
                utt.rate = 1;
                synth.speak(utt);
            }

            function submitAction(action) {
                if (!form) {
                    return;
                }
                const temp = document.createElement('button');
                temp.type = 'submit';
                temp.name = 'checkout_action';
                temp.value = action;
                temp.style.display = 'none';
                form.appendChild(temp);
                temp.click();
                form.removeChild(temp);
            }

            function readCheckoutSummary() {
                const totalText = totalEl ? totalEl.textContent.trim() : 'total unavailable';
                speak(`Summary. Name ${nameInput?.value || 'not provided'}. Payment method ${paymentSelect?.value || 'not provided'}. Total ${totalText}.`);
            }

            function getGeneratedPromoCodeFromUi() {
                const generatedStrong = Array.from(document.querySelectorAll('p strong')).find((el) => {
                    const txt = (el.textContent || '').trim();
                    return txt.length >= 4 && /^[A-Z0-9-]+$/i.test(txt);
                });

                return generatedStrong ? String(generatedStrong.textContent || '').trim() : '';
            }

            function executeVoiceActions(actions) {
                if (!Array.isArray(actions)) {
                    return;
                }

                actions.forEach((action) => {
                    if (!action || typeof action !== 'object') {
                        return;
                    }

                    if (action.type === 'set_field') {
                        const fieldId = String(action.field_id || '');
                        const value = String(action.value || '');
                        const field = document.getElementById(fieldId);
                        if (field) {
                            field.value = value;
                            field.dispatchEvent(new Event('input', { bubbles: true }));
                        }
                        return;
                    }

                    if (action.type === 'set_payment_mode') {
                        if (paymentSelect) {
                            paymentSelect.value = String(action.value || 'Cash');
                            paymentSelect.dispatchEvent(new Event('change', { bubbles: true }));
                        }
                        return;
                    }

                    if (action.type === 'submit_checkout_action') {
                        submitAction(String(action.value || ''));
                        return;
                    }

                    if (action.type === 'apply_generated_promo') {
                        const generated = getGeneratedPromoCodeFromUi();
                        if (promoInput && generated !== '') {
                            promoInput.value = generated.toUpperCase();
                            promoInput.dispatchEvent(new Event('input', { bubbles: true }));
                            submitAction('apply_promo');
                            return;
                        }

                        showVoiceStatus('No generated promo code found. Say generate promo and try this command again.', true, true);
                        return;
                    }

                    if (action.type === 'read_checkout_summary') {
                        readCheckoutSummary();
                        return;
                    }

                    if (action.type === 'click_confirm_order') {
                        if (confirmBtn) {
                            confirmBtn.click();
                        }
                        return;
                    }

                    if (action.type === 'navigate') {
                        const url = String(action.url || '');
                        if (url !== '') {
                            window.location.href = url;
                        }
                        return;
                    }

                    if (action.type === 'reload_page') {
                        window.location.reload();
                    }
                });
            }

            async function handleVoiceCommand(rawText) {
                try {
                    const response = await fetch('{{ path('app_api_ai_voice_command') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            context: 'checkout',
                            transcript: rawText,
                        }),
                    });

                    const data = await response.json();
                    if (!response.ok || !data.ok) {
                        showVoiceStatus(data.speak || 'Voice processing error.', true, true);
                        return;
                    }

                    executeVoiceActions(data.actions || []);
                    if (typeof data.speak === 'string' && data.speak !== '') {
                        speak(data.speak);
                    }
                } catch (_error) {
                    showVoiceStatus('Network error during voice command.', true, true);
                }
            }

            if (!hasVoice) {
                fab.style.opacity = '0.65';
                fab.addEventListener('click', function () {
                    showVoiceStatus('Voice recognition is not supported by this browser.', true);
                });
                return;
            }

            const recognition = new SpeechRecognition();
            recognition.lang = 'fr-FR';
            recognition.continuous = false;
            recognition.interimResults = false;
            recognition.maxAlternatives = 1;

            function startRecognitionSafely(quiet = false) {
                if (isListening || isRecognitionStarting) {
                    return;
                }

                try {
                    isRecognitionStarting = true;
                    recognition.start();
                    restartOnEnd = false;
                    fab.style.background = 'linear-gradient(135deg, #ef4444 0%, #dc2626 100%)';
                    if (!quiet) {
                        // Ne pas parler au moment du start pour eviter de couper l'ecoute.
                        showVoiceStatus('Listening... say your voice command.', false, false);
                    }
                } catch (_error) {
                    isRecognitionStarting = false;
                    showVoiceStatus('Unable to start the microphone, try again.', true);
                }
            }

            recognition.onstart = function () {
                isRecognitionStarting = false;
                isListening = true;
            };

            recognition.onresult = function (event) {
                for (let i = event.resultIndex; i < event.results.length; i++) {
                    const result = event.results[i];
                    if (!result.isFinal) {
                        continue;
                    }

                    const transcript = result?.[0]?.transcript || '';
                    if (transcript) {
                        networkRetryCount = 0;
                        manualStop = true;
                        restartOnEnd = false;
                        handleVoiceCommand(transcript);
                    }
                }
            };

            recognition.onerror = function (event) {
                const code = event?.error || 'unknown';
                isRecognitionStarting = false;
                isListening = false;

                if (code === 'not-allowed' || code === 'service-not-allowed') {
                    showVoiceStatus('Permission micro refusee. Autorisez le micro pour ce site puis reessayez.', true);
                    return;
                }

                if (code === 'audio-capture') {
                    showVoiceStatus('Aucun micro detecte ou accessible.', true);
                    return;
                }

                if (code === 'network') {
                    if (networkRetryCount < 1) {
                        networkRetryCount++;
                    showVoiceStatus('Browser voice service unavailable. Retrying...', true, false);
                        setTimeout(function () {
                            startRecognitionSafely(true);
                        }, 550);

                        return;
                    }

                    restartOnEnd = false;
                    showVoiceStatus('Browser voice service unavailable. Use text fallback.', true);
                    openVoiceFallbackPrompt();
                    return;
                }

                if (code === 'no-speech') {
                    showVoiceStatus('No speech detected. Speak right after clicking the microphone.', true, false);
                    return;
                }

                if (code !== 'aborted') {
                    showVoiceStatus('Voice error: ' + code + '. Please try again.', true);
                }
            };

            recognition.onend = function () {
                isRecognitionStarting = false;
                isListening = false;
                fab.style.background = 'linear-gradient(135deg, #0f766e 0%, #0d9488 100%)';
            };

            async function ensureMicroPermission() {
                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    return true;
                }

                try {
                    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                    stream.getTracks().forEach(function (t) { t.stop(); });

                    return true;
                } catch (_error) {
                    showVoiceStatus('Microphone not authorized. Enable browser microphone access.', true);

                    return false;
                }
            }

            fab.addEventListener('click', async function () {
                if (isListening || isRecognitionStarting) {
                    manualStop = true;
                    restartOnEnd = false;
                    isRecognitionStarting = false;
                    recognition.stop();
                    isListening = false;
                    showVoiceStatus('Listening stopped.', false, false);

                    return;
                }

                const allowed = await ensureMicroPermission();
                if (!allowed) {
                    return;
                }

                try {
                    networkRetryCount = 0;
                    manualStop = false;
                    restartOnEnd = false;
                    synth.cancel();
                    startRecognitionSafely();
                } catch (_error) {
                    showVoiceStatus('Impossible de demarrer le micro, reessayez.', true);
                }
            });

                showVoiceStatus('Checkout voice assistant active.', false);
        })();
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (!window.GestureAssistant) {
                return;
            }

            const focusOrder = ['nom_client', 'adresse_livraison', 'mode_paiement', 'promo_code'];

            window.GestureAssistant.create({
                id: 'checkout',
                autoSpeak: true,
                onGesture: async function (gesture) {
                    try {
                        const response = await fetch('{{ path('app_api_ai_gesture_command') }}', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ context: 'checkout', gesture: gesture })
                        });

                        const data = await response.json();
                        if (!response.ok || !data.ok) {
                            return data.speak || 'Gesture command not recognized.';
                        }

                        const actions = Array.isArray(data.actions) ? data.actions : [];
                        for (const action of actions) {
                            if (!action || typeof action !== 'object') continue;

                            if (action.type === 'focus_next_checkout_field') {
                                const activeId = document.activeElement?.id || '';
                                const currentIndex = focusOrder.indexOf(activeId);
                                const nextIndex = (currentIndex + 1) % focusOrder.length;
                                const nextField = document.getElementById(focusOrder[nextIndex]);
                                if (nextField) {
                                    nextField.focus();
                                }
                            }

                            if (action.type === 'submit_checkout_action') {
                                const value = String(action.value || '');
                                const btn = document.querySelector(`button[name="checkout_action"][value="${value}"]`);
                                if (btn) {
                                    btn.click();
                                }
                            }

                            if (action.type === 'click_confirm_order') {
                                const confirmBtn = document.getElementById('confirm-order-btn');
                                if (confirmBtn) {
                                    confirmBtn.click();
                                }
                            }

                            if (action.type === 'read_checkout_summary') {
                                const totalEl = Array.from(document.querySelectorAll('span')).find((el) => (el.textContent || '').includes('DT') && el.style.fontSize === '24px');
                                const total = totalEl ? totalEl.textContent.trim() : 'indisponible';
                                return `Order summary. Total ${total}.`;
                            }
                        }

                        return typeof data.speak === 'string' ? data.speak : 'Gesture command executed.';
                    } catch (_error) {
                        return 'Gesture service temporarily unavailable.';
                    }
                }
            });
        });
    </script>
{% endblock %}
