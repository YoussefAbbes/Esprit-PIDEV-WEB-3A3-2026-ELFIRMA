{% extends 'base.html.twig' %}

{% block title %}Créer une commande - EL FIRMA{% endblock %}

{% block body %}
{% set formErrors = form_errors|default({}) %}
{% set oldInput = old|default({}) %}
<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8">
            <div style="background: white; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); overflow: hidden;">
                <div style="background: linear-gradient(135deg, #2d5016 0%, #1e3a0f 100%); padding: 25px; color: white;">
                    <h2 style="margin: 0; display: flex; align-items: center; gap: 15px;">
                        <span class="material-symbols-outlined" style="font-size: 32px;">shopping_bag</span>
                        Finaliser votre commande
                    </h2>
                </div>

                <form method="POST" style="padding: 30px;">
                    {% if formErrors._global is defined %}
                        <div class="alert alert-danger" role="alert" style="margin-bottom: 20px;">
                            {% for err in formErrors._global %}
                                <div>{{ err }}</div>
                            {% endfor %}
                        </div>
                    {% endif %}
                    <!-- Informations client -->
                    <div style="margin-bottom: 30px;">
                        <h4 style="color: #2d5016; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                            <span class="material-symbols-outlined">person</span>
                            Informations client
                        </h4>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="nom_client" style="font-weight: 600; color: #374151; margin-bottom: 8px;">Nom complet *</label>
                                <input type="text" id="nom_client" name="nom_client" value="{{ oldInput.nom_client|default('') }}"
                                       style="width: 100%; padding: 12px 15px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 16px;">
                                {% if formErrors.nom_client is defined %}
                                    {% for err in formErrors.nom_client %}
                                        <div style="color: #dc2626; font-size: 13px; margin-top: 6px;">{{ err }}</div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="mode_paiement" style="font-weight: 600; color: #374151; margin-bottom: 8px;">Mode de paiement *</label>
                                <select id="mode_paiement" name="mode_paiement" 
                                        style="width: 100%; padding: 12px 15px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 16px;">
                                    <option value="Cash" {% if oldInput.mode_paiement|default('Cash') == 'Cash' %}selected{% endif %}>Cash (à la livraison)</option>
                                    <option value="Carte bancaire" {% if oldInput.mode_paiement|default('Cash') == 'Carte bancaire' %}selected{% endif %}>Carte bancaire</option>
                                    <option value="Virement" {% if oldInput.mode_paiement|default('Cash') == 'Virement' %}selected{% endif %}>Virement bancaire</option>
                                </select>
                                {% if formErrors.mode_paiement is defined %}
                                    {% for err in formErrors.mode_paiement %}
                                        <div style="color: #dc2626; font-size: 13px; margin-top: 6px;">{{ err }}</div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            <div class="col-12 mb-3" style="background: #fffbeb; border: 1px solid #fde68a; border-radius: 10px; padding: 15px;">
                                <p style="margin: 0 0 10px 0; font-weight: 700; color: #92400e;">Code promo (valable 3 jours)</p>
                                <p style="margin: 0 0 12px 0; color: #78350f; font-size: 14px;">Génération disponible pour un panier à partir de {{ promo_min_total|number_format(0, '.', ' ') }} DT.</p>
                                <div style="display: flex; flex-wrap: wrap; gap: 10px; align-items: center;">
                                    <input type="text" id="promo_code" name="promo_code" value="{{ oldInput.promo_code|default('') }}" placeholder="Entrez votre code promo"
                                           style="flex: 1; min-width: 220px; padding: 10px 12px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 15px;">
                                    <button type="submit" name="checkout_action" value="generate_promo"
                                            style="background: #92400e; color: white; border: none; padding: 10px 14px; border-radius: 8px; font-weight: 600; cursor: pointer;">
                                        Générer code
                                    </button>
                                    <button type="submit" name="checkout_action" value="apply_promo"
                                            style="background: #b45309; color: white; border: none; padding: 10px 14px; border-radius: 8px; font-weight: 600; cursor: pointer;">
                                        Appliquer code
                                    </button>
                                </div>
                                {% if promo_generated_code %}
                                    <p style="margin: 10px 0 0 0; font-size: 14px; color: #065f46;">
                                        Code généré: <strong>{{ promo_generated_code }}</strong>
                                        {% if promo_expires_at %}
                                            (expire le {{ promo_expires_at|date('d/m/Y H:i') }})
                                        {% endif %}
                                    </p>
                                {% endif %}
                                {% if promo_is_applied %}
                                    <p style="margin: 8px 0 0 0; font-size: 14px; color: #166534; font-weight: 700;">
                                        Code promo appliqué: réduction de {{ promo_percent }}%
                                    </p>
                                {% endif %}
                                {% if formErrors.promo_code is defined %}
                                    {% for err in formErrors.promo_code %}
                                        <div style="color: #dc2626; font-size: 13px; margin-top: 6px;">{{ err }}</div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            <div class="col-12 mb-3" style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 10px; padding: 15px;">
                                <p style="margin: 0 0 10px 0; font-weight: 700; color: #2d5016;">Champs remplis automatiquement</p>
                                <ul style="margin: 0; padding-left: 18px; color: #4b5563; font-size: 14px;">
                                    <li>Date de commande: maintenant</li>
                                    <li>Statut commande: En attente</li>
                                    <li>Statut paiement: Non payé</li>
                                    <li>Prix total: calculé depuis le panier</li>
                                    <li>Produit et quantité: récupérés depuis le panier</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Récapitulatif de la commande -->
                    <div style="margin-bottom: 30px;">
                        <h4 style="color: #2d5016; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                            <span class="material-symbols-outlined">receipt</span>
                            Récapitulatif de votre commande
                        </h4>
                        
                        <div style="background: #f9fafb; border-radius: 10px; padding: 20px;">
                            {% for item in items %}
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px 0; {% if not loop.last %}border-bottom: 1px solid #e5e7eb;{% endif %}">
                                <div style="display: flex; align-items: center; gap: 15px;">
                                    <div style="width: 60px; height: 60px; border-radius: 8px; overflow: hidden; background: linear-gradient(135deg, #2d5016 0%, #1e3a0f 100%);">
                                        {% if item.produit.image %}
                                            <img src="{{ asset('uploads/produits/' ~ item.produit.image) }}" alt="{{ item.produit.nom }}" style="width: 100%; height: 100%; object-fit: cover;">
                                        {% else %}
                                            <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                                                <span class="material-symbols-outlined" style="color: rgba(255,255,255,0.5); font-size: 24px;">package_2</span>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div>
                                        <h6 style="margin: 0 0 5px 0; font-weight: 700;">{{ item.produit.nom }}</h6>
                                        <p style="margin: 0; font-size: 14px; color: #6b7280;">{{ item.produit.prixUnitaire }} DT x {{ item.quantite }}</p>
                                    </div>
                                </div>
                                <div style="text-align: right;">
                                    <span style="font-size: 18px; font-weight: 700; color: #16a34a;">{{ item.subtotal }} DT</span>
                                </div>
                            </div>
                            {% endfor %}
                            
                            <div style="border-top: 2px solid #e5e7eb; margin-top: 20px; padding-top: 20px;">
                                {% if promo_discount|default(0) > 0 %}
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                        <span style="font-size: 16px; font-weight: 600; color: #92400e;">Réduction promo ({{ promo_percent }}%) :</span>
                                        <span style="font-size: 18px; font-weight: 700; color: #b45309;">-{{ promo_discount|number_format(2, '.', ' ') }} DT</span>
                                    </div>
                                {% endif %}
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="font-size: 20px; font-weight: 700; color: #2d5016;">Total à payer:</span>
                                    <span style="font-size: 24px; font-weight: 900; color: #16a34a;">{{ final_total|default(total)|number_format(2, '.', ' ') }} DT</span>
                                </div>
                                {% if promo_discount|default(0) > 0 %}
                                    <div style="text-align: right; margin-top: 4px; color: #6b7280; font-size: 13px;">Sous-total avant réduction: {{ total|number_format(2, '.', ' ') }} DT</div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <!-- Boutons d'action -->
                    <div style="display: flex; gap: 15px; justify-content: space-between;">
                        <a href="{{ path('app_panier_index') }}" style="background: #6b7280; color: white; padding: 15px 30px; border-radius: 10px; text-decoration: none; font-weight: 600;">
                            Retour au panier
                        </a>
                        <button type="submit" name="checkout_action" value="confirm_order" style="background: linear-gradient(135deg, #16a34a 0%, #15803d 100%); color: white; border: none; padding: 15px 30px; border-radius: 10px; font-weight: 700; cursor: pointer; flex: 1; max-width: 300px;">
                            Confirmer la commande
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-4">
            <div style="background: white; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); overflow: hidden; position: sticky; top: 20px;">
                <div style="background: linear-gradient(135deg, #16a34a 0%, #15803d 100%); padding: 25px; color: white;">
                    <h4 style="margin: 0; display: flex; align-items: center; gap: 10px;">
                        <span class="material-symbols-outlined">info</span>
                        Informations importantes
                    </h4>
                </div>

                <div style="padding: 30px;">
                    <div style="margin-bottom: 20px;">
                        <h6 style="color: #2d5016; font-weight: 700; margin-bottom: 10px;">
                            <span class="material-symbols-outlined" style="font-size: 18px; vertical-align: middle;">local_shipping</span>
                            Livraison
                        </h6>
                        <p style="font-size: 14px; color: #6b7280; margin: 0;">
                            Livraison gratuite pour toute commande. Délai de livraison : 2-3 jours ouvrables.
                        </p>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <h6 style="color: #2d5016; font-weight: 700; margin-bottom: 10px;">
                            <span class="material-symbols-outlined" style="font-size: 18px; vertical-align: middle;">payment</span>
                            Paiement
                        </h6>
                        <p style="font-size: 14px; color: #6b7280; margin: 0;">
                            Paiement sécurisé. Possibilité de payer à la livraison ou par virement.
                        </p>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <h6 style="color: #2d5016; font-weight: 700; margin-bottom: 10px;">
                            <span class="material-symbols-outlined" style="font-size: 18px; vertical-align: middle;">support_agent</span>
                            Support
                        </h6>
                        <p style="font-size: 14px; color: #6b7280; margin: 0;">
                            Notre équipe est disponible pour vous aider. Contactez-nous en cas de besoin.
                        </p>
                    </div>

                    <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 15px;">
                        <p style="font-size: 12px; color: #166534; margin: 0; text-align: center;">
                            <span class="material-symbols-outlined" style="font-size: 16px; vertical-align: middle;">verified</span>
                            Commande sécurisée et garantie
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="position: fixed; top: 20px; right: 20px; z-index: 9999;">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{% for message in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="position: fixed; top: 20px; right: 20px; z-index: 9999;">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}
{% endblock %}