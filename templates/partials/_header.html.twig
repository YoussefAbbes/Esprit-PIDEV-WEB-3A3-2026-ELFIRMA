<script>
/* ── Global Notification Bell ── */
(function () {
  var btn     = document.getElementById('hdrNotifBtn');
  var panel   = document.getElementById('hdrNotifPanel');
  var closeEl = document.getElementById('hdrNpClose');
  var listEl  = document.getElementById('hdrNpList');
  var badgeEl = document.getElementById('hdrNotifBadge');
  var subEl   = document.getElementById('hdrNpSub');
  if (!btn || !panel) return;

  /* ── helpers ── */
  var today = new Date(); today.setHours(0,0,0,0);

  function daysUntil(dateStr) {
    return Math.round((new Date(dateStr + 'T00:00:00') - today) / 86400000);
  }
  function urgencyStyle(days) {
    if (days < 0)   return 'background:#fee2e2;color:#991b1b;';
    if (days <= 7)  return 'background:#fef3c7;color:#92400e;';
    if (days <= 30) return 'background:#dcfce7;color:#166534;';
    return 'background:#eff6ff;color:#1d4ed8;';
  }
  function daysLabel(days) {
    if (days < 0)   return '🔴 Overdue ' + Math.abs(days) + 'd';
    if (days === 0) return '🔴 Today!';
    if (days === 1) return '🔴 Tomorrow';
    if (days <= 7)  return '🟠 In ' + days + 'd';
    if (days <= 30) return '🟡 In ' + days + 'd';
    return '🟢 In ' + days + 'd';
  }
  var EMOJIS = {
    wheat:'🌾',barley:'🌾',corn:'🌽',maize:'🌽',rice:'🌾',
    tomato:'🍅',tomate:'🍅',potato:'🥔',pepper:'🫑',poivron:'🫑',
    watermelon:'🍉',pastèque:'🍉',olive:'🫒',onion:'🧅',oignon:'🧅',
    carrot:'🥕',carotte:'🥕',sunflower:'🌻',melon:'🍈',
    cucumber:'🥒',eggplant:'🍆',garlic:'🧄',lettuce:'🥬'
  };
  function cropEmoji(name) {
    var n = (name||'').toLowerCase();
    for (var k in EMOJIS) { if (n.indexOf(k) !== -1) return EMOJIS[k]; }
    return '🌿';
  }

  /* ── populate ── */
  function populate(items) {
    var count = items.length;

    if (count > 0) {
      badgeEl.textContent   = count > 9 ? '9+' : count;
      badgeEl.style.display = 'flex';
      setTimeout(function () {
        btn.classList.add('ringing');
        setTimeout(function () { btn.classList.remove('ringing'); }, 700);
      }, 1600);
    } else {
      badgeEl.style.display = 'none';
    }

    if (subEl) {
      subEl.textContent = count > 0
        ? count + ' crop' + (count !== 1 ? 's' : '') + ' need harvesting soon'
        : 'No upcoming harvests right now';
    }

    if (items.length === 0) {
      listEl.innerHTML =
        '<div class="hdr-np-empty">' +
          '<i class="bi bi-check-circle" style="color:#16a34a;"></i>' +
          '<span>All harvests are up to date!</span>' +
        '</div>';
      return;
    }

    listEl.innerHTML = items.map(function (it) {
      var days  = daysUntil(it.date);
      var style = urgencyStyle(days);
      return (
        '<div class="hdr-np-item">' +
          '<div class="hdr-np-emoji">' + cropEmoji(it.name) + '</div>' +
          '<div class="hdr-np-body">' +
            '<div class="hdr-np-name">' + it.name + '</div>' +
            '<div class="hdr-np-parcel">' +
              '<i class="bi bi-map-fill" style="color:#16a34a;font-size:.65rem;"></i>' + it.parcelle +
            '</div>' +
            '<span class="hdr-np-chip" style="' + style + '">' +
              '<i class="bi bi-calendar3"></i>' + it.dateDisplay +
            '</span>' +
          '</div>' +
          '<div class="hdr-np-days">' + daysLabel(days) + '</div>' +
        '</div>'
      );
    }).join('');
  }

  /* ── read data from cultures page if present, else show link ── */
  function init() {
    var dataEl = document.getElementById('ccUpcomingData');
    if (dataEl) {
      var items = [];
      try { items = JSON.parse(dataEl.dataset.items || '[]'); } catch (e) {}
      /* Keep all items with a date — past ones show as overdue, not silently hidden */
      items = items.filter(function (it) {
        return !!it.date;
      }).sort(function (a, b) {
        return new Date(a.date) - new Date(b.date);
      });
      populate(items);
    } else {
      /* not on cultures page — show a prompt */
      badgeEl.style.display = 'none';
      if (subEl) subEl.textContent = 'Visit Crops page to see harvests';
      listEl.innerHTML =
        '<div class="hdr-np-empty">' +
          '<i class="bi bi-flower2"></i>' +
          '<span style="font-size:.8rem;">Open the <strong>Crops</strong> page to load upcoming harvest alerts.</span>' +
        '</div>';
    }
  }

  /* ── toggle ── */
  var isOpen = false;
  function openPanel()  { isOpen = true;  panel.classList.add('open');    btn.setAttribute('aria-expanded','true');  }
  function closePanel() { isOpen = false; panel.classList.remove('open'); btn.setAttribute('aria-expanded','false'); }

  btn.addEventListener('click', function (e) { e.stopPropagation(); isOpen ? closePanel() : openPanel(); });
  if (closeEl) closeEl.addEventListener('click', function (e) { e.stopPropagation(); closePanel(); });
  document.addEventListener('click', function (e) {
    var w = document.getElementById('hdrNotifWrapper');
    if (isOpen && w && !w.contains(e.target)) closePanel();
  });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && isOpen) closePanel(); });

  /* run after DOM is ready */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
