<style>
/* ── Notification Bell in Header ── */
#hdrNotifWrapper {
  position: relative;
  display: flex;
  align-items: center;
}
#hdrNotifBtn {
  display: flex; align-items: center; justify-content: center;
  width: 40px; height: 40px; border-radius: 50%;
  background: linear-gradient(135deg, #116530 0%, #0c4a23 100%);
  border: none; cursor: pointer; flex-shrink: 0;
  transition: all 0.3s ease;
  box-shadow: 0 2px 8px rgba(17,101,48,0.15);
  text-decoration: none; color: white; position: relative;
}
#hdrNotifBtn:hover { transform: scale(1.1); box-shadow: 0 4px 14px rgba(17,101,48,0.3); }
#hdrNotifBtn.ringing { animation: hdr-bell-ring 0.65s cubic-bezier(0.36,0.07,0.19,0.97) both; }
@keyframes hdr-bell-ring {
  0%,100% { transform: rotate(0); }
  15%     { transform: rotate(15deg); }
  30%     { transform: rotate(-13deg); }
  45%     { transform: rotate(10deg); }
  60%     { transform: rotate(-7deg); }
  75%     { transform: rotate(4deg); }
}
#hdrNotifBtn i { font-size: 1.1rem; }
#hdrNotifBadge {
  position: absolute; top: -4px; right: -4px;
  background: #ef4444; color: #fff;
  font-size: 0.6rem; font-weight: 800;
  min-width: 18px; height: 18px;
  border-radius: 9px; padding: 0 4px;
  display: none; align-items: center; justify-content: center;
  border: 2px solid #fff;
  box-shadow: 0 2px 6px rgba(239,68,68,0.4);
  animation: hdr-badge-pop 0.35s cubic-bezier(0.34,1.56,0.64,1) both;
}
@keyframes hdr-badge-pop { from { transform:scale(0); } to { transform:scale(1); } }

#hdrNotifPanel {
  position: absolute;
  top: 52px; right: -8px;
  width: 320px;
  max-height: 420px;
  background: #fff;
  border-radius: 18px;
  box-shadow: 0 16px 52px rgba(0,0,0,0.18), 0 4px 16px rgba(0,0,0,0.08);
  overflow: hidden;
  display: flex; flex-direction: column;
  z-index: 9999;
  transform: scale(0.88) translateY(-12px);
  transform-origin: top right;
  opacity: 0; visibility: hidden;
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1),
              opacity 0.25s ease, visibility 0s linear 0.3s;
  pointer-events: none;
}
#hdrNotifPanel.open {
  transform: scale(1) translateY(0);
  opacity: 1; visibility: visible;
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1),
              opacity 0.25s ease, visibility 0s linear 0s;
  pointer-events: all;
}
.hdr-np-head {
  background: linear-gradient(135deg, #052e16 0%, #116530 100%);
  padding: 14px 16px;
  display: flex; align-items: flex-start; gap: 10px; flex-shrink: 0;
}
.hdr-np-head-icon { font-size: 1.15rem; color: #fbbf24; flex-shrink: 0; margin-top: 1px; }
.hdr-np-head-text { flex: 1; }
.hdr-np-head-text h6 { color: #fff; margin: 0; font-size: 0.88rem; font-weight: 800; }
.hdr-np-head-text span { color: rgba(255,255,255,0.6); font-size: 0.68rem; }
.hdr-np-close {
  width: 26px; height: 26px; border-radius: 50%;
  background: rgba(255,255,255,0.14); border: none;
  color: #fff; cursor: pointer; font-size: 0.75rem;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: background 0.2s;
}
.hdr-np-close:hover { background: rgba(255,255,255,0.28); }
.hdr-np-list {
  overflow-y: auto; flex: 1;
  scrollbar-width: thin; scrollbar-color: #d1fae5 transparent;
}
.hdr-np-item {
  display: flex; align-items: flex-start; gap: 11px;
  padding: 12px 15px; border-bottom: 1px solid #f3f4f6;
  transition: background 0.15s;
}
.hdr-np-item:last-child { border-bottom: none; }
.hdr-np-item:hover { background: #f9fafb; }
.hdr-np-emoji {
  width: 36px; height: 36px; border-radius: 10px;
  background: linear-gradient(135deg, #f0fdf4, #dcfce7);
  border: 1.5px solid #bbf7d0;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem; flex-shrink: 0; margin-top: 1px;
}
.hdr-np-body { flex: 1; min-width: 0; }
.hdr-np-name {
  font-size: 0.82rem; font-weight: 700; color: #111827;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  margin-bottom: 2px;
}
.hdr-np-parcel {
  font-size: 0.68rem; color: #6b7280;
  display: flex; align-items: center; gap: 3px; margin-bottom: 5px;
}
.hdr-np-chip {
  display: inline-flex; align-items: center; gap: 3px;
  font-size: 0.65rem; font-weight: 700;
  padding: 2px 8px; border-radius: 20px;
}
.hdr-np-days {
  font-size: 0.65rem; font-weight: 800;
  white-space: nowrap; flex-shrink: 0;
  text-align: right; margin-top: 3px;
}
.hdr-np-empty {
  padding: 32px 16px; text-align: center; color: #9ca3af;
}
.hdr-np-empty i { font-size: 2rem; display: block; margin-bottom: 8px; }
.hdr-np-footer {
  padding: 10px 16px; border-top: 1px solid #f3f4f6;
  text-align: center; flex-shrink: 0; background: #fafafa;
}
.hdr-np-footer a {
  font-size: 0.75rem; font-weight: 700; color: #116530;
  text-decoration: none;
  display: inline-flex; align-items: center; gap: 4px;
}
.hdr-np-footer a:hover { color: #052e16; }
@media (max-width: 480px) {
  #hdrNotifPanel { width: calc(100vw - 24px); right: -4px; }
}

.hdr-admin-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-left: 12px;
  padding: 8px 12px;
  border-radius: 10px;
  background: linear-gradient(135deg, #0b3b8f 0%, #1d4ed8 100%);
  color: #fff;
  text-decoration: none;
  font-size: 0.82rem;
  font-weight: 700;
  box-shadow: 0 4px 12px rgba(29, 78, 216, 0.25);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.hdr-admin-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 16px rgba(29, 78, 216, 0.35);
  color: #fff;
}

@media (max-width: 1199.98px) {
  .hdr-admin-btn {
    display: none;
  }
}
</style>

