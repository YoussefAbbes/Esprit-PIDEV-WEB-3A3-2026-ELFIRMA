<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <title>{% block title %}EL FIRMA{% endblock %}</title>
  <meta name="description" content="{% block meta_description %}{% endblock %}">
  <meta name="keywords" content="{% block meta_keywords %}{% endblock %}">

  <!-- Favicons -->
  <link href="{{ asset('assets/img/favicon.png') }}" rel="icon">
  <link href="{{ asset('assets/img/apple-touch-icon.png') }}" rel="apple-touch-icon">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400;1,500;1,600;1,700;1,800&family=Marcellus:wght@400&display=swap" rel="stylesheet">

  <!-- Vendor CSS Files -->
  <link href="{{ asset('assets/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
  <link href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}" rel="stylesheet">

  <!-- Main CSS File -->
  <link href="{{ asset('assets/css/main.css') }}" rel="stylesheet">

  {% block stylesheets %}{% endblock %}

  <style>
    :root {
      --accent-color: #116530;
      --heading-color: #2d465e;
      --default-color: #212529;
      --background-color: #ffffff;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      height: 100%;
      width: 100%;
      overflow-x: hidden;
    }

    body.auth-page {
      min-height: 100vh;
      font-family: 'Open Sans', sans-serif;
      color: var(--default-color);
      position: relative;
    }

    /* Background Image with Overlay */
    body.auth-page::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: url('/assets/img/hero_1.jpg');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      filter: brightness(0.55) saturate(1.1);
      z-index: -2;
    }

    body.auth-page::after {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(135deg,
        rgba(45, 70, 94, 0.65) 0%,
        rgba(6, 6, 6, 0.45) 50%,
        rgba(17, 101, 48, 0.25) 100%);
      z-index: -1;
    }

    /* Main Wrapper */
    .auth-wrapper {
      width: 100%;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      position: relative;
      z-index: 1;
    }

    /* Header with Logo */
    .auth-header-bar {
      padding: 20px 40px;
      display: flex;
      justify-content: center;
      align-items: center;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(10px);
      box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
      animation: slideDown 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
      border-bottom: 3px solid var(--accent-color);
    }

    .auth-header-logo {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .auth-header-logo img {
      width: 50px;
      height: auto;
      animation: logoEnter 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
    }

    .auth-header-logo h1 {
      font-family: 'Marcellus', serif;
      font-size: 1.8rem;
      color: var(--heading-color);
      margin: 0;
      font-weight: 400;
      animation: logoEnter 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
    }

    /* Content Area */
    .auth-content-wrapper {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
    }

    /* Main Container */
    .auth-container {
      width: 100%;
      max-width: 1200px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }

    /* Left Side - Brand */
    .auth-brand {
      padding: 40px;
      display: flex;
      flex-direction: column;
      gap: 30px;
      animation: slideInLeft 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.4s both;
    }

    .auth-logo-section {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .auth-logo-section h2 {
      font-family: 'Marcellus', serif;
      font-size: 2.8rem;
      color: #ffffff;
      font-weight: 400;
      line-height: 1.2;
      text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    }

    .auth-logo-section p {
      font-size: 1.05rem;
      color: rgba(255, 255, 255, 0.9);
      line-height: 1.6;
      text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
    }

    .auth-features {
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    .auth-feature {
      display: flex;
      align-items: flex-start;
      gap: 15px;
      background: rgba(255, 255, 255, 0.1);
      padding: 16px;
      border-radius: 10px;
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      transition: all 0.3s ease;
      animation: slideInLeft 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    .auth-feature:nth-child(1) { animation-delay: 0.5s; }
    .auth-feature:nth-child(2) { animation-delay: 0.6s; }
    .auth-feature:nth-child(3) { animation-delay: 0.7s; }

    .auth-feature:hover {
      background: rgba(255, 255, 255, 0.15);
      transform: translateX(8px);
    }

    .auth-feature i {
      color: #4ade80;
      font-size: 1.3rem;
      flex-shrink: 0;
      margin-top: 3px;
    }

    .auth-feature span {
      color: rgba(255, 255, 255, 0.95);
      font-size: 0.95rem;
      font-weight: 500;
    }

    /* Right Side - Form */
    .auth-form-section {
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(20px);
      padding: 50px 45px;
      border-radius: 16px;
      box-shadow: 0 20px 80px rgba(0, 0, 0, 0.3),
                  0 0 40px rgba(17, 101, 48, 0.2);
      animation: slideInRight 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.8s both;
      border-top: 4px solid var(--accent-color);
      position: relative;
      overflow: hidden;
    }

    .auth-form-section::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -30%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(17, 101, 48, 0.1) 0%, transparent 70%);
      border-radius: 50%;
      animation: float 6s ease-in-out infinite;
    }

    .auth-form-header {
      margin-bottom: 35px;
      text-align: center;
      position: relative;
      z-index: 1;
    }

    .auth-form-header h2 {
      font-family: 'Marcellus', serif;
      font-size: 2rem;
      color: var(--heading-color);
      font-weight: 400;
      margin-bottom: 12px;
    }

    .auth-form-header p {
      color: #888;
      font-size: 0.95rem;
    }

    .auth-form {
      display: flex;
      flex-direction: column;
      gap: 20px;
      position: relative;
      z-index: 1;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
      animation: slideInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    .form-group:nth-child(1) { animation-delay: 0.9s; }
    .form-group:nth-child(2) { animation-delay: 1s; }
    .form-group:nth-child(3) { animation-delay: 1.1s; }
    .form-group:nth-child(4) { animation-delay: 1.2s; }
    .form-group:nth-child(5) { animation-delay: 1.3s; }

    .form-group label {
      font-weight: 600;
      color: var(--heading-color);
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .form-control {
      padding: 12px 16px;
      border: 2px solid #e0e0e0;
      border-radius: 10px;
      font-size: 0.95rem;
      font-family: 'Open Sans', sans-serif;
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      background: #fafafa;
    }

    .form-control::placeholder {
      color: #ccc;
    }

    .form-control:focus {
      border-color: var(--accent-color);
      background: white;
      box-shadow: 0 0 0 4px rgba(17, 101, 48, 0.1);
      outline: none;
      transform: translateY(-2px);
    }

    .form-check {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.9rem;
      color: #555;
    }

    .form-check input {
      width: 18px;
      height: 18px;
      cursor: pointer;
      accent-color: var(--accent-color);
    }

    .form-check a {
      color: var(--accent-color);
      font-weight: 600;
    }

    .btn-auth {
      padding: 13px 24px;
      background: linear-gradient(135deg, var(--accent-color) 0%, #0d4c23 100%);
      color: white;
      border: none;
      border-radius: 10px;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 1.2px;
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      margin-top: 10px;
      animation: slideInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 1.4s both;
      position: relative;
      overflow: hidden;
    }

    .btn-auth::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      width: 0;
      height: 0;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.3);
      transform: translate(-50%, -50%);
      transition: width 0.6s, height 0.6s;
      z-index: 0;
    }

    .btn-auth span {
      position: relative;
      z-index: 1;
    }

    .btn-auth:hover {
      background: linear-gradient(135deg, #0d4c23 0%, #082f17 100%);
      transform: translateY(-3px);
      box-shadow: 0 12px 30px rgba(17, 101, 48, 0.35);
    }

    .btn-auth:hover::before {
      width: 400px;
      height: 400px;
    }

    .btn-auth:active {
      transform: translateY(-1px);
    }

    .form-divider {
      display: flex;
      align-items: center;
      gap: 15px;
      margin: 20px 0;
      color: #ccc;
      animation: slideInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 1.5s both;
    }

    .form-divider::before,
    .form-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #ddd;
    }

    .form-divider span {
      font-size: 0.85rem;
      color: #999;
    }

    .auth-footer {
      text-align: center;
      margin-top: 25px;
      padding-top: 20px;
      border-top: 1px solid #f0f0f0;
      animation: slideInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 1.6s both;
      position: relative;
      z-index: 1;
    }

    .auth-footer p {
      font-size: 0.9rem;
      color: #666;
    }

    .auth-footer a {
      color: var(--accent-color);
      font-weight: 700;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .auth-footer a:hover {
      color: #0d4c23;
    }

    /* Password Strength */
    .password-strength {
      height: 6px;
      background: #e8e8e8;
      border-radius: 3px;
      overflow: hidden;
      margin-top: 6px;
    }

    .password-strength-meter {
      height: 100%;
      width: 0;
      transition: width 0.4s ease, background-color 0.3s ease;
      border-radius: 3px;
    }

    .password-strength-meter.weak {
      width: 33%;
      background: linear-gradient(90deg, #dc3545, #dd5a6f);
    }

    .password-strength-meter.medium {
      width: 66%;
      background: linear-gradient(90deg, #ffc107, #ffb300);
    }

    .password-strength-meter.strong {
      width: 100%;
      background: linear-gradient(90deg, var(--accent-color), #0d7c3d);
    }

    #strengthText {
      font-size: 0.75rem;
      font-weight: 600;
      margin-top: 4px;
      display: block;
    }

    /* Animations */
    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideInLeft {
      from {
        opacity: 0;
        transform: translateX(-50px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes slideInRight {
      from {
        opacity: 0;
        transform: translateX(50px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes slideInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes logoEnter {
      from {
        opacity: 0;
        transform: scale(0.8);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-20px);
      }
    }

    /* Responsive */
    @media (max-width: 1024px) {
      .auth-container {
        grid-template-columns: 1fr;
        gap: 40px;
      }

      .auth-brand {
        padding: 20px;
      }

      .auth-logo-section h2 {
        font-size: 2.2rem;
      }

      .auth-form-section {
        padding: 40px 35px;
      }
    }

    @media (max-width: 640px) {
      .auth-header-bar {
        padding: 15px 20px;
      }

      .auth-header-logo img {
        width: 40px;
      }

      .auth-header-logo h1 {
        font-size: 1.4rem;
      }

      .auth-content-wrapper {
        padding: 25px 15px;
      }

      .auth-container {
        gap: 30px;
      }

      .auth-brand {
        padding: 15px;
      }

      .auth-logo-section h2 {
        font-size: 1.8rem;
      }

      .auth-logo-section p {
        font-size: 0.95rem;
      }

      .auth-form-section {
        padding: 30px 20px;
      }

      .auth-form-header h2 {
        font-size: 1.5rem;
      }

      .btn-auth {
        padding: 11px 20px;
        font-size: 0.9rem;
      }

      .auth-feature {
        padding: 12px;
        gap: 12px;
      }

      .auth-feature i {
        font-size: 1.1rem;
      }

      .auth-feature span {
        font-size: 0.85rem;
      }
    }
  </style>
</head>

<body class="auth-page">

  <div class="auth-wrapper">
    <!-- Header with Logo -->
    <div class="auth-header-bar">
      <div class="auth-header-logo">
        <img src="{{ asset('assets/img/logo.png') }}" alt="EL FIRMA">
        <h1>EL FIRMA</h1>
      </div>
    </div>

    <!-- Content -->
    <div class="auth-content-wrapper">
      <div class="auth-container">
        {% block content %}{% endblock %}
      </div>
    </div>
  </div>

  <!-- Vendor JS Files -->
  <script src="{{ asset('assets/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
  
  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  {% block javascripts %}{% endblock %}

</body>

</html>
