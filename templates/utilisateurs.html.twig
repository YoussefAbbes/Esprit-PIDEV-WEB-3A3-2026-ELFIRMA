<!-- User Table Container -->
<div class="glass-card rounded-xl overflow-hidden border border-white/20 shadow-2xl">
<div class="overflow-x-auto">
<table class="w-full text-left border-collapse">
<thead>
<tr class="bg-surface-container-low/50">
<th class="px-8 py-6 text-xs font-black text-on-surface-variant uppercase tracking-widest">User</th>
<th class="px-8 py-6 text-xs font-black text-on-surface-variant uppercase tracking-widest">Email</th>
<th class="px-8 py-6 text-xs font-black text-on-surface-variant uppercase tracking-widest">Role</th>
<th class="px-8 py-6 text-xs font-black text-on-surface-variant uppercase tracking-widest">Created Date</th>
<th class="px-8 py-6 text-xs font-black uppercase">QR Code</th>
<th class="px-8 py-6 text-xs font-black text-on-surface-variant uppercase tracking-widest text-right">Actions</th>
</tr>
</thead>
<tbody class="divide-y divide-outline-variant/10">
{% if users is defined and users|length > 0 %}
  {% for user in users %}
    <tr class="hover:bg-white/30 transition-colors group">
      <td class="px-8 py-6">
        <div class="flex items-center gap-4">
          {% set photo = user.imageU %}
          {% if photo is null or photo == '' or photo == 'default.JPG' %}
            <img src="{{ asset('assets/img/default.JPG') }}" class="w-12 h-12 rounded-full object-cover" alt="{{ user.nomU }} {{ user.prenomU }}">
          {% elseif photo starts with 'uploads/' %}
            <img src="{{ asset(photo) }}" class="w-12 h-12 rounded-full object-cover" alt="{{ user.nomU }} {{ user.prenomU }}">
          {% elseif photo starts with 'http' or photo starts with '/' %}
            <img src="{{ photo }}" class="w-12 h-12 rounded-full object-cover" alt="{{ user.nomU }} {{ user.prenomU }}">
          {% else %}
            <img src="{{ asset('uploads/users/' ~ photo) }}" class="w-12 h-12 rounded-full object-cover" alt="{{ user.nomU }} {{ user.prenomU }}">
          {% endif %}
          <div>
            <p class="font-bold text-primary">{{ user.nomU }} {{ user.prenomU }}</p>
            <p class="text-sm text-on-surface-variant">{{ user.emailU }}</p>
          </div>
        </div>
      </td>
      <td class="px-8 py-6">
        <p class="text-sm text-on-surface-variant">{{ user.emailU }}</p>
      </td>
      <td class="px-8 py-6">
        {% if user.roleU == 'employee' %}
          <span class="px-4 py-1 rounded-full bg-[#43682b] text-white text-xs font-bold">Employee</span>
        {% elseif user.roleU == 'client' %}
          <span class="px-4 py-1 rounded-full bg-[#934b19] text-white text-xs font-bold">Client</span>
        {% elseif user.roleU == 'admin' %}
          <span class="px-4 py-1 rounded-full bg-[#9c27b0] text-white text-xs font-bold">Admin</span>
        {% else %}
          <span class="px-4 py-1 rounded-full bg-primary-container text-white text-xs font-bold">{{ user.roleU }}</span>
        {% endif %}
      </td>
      <td class="px-8 py-6">
        <p class="text-sm text-on-surface-variant">{{ user.dateCreationU ? user.dateCreationU|date('M d, Y') : 'N/A' }}</p>
      </td>
      <td class="text-center align-middle">
    <button class="btn btn-dark d-flex justify-content-center align-items-center mx-auto"
            onclick="showQr('{{ user.qrCode }}')"
            style="width: 45px; height: 45px; border-radius: 10px;">
        <i class="fa-solid fa-qrcode" style="font-size: 40px;"></i>
    </button>
</td>
      <td class="px-8 py-6 text-right">
        <div class="flex items-center justify-end gap-2">
          <button class="p-2 rounded-full hover:bg-primary/5 text-primary transition-all edit-user-btn" data-user-id="{{ user.idU }}" data-nom="{{ user.nomU }}" data-prenom="{{ user.prenomU }}" data-email="{{ user.emailU }}" data-role="{{ user.roleU }}" data-image="{{ user.imageU }}">
            <span class="material-symbols-outlined" data-icon="edit">edit</span>
          </button>
          <button class="p-2 rounded-full hover:bg-error/5 text-error transition-all delete-user-btn" data-user-id="{{ user.idU }}" data-user-name="{{ user.nomU }} {{ user.prenomU }}">
            <span class="material-symbols-outlined" data-icon="delete">delete</span>
          </button>
        </div>
      </td>
    </tr>
  {% endfor %}
{% else %}
  <tr>
    <td colspan="5" class="px-8 py-12 text-center">
      <div class="flex flex-col items-center justify-center">
        <span class="material-symbols-outlined text-4xl text-outline mb-4">person_search</span>
        <p class="text-on-surface-variant font-semibold">No users found</p>
      </div>
    </td>
  </tr>
{% endif %}
</tbody>
</table>
</div>
<!-- Empty State Concept (Hidden by default but integrated) -->
<div class="hidden flex-col items-center justify-center py-24 text-center">
<div class="w-24 h-24 rounded-full bg-surface-container-low flex items-center justify-center mb-6">
<span class="material-symbols-outlined text-4xl text-outline" data-icon="person_search">person_search</span>
</div>
<h3 class="text-2xl font-black text-primary mb-2">No user found</h3>
<p class="text-on-surface-variant max-w-sm mx-auto">We found no results for your search. Try adjusting your filters.</p>
<button class="mt-8 px-8 py-3 bg-primary text-surface rounded-full font-bold">View all users</button>
</div>
<!-- Pagination -->
<div class="px-8 py-6 bg-surface-container-low/30 flex items-center justify-between border-t border-outline-variant/10">
<p class="text-sm text-on-surface-variant font-medium">Showing <span class="font-bold text-primary">1-10</span> of <span class="font-bold text-primary">{{ totalUsers is defined ? totalUsers : 0 }}</span> users</p>
<div class="flex items-center gap-2">
<button class="p-2 rounded-full hover:bg-surface-container-highest disabled:opacity-30 transition-all" disabled="">
<span class="material-symbols-outlined" data-icon="chevron_left">chevron_left</span>
</button>
<div class="flex items-center gap-1">
<button class="w-10 h-10 rounded-full bg-primary text-surface font-bold">1</button>
<button class="w-10 h-10 rounded-full hover:bg-surface-container-highest font-bold transition-all">2</button>
<button class="w-10 h-10 rounded-full hover:bg-surface-container-highest font-bold transition-all">3</button>
<span class="px-2">...</span>
<button class="w-10 h-10 rounded-full hover:bg-surface-container-highest font-bold transition-all">5</button>
</div>
<button class="p-2 rounded-full hover:bg-surface-container-highest transition-all">
<span class="material-symbols-outlined" data-icon="chevron_right">chevron_right</span>
</button>
</div>
</div>
</div>
</section>

<!-- Complaints Section -->
<section class="p-8 flex-1 flex flex-col gap-8">
<div style="margin-top: 40px;">
  <h2 class="text-3xl font-black text-primary mb-6">Complaints Management</h2>

  <!-- Complaints Table -->
  <div class="glass-card rounded-xl overflow-hidden border border-white/20 shadow-2xl">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-surface-container-low/50">
            <th class="px-8 py-6 text-xs font-black text-on-surface-variant uppercase tracking-widest">Title</th>
            <th class="px-8 py-6 text-xs font-black text-on-surface-variant uppercase tracking-widest">Description</th>
            <th class="px-8 py-6 text-xs font-black text-on-surface-variant uppercase tracking-widest">Type</th>
            <th class="px-8 py-6 text-xs font-black text-on-surface-variant uppercase tracking-widest">User</th>
            <th class="px-8 py-6 text-xs font-black text-on-surface-variant uppercase tracking-widest">Date</th>
            <th class="px-8 py-6 text-xs font-black text-on-surface-variant uppercase tracking-widest">Status</th>
            <th class="px-8 py-6 text-xs font-black text-on-surface-variant uppercase tracking-widest text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/10">
          {% if complaints is defined and complaints|length > 0 %}
            {% for complaint in complaints %}
              <tr class="hover:bg-white/30 transition-colors group" id="complaint-{{ complaint.idrU }}">
                <td class="px-8 py-6">
                  <p class="font-bold text-primary">{{ complaint.titreU }}</p>
                </td>
                <td class="px-8 py-6">
                  <p class="text-sm text-on-surface-variant">{{ complaint.descriptionU }}</p>
                </td>
                <td class="px-8 py-6">
                  <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-semibold capitalize">{{ complaint.typeReclamationU }}</span>
                </td>
                <td class="px-8 py-6">
                  <p class="font-semibold text-primary">{{ complaint.utilisateur.nomU }} {{ complaint.utilisateur.prenomU }}</p>
                  <p class="text-xs text-on-surface-variant">{{ complaint.utilisateur.emailU }}</p>
                </td>
                <td class="px-8 py-6">
                  <p class="text-sm text-on-surface-variant">{{ complaint.dateReclamationU ? complaint.dateReclamationU|date('M d, Y') : 'N/A' }}</p>
                </td>
                <td class="px-8 py-6">
                  {% if complaint.statutU == 'pending' %}
                    <span class="px-3 py-1 rounded-full bg-yellow-100 text-yellow-800 text-xs font-bold">Pending</span>
                  {% elseif complaint.statutU == 'reviewed' %}
                    <span class="px-3 py-1 rounded-full bg-green-100 text-green-800 text-xs font-bold">Reviewed</span>
                  {% else %}
                    <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-800 text-xs font-bold">{{ complaint.statutU|capitalize }}</span>
                  {% endif %}
                </td>
                <td class="px-8 py-6 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <button class="p-2 rounded-full hover:bg-primary/5 text-primary transition-all reply-complaint-btn" data-complaint-id="{{ complaint.idrU }}" data-user-email="{{ complaint.utilisateur.emailU }}" data-complaint-title="{{ complaint.titreU }}" title="Reply by Email">
                      <span class="material-symbols-outlined" data-icon="reply">reply</span>
                    </button>
