<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>User Profile</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        body {
            background: radial-gradient(circle at top left, #d1fae5, #ecfdf5, #f0fdf4);
        }
    </style>
</head>

<body class="min-h-screen flex items-center justify-center">

<!-- CARD -->
<div class="backdrop-blur-xl bg-white/80 shadow-2xl rounded-3xl p-8 
            w-full max-w-md sm:max-w-lg 
            mx-4 border border-green-200 relative overflow-hidden">

    <!-- DECOR -->
    <div class="absolute -top-10 -right-10 w-40 h-40 bg-green-300 rounded-full opacity-30"></div>
    <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-green-400 rounded-full opacity-20"></div>

    <!-- PHOTO -->
    <div class="flex justify-center relative">
        <div class="p-1 rounded-full bg-gradient-to-tr from-green-500 to-emerald-300 shadow-lg">
            <img
                src="{{ asset(user.imageU) }}"
                class="w-32 h-32 sm:w-36 sm:h-36 rounded-full object-cover border-4 border-white"
                alt="profile"
            >
        </div>
    </div>

    <!-- NAME -->
    <h1 class="text-3xl sm:text-4xl font-bold text-center text-green-900 mt-6">
        {{ user.nomU }} {{ user.prenomU }}
    </h1>

    <!-- EMAIL -->
    <div class="flex items-center justify-center gap-2 mt-3 text-gray-600 text-base sm:text-lg">
        <i class="fa-solid fa-envelope text-green-600"></i>
        <span>{{ user.emailU }}</span>
    </div>

    <!-- ROLE -->
    <div class="mt-6 flex justify-center">
        <span class="px-6 py-2 rounded-full text-white text-sm sm:text-base font-semibold shadow-md
            {% if user.roleU == 'admin' %}
                bg-purple-600
            {% elseif user.roleU == 'employee' %}
                bg-green-600
            {% else %}
                bg-orange-500
            {% endif %}
        ">
            {{ user.roleU|capitalize }}
        </span>
    </div>

    <!-- INFO BOX -->
    <div class="mt-6 bg-white/70 rounded-xl p-5 border border-green-100 shadow-sm">

        <div class="text-sm sm:text-base text-gray-700 space-y-3">

            <div class="flex justify-between">
                <span>ID</span>
                <span class="font-semibold text-green-900">#{{ user.idU }}</span>
            </div>

            <div class="flex justify-between">
                <span>Status</span>
                <span class="text-green-700 font-semibold">Active</span>
            </div>

            <div class="flex justify-between">
                <span>System</span>
                <span class="text-gray-500">Elfirma</span>
            </div>

        </div>
    </div>

    <!-- FOOTER -->
    <div class="mt-7 text-center text-xs sm:text-sm text-gray-400">
        🌿 Elfirma Agricultural System
    </div>

</div>

</body>
</html>

