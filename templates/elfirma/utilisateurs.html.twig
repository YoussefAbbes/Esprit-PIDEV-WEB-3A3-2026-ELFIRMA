<!-- Reply to Complaint Script -->
<script>
  const replyComplaintModal = document.getElementById('replyComplaintModal');
  const replyComplaintForm = document.getElementById('replyComplaintForm');
  const closeReplyModalBtn = document.getElementById('closeReplyModalBtn');
  const cancelReplyBtn = document.getElementById('cancelReplyBtn');
  const replyMessage = document.getElementById('replyMessage');
  const charCount = document.getElementById('charCount');

  // Character counter
  if (replyMessage) {
    replyMessage.addEventListener('input', function() {
      charCount.textContent = this.value.length;
    });
  }

  // Reply button handlers
  document.querySelectorAll('.reply-complaint-btn').forEach(btn => {
    btn.addEventListener('click', async function(e) {
      e.preventDefault();
      const complaintId = this.getAttribute('data-complaint-id');
      const userEmail = this.getAttribute('data-user-email');
      const complaintTitle = this.getAttribute('data-complaint-title');

      if (!complaintId) {
        alert('Error: Complaint ID not found');
        return;
      }

      // Get complaint details from row
      const row = document.getElementById('complaint-' + complaintId);
      const titleCell = row.querySelector('td:nth-child(1)');
      const userCell = row.querySelector('td:nth-child(4)');

      // Fill modal
      document.getElementById('replyComplaintId').value = complaintId;
      document.getElementById('replyComplaintTitle').textContent = titleCell ? titleCell.textContent.trim() : 'Complaint';
      document.getElementById('replyComplaintUser').textContent = 'To: ' + (userEmail || 'User');
      document.getElementById('replyMessage').value = '';
      charCount.textContent = '0';

      // Clear errors
      document.getElementById('replyMessage').classList.remove('error-field');
      document.getElementById('replyMessageError').textContent = '';

      // Open modal
      replyComplaintModal.classList.remove('hidden');
    });
  });

  // Close modal handlers
  closeReplyModalBtn.addEventListener('click', function() {
    replyComplaintModal.classList.add('hidden');
  });

  cancelReplyBtn.addEventListener('click', function() {
    replyComplaintModal.classList.add('hidden');
  });

  // Close on backdrop click
  replyComplaintModal.addEventListener('click', function(e) {
    if (e.target === replyComplaintModal) {
      replyComplaintModal.classList.add('hidden');
    }
  });

  // Form submission
  replyComplaintForm.addEventListener('submit', async function(e) {
    e.preventDefault();

    // Clear previous errors
    document.getElementById('replyMessage').classList.remove('error-field');
    document.getElementById('replyMessageError').textContent = '';

    // Get form data
    const complaintId = document.getElementById('replyComplaintId').value;
    const message = replyMessage.value.trim();

    // Validation
    if (!complaintId) {
      alert('Error: Complaint ID not found');
      return;
    }

    if (!message) {
      document.getElementById('replyMessage').classList.add('error-field');
      document.getElementById('replyMessageError').textContent = 'Reply message is required';
      return;
    }

    if (message.length < 10) {
      document.getElementById('replyMessage').classList.add('error-field');
      document.getElementById('replyMessageError').textContent = 'Reply message must be at least 10 characters long';
      return;
    }

    // Show loading state
    const submitBtn = document.getElementById('submitReplyBtn');
    const originalText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">hourglass_empty</span><span>Sending...</span>';

    try {
      const response = await fetch('{{ path('elfirma_reply_complaint') }}', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: new URLSearchParams({
          complaint_id: complaintId,
          reply_message: message
        })
      });

      const data = await response.json();

      if (data.success) {
        // Show success message
        Swal.fire({
          title: 'Success!',
          text: data.message || 'Reply sent successfully!',
          icon: 'success',
          confirmButtonColor: '#43682b'
        }).then(() => {
          // Close modal and reset form
          replyComplaintModal.classList.add('hidden');
          replyComplaintForm.reset();
          charCount.textContent = '0';

          // Update status in table if needed
          const row = document.getElementById('complaint-' + complaintId);
          if (row) {
            const statusCell = row.querySelector('td:nth-child(6)');
            if (statusCell) {
              statusCell.innerHTML = '<span class="px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold">Responded</span>';
            }
          }
        });
      } else {
        // Show error message
        if (data.errors) {
          for (const [field, errorMsg] of Object.entries(data.errors)) {
            if (field === 'reply_message') {
              document.getElementById('replyMessage').classList.add('error-field');
              document.getElementById('replyMessageError').textContent = errorMsg;
            }
          }
        } else {
          Swal.fire({
            title: 'Error!',
            text: data.message || 'An error occurred while sending the reply',
            icon: 'error',
            confirmButtonColor: '#ba1a1a'
          });
        }
      }
    } catch (error) {
      console.error('Error:', error);
      Swal.fire({
        title: 'Error!',
        text: 'An error occurred while sending the reply',
        icon: 'error',
        confirmButtonColor: '#ba1a1a'
      });
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  });
</script>

<script>
  // Search filtering
  document.addEventListener('DOMContentLoaded', function() {
    const headerSearchInput = document.getElementById('headerSearchInput');

    if (headerSearchInput) {
      headerSearchInput.addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase();
        const tableRows = document.querySelectorAll('tbody tr');

        tableRows.forEach(row => {
          // Skip empty state row
          if (row.querySelector('td[colspan]')) return;

          const fullText = row.textContent.toLowerCase();
          row.style.display = fullText.includes(searchTerm) ? '' : 'none';
        });
      });
    }
  });
</script>

