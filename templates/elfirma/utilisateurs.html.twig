{% extends "baseback.html.twig" %}

{% block title %}User Management - Elfirma{% endblock %}

{% block body %}
<!-- TopNavBar Component -->
<header class="sticky top-0 z-30 flex justify-between items-center w-full px-8 py-4 bg-surface border-b border-outline-variant/10 backdrop-blur-md">
  <div class="flex items-center gap-4 flex-1">
    <h1 class="text-2xl font-black text-primary">User Management</h1>
  </div>
  <div class="flex items-center gap-4">
    <a href="/home" class="flex items-center gap-2 px-6 py-2.5 bg-primary text-on-primary font-semibold rounded-full hover:shadow-lg transition-all hover:translate-y-[-2px] shadow-md text-sm">
      <span class="material-symbols-outlined text-lg" data-icon="language">language</span>
      Website
    </a>
    <button class="p-3 rounded-full text-primary hover:bg-surface-container-low transition-colors active:scale-95">
      <span class="material-symbols-outlined" data-icon="notifications">notifications</span>
    </button>
    <button class="p-3 rounded-full text-primary hover:bg-surface-container-low transition-colors active:scale-95">
      <span class="material-symbols-outlined" data-icon="settings">settings</span>
    </button>
    <button onclick="window.location.href='{{ path('elfirma_profile') }}'" class="p-3 rounded-full text-primary hover:bg-surface-container-low transition-colors active:scale-95">
      <span class="material-symbols-outlined" data-icon="account_circle">account_circle</span>
    </button>
  </div>
</header>

<div class="flex flex-col gap-8 p-8 bg-surface min-h-screen">
  <!-- Header Section -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
    <div>
      <h2 class="text-3xl font-black text-primary tracking-tight mb-2">User Management</h2>
      <p class="text-on-surface-variant max-w-2xl text-sm">Manage access and roles for your agricultural team. Handle permissions for administrators, managers and workers.</p>
    </div>
    <button class="flex items-center gap-2 px-8 py-3 bg-primary text-on-primary font-bold rounded-full shadow-lg hover:shadow-xl hover:translate-y-[-2px] transition-all w-fit whitespace-nowrap" id="addUserBtn">
      <span class="material-symbols-outlined" data-icon="person_add">person_add</span>
      Add User
    </button>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Total Users Card -->
    <div class="bg-white rounded-2xl p-6 shadow-sm border border-outline-variant/10 hover:shadow-md transition-shadow">
      <div class="flex items-start justify-between mb-4">
        <div>
          <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-2">Total Users</p>
          <p class="text-4xl font-black text-primary">{{ totalUsers is defined ? totalUsers : 0 }}</p>
        </div>
        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
          <span class="material-symbols-outlined text-primary">person</span>
        </div>
      </div>
      <div class="flex items-center gap-2 text-sm">
        <span class="material-symbols-outlined text-sm text-primary-container">trending_up</span>
        <span class="text-on-surface-variant font-semibold">+3 this month</span>
      </div>
    </div>

    <!-- Active Users Card -->
    <div class="bg-white rounded-2xl p-6 shadow-sm border border-outline-variant/10 hover:shadow-md transition-shadow">
      <div class="flex items-start justify-between mb-4">
        <div>
          <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-2">Active Members</p>
          <p class="text-4xl font-black text-primary">{{ employeeCount is defined ? employeeCount + clientCount + adminCount : 0 }}</p>
        </div>
        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
          <span class="material-symbols-outlined text-primary">check_circle</span>
        </div>
      </div>
      <div class="w-full h-2 bg-surface-container-low rounded-full overflow-hidden">
        <div class="h-full bg-primary w-[85%]"></div>
      </div>
    </div>

    <!-- User Roles Card -->
    <div class="bg-white rounded-2xl p-6 shadow-sm border border-outline-variant/10 hover:shadow-md transition-shadow">
      <div class="flex items-start justify-between mb-4">
        <div>
          <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-2">User Roles</p>
          <div class="flex gap-3 items-center">
            <span class="text-sm font-bold">
              <span class="text-primary">{{ adminCount is defined ? adminCount : 0 }}</span>
              <span class="text-on-surface-variant">Admins</span>
            </span>
          </div>
        </div>
        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
          <span class="material-symbols-outlined text-primary">admin_panel_settings</span>
        </div>
      </div>
      <p class="text-xs text-on-surface-variant">{{ employeeCount is defined ? employeeCount : 0 }} Employees • {{ clientCount is defined ? clientCount : 0 }} Clients</p>
    </div>
  </div>

  <!-- User Distribution Chart -->
  {% if employeeCount is defined or clientCount is defined or adminCount is defined %}
  <div class="bg-white rounded-2xl p-8 shadow-sm border border-outline-variant/10">
    <h3 class="text-xl font-black text-primary mb-6">User Distribution</h3>
    <div class="flex items-center justify-center" style="height: 300px; width: 100%;">
      <canvas id="userDistributionChart"></canvas>
    </div>
  </div>
  {% endif %}
  <!-- Search and Actions -->
  <div class="flex flex-col md:flex-row md:items-center gap-4">
    <div class="relative flex-1 max-w-md">
      <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-lg">search</span>
      <input id="headerSearchInput" class="w-full pl-12 pr-4 py-3 bg-white border border-outline-variant/20 rounded-xl focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all text-sm font-medium" placeholder="Search users..." type="text"/>
    </div>
  </div>

  <!-- User Table Container -->
  <div class="bg-white rounded-2xl shadow-sm border border-outline-variant/10 overflow-hidden">
<div class="overflow-x-auto">
<table class="w-full text-left">
<thead>
<tr class="bg-surface-container-low border-b border-outline-variant/10">
<th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider">User</th>
<th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Email</th>
<th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Role</th>
<th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Joined</th>
<th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider">QR</th>
<th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider text-right">Actions</th>
</tr>
</thead>
<tbody class="divide-y divide-outline-variant/5">
{% if users is defined and users|length > 0 %}
  {% for user in users %}
    <tr class="hover:bg-surface-container-low/50 transition-colors">
      <td class="px-6 py-4">
        <div class="flex items-center gap-3">
          {% set photo = user.imageU %}
          {% if photo is null or photo == '' or photo == 'default.JPG' %}
            <img src="{{ asset('assets/img/default.JPG') }}" class="w-10 h-10 rounded-full object-cover flex-shrink-0" alt="{{ user.nomU }}">
          {% elseif photo starts with 'uploads/' %}
            <img src="{{ asset(photo) }}" class="w-10 h-10 rounded-full object-cover flex-shrink-0" alt="{{ user.nomU }}">
          {% elseif photo starts with 'http' or photo starts with '/' %}
            <img src="{{ photo }}" class="w-10 h-10 rounded-full object-cover flex-shrink-0" alt="{{ user.nomU }}">
          {% else %}
            <img src="{{ asset('uploads/users/' ~ photo) }}" class="w-10 h-10 rounded-full object-cover flex-shrink-0" alt="{{ user.nomU }}">
          {% endif %}
          <div>
            <p class="font-bold text-sm text-primary">{{ user.nomU }} {{ user.prenomU }}</p>
            <p class="text-xs text-on-surface-variant">{{ user.emailU }}</p>
          </div>
        </div>
      </td>
      <td class="px-6 py-4">
        <p class="text-sm text-on-surface-variant truncate">{{ user.emailU }}</p>
      </td>
      <td class="px-6 py-4">
        {% if user.roleU == 'employee' %}
          <span class="inline-flex px-3 py-1 bg-[#43682b]/10 text-[#43682b] text-xs font-bold rounded-full">Employee</span>
        {% elseif user.roleU == 'client' %}
          <span class="inline-flex px-3 py-1 bg-[#934b19]/10 text-[#934b19] text-xs font-bold rounded-full">Client</span>
        {% elseif user.roleU == 'admin' %}
          <span class="inline-flex px-3 py-1 bg-[#9c27b0]/10 text-[#9c27b0] text-xs font-bold rounded-full">Admin</span>
        {% else %}
          <span class="inline-flex px-3 py-1 bg-primary/10 text-primary text-xs font-bold rounded-full">{{ user.roleU }}</span>
        {% endif %}
      </td>
      <td class="px-6 py-4">
        <p class="text-sm text-on-surface-variant">{{ user.dateCreationU ? user.dateCreationU|date('M d, Y') : 'N/A' }}</p>
      </td>
      <td class="px-6 py-4 text-center">
        <button class="inline-flex items-center justify-center w-8 h-8 rounded-lg hover:bg-surface-container-low transition-colors" onclick="showQr('{{ user.qrCode }}')">
          <i class="fa-solid fa-qrcode text-sm text-primary"></i>
        </button>
      </td>
      <td class="px-6 py-4 text-right">
        <div class="flex items-center justify-end gap-1">
          <button class="p-2 rounded-lg hover:bg-primary/10 text-primary transition-all edit-user-btn" data-user-id="{{ user.idU }}" data-nom="{{ user.nomU }}" data-prenom="{{ user.prenomU }}" data-email="{{ user.emailU }}" data-role="{{ user.roleU }}" data-image="{{ user.imageU }}" title="Edit">
            <span class="material-symbols-outlined text-lg">edit</span>
          </button>
          <button class="p-2 rounded-lg hover:bg-error/10 text-error transition-all delete-user-btn" data-user-id="{{ user.idU }}" data-user-name="{{ user.nomU }} {{ user.prenomU }}" title="Delete">
            <span class="material-symbols-outlined text-lg">delete</span>
          </button>
        </div>
      </td>
    </tr>
  {% endfor %}
{% else %}
  <tr>
    <td colspan="6" class="px-6 py-16 text-center">
      <div class="flex flex-col items-center justify-center">
        <span class="material-symbols-outlined text-5xl text-outline-variant/50 mb-4">person_search</span>
        <p class="text-on-surface-variant font-semibold text-lg">No users found</p>
        <p class="text-on-surface-variant/70 text-sm mt-1">Try adjusting your search filters</p>
      </div>
    </td>
  </tr>
{% endif %}
</tbody>
</table>
</div>
  </div>

  <!-- Complaints Section -->
  <div>
    <h2 class="text-2xl font-black text-primary mb-6">Complaints Management</h2>

    <!-- Complaints Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-outline-variant/10 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="bg-surface-container-low border-b border-outline-variant/10">
            <th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Title</th>
            <th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Description</th>
            <th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Type</th>
            <th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider">User</th>
            <th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Date</th>
            <th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Status</th>
            <th class="px-6 py-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/5">
          {% if complaints is defined and complaints|length > 0 %}
            {% for complaint in complaints %}
              <tr class="hover:bg-surface-container-low/50 transition-colors" id="complaint-{{ complaint.idrU }}">
                <td class="px-6 py-4">
                  <p class="font-bold text-sm text-primary">{{ complaint.titreU }}</p>
                </td>
                <td class="px-6 py-4">
                  <p class="text-sm text-on-surface-variant truncate">{{ complaint.descriptionU }}</p>
                </td>
                <td class="px-6 py-4">
                  <span class="inline-flex px-3 py-1 bg-primary/10 text-primary text-xs font-semibold rounded-full capitalize">{{ complaint.typeReclamationU }}</span>
                </td>
                <td class="px-6 py-4">
                  <p class="font-semibold text-sm text-primary">{{ complaint.utilisateur.nomU }} {{ complaint.utilisateur.prenomU }}</p>
                  <p class="text-xs text-on-surface-variant">{{ complaint.utilisateur.emailU }}</p>
                </td>
                <td class="px-6 py-4">
                  <p class="text-sm text-on-surface-variant">{{ complaint.dateReclamationU ? complaint.dateReclamationU|date('M d, Y') : 'N/A' }}</p>
                </td>
                <td class="px-6 py-4">
                  {% if complaint.statutU == 'pending' %}
                    <span class="inline-flex px-3 py-1 bg-yellow-100 text-yellow-800 text-xs font-bold rounded-full">Pending</span>
                  {% elseif complaint.statutU == 'reviewed' %}
                    <span class="inline-flex px-3 py-1 bg-green-100 text-green-800 text-xs font-bold rounded-full">Reviewed</span>
                  {% else %}
                    <span class="inline-flex px-3 py-1 bg-gray-100 text-gray-800 text-xs font-bold rounded-full">{{ complaint.statutU|capitalize }}</span>
                  {% endif %}
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end gap-1">
                    <button class="p-2 rounded-lg hover:bg-primary/10 text-primary transition-all reply-complaint-btn" data-complaint-id="{{ complaint.idrU }}" data-user-email="{{ complaint.utilisateur.emailU }}" data-complaint-title="{{ complaint.titreU }}" title="Reply">
                      <span class="material-symbols-outlined text-lg">reply</span>
                    </button>
                    <button class="p-2 rounded-lg hover:bg-green-100/50 text-green-700 transition-all validate-complaint-btn" data-complaint-id="{{ complaint.idrU }}" title="Mark Reviewed">
                      <span class="material-symbols-outlined text-lg">check_circle</span>
                    </button>
                  </div>
                </td>
              </tr>
            {% endfor %}
          {% else %}
            <tr>
              <td colspan="7" class="px-6 py-16 text-center">
                <div class="flex flex-col items-center justify-center">
                  <span class="material-symbols-outlined text-5xl text-outline-variant/50 mb-4">chat_bubble_outline</span>
                  <p class="text-on-surface-variant font-semibold text-lg">No complaints found</p>
                  <p class="text-on-surface-variant/70 text-sm mt-1">All complaints have been handled</p>
                </div>
              </td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- JavaScript for Complaint Actions -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  document.querySelectorAll('.validate-complaint-btn').forEach(btn => {
    btn.addEventListener('click', async function() {
      const complaintId = this.getAttribute('data-complaint-id');
      const row = document.getElementById('complaint-' + complaintId);

      if (!complaintId) {
        alert('Error: Complaint ID not found');
        return;
      }

      try {
        const response = await fetch('{{ path('elfirma_validate_complaint') }}', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: 'complaint_id=' + complaintId
        });

        const data = await response.json();

        if (data.success) {
          // Update status badge
          const statusCell = row.querySelector('td:nth-child(6)');
          statusCell.innerHTML = '<span class="px-3 py-1 rounded-full bg-green-100 text-green-800 text-xs font-bold">Reviewed</span>';

          // Show success message
          alert('Complaint marked as reviewed!');
        } else {
          alert('Error: ' + (data.message || 'Failed to update complaint'));
        }
      } catch (error) {
        console.error('Error:', error);
        alert('An error occurred while updating the complaint');
      }
    });
  });
</script>

</div>

<!-- Floating Action Button -->

<button class="fixed bottom-10 right-10 w-16 h-16 bg-primary text-surface rounded-full shadow-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all z-50 md:hidden">
<span class="material-symbols-outlined text-3xl" data-icon="person_add">person_add</span>
</button>

<!-- Add User Modal -->
<div id="addUserModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-[#fbfbe2] dark:bg-[#173901] rounded-2xl shadow-2xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
    <!-- Modal Header -->
    <div class="sticky top-0 flex justify-between items-center p-8 border-b border-outline-variant/20 bg-[#fbfbe2] dark:bg-[#173901]">
      <div>
        <h2 class="text-3xl font-black text-primary" id="modalTitle">Add New User</h2>
        <p class="text-sm text-on-surface-variant mt-1" id="modalSubtitle">Fill in the details to create a new user account</p>
      </div>
      <button id="closeModalBtn" class="p-2 rounded-full hover:bg-surface-container-highest transition-colors">
        <span class="material-symbols-outlined text-2xl text-on-surface">close</span>
      </button>
    </div>

    <!-- Modal Body -->
    <form id="addUserForm" class="p-8 space-y-6">
      <input type="hidden" id="userIdModal" name="user_id" value="">
      <!-- Photo Upload -->
      <div class="text-center">
        <p class="font-semibold text-primary mb-4">Add Profile Photo</p>
        <div class="flex flex-col items-center gap-4">
          <div class="w-32 h-32 rounded-full bg-primary-container flex items-center justify-center overflow-hidden border-4 border-primary-container/30" id="photoPreviewModal">
            <span class="material-symbols-outlined text-6xl text-surface">person</span>
          </div>
          <label class="flex items-center gap-2 px-6 py-2 bg-primary-container text-on-primary font-semibold rounded-full cursor-pointer hover:opacity-90 transition-all">
            <span class="material-symbols-outlined">upload_file</span>
            Choose Photo
            <input type="file" id="photoInputModal" name="photo" class="hidden" accept="image/*">
          </label>
          <p class="text-xs text-on-surface-variant">Optional - Leave empty for default</p>
        </div>
      </div>

      <!-- Form Fields Row 1 -->
      <div class="grid grid-cols-2 gap-4">
        <!-- Last Name -->
        <div>
          <label for="nomModal" class="block font-semibold text-primary mb-2">Last Name</label>
          <input type="text" id="nomModal" name="nom" class="w-full px-4 py-3 bg-surface-container-low border-2 border-outline-variant/30 rounded-xl focus:border-primary focus:outline-none transition-colors" placeholder="Dupont">
          <p class="text-xs text-on-surface-variant mt-1">Max. 10 characters</p>
          <div class="error-message-modal" id="nomErrorModal"></div>
        </div>

        <!-- First Name -->
        <div>
          <label for="prenomModal" class="block font-semibold text-primary mb-2">First Name</label>
          <input type="text" id="prenomModal" name="prenom" class="w-full px-4 py-3 bg-surface-container-low border-2 border-outline-variant/30 rounded-xl focus:border-primary focus:outline-none transition-colors" placeholder="Jean">
          <p class="text-xs text-on-surface-variant mt-1">Max. 10 characters</p>
          <div class="error-message-modal" id="prenomErrorModal"></div>
        </div>
      </div>

      <!-- Email -->
      <div>
        <label for="emailModal" class="block font-semibold text-primary mb-2">Email Address</label>
        <input type="text" id="emailModal" name="email" class="w-full px-4 py-3 bg-surface-container-low border-2 border-outline-variant/30 rounded-xl focus:border-primary focus:outline-none transition-colors" placeholder="you@example.com">
        <div class="error-message-modal" id="emailErrorModal"></div>
      </div>

      <!-- Form Fields Row 2 -->
      <div class="grid grid-cols-2 gap-4">
        <!-- Password -->
        <div>
          <label for="passwordModal" class="block font-semibold text-primary mb-2">Password</label>
          <input type="text" id="passwordModal" name="password" class="w-full px-4 py-3 bg-surface-container-low border-2 border-outline-variant/30 rounded-xl focus:border-primary focus:outline-none transition-colors" placeholder="••••••">
          <p class="text-xs text-on-surface-variant mt-1">3-7 characters</p>
          <div class="error-message-modal" id="passwordErrorModal"></div>
        </div>

        <!-- Role -->
        <div>
          <label for="roleModal" class="block font-semibold text-primary mb-2">Role</label>
          <select id="roleModal" name="role" class="w-full px-4 py-3 bg-surface-container-low border-2 border-outline-variant/30 rounded-xl focus:border-primary focus:outline-none transition-colors">
            <option value="">Select a role</option>
            <option value="employee">Employee</option>
            <option value="client">Client</option>
          </select>
          <div class="error-message-modal" id="roleErrorModal"></div>
        </div>
      </div>

      <!-- Modal Footer -->
      <div class="flex gap-4 pt-6 border-t border-outline-variant/20">
        <button type="button" id="cancelModalBtn" class="flex-1 px-6 py-3 bg-surface-container-highest text-primary font-semibold rounded-xl hover:opacity-80 transition-colors">
          Cancel
        </button>
        <button type="submit" id="submitModalBtn" class="flex-1 px-6 py-3 bg-primary-container text-on-primary font-semibold rounded-xl hover:translate-y-[-2px] transition-all shadow-lg">
          <span class="flex items-center justify-center gap-2">
            <span class="material-symbols-outlined" id="submitBtnIcon">person_add</span>
            <span id="submitBtnText">Create User</span>
          </span>
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Styles -->
<style>
  .error-message-modal {
    color: #ba1a1a;
    font-size: 0.75rem;
    font-weight: 600;
    margin-top: 0.5rem;
    display: block;
  }

  #nomModal.error-field,
  #prenomModal.error-field,
  #emailModal.error-field,
  #passwordModal.error-field,
  #roleModal.error-field {
    border-color: #ba1a1a !important;
    background-color: rgba(186, 26, 26, 0.05);
  }

  /* Custom scrollbar styling */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  ::-webkit-scrollbar-track {
    background: transparent;
  }

  ::-webkit-scrollbar-thumb {
    background: #c3c9b9;
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #a3a9a0;
  }

  /* Table row hover animation */
  tbody tr {
    animation: slideIn 0.2s ease-out;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Glass card effect */
  .glass-card {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
  }
</style>

<!-- Modal JavaScript -->
<script>
  // Photo Preview
  const photoInputModal = document.getElementById('photoInputModal');
  const photoPreviewModal = document.getElementById('photoPreviewModal');

  if (photoInputModal && photoPreviewModal) {
    photoInputModal.addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function(event) {
          photoPreviewModal.style.backgroundImage = `url(${event.target.result})`;
          photoPreviewModal.style.backgroundSize = 'cover';
          photoPreviewModal.style.backgroundPosition = 'center';
          const icon = photoPreviewModal.querySelector('span');
          if (icon) icon.style.display = 'none';
        };
        reader.readAsDataURL(file);
      }
    });
  }

  // Modal Control
  const addUserBtn = document.getElementById('addUserBtn');
  const addUserModal = document.getElementById('addUserModal');
  const closeModalBtn = document.getElementById('closeModalBtn');
  const cancelModalBtn = document.getElementById('cancelModalBtn');
  const addUserForm = document.getElementById('addUserForm');

  // Function to reset modal for adding new user
  function resetModalForAdd() {
    document.getElementById('modalTitle').textContent = 'Add New User';
    document.getElementById('modalSubtitle').textContent = 'Fill in the details to create a new user account';
    document.getElementById('userIdModal').value = '';
    document.getElementById('submitBtnIcon').textContent = 'person_add';
    document.getElementById('submitBtnText').textContent = 'Create User';
    addUserForm.reset();
    photoPreviewModal.style.backgroundImage = '';
    photoPreviewModal.querySelector('span').style.display = '';
    document.querySelectorAll('[id$="Modal"]').forEach(el => {
      el.classList.remove('error-field');
    });
    document.querySelectorAll('.error-message-modal').forEach(el => {
      el.textContent = '';
    });
  }

  // Open Modal for Adding
  addUserBtn.addEventListener('click', function() {
    resetModalForAdd();
    addUserModal.classList.remove('hidden');
  });

  // Edit User Button Handler
  document.querySelectorAll('.edit-user-btn').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      const userId = this.dataset.userId;
      const nom = this.dataset.nom;
      const prenom = this.dataset.prenom;
      const email = this.dataset.email;
      const role = this.dataset.role;
      const image = this.dataset.image;

      // Update modal title
      document.getElementById('modalTitle').textContent = 'Edit User';
      document.getElementById('modalSubtitle').textContent = `Update ${nom} ${prenom}'s information`;
      document.getElementById('userIdModal').value = userId;
      document.getElementById('submitBtnIcon').textContent = 'edit';
      document.getElementById('submitBtnText').textContent = 'Update User';

      // Fill form fields
      document.getElementById('nomModal').value = nom;
      document.getElementById('prenomModal').value = prenom;
      document.getElementById('emailModal').value = email;
      document.getElementById('roleModal').value = role;

      // Clear new photo input
      document.getElementById('photoInputModal').value = '';

      // Display current photo
      const photoPreview = document.getElementById('photoPreviewModal');
      photoPreview.querySelector('span').style.display = 'none';

      if (image && image !== 'default.JPG' && image !== '') {
        if (image.startsWith('uploads/')) {
          photoPreview.style.backgroundImage = `url('{{ asset('') }}${image}')`;
        } else if (image.startsWith('http') || image.startsWith('/')) {
          photoPreview.style.backgroundImage = `url('${image}')`;
        } else {
          photoPreview.style.backgroundImage = `url('{{ asset('uploads/users/') }}${image}')`;
        }
      } else {
        photoPreview.style.backgroundImage = `url('{{ asset('assets/img/default.JPG') }}')`;
      }
      photoPreview.style.backgroundSize = 'cover';
      photoPreview.style.backgroundPosition = 'center';

      // Clear errors
      document.querySelectorAll('[id$="Modal"]').forEach(el => {
        el.classList.remove('error-field');
      });
      document.querySelectorAll('.error-message-modal').forEach(el => {
        el.textContent = '';
      });

      // Open modal
      addUserModal.classList.remove('hidden');
    });
  });

  // Close Modal
  closeModalBtn.addEventListener('click', function() {
    addUserModal.classList.add('hidden');
  });

  cancelModalBtn.addEventListener('click', function() {
    addUserModal.classList.add('hidden');
  });

  // Close on backdrop click
  addUserModal.addEventListener('click', function(e) {
    if (e.target === addUserModal) {
      addUserModal.classList.add('hidden');
    }
  });

  // Form Submission
  addUserForm.addEventListener('submit', async function(e) {
    e.preventDefault();

    // Clear previous errors
    document.querySelectorAll('[id$="Modal"]').forEach(el => {
      el.classList.remove('error-field');
    });
    document.querySelectorAll('.error-message-modal').forEach(el => {
      el.textContent = '';
    });

    // Get form data
    const formData = new FormData(addUserForm);
    const userId = document.getElementById('userIdModal').value;

    // Determine endpoint
    let endpoint = '{{ path("elfirma_add_user") }}';
    let method = 'POST';

    if (userId) {
      endpoint = '{{ path("elfirma_update_user") }}';
      method = 'POST';
    }

    try {
      const response = await fetch(endpoint, {
        method: method,
        body: formData
      });

      const data = await response.json();

      if (data.success) {
        const message = userId ? 'User updated successfully!' : 'User created successfully!';
        alert(message);
        addUserModal.classList.add('hidden');
        // Reload page to show updated/new user
        window.location.reload();
      } else {
        // Display errors
        if (data.errors) {
          for (const [field, message] of Object.entries(data.errors)) {
            const input = document.getElementById(field + 'Modal');
            const errorEl = document.getElementById(field + 'ErrorModal');
            if (input) input.classList.add('error-field');
            if (errorEl) errorEl.textContent = message;
          }
        }
      }
    } catch (error) {
      console.error('Error:', error);
      const msg = userId ? 'An error occurred while updating the user' : 'An error occurred while creating the user';
      alert(msg);
    }
  });

  // Delete User Button Handler
  document.querySelectorAll('.delete-user-btn').forEach(btn => {
    btn.addEventListener('click', async function(e) {
      e.preventDefault();
      const userId = this.dataset.userId;
      const userName = this.dataset.userName;

      const result = await Swal.fire({
        title: 'Delete User',
        text: `Are you sure you want to delete ${userName}? This action cannot be undone.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ba1a1a',
        cancelButtonColor: '#73796c',
        confirmButtonText: 'Yes, delete',
        cancelButtonText: 'Cancel'
      });

      if (result.isConfirmed) {
        try {
          const formData = new FormData();
          formData.append('user_id', userId);

          const response = await fetch('{{ path("elfirma_delete_user") }}', {
            method: 'POST',
            body: formData
          });

          const data = await response.json();

          if (data.success) {
            Swal.fire({
              title: 'Deleted!',
              text: 'User has been deleted successfully.',
              icon: 'success',
              confirmButtonColor: '#43682b'
            }).then(() => {
              window.location.reload();
            });
          } else {
            Swal.fire({
              title: 'Error!',
              text: data.message || 'An error occurred while deleting the user.',
              icon: 'error',
              confirmButtonColor: '#ba1a1a'
            });
          }
        } catch (error) {
          console.error('Error:', error);
          Swal.fire({
            title: 'Error!',
            text: 'An error occurred while deleting the user.',
            icon: 'error',
            confirmButtonColor: '#ba1a1a'
          });
        }
      }
    });
  });
</script>

<!-- Chart Script -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('userDistributionChart');
    if (ctx) {
      const employeeCount = {{ employeeCount is defined ? employeeCount : 0 }};
      const clientCount = {{ clientCount is defined ? clientCount : 0 }};
      const adminCount = {{ adminCount is defined ? adminCount : 0 }};

      const total = employeeCount + clientCount + adminCount;

      const employeePercent = total > 0 ? ((employeeCount / total) * 100).toFixed(1) : 0;
      const clientPercent = total > 0 ? ((clientCount / total) * 100).toFixed(1) : 0;
      const adminPercent = total > 0 ? ((adminCount / total) * 100).toFixed(1) : 0;

      new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: [
            'Employees (' + employeePercent + '%)',
            'Clients (' + clientPercent + '%)',
            'Admins (' + adminPercent + '%)'
          ],
          datasets: [{
            data: [employeeCount, clientCount, adminCount],
            backgroundColor: [
              '#43682b',
              '#934b19',
              '#9c27b0'
            ],
            borderColor: [
              '#2d4620',
              '#6a3612',
              '#6b1b7d'
            ],
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                font: {
                  size: 12,
                  weight: 'bold'
                },
                color: '#1b1d0e',
                padding: 15,
                usePointStyle: true
              }
            }
          }
        }
      });
    }
  });
</script>

