            <div id="extractedTextDisplay" class="bg-white p-3 rounded-lg border border-outline-variant/20 max-h-32 overflow-y-auto text-sm text-on-surface"></div>
            <input type="hidden" id="generatedPdfPath" name="generated_pdf_file" value="">
