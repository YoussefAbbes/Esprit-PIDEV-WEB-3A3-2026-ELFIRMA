<!-- Import _nav_routes.html.twig for sidebar -->
{{ include('elfirma/_nav_routes.html.twig') }}

<script>
  // DOM Elements
  const addContractModal = document.getElementById('addContractModal');
  const editContractModal = document.getElementById('editContractModal');
  const deleteContractModal = document.getElementById('deleteContractModal');
  const addContractForm = document.getElementById('addContractForm');
  const editContractForm = document.getElementById('editContractForm');
  const closeContractModalBtn = document.getElementById('closeContractModalBtn');
  const cancelContractBtn = document.getElementById('cancelContractBtn');
  const closeEditContractModalBtn = document.getElementById('closeEditContractModalBtn');
  const cancelEditContractBtn = document.getElementById('cancelEditContractBtn');
  const closeDeleteContractModalBtn = document.getElementById('closeDeleteContractModalBtn');
  const cancelDeleteContractBtn = document.getElementById('cancelDeleteContractBtn');
  const confirmDeleteContractBtn = document.getElementById('confirmDeleteContractBtn');
  const addContractBtn = document.getElementById('addContractBtn');

  // Tab Management for PDF/Image
  const pdfTabBtn = document.getElementById('pdfTabBtn');
  const imageTabBtn = document.getElementById('imageTabBtn');
  const pdfTabContent = document.getElementById('pdfTabContent');
  const imageTabContent = document.getElementById('imageTabContent');
  const extractImageBtn = document.getElementById('extractImageBtn');
  const contractImage = document.getElementById('contractImage');
  const extractingIndicator = document.getElementById('extractingIndicator');
  const extractedTextContainer = document.getElementById('extractedTextContainer');
  const extractedTextDisplay = document.getElementById('extractedTextDisplay');
  const generatedPdfPath = document.getElementById('generatedPdfPath');
  const extractedTextInput = document.getElementById('extractedTextInput');

  // Tab switching
  pdfTabBtn.addEventListener('click', (e) => {
    e.preventDefault();
    pdfTabBtn.classList.add('active-tab');
    imageTabBtn.classList.remove('active-tab');
    pdfTabContent.classList.remove('hidden');
    imageTabContent.classList.add('hidden');
    pdfTabBtn.style.borderBottomColor = '#0a2200';
    imageTabBtn.style.borderBottomColor = 'transparent';
    contractImage.value = '';
    extractedTextContainer.classList.add('hidden');
    extractingIndicator.classList.add('hidden');
  });

  imageTabBtn.addEventListener('click', (e) => {
    e.preventDefault();
    imageTabBtn.classList.add('active-tab');
    pdfTabBtn.classList.remove('active-tab');
    imageTabContent.classList.remove('hidden');
    pdfTabContent.classList.add('hidden');
    imageTabBtn.style.borderBottomColor = '#0a2200';
    pdfTabBtn.style.borderBottomColor = 'transparent';
    document.getElementById('pdf').value = '';
  });

  // Handle file selection
  contractImage.addEventListener('change', async function(e) {
    if (!this.files || !this.files[0]) {
      return;
    }

    const file = this.files[0];
    const maxSize = 5 * 1024 * 1024; // 5MB
    const selectedFileInfo = document.getElementById('selectedFileInfo');
    const selectedFileName = document.getElementById('selectedFileName');
    const selectedFileSize = document.getElementById('selectedFileSize');

    // Show selected file info
    selectedFileName.textContent = file.name;
    selectedFileSize.textContent = (file.size / 1024).toFixed(2) + ' KB';
    selectedFileInfo.classList.remove('hidden');

    // Validate file size
    if (file.size > maxSize) {
      Swal.fire({
        title: 'File Too Large',
        text: 'Image file must be smaller than 5MB',
        icon: 'error',
        confirmButtonColor: '#0a2200'
      });
      contractImage.value = '';
      selectedFileInfo.classList.add('hidden');
      return;
    }

    // Auto-extract text
    await extractTextFromImage(file);
  });

  // Drag and drop support
  const imageSelectionArea = document.getElementById('imageSelectionArea');

  imageSelectionArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    imageSelectionArea.style.backgroundColor = 'rgba(10, 34, 0, 0.05)';
    imageSelectionArea.style.borderColor = '#0a2200';
  });

  imageSelectionArea.addEventListener('dragleave', () => {
    imageSelectionArea.style.backgroundColor = 'transparent';
    imageSelectionArea.style.borderColor = 'rgba(195, 201, 185, 0.4)';
  });

  imageSelectionArea.addEventListener('drop', (e) => {
    e.preventDefault();
    imageSelectionArea.style.backgroundColor = 'transparent';
    imageSelectionArea.style.borderColor = 'rgba(195, 201, 185, 0.4)';

    const files = e.dataTransfer.files;
    if (files && files[0]) {
      contractImage.files = files;
      const changeEvent = new Event('change', { bubbles: true });
      contractImage.dispatchEvent(changeEvent);
    }
  });

  // Extract Image Function
  async function extractTextFromImage(file) {
    extractingIndicator.classList.remove('hidden');
    extractedTextContainer.classList.add('hidden');

    const formData = new FormData();
    formData.append('image_file', file);
    formData.append('supplier_name', 'Unknown Supplier');

    try {
      const response = await fetch('{{ path("elfirma_image_to_pdf") }}', {
        method: 'POST',
        body: formData
      });

      const data = await response.json();
      extractingIndicator.classList.add('hidden');

      if (data.success) {
        // Display extracted text
        extractedTextDisplay.textContent = data.extracted_text;
        generatedPdfPath.value = data.pdf_file;
        extractedTextInput.value = data.extracted_text;
        extractedTextContainer.classList.remove('hidden');

        // Show success message
        Swal.fire({
          title: 'Success!',
          text: 'Text extracted successfully from image',
          icon: 'success',
          confirmButtonColor: '#0a2200',
          timer: 2000
        });
      } else {
        Swal.fire({
          title: 'Error',
          text: data.error || 'Failed to extract text from image',
          icon: 'error',
          confirmButtonColor: '#0a2200'
        });
      }
    } catch (error) {
      extractingIndicator.classList.add('hidden');
      console.error('Error:', error);

      Swal.fire({
        title: 'Error',
        text: 'An error occurred while extracting text',
        icon: 'error',
        confirmButtonColor: '#0a2200'
      });
    }
  }

  // Manual extract button (in case user wants to re-extract)
  extractImageBtn.addEventListener('click', async (e) => {
    e.preventDefault();

    if (!contractImage.files || !contractImage.files[0]) {
      Swal.fire({
        title: 'No Image Selected',
        text: 'Please select an image file first',
        icon: 'warning',
        confirmButtonColor: '#0a2200'
      });
      return;
    }

    const file = contractImage.files[0];
    await extractTextFromImage(file);
  });

  // Clear image function
  function clearSelectedImage(e) {
    if (e) e.preventDefault();
    contractImage.value = '';
    document.getElementById('selectedFileInfo').classList.add('hidden');
    extractedTextContainer.classList.add('hidden');
    extractingIndicator.classList.add('hidden');
  }

  // Form fields
  const startDateField = document.getElementById('startDate');
  const endDateField = document.getElementById('endDate');
  const contractTypeField = document.getElementById('contractType');
  const contractStatusField = document.getElementById('contractStatus');

  const editStartDateField = document.getElementById('editStartDate');
  const editEndDateField = document.getElementById('editEndDate');
  const editContractTypeField = document.getElementById('editContractType');
  const editContractStatusField = document.getElementById('editContractStatus');

  let currentEditingContractId = null;
  let currentDeletingContractId = null;

  // Validation Helper
  function updateFieldValidation(fieldId, isValid, message = '') {
    const field = document.getElementById(fieldId);
    const errorEl = document.getElementById(fieldId + 'Error');

    if (isValid) {
      field.classList.remove('error-field');
      if (errorEl) {
        errorEl.textContent = '';
        errorEl.style.display = 'none';
      }
    } else {
      field.classList.add('error-field');
      if (errorEl) {
        errorEl.textContent = message;
        errorEl.style.display = 'block';
      }
    }
  }

  // Validation Functions for Contract
  function validateDateDebut(value) {
    if (value.trim() === '') {
      return { valid: false, message: 'Start date is required' };
    }
    return { valid: true, message: '' };
  }

  function validateDateFin(value, dateDebutValue) {
    if (value.trim() === '') {
      return { valid: false, message: 'End date is required' };
    }
    if (dateDebutValue && value <= dateDebutValue) {
      return { valid: false, message: 'End date must be after start date' };
    }
    return { valid: true, message: '' };
  }

  function validateContractType(value) {
    if (value === '') {
      return { valid: false, message: 'Please select a contract type' };
    }
    return { valid: true, message: '' };
  }

  function validateContractStatus(value) {
    if (value === '') {
      return { valid: false, message: 'Please select a status' };
    }
    return { valid: true, message: '' };
  }

  // Real-time validation for add form
  startDateField.addEventListener('change', function() {
    const validation = validateDateDebut(this.value);
    updateFieldValidation('startDate', validation.valid, validation.message);
    if (endDateField.value) {
      const finValidation = validateDateFin(endDateField.value, this.value);
      updateFieldValidation('endDate', finValidation.valid, finValidation.message);
    }
  });

  endDateField.addEventListener('change', function() {
    const validation = validateDateFin(this.value, startDateField.value);
    updateFieldValidation('endDate', validation.valid, validation.message);
  });

  contractTypeField.addEventListener('change', function() {
    const validation = validateContractType(this.value);
    updateFieldValidation('contractType', validation.valid, validation.message);
  });

  contractStatusField.addEventListener('change', function() {
    const validation = validateContractStatus(this.value);
    updateFieldValidation('contractStatus', validation.valid, validation.message);
  });

  // Real-time validation for edit form
  editStartDateField.addEventListener('change', function() {
    const validation = validateDateDebut(this.value);
    updateFieldValidation('editStartDate', validation.valid, validation.message);
    if (editEndDateField.value) {
      const finValidation = validateDateFin(editEndDateField.value, this.value);
      updateFieldValidation('editEndDate', finValidation.valid, finValidation.message);
    }
  });

  editEndDateField.addEventListener('change', function() {
    const validation = validateDateFin(this.value, editStartDateField.value);
    updateFieldValidation('editEndDate', validation.valid, validation.message);
  });

  editContractTypeField.addEventListener('change', function() {
    const validation = validateContractType(this.value);
    updateFieldValidation('editContractType', validation.valid, validation.message);
  });

  editContractStatusField.addEventListener('change', function() {
    const validation = validateContractStatus(this.value);
    updateFieldValidation('editContractStatus', validation.valid, validation.message);
  });

  // Add Contract Modal Management
  addContractBtn.addEventListener('click', () => {
    addContractForm.reset();
    document.querySelectorAll('.error-message-contract').forEach(el => {
      el.textContent = '';
      el.style.display = 'none';
    });
    document.querySelectorAll('.error-field').forEach(el => el.classList.remove('error-field'));
    addContractModal.classList.remove('hidden');
    // Reset to PDF tab
    pdfTabBtn.click();
  });

  closeContractModalBtn.addEventListener('click', () => {
    addContractModal.classList.add('hidden');
    addContractForm.reset();
  });

  cancelContractBtn.addEventListener('click', () => {
    addContractModal.classList.add('hidden');
    addContractForm.reset();
  });

  addContractModal.addEventListener('click', (e) => {
    if (e.target === addContractModal) {
      addContractModal.classList.add('hidden');
      addContractForm.reset();
    }
  });

  // Add Contract Form Submission
  addContractForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Clear errors first
    document.querySelectorAll('#addContractForm .error-field').forEach(el => {
      el.classList.remove('error-field');
    });
    document.querySelectorAll('[id$="Error"]').forEach(el => {
      el.textContent = '';
      el.style.display = 'none';
    });

    // Validate before submission
    let hasErrors = false;
    const dateDebutValidation = validateDateDebut(startDateField.value);
    const dateFinValidation = validateDateFin(endDateField.value, startDateField.value);
    const typeValidation = validateContractType(contractTypeField.value);
    const statusValidation = validateContractStatus(contractStatusField.value);

    if (!dateDebutValidation.valid) {
      updateFieldValidation('startDate', false, dateDebutValidation.message);
      hasErrors = true;
    }
    if (!dateFinValidation.valid) {
      updateFieldValidation('endDate', false, dateFinValidation.message);
      hasErrors = true;
    }
    if (!typeValidation.valid) {
      updateFieldValidation('contractType', false, typeValidation.message);
      hasErrors = true;
    }
    if (!statusValidation.valid) {
      updateFieldValidation('contractStatus', false, statusValidation.message);
      hasErrors = true;
    }

    if (hasErrors) {
      return;
    }

    const formData = new FormData(addContractForm);

    try {
      const response = await fetch('{{ path("elfirma_create_contract") }}', {
        method: 'POST',
        body: formData
      });

      const data = await response.json();

      if (data.success) {
        Swal.fire({
          title: 'Success!',
          text: 'Contract created successfully',
          icon: 'success',
          confirmButtonColor: '#0a2200'
        }).then(() => location.reload());
      } else {
        if (data.errors) {
          for (const [field, message] of Object.entries(data.errors)) {
            const fieldMap = {
              'type': 'contractType',
              'startDate': 'startDate',
              'endDate': 'endDate',
              'status': 'contractStatus'
            };
            const inputId = fieldMap[field] || field;
            const input = document.getElementById(inputId);
            const errorEl = document.getElementById(inputId + 'Error');
            if (input) input.classList.add('error-field');
            if (errorEl) {
              errorEl.textContent = message;
              errorEl.style.display = 'block';
            }
          }
        }
      }
    } catch (error) {
      console.error('Error:', error);
      Swal.fire('Error', 'An error occurred', 'error');
    }
  });

  // Edit Contract Modal Management
  document.addEventListener('click', function(e) {
    if (e.target.closest('.edit-contract-btn')) {
      const btn = e.target.closest('.edit-contract-btn');
      currentEditingContractId = btn.dataset.contractId;

      document.getElementById('editContractId').value = btn.dataset.contractId;
      editContractTypeField.value = btn.dataset.contractType;
      editStartDateField.value = btn.dataset.contractStart;
      editEndDateField.value = btn.dataset.contractEnd;
      editContractStatusField.value = btn.dataset.contractStatus;

      document.querySelectorAll('[id^="edit"][id$="Error"]').forEach(el => {
        el.textContent = '';
        el.style.display = 'none';
      });
      document.querySelectorAll('#editContractForm .error-field').forEach(el => {
        el.classList.remove('error-field');
      });

      editContractModal.classList.remove('hidden');
    }
  });

  closeEditContractModalBtn.addEventListener('click', function() {
    editContractModal.classList.add('hidden');
  });

  cancelEditContractBtn.addEventListener('click', function() {
    editContractModal.classList.add('hidden');
  });

  editContractModal.addEventListener('click', (e) => {
    if (e.target === editContractModal) editContractModal.classList.add('hidden');
  });

  // Edit Contract Form Submission
  editContractForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    document.querySelectorAll('[id^="edit"][id$="Error"]').forEach(el => {
      el.textContent = '';
      el.style.display = 'none';
    });
    document.querySelectorAll('#editContractForm .error-field').forEach(el => {
      el.classList.remove('error-field');
    });

    // Validate before submission
    let hasErrors = false;
    const dateDebutValidation = validateDateDebut(editStartDateField.value);
    const dateFinValidation = validateDateFin(editEndDateField.value, editStartDateField.value);
    const typeValidation = validateContractType(editContractTypeField.value);
    const statusValidation = validateContractStatus(editContractStatusField.value);

    if (!dateDebutValidation.valid) {
      updateFieldValidation('editStartDate', false, dateDebutValidation.message);
      hasErrors = true;
    }
    if (!dateFinValidation.valid) {
      updateFieldValidation('editEndDate', false, dateFinValidation.message);
      hasErrors = true;
    }
    if (!typeValidation.valid) {
      updateFieldValidation('editContractType', false, typeValidation.message);
      hasErrors = true;
    }
    if (!statusValidation.valid) {
      updateFieldValidation('editContractStatus', false, statusValidation.message);
      hasErrors = true;
    }

    if (hasErrors) {
      return;
    }

    const formData = new FormData();
    formData.append('contract_id', currentEditingContractId);
    formData.append('type', editContractTypeField.value);
    formData.append('startDate', editStartDateField.value);
    formData.append('endDate', editEndDateField.value);
    formData.append('status', editContractStatusField.value);

    try {
      const response = await fetch('{{ path("elfirma_update_contract_page") }}', {
        method: 'POST',
        body: formData
      });

      const data = await response.json();

      if (data.success) {
        Swal.fire({
          title: 'Success!',
          text: 'Contract updated successfully',
          icon: 'success',
          confirmButtonColor: '#0a2200'
        }).then(() => location.reload());
      } else {
        if (data.errors) {
          for (const [field, message] of Object.entries(data.errors)) {
            const fieldMap = {
              'type': 'editContractType',
              'startDate': 'editStartDate',
              'endDate': 'editEndDate',
              'status': 'editContractStatus'
            };
            const inputId = fieldMap[field] || 'edit' + field.charAt(0).toUpperCase() + field.slice(1);
            const input = document.getElementById(inputId);
            const errorEl = document.getElementById(inputId + 'Error');
            if (input) input.classList.add('error-field');
            if (errorEl) {
              errorEl.textContent = message;
              errorEl.style.display = 'block';
            }
          }
        }
      }
    } catch (error) {
      console.error('Error:', error);
      Swal.fire('Error', 'An error occurred', 'error');
    }
  });

  // Delete Contract Modal Management
  document.addEventListener('click', function(e) {
    if (e.target.closest('.delete-contract-btn')) {
      const btn = e.target.closest('.delete-contract-btn');
      currentDeletingContractId = btn.dataset.contractId;
      deleteContractModal.classList.remove('hidden');
    }
  });

  closeDeleteContractModalBtn.addEventListener('click', () => deleteContractModal.classList.add('hidden'));
  cancelDeleteContractBtn.addEventListener('click', () => deleteContractModal.classList.add('hidden'));
  deleteContractModal.addEventListener('click', (e) => {
    if (e.target === deleteContractModal) deleteContractModal.classList.add('hidden');
  });

  confirmDeleteContractBtn.addEventListener('click', async () => {
    const formData = new FormData();
    formData.append('contract_id', currentDeletingContractId);

    try {
      const response = await fetch('{{ path("elfirma_delete_contract_page") }}', {
        method: 'POST',
        body: formData
      });

      const data = await response.json();

      if (data.success) {
        Swal.fire({
          title: 'Success!',
          text: 'Contract deleted successfully',
          icon: 'success',
          confirmButtonColor: '#0a2200'
        }).then(() => location.reload());
      } else {
        Swal.fire('Error', 'Failed to delete contract', 'error');
      }
    } catch (error) {
      console.error('Error:', error);
      Swal.fire('Error', 'An error occurred', 'error');
    }
  });

  // CONTRACT STATISTICS CHART
  document.addEventListener('DOMContentLoaded', function() {
    const activeCount = {{ contractStats.active ?? 0 }};
    const pendingCount = {{ contractStats.pending ?? 0 }};
    const expiredCount = {{ contractStats.expired ?? 0 }};
    const totalCount = {{ contractStats.total ?? 0 }};

    // Update stat card values
    document.getElementById('totalContractCount').textContent = totalCount;
    document.getElementById('activeContractCount').textContent = activeCount;
    document.getElementById('pendingContractCount').textContent = pendingCount;
    document.getElementById('expiredContractCount').textContent = expiredCount;

    // Create Chart.js Doughnut Chart
    const ctx = document.getElementById('contractStatusChart');
    if (ctx) {
      const chartData = {
        labels: ['Active', 'Pending', 'Expired'],
        datasets: [{
          data: [activeCount, pendingCount, expiredCount],
          backgroundColor: [
            '#116530', // Active - primary green
            '#ffb732', // Pending - warning orange
            '#ba1a1a'  // Expired - error red
          ],
          borderColor: [
            '#0a2200',
            '#f57600',
            '#8a1515'
          ],
          borderWidth: 2.5,
          borderRadius: 10,
          spacing: 3
        }]
      };

      const chart = new Chart(ctx, {
        type: 'doughnut',
        data: chartData,
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                font: {
                  family: "'Inter', sans-serif",
                  size: 13,
                  weight: '600'
                },
                color: '#43493d',
                padding: 20,
                usePointStyle: true,
                pointStyle: 'circle'
              }
            },
            tooltip: {
              backgroundColor: 'rgba(10, 34, 0, 0.9)',
              titleFont: {
                family: "'Inter', sans-serif",
                size: 14,
                weight: '700'
              },
              bodyFont: {
                family: "'Open Sans', sans-serif",
                size: 13
              },
              padding: 12,
              titleColor: '#fbfbe2',
              bodyColor: '#fbfbe2',
              borderColor: 'rgba(210, 226, 201, 0.3)',
              borderWidth: 1,
              displayColors: true,
              callbacks: {
                label: function(context) {
                  const total = context.dataset.data.reduce((a, b) => a + b, 0);
                  const percentage = total > 0 ? Math.round((context.parsed / total) * 100) : 0;
                  return context.label + ': ' + context.parsed + ' (' + percentage + '%)';
                }
              }
            }
          }
        }
      });
    }

    // CONTRACT SORT FUNCTIONALITY
    const contractSortSelect = document.getElementById('contractSortSelect');
    const contractTable = document.querySelector('table');

    if (contractSortSelect && contractTable) {
      contractSortSelect.addEventListener('change', function() {
        const rows = Array.from(contractTable.querySelectorAll('tbody tr.contract-row'));
        const sortValue = this.value;

        rows.sort((a, b) => {
          let comparison = 0;

          if (sortValue === 'date-desc') {
            const dateAStr = a.getAttribute('data-contract-end-date') || '9999-12-31';
            const dateBStr = b.getAttribute('data-contract-end-date') || '9999-12-31';
            comparison = dateBStr.localeCompare(dateAStr);
          } else if (sortValue === 'date-asc') {
            const dateAStr = a.getAttribute('data-contract-end-date') || '0000-01-01';
            const dateBStr = b.getAttribute('data-contract-end-date') || '0000-01-01';
            comparison = dateAStr.localeCompare(dateBStr);
          } else if (sortValue === 'status') {
            const statusOrder = { 'Active': 0, 'Pending': 1, 'Inactive': 2, 'Expired': 3 };
            const statusA = a.getAttribute('data-contract-status') || 'Inactive';
            const statusB = b.getAttribute('data-contract-status') || 'Inactive';
            comparison = (statusOrder[statusA] || 999) - (statusOrder[statusB] || 999);
          } else if (sortValue === 'type') {
            const typeA = a.getAttribute('data-contract-type') || '';
            const typeB = b.getAttribute('data-contract-type') || '';
            comparison = typeA.localeCompare(typeB);
          }

          return comparison;
        });

        const tbody = contractTable.querySelector('tbody');
        rows.forEach(row => tbody.appendChild(row));
      });
    }

    // CONTRACT SEARCH FUNCTIONALITY
    const contractSearchInput = document.getElementById('contractSearchInput');

    if (contractSearchInput && contractTable) {
      contractSearchInput.addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase().trim();
        const rows = contractTable.querySelectorAll('tbody tr.contract-row');

        rows.forEach(row => {
          const type = (row.getAttribute('data-contract-type') || '').toLowerCase();
          const status = (row.getAttribute('data-contract-status') || '').toLowerCase();
          const startDate = (row.getAttribute('data-contract-start-date') || '').toLowerCase();
          const endDate = (row.getAttribute('data-contract-end-date') || '').toLowerCase();

          const matches = type.includes(searchTerm) ||
                         status.includes(searchTerm) ||
                         startDate.includes(searchTerm) ||
                         endDate.includes(searchTerm) ||
                         searchTerm === '';

          row.style.display = matches ? '' : 'none';
        });
      });
    }

    // Add animation styles if not already present
    if (!document.getElementById('sort-animation-styles')) {
      const style = document.createElement('style');
      style.id = 'sort-animation-styles';
      style.textContent = `
        @keyframes slideIn {
          from {
            opacity: 0;
            transform: translateY(10px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }
        .contract-row {
          animation: slideIn 0.3s ease-out;
        }
        @keyframes popUp {
          0% {
            opacity: 0;
            transform: scale(0.9);
          }
          100% {
            opacity: 1;
            transform: scale(1);
          }
        }
        .stats-appear {
          animation: popUp 0.5s ease-out;
        }
        .stats-appear.delay-1 {
          animation-delay: 0.1s;
        }
        .stats-appear.delay-2 {
          animation-delay: 0.2s;
        }
        .stats-appear.delay-3 {
          animation-delay: 0.3s;
        }
        .active-tab {
          border-bottom-color: #0a2200 !important;
          color: #0a2200 !important;
        }
        .tab-content {
          transition: all 0.3s ease-in-out;
        }
      `;
      document.head.appendChild(style);
    }
  });
</script>

