<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>{{ culture.nomCulture }} - Crop Details - Elfirma</title>
    <link href="{{ asset('styles/elfirma-theme.css') }}" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Open_Sans:wght@400;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
        body { font-family: 'Open_Sans', sans-serif; background-color: #fbfbe2; color: #1b1d0e; }
        h1, h2, h3, h4, .font-headline { font-family: 'Inter', sans-serif; }
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu { display: block; }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "surface-container-low": "#f5f5dc", "outline-variant": "#c3c9b9", "surface-container-highest": "#e4e4cc",
                        "on-surface": "#1b1d0e", "surface-container-high": "#eaead1", "on-surface-variant": "#43493d",
                        "background": "#fbfbe2", "surface": "#fbfbe2", "primary": "#0a2200", "on-primary": "#ffffff",
                        "secondary": "#934b19", "on-secondary": "#ffffff", "secondary-container": "#fc9f66", "primary-container": "#173901",
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-surface">
    <!-- Sidebar -->
    <aside class="hidden md:flex h-screen w-72 fixed left-0 top-0 bg-[#f5f5dc] flex-col py-8 pr-4 z-40">
        <div class="px-8 mb-8">
            <h1 class="text-3xl font-black text-[#0a2200] tracking-tighter">Elfirma</h1>
            <p class="font-semibold text-[#43493d] text-sm">Farm Management</p>
        </div>
        <nav class="flex-1 space-y-1">
            <a class="flex items-center gap-4 py-3 px-8 text-[#43493d] hover:bg-[#e4e4cc] hover:translate-x-1 transition-all rounded-r-full group" href="{{ path('elfirma_page', { module: 'tableau-de-bord' }) }}">
                <span class="material-symbols-outlined">dashboard</span>
                <span class="font-semibold">Dashboard</span>
            </a>
            <a class="flex items-center gap-4 py-3 px-8 text-[#43493d] hover:bg-[#e4e4cc] hover:translate-x-1 transition-all rounded-r-full group" href="{{ path('elfirma_page', { module: 'utilisateurs' }) }}">
                <span class="material-symbols-outlined">group</span>
                <span class="font-semibold">Users</span>
            </a>
            
            <!-- Field Management Dropdown -->
            <div class="dropdown relative">
                <button class="flex items-center justify-between gap-4 py-3 px-8 w-full text-[#43493d] bg-[#0a2200] text-[#fbfbe2] rounded-r-full shadow-lg transition-all">
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined">agriculture</span>
                        <span class="font-semibold">Field Management</span>
                    </div>
                    <span class="material-symbols-outlined text-sm">expand_more</span>
                </button>
                <div class="dropdown-menu pl-12 mt-1 space-y-1">
                    <a class="flex items-center gap-3 py-2 px-4 text-[#43493d] hover:bg-[#e4e4cc] rounded-r-full text-sm font-semibold transition-all" href="{{ path('parcelle_index') }}">
                        <span class="material-symbols-outlined text-lg">terrain</span>
                        Parcels Management
                    </a>
                    <a class="flex items-center gap-3 py-2 px-4 text-[#fbfbe2] bg-[#0a2200] rounded-r-full text-sm font-semibold" href="{{ path('culture_index') }}">
                        <span class="material-symbols-outlined text-lg">eco</span>
                        Crops Management
                    </a>
                </div>
            </div>
            
            <a class="flex items-center gap-4 py-3 px-8 text-[#43493d] hover:bg-[#e4e4cc] hover:translate-x-1 transition-all rounded-r-full group" href="{{ path('elfirma_page', { module: 'animaux-elevages' }) }}">
                <span class="material-symbols-outlined">pets</span>
                <span class="font-semibold">Livestock</span>
            </a>
            <a class="flex items-center gap-4 py-3 px-8 text-[#43493d] hover:bg-[#e4e4cc] hover:translate-x-1 transition-all rounded-r-full group" href="{{ path('elfirma_page', { module: 'produits-commandes' }) }}">
                <span class="material-symbols-outlined">shopping_basket</span>
                <span class="font-semibold">Products & Orders</span>
            </a>
            <a class="flex items-center gap-4 py-3 px-8 text-[#43493d] hover:bg-[#e4e4cc] hover:translate-x-1 transition-all rounded-r-full group" href="{{ path('elfirma_page', { module: 'equipements-maintenance' }) }}">
                <span class="material-symbols-outlined">handyman</span>
                <span class="font-semibold">Equipment & Maintenance</span>
            </a>
            <a class="flex items-center gap-4 py-3 px-8 text-[#43493d] hover:bg-[#e4e4cc] hover:translate-x-1 transition-all rounded-r-full group" href="{{ path('elfirma_page', { module: 'fournisseurs-contrats' }) }}">
                <span class="material-symbols-outlined">contract</span>
                <span class="font-semibold">Suppliers & Contracts</span>
            </a>
        </nav>
        <div class="px-8 mt-auto pt-8 border-t border-outline-variant/15 flex flex-col gap-4">
            <div class="space-y-2">
                <a class="flex items-center gap-4 text-[#43493d] text-sm hover:text-secondary transition-colors" href="#">
                    <span class="material-symbols-outlined">help</span> Help
                </a>
                <a class="flex items-center gap-4 text-[#43493d] text-sm hover:text-secondary transition-colors" href="#">
                    <span class="material-symbols-outlined">logout</span> Logout
                </a>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="md:ml-64 min-h-screen p-4 md:p-6 space-y-8">
        <!-- Header -->
        <header class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex items-center gap-4">
                <a href="{{ path('culture_index') }}" class="p-2 rounded-lg hover:bg-surface-container-low transition-colors">
                    <span class="material-symbols-outlined text-on-surface-variant">arrow_back</span>
                </a>
                <div>
                    <h2 class="text-4xl font-black text-primary tracking-tighter leading-none mb-2">{{ culture.nomCulture }}</h2>
                    <p class="text-on-surface-variant text-lg">
                        {% if culture.statut == 'Planted' %}
                            <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-bold">{{ culture.statut }}</span>
                        {% elseif culture.statut == 'Growing' %}
                            <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold">{{ culture.statut }}</span>
                        {% elseif culture.statut == 'Ready to Harvest' %}
                            <span class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-xs font-bold">{{ culture.statut }}</span>
                        {% elseif culture.statut == 'Harvested' %}
                            <span class="bg-purple-100 text-purple-700 px-3 py-1 rounded-full text-xs font-bold">{{ culture.statut }}</span>
                        {% else %}
                            <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-xs font-bold">{{ culture.statut ?? 'N/A' }}</span>
                        {% endif %}
                    </p>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <a href="{{ path('culture_edit', {id: culture.id}) }}" class="flex items-center gap-2 bg-primary text-on-primary px-8 py-3 rounded-full font-bold shadow-lg active:scale-95 duration-150 transition-all hover:opacity-90">
                    <span class="material-symbols-outlined">edit</span>
                    Edit Crop
                </a>
            </div>
        </header>

        <!-- Crop Details -->
        <section class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Main Info Card -->
            <div class="lg:col-span-2 bg-white rounded-xl shadow-sm p-8 space-y-6">
                <h3 class="text-xl font-black text-primary tracking-tight">Crop Information</h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-lg bg-green-500/10 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-green-600">eco</span>
                        </div>
                        <div>
                            <p class="text-xs font-bold uppercase text-on-surface-variant">Crop Name</p>
                            <p class="text-lg font-bold text-primary">{{ culture.nomCulture }}</p>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-lg bg-purple-500/10 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-purple-600">category</span>
                        </div>
                        <div>
                            <p class="text-xs font-bold uppercase text-on-surface-variant">Variety</p>
                            <p class="text-lg font-bold text-primary">{{ culture.variete ?? 'Not specified' }}</p>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-lg bg-orange-500/10 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-orange-600">terrain</span>
                        </div>
                        <div>
                            <p class="text-xs font-bold uppercase text-on-surface-variant">Assigned Parcel</p>
                            {% if culture.parcelle %}
                                <a href="{{ path('parcelle_show', {id: culture.parcelle.id}) }}" class="text-lg font-bold text-primary hover:underline">
                                    {{ culture.parcelle.nom }}
                                </a>
                            {% else %}
                                <p class="text-lg font-bold text-on-surface-variant">Not assigned</p>
                            {% endif %}
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-blue-600">flag</span>
                        </div>
                        <div>
                            <p class="text-xs font-bold uppercase text-on-surface-variant">Status</p>
                            <p class="text-lg font-bold text-primary">{{ culture.statut ?? 'Not set' }}</p>
                        </div>
                    </div>
                </div>

                <!-- Dates Section -->
                <div class="pt-6 border-t border-outline-variant/15">
                    <h4 class="text-lg font-bold text-primary mb-4">Key Dates</h4>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="bg-surface-container-low p-4 rounded-xl">
                            <div class="flex items-center gap-2 mb-2">
                                <span class="material-symbols-outlined text-green-600">event</span>
                                <p class="text-xs font-bold uppercase text-on-surface-variant">Planting Date</p>
                            </div>
                            <p class="text-xl font-black text-primary">{{ culture.datePlantation ? culture.datePlantation|date('d M Y') : 'Not set' }}</p>
                        </div>
                        <div class="bg-surface-container-low p-4 rounded-xl">
                            <div class="flex items-center gap-2 mb-2">
                                <span class="material-symbols-outlined text-orange-600">schedule</span>
                                <p class="text-xs font-bold uppercase text-on-surface-variant">Expected Harvest</p>
                            </div>
                            <p class="text-xl font-black text-primary">{{ culture.dateRecoltePrevue ? culture.dateRecoltePrevue|date('d M Y') : 'Not set' }}</p>
                        </div>
                        <div class="bg-surface-container-low p-4 rounded-xl">
                            <div class="flex items-center gap-2 mb-2">
                                <span class="material-symbols-outlined text-purple-600">check_circle</span>
                                <p class="text-xs font-bold uppercase text-on-surface-variant">Actual Harvest</p>
                            </div>
                            <p class="text-xl font-black text-primary">{{ culture.dateRecolteReelle ? culture.dateRecolteReelle|date('d M Y') : 'Pending' }}</p>
                        </div>
                    </div>
                </div>

                <!-- Observations -->
                {% if culture.observations %}
                <div class="pt-6 border-t border-outline-variant/15">
                    <h4 class="text-lg font-bold text-primary mb-4">Observations</h4>
                    <div class="bg-surface-container-low p-4 rounded-xl">
                        <p class="text-on-surface-variant leading-relaxed">{{ culture.observations }}</p>
                    </div>
                </div>
                {% endif %}
            </div>

            <!-- Stats Sidebar -->
            <div class="space-y-6">
                <!-- Quantities Card -->
                <div class="bg-white rounded-xl shadow-sm p-6 space-y-4">
                    <h3 class="text-lg font-black text-primary tracking-tight">Production Data</h3>
                    
                    <div class="space-y-4">
                        <div class="flex items-center justify-between py-3 border-b border-outline-variant/15">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-green-600">grass</span>
                                <span class="font-semibold text-on-surface-variant">Qty Planted</span>
                            </div>
                            <span class="text-xl font-black text-primary">{{ culture.quantitePlantee|number_format(0) }}</span>
                        </div>
                        
                        <div class="flex items-center justify-between py-3 border-b border-outline-variant/15">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-orange-600">inventory_2</span>
                                <span class="font-semibold text-on-surface-variant">Qty Harvested</span>
                            </div>
                            <span class="text-xl font-black text-primary">{{ culture.quantiteRecoltee|number_format(0) }}</span>
                        </div>
                        
                        <div class="flex items-center justify-between py-3 border-b border-outline-variant/15">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-blue-600">speed</span>
                                <span class="font-semibold text-on-surface-variant">Yield (kg/ha)</span>
                            </div>
                            <span class="text-xl font-black text-primary">{{ culture.rendement ? culture.rendement|number_format(2) : '-' }}</span>
                        </div>
                        
                        <div class="flex items-center justify-between py-3">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-red-600">payments</span>
                                <span class="font-semibold text-on-surface-variant">Production Cost</span>
                            </div>
                            <span class="text-xl font-black text-secondary">{{ culture.coutProduction|number_format(2) }} €</span>
                        </div>
                    </div>
                </div>

                <!-- Efficiency Card -->
                {% if culture.quantitePlantee > 0 %}
                <div class="bg-gradient-to-br from-primary to-primary-container rounded-xl shadow-lg p-6 text-white">
                    <h3 class="text-lg font-black tracking-tight mb-4">Efficiency</h3>
                    <div class="text-center">
                        <p class="text-5xl font-black">{{ ((culture.quantiteRecoltee / culture.quantitePlantee) * 100)|number_format(1) }}%</p>
                        <p class="text-sm opacity-80 mt-2">Harvest Rate</p>
                    </div>
                    {% if culture.coutProduction > 0 and culture.quantiteRecoltee > 0 %}
                    <div class="mt-6 pt-4 border-t border-white/20 text-center">
                        <p class="text-2xl font-bold">{{ (culture.coutProduction / culture.quantiteRecoltee)|number_format(2) }} €</p>
                        <p class="text-sm opacity-80">Cost per Unit</p>
                    </div>
                    {% endif %}
                </div>
                {% endif %}

                <!-- Quick Actions -->
                <div class="bg-white rounded-xl shadow-sm p-6">
                    <h3 class="text-lg font-black text-primary tracking-tight mb-4">Quick Actions</h3>
                    <div class="space-y-3">
                        <a href="{{ path('culture_edit', {id: culture.id}) }}" class="flex items-center gap-3 p-3 rounded-lg hover:bg-surface-container-low transition-colors">
                            <span class="material-symbols-outlined text-yellow-600">edit</span>
                            <span class="font-semibold text-on-surface">Edit Crop</span>
                        </a>
                        {% if culture.parcelle %}
                        <a href="{{ path('parcelle_show', {id: culture.parcelle.id}) }}" class="flex items-center gap-3 p-3 rounded-lg hover:bg-surface-container-low transition-colors">
                            <span class="material-symbols-outlined text-green-600">terrain</span>
                            <span class="font-semibold text-on-surface">View Parcel</span>
                        </a>
                        {% endif %}
                        <form action="{{ path('culture_delete', {id: culture.id}) }}" method="POST" onsubmit="return confirm('Are you sure you want to delete this crop?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ culture.id) }}">
                            <button type="submit" class="flex items-center gap-3 p-3 rounded-lg hover:bg-red-50 transition-colors w-full text-left">
                                <span class="material-symbols-outlined text-red-600">delete</span>
                                <span class="font-semibold text-red-600">Delete Crop</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="md:ml-64 flex justify-between items-center px-12 py-8 bg-[#fbfbe2] border-t border-[#c3c9b9]/15">
        <p class="text-sm tracking-wide text-on-surface-variant">Elfirma © 2026</p>
        <div class="flex gap-8">
            <a class="text-sm tracking-wide text-[#43493d] hover:text-[#934b19] transition-colors" href="#">Technical Support</a>
            <a class="text-sm tracking-wide text-[#43493d] hover:text-[#934b19] transition-colors" href="#">Legal Notice</a>
            <a class="text-sm tracking-wide text-[#43493d] hover:text-[#934b19] transition-colors" href="#">Privacy</a>
        </div>
    </footer>

    <script>
        document.querySelectorAll('.dropdown > button').forEach(btn => {
            btn.addEventListener('click', function(e) {
                const menu = this.nextElementSibling;
                menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
            });
        });
    </script>
{{ include('elfirma/_nav_routes.html.twig') }}
</body>
</html>

