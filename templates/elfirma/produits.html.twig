<!DOCTYPE html>
<html class="light" lang="fr">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <link href="{{ asset('styles/elfirma-theme.css') }}" rel="stylesheet"/>
    <title>Elfirma - Produits</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Open_Sans:wght@400;600&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols_Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <style>
        body { font-family: 'Open Sans', sans-serif; }
        h1, h2, h3 { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .modal { display: none; position: fixed; z-index: 100; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.4); }
        .modal.active { display: flex; align-items: center; justify-content: center; }
        .submenu-item { transition: all 0.2s ease; }
        .submenu-item:hover { transform: translateX(4px); }
    </style>
</head>
<body class="bg-[#fbfbe2] text-[#1b1d0e] min-h-screen flex">
    <!-- Sidebar -->
    <aside class="hidden md:flex flex-col h-screen w-72 fixed left-0 top-0 py-8 pr-4 bg-[#f5f5dc]">
        <div class="px-8 mb-8">
            <h1 class="text-3xl font-black text-[#0a2200] tracking-tighter">Elfirma</h1>
            <p class="text-[#43493d] text-sm">Gestion Agricole</p>
        </div>
        <nav class="flex-1 flex flex-col space-y-1">
            <a class="flex items-center gap-4 py-3 px-8 text-[#43493d] hover:bg-[#e4e4cc]/30 transition-colors" href="{{ path('elfirma_page', { module: 'tableau-de-bord' }) }}">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Tableau de Bord</span>
            </a>
            <a class="flex items-center gap-4 py-3 px-8 text-[#43493d] hover:bg-[#e4e4cc]/30 transition-colors" href="{{ path('elfirma_page', { module: 'utilisateurs' }) }}">
                <span class="material-symbols-outlined">group</span>
                <span>User Management</span>
            </a>
            <a class="flex items-center gap-4 py-3 px-8 text-[#43493d] hover:bg-[#e4e4cc]/30 transition-colors" href="{{ path('elfirma_page', { module: 'parcelles-cultures' }) }}">
                <span class="material-symbols-outlined">agriculture</span>
                <span>Field Management</span>
            </a>
            <a class="flex items-center gap-4 py-3 px-8 text-[#43493d] hover:bg-[#e4e4cc]/30 transition-colors" href="{{ path('elfirma_page', { module: 'animaux-elevages' }) }}">
                <span class="material-symbols-outlined">pets</span>
                <span>Livestock Management</span>
            </a>
            
            <!-- Product Management with submenu -->
            <div class="py-1">
                <div class="flex items-center gap-4 py-3 px-8 bg-[#2d5016] text-white rounded-l-full ml-auto">
                    <span class="material-symbols-outlined">shopping_basket</span>
                    <span class="flex-1">Product Management</span>
                    <span class="material-symbols-outlined text-sm">expand_less</span>
                </div>
                <div class="mt-1 ml-8">
                    <a class="flex items-center gap-3 py-3 px-6 text-[#43493d] hover:bg-[#e4e4cc]/30 rounded-l-full ml-auto mb-1" href="{{ path('elfirma_page', { module: 'categories' }) }}">
                        <span class="material-symbols-outlined text-sm">category</span>
                        <span>Categories</span>
                    </a>
                    <a class="flex items-center gap-3 py-3 px-6 bg-[#1e3a0f] text-white rounded-l-full ml-auto" href="{{ path('elfirma_page', { module: 'produits' }) }}">
                        <span class="material-symbols-outlined text-sm">inventory_2</span>
                        <span>Products</span>
                    </a>
                </div>
            </div>
            
            <a class="flex items-center gap-4 py-3 px-8 text-[#43493d] hover:bg-[#e4e4cc]/30 transition-colors" href="{{ path('elfirma_page', { module: 'equipements-maintenance' }) }}">
                <span class="material-symbols-outlined">handyman</span>
                <span>Equipment Management</span>
            </a>
            <a class="flex items-center gap-4 py-3 px-8 text-[#43493d] hover:bg-[#e4e4cc]/30 transition-colors" href="{{ path('elfirma_page', { module: 'fournisseurs-contrats' }) }}">
                <span class="material-symbols-outlined">description</span>
                <span>Contract Management</span>
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 md:ml-72 min-h-screen flex flex-col">
        <!-- Header -->
        <header class="sticky top-0 z-50 bg-[#fbfbe2]/70 backdrop-blur-xl px-8 py-4 flex justify-between items-center border-b border-[#c3c9b9]/20">
            <h2 class="text-2xl font-black text-[#0a2200]">Gestion des Produits</h2>
            <div class="flex items-center gap-3 bg-[#f5f5dc] px-4 py-1.5 rounded-full">
                <div class="text-right">
                    <p class="text-sm font-bold text-[#0a2200]">Admin Elfirma</p>
                    <p class="text-xs text-[#43493d]">Directeur</p>
                </div>
            </div>
        </header>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="mx-8 mt-4 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative">
                <span class="block sm:inline">{{ message }}</span>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="mx-8 mt-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
                <span class="block sm:inline">{{ message }}</span>
            </div>
        {% endfor %}

        <!-- Content -->
        <div class="p-8 lg:p-12 space-y-8">
            <!-- Statistics Cards -->
            <section class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <!-- Total Products -->
                <div class="bg-gradient-to-br from-green-600 to-green-700 rounded-2xl p-6 text-white shadow-lg">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <p class="text-green-100 text-sm font-semibold uppercase tracking-wide">Total Produits</p>
                            <p class="text-4xl font-black mt-2">{{ produits|length }}</p>
                        </div>
                        <div class="bg-white/20 p-4 rounded-xl">
                            <span class="material-symbols-outlined text-4xl">inventory_2</span>
                        </div>
                    </div>
                </div>

                <!-- Total Stock -->
                <div class="bg-gradient-to-br from-emerald-600 to-emerald-700 rounded-2xl p-6 text-white shadow-lg">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <p class="text-emerald-100 text-sm font-semibold uppercase tracking-wide">Stock Total</p>
                            <p class="text-4xl font-black mt-2">
                                {% set totalStock = 0 %}
                                {% for produit in produits %}
                                    {% set totalStock = totalStock + produit.quantiteStock %}
                                {% endfor %}
                                {{ totalStock }}
                            </p>
                        </div>
                        <div class="bg-white/20 p-4 rounded-xl">
                            <span class="material-symbols-outlined text-4xl">warehouse</span>
                        </div>
                    </div>
                </div>

                <!-- Low Stock Alert -->
                <div class="bg-gradient-to-br from-orange-600 to-orange-700 rounded-2xl p-6 text-white shadow-lg">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <p class="text-orange-100 text-sm font-semibold uppercase tracking-wide">Stock Faible</p>
                            <p class="text-4xl font-black mt-2">
                                {% set lowStock = 0 %}
                                {% for produit in produits %}
                                    {% if produit.quantiteStock < 20 %}
                                        {% set lowStock = lowStock + 1 %}
                                    {% endif %}
                                {% endfor %}
                                {{ lowStock }}
                            </p>
                        </div>
                        <div class="bg-white/20 p-4 rounded-xl">
                            <span class="material-symbols-outlined text-4xl">warning</span>
                        </div>
                    </div>
                </div>

                <!-- Total Value -->
                <div class="bg-gradient-to-br from-teal-600 to-teal-700 rounded-2xl p-6 text-white shadow-lg">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <p class="text-teal-100 text-sm font-semibold uppercase tracking-wide">Valeur Stock</p>
                            <p class="text-3xl font-black mt-2">
                                {% set totalValue = 0 %}
                                {% for produit in produits %}
                                    {% set totalValue = totalValue + (produit.prixUnitaire * produit.quantiteStock) %}
                                {% endfor %}
                                {{ totalValue|number_format(2, ',', ' ') }} DT
                            </p>
                        </div>
                        <div class="bg-white/20 p-4 rounded-xl">
                            <span class="material-symbols-outlined text-4xl">payments</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Header Section -->
            <section class="flex flex-col md:flex-row md:items-end justify-between gap-6">
                <div>
                    <h2 class="text-4xl font-black text-[#0a2200] tracking-tight leading-none mb-2">Products Agricoles</h2>
                    <p class="text-[#43493d] max-w-xl">Gérez votre inventaire de produits et stocks.</p>
                </div>
                <button onclick="openModal('createModal')" class="flex items-center gap-2 bg-gradient-to-r from-green-600 to-green-700 text-white font-bold py-3 px-8 rounded-full shadow-lg hover:from-green-700 hover:to-green-800 transition-all transform hover:scale-105">
                    <span class="material-symbols-outlined">add_circle</span>
                    <span>New Product</span>
                </button>
            </section>

            <!-- Search, Filter and Sort Section -->
            <section class="bg-white rounded-xl p-6 shadow-sm border-2 border-green-100">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
                    <!-- Search Bar -->
                    <div class="md:col-span-4 relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-gray-400">search</span>
                        <input 
                            type="text" 
                            id="searchInput"
                            placeholder="Rechercher un produit..." 
                            class="w-full pl-12 pr-4 py-3 border-2 border-green-200 rounded-xl focus:border-green-500 focus:ring-4 focus:ring-green-100 transition-all"
                            onkeyup="filterTable()"
                        />
                    </div>
                    
                    <!-- Category Filter -->
                    <div class="md:col-span-3">
                        <select 
                            id="categoryFilter" 
                            onchange="filterTable()"
                            class="w-full px-4 py-3 border-2 border-green-200 rounded-xl focus:border-green-500 focus:ring-4 focus:ring-green-100 bg-white font-semibold text-gray-700 cursor-pointer">
                            <option value="">Toutes catégories</option>
                            {% for categorie in categories %}
                                <option value="{{ categorie.nom|lower }}">{{ categorie.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <!-- Status Filter -->
                    <div class="md:col-span-2">
                        <select 
                            id="statusFilter" 
                            onchange="filterTable()"
                            class="w-full px-4 py-3 border-2 border-green-200 rounded-xl focus:border-green-500 focus:ring-4 focus:ring-green-100 bg-white font-semibold text-gray-700 cursor-pointer">
                            <option value="">Tous statuts</option>
                            <option value="disponible">Disponible</option>
                            <option value="rupture">Rupture</option>
                            <option value="expiré">Expiré</option>
                        </select>
                    </div>
                    
                    <!-- Sort Options -->
                    <div class="md:col-span-2">
                        <select 
                            id="sortSelect" 
                            onchange="sortTable()"
                            class="w-full px-4 py-3 border-2 border-green-200 rounded-xl focus:border-green-500 focus:ring-4 focus:ring-green-100 bg-white font-semibold text-gray-700 cursor-pointer">
                            <option value="name-asc">Nom A→Z</option>
                            <option value="name-desc">Nom Z→A</option>
                            <option value="stock-desc">Stock ↓</option>
                            <option value="stock-asc">Stock ↑</option>
                            <option value="price-desc">Prix ↓</option>
                            <option value="price-asc">Prix ↑</option>
                        </select>
                    </div>
                    
                    <div class="md:col-span-1">
                        <button onclick="resetFilters()" class="w-full px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold rounded-xl transition-all">
                            <span class="material-symbols-outlined">refresh</span>
                        </button>
                    </div>
                </div>
                
                <!-- Results Counter -->
                <div class="mt-4 text-sm text-gray-600">
                    <span id="resultCount">{{ produits|length }}</span> produit(s) trouvé(s)
                </div>
            </section>

            <!-- Products Table -->
            <section class="bg-white rounded-xl p-8 shadow-sm border-2 border-green-100">
                <h3 class="text-2xl font-bold text-[#0a2200] mb-6 flex items-center gap-3">
                    <span class="material-symbols-outlined text-green-600">list</span>
                    Liste des Produits
                </h3>
                <div class="overflow-x-auto">
                    <table class="w-full" id="produitsTable">
                        <thead>
                            <tr class="text-left text-[#43493d] text-xs uppercase tracking-widest font-black border-b-2 border-green-200">
                                <th class="pb-4 px-4">ID</th>
                                <th class="pb-4 px-4">Nom</th>
                                <th class="pb-4 px-4">Catégorie</th>
                                <th class="pb-4 px-4">Type</th>
                                <th class="pb-4 px-4">Prix (DT)</th>
                                <th class="pb-4 px-4">Stock</th>
                                <th class="pb-4 px-4">Statut</th>
                                <th class="pb-4 px-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm" id="tableBody">
                            {% for produit in produits %}
                            <tr class="border-b border-green-50 hover:bg-green-50 transition-colors" 
                                data-name="{{ produit.nom|lower }}" 
                                data-category="{{ produit.categorie ? produit.categorie.nom|lower : '' }}" 
                                data-status="{{ produit.statut|lower }}"
                                data-stock="{{ produit.quantiteStock }}"
                                data-price="{{ produit.prixUnitaire }}"
                                data-id="{{ produit.idProduit }}">
                                <td class="py-5 px-4 font-mono font-bold text-green-700">#{{ produit.idProduit }}</td>
                                <td class="py-5 px-4 font-bold text-[#1b1d0e]">{{ produit.nom }}</td>
                                <td class="py-5 px-4">
                                    {% if produit.categorie %}
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold">
                                            <span class="material-symbols-outlined text-xs">category</span>
                                            {{ produit.categorie.nom }}
                                        </span>
                                    {% else %}
                                        <span class="text-red-500">Non définie</span>
                                    {% endif %}
                                </td>
                                <td class="py-5 px-4 text-[#43493d]">{{ produit.type }}</td>
                                <td class="py-5 px-4 font-black text-green-700">{{ produit.prixUnitaire }} DT</td>
                                <td class="py-5 px-4">
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold
                                        {% if produit.quantiteStock < 20 %}bg-gradient-to-r from-red-100 to-orange-100 text-red-700 border border-red-200
                                        {% else %}bg-gradient-to-r from-green-100 to-emerald-100 text-green-700 border border-green-200{% endif %}">
                                        <span class="material-symbols-outlined text-xs">inventory</span>
                                        {{ produit.quantiteStock }}
                                    </span>
                                </td>
                                <td class="py-5 px-4">
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold
                                        {% if produit.statut == 'Disponible' %}bg-gradient-to-r from-green-100 to-emerald-100 text-green-700 border border-green-200
                                        {% elseif produit.statut == 'Rupture' %}bg-gradient-to-r from-red-100 to-orange-100 text-red-700 border border-red-200
                                        {% else %}bg-gray-100 text-gray-700 border border-gray-200{% endif %}">
                                        {{ produit.statut }}
                                    </span>
                                </td>
                                <td class="py-5 px-4">
                                    <div class="flex gap-2">
                                        <button onclick='openEditModal({{ produit.idProduit }}, {{ produit|json_encode|raw }})' 
                                                class="p-2.5 bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-lg hover:from-blue-600 hover:to-blue-700 transition-all shadow-sm">
                                            <span class="material-symbols-outlined text-sm">edit</span>
                                        </button>
                                        <form method="POST" action="{{ path('produit_delete', { id: produit.idProduit }) }}" 
                                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce produit ?');" style="display: inline;">
                                            <button type="submit" class="p-2.5 bg-gradient-to-r from-red-500 to-red-600 text-white rounded-lg hover:from-red-600 hover:to-red-700 transition-all shadow-sm">
                                                <span class="material-symbols-outlined text-sm">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% else %}
                            <tr id="emptyRow">
                                <td colspan="8" class="py-12 px-4 text-center">
                                    <div class="flex flex-col items-center gap-4">
                                        <span class="material-symbols-outlined text-6xl text-gray-300">inventory_off</span>
                                        <p class="text-gray-500 text-lg">Aucun produit trouvé. Créez votre premier produit !</p>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </main>

    <!-- Create Modal -->
    <div id="createModal" class="modal">
        <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-2xl font-bold text-[#0a2200]">Nouveau Produit</h3>
                <button onclick="closeModal('createModal')" class="text-[#43493d] hover:text-[#0a2200]">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <form method="POST" action="{{ path('produit_create') }}">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Nom du produit *</label>
                        <input type="text" name="nom" required minlength="3" maxlength="100" 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20"
                               placeholder="Ex: Huile d'olive extra vierge">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Type *</label>
                        <input type="text" name="type" required minlength="3" maxlength="30" 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20"
                               placeholder="Ex: Biologique, Premium">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Catégorie *</label>
                        <select name="categorie_id" required 
                                class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                            <option value="">Sélectionner une catégorie</option>
                            {% for categorie in categories %}
                                <option value="{{ categorie.id }}">{{ categorie.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Prix Unitaire (DT) *</label>
                        <input type="number" name="prix_unitaire" step="0.01" min="0" required 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20"
                               placeholder="0.00">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Quantité en Stock *</label>
                        <input type="number" name="quantite_stock" min="0" required 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20"
                               placeholder="0">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Qualité</label>
                        <input type="text" name="qualite" maxlength="20" 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20"
                               placeholder="Ex: Grade A">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Date de Production</label>
                        <input type="date" name="date_production" 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Date d'Expiration</label>
                        <input type="date" name="date_expiration" 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Statut</label>
                        <select name="statut" 
                                class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                            <option value="Disponible">Disponible</option>
                            <option value="Rupture">Rupture</option>
                            <option value="Expiré">Expiré</option>
                        </select>
                    </div>
                </div>
                <div class="flex gap-3">
                    <button type="button" onclick="closeModal('createModal')" 
                            class="flex-1 py-3 px-6 rounded-lg border-2 border-[#c3c9b9] text-[#1b1d0e] font-bold hover:bg-[#f5f5dc]">
                        Annuler
                    </button>
                    <button type="submit" class="flex-1 py-3 px-6 rounded-lg bg-[#0a2200] text-white font-bold hover:bg-[#173901]">
                        Créer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Modal -->
    <div id="editModal" class="modal">
        <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-2xl font-bold text-[#0a2200]">Modifier le Produit</h3>
                <button onclick="closeModal('editModal')" class="text-[#43493d] hover:text-[#0a2200]">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <form id="editForm" method="POST" action="">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Nom du produit *</label>
                        <input type="text" id="editNom" name="nom" required minlength="3" maxlength="100" 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Type *</label>
                        <input type="text" id="editType" name="type" required minlength="3" maxlength="30" 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Catégorie *</label>
                        <select id="editCategorieId" name="categorie_id" required 
                                class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                            <option value="">Sélectionner une catégorie</option>
                            {% for categorie in categories %}
                                <option value="{{ categorie.id }}">{{ categorie.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Prix Unitaire (DT) *</label>
                        <input type="number" id="editPrix" name="prix_unitaire" step="0.01" min="0" required 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Quantité en Stock *</label>
                        <input type="number" id="editQuantite" name="quantite_stock" min="0" required 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Qualité</label>
                        <input type="text" id="editQualite" name="qualite" maxlength="20" 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Date de Production</label>
                        <input type="date" id="editDateProduction" name="date_production" 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Date d'Expiration</label>
                        <input type="date" id="editDateExpiration" name="date_expiration" 
                               class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-[#1b1d0e] mb-2">Statut</label>
                        <select id="editStatut" name="statut" 
                                class="w-full px-4 py-3 rounded-lg border border-[#c3c9b9] focus:border-[#0a2200] focus:ring-2 focus:ring-[#0a2200]/20">
                            <option value="Disponible">Disponible</option>
                            <option value="Rupture">Rupture</option>
                            <option value="Expiré">Expiré</option>
                        </select>
                    </div>
                </div>
                <div class="flex gap-3">
                    <button type="button" onclick="closeModal('editModal')" 
                            class="flex-1 py-3 px-6 rounded-lg border-2 border-[#c3c9b9] text-[#1b1d0e] font-bold hover:bg-[#f5f5dc]">
                        Annuler
                    </button>
                    <button type="submit" class="flex-1 py-3 px-6 rounded-lg bg-[#0a2200] text-white font-bold hover:bg-[#173901]">
                        Modifier
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openModal(modalId) {
            document.getElementById(modalId).classList.add('active');
        }
        
        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        }
        
        function openEditModal(id, produit) {
            document.getElementById('editNom').value = produit.nom;
            document.getElementById('editType').value = produit.type;
            document.getElementById('editPrix').value = produit.prix_unitaire;
            document.getElementById('editQuantite').value = produit.quantite_stock;
            document.getElementById('editQualite').value = produit.qualite || '';
            document.getElementById('editStatut').value = produit.statut || 'Disponible';
            
            if (produit.categorie && produit.categorie.id) {
                document.getElementById('editCategorieId').value = produit.categorie.id;
            }
            
            if (produit.date_production && produit.date_production.date) {
                document.getElementById('editDateProduction').value = produit.date_production.date.substring(0, 10);
            }
            
            if (produit.date_expiration && produit.date_expiration.date) {
                document.getElementById('editDateExpiration').value = produit.date_expiration.date.substring(0, 10);
            }
            
            document.getElementById('editForm').action = '{{ path('produit_edit', { id: '__ID__' }) }}'.replace('__ID__', id);
            openModal('editModal');
        }
        
        // Search and Filter Functions
        function filterTable() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const categoryFilter = document.getElementById('categoryFilter').value.toLowerCase();
            const statusFilter = document.getElementById('statusFilter').value.toLowerCase();
            const rows = document.querySelectorAll('#tableBody tr:not(#emptyRow)');
            let visibleCount = 0;
            
            rows.forEach(row => {
                const name = row.dataset.name || '';
                const category = row.dataset.category || '';
                const status = row.dataset.status || '';
                
                const matchesSearch = name.includes(searchTerm);
                const matchesCategory = !categoryFilter || category === categoryFilter;
                const matchesStatus = !statusFilter || status === statusFilter;
                
                if (matchesSearch && matchesCategory && matchesStatus) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });
            
            document.getElementById('resultCount').textContent = visibleCount;
        }
        
        function sortTable() {
            const select = document.getElementById('sortSelect');
            const sortType = select.value;
            const tbody = document.getElementById('tableBody');
            const rows = Array.from(tbody.querySelectorAll('tr:not(#emptyRow)'));
            
            rows.sort((a, b) => {
                switch(sortType) {
                    case 'name-asc':
                        return a.dataset.name.localeCompare(b.dataset.name);
                    case 'name-desc':
                        return b.dataset.name.localeCompare(a.dataset.name);
                    case 'stock-asc':
                        return parseInt(a.dataset.stock) - parseInt(b.dataset.stock);
                    case 'stock-desc':
                        return parseInt(b.dataset.stock) - parseInt(a.dataset.stock);
                    case 'price-asc':
                        return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
                    case 'price-desc':
                        return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
                    default:
                        return 0;
                }
            });
            
            rows.forEach(row => tbody.appendChild(row));
        }
        
        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('categoryFilter').selectedIndex = 0;
            document.getElementById('statusFilter').selectedIndex = 0;
            document.getElementById('sortSelect').selectedIndex = 0;
            filterTable();
            sortTable();
        }
        
        // Close modal when clicking outside
        window.onclick = function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.classList.remove('active');
            }
        }
    </script>
</body>
</html>
