<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Parcel Details - Elfirma</title>
    <link href="{{ asset('styles/elfirma-theme.css') }}" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Open_Sans:wght@400;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
        body { font-family: 'Open_Sans', sans-serif; background-color: #fbfbe2; color: #1b1d0e; }
        h1, h2, h3, h4, .font-headline { font-family: 'Inter', sans-serif; }
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu { display: block; }
        #parcel-map { height: 400px; width: 100%; border-radius: 12px; z-index: 1; }

        /* Pulsing marker ring */
        @keyframes ping {
            0%   { transform: scale(1);   opacity: 0.8; }
            70%  { transform: scale(2.8); opacity: 0; }
            100% { transform: scale(2.8); opacity: 0; }
        }
        .marker-ping {
            position: absolute; inset: 0; border-radius: 50%;
            animation: ping 1.8s cubic-bezier(0, 0, 0.2, 1) infinite;
        }

        /* Leaflet scale bar */
        .leaflet-control-scale-line {
            border: 2px solid #0a2200; border-top: none;
            color: #0a2200; font-family: 'Inter', sans-serif;
            font-weight: 700; font-size: 10px; background: rgba(255,255,255,0.9);
            padding: 1px 4px;
        }
        /* Area circle tooltip */
        .area-circle-tooltip {
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
            font-family: 'Inter', sans-serif;
            font-weight: 800;
            font-size: 13px;
            white-space: nowrap;
        }
        .area-circle-tooltip::before { display: none !important; }

        /* Image lightbox */
        .lightbox { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 100; align-items: center; justify-content: center; }
        .lightbox.active { display: flex; }
        .lightbox img { max-width: 90%; max-height: 90%; border-radius: 12px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); }
        .lightbox-close { position: absolute; top: 20px; right: 30px; color: white; font-size: 40px; cursor: pointer; transition: transform 0.2s; }
        .lightbox-close:hover { transform: scale(1.1); }

        /* Image hover effect */
        .parcel-image-container { position: relative; overflow: hidden; border-radius: 16px; cursor: pointer; }
        .parcel-image-container img { transition: transform 0.4s ease; }
        .parcel-image-container:hover img { transform: scale(1.05); }
        .parcel-image-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 50%); opacity: 0; transition: opacity 0.3s; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 20px; }
        .parcel-image-container:hover .parcel-image-overlay { opacity: 1; }

        /* ── Button system ──────────────────────────────────────────── */
        .btn-show {
            display: inline-flex; align-items: center; gap: 8px;
            font-weight: 700; font-size: 14px; font-family: 'Inter', sans-serif;
            padding: 11px 22px; border-radius: 9999px; cursor: pointer;
            border: 2px solid transparent;
            transition: transform 0.18s cubic-bezier(0.34,1.56,0.64,1),
                        box-shadow 0.18s ease, background-color 0.15s ease,
                        border-color 0.15s ease, color 0.15s ease;
        }
        .btn-show:hover  { transform: translateY(-2px) scale(1.03); }
        .btn-show:active { transform: translateY(0) scale(0.97); }
        .btn-show-edit   { background: #f59e0b; color: #fff; box-shadow: 0 2px 10px rgba(245,158,11,0.3); }
        .btn-show-edit:hover   { background: #d97706; box-shadow: 0 8px 22px rgba(245,158,11,0.4); }
        .btn-show-danger { background: #ef4444; color: #fff; box-shadow: 0 2px 10px rgba(239,68,68,0.28); }
        .btn-show-danger:hover { background: #dc2626; box-shadow: 0 8px 22px rgba(239,68,68,0.36); }
        .btn-show-ghost  { background: #fff; color: #43493d; border-color: #d9ddcc; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
        .btn-show-ghost:hover  { border-color: #0a2200; color: #0a2200; box-shadow: 0 5px 14px rgba(10,34,0,0.1); }
        .btn-show-map    { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
        .btn-show-map:hover    { background: #2563eb; color: #fff; border-color: #2563eb; box-shadow: 0 6px 18px rgba(37,99,235,0.3); }

        .reco-input {
            width: 100%;
            border: 1px solid #c3c9b9;
            border-radius: 10px;
            padding: 10px 12px;
            background: #fff;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }
        .reco-input:focus {
            border-color: #0a2200;
            box-shadow: 0 0 0 3px rgba(10, 34, 0, 0.08);
            outline: none;
        }
        .importance-track {
            width: 100%;
            height: 8px;
            border-radius: 9999px;
            background: #e4e4cc;
            overflow: hidden;
        }
        .importance-fill {
            height: 100%;
            border-radius: 9999px;
            background: linear-gradient(90deg, #0a2200, #2f6f0a);
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "surface-container-low": "#f5f5dc", "outline-variant": "#c3c9b9", "surface-container-highest": "#e4e4cc",
                        "on-surface": "#1b1d0e", "surface-container-high": "#eaead1", "on-surface-variant": "#43493d",
                        "background": "#fbfbe2", "surface": "#fbfbe2", "primary": "#0a2200", "on-primary": "#ffffff",
                        "secondary": "#934b19", "on-secondary": "#ffffff",
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-surface">
    {% include 'elfirma/_admin_sidebar.html.twig' with { 'current_module': 'parcelles-cultures' } %}

    <!-- Main Content -->
    <main class="md:ml-72 min-h-screen p-4 md:p-6 space-y-8">
        <header class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <nav class="flex items-center gap-2 text-sm text-on-surface-variant mb-2">
                    <a href="{{ path('parcelle_index') }}" class="hover:text-primary">Parcels</a>
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                    <span class="text-primary font-semibold">{{ parcelle.nom }}</span>
                </nav>
                <h2 class="text-4xl font-black text-primary tracking-tighter leading-none mb-2">{{ parcelle.nom }}</h2>
                <p class="text-on-surface-variant text-lg">Parcel details and associated crops</p>
            </div>
            <div class="flex items-center gap-3 flex-wrap">
                <a href="{{ path('parcelle_map') }}" class="btn-show btn-show-map">
                    <span class="material-symbols-outlined" style="font-size:18px;">map</span>
                    View on Map
                </a>
                <a href="{{ path('irrigation_index', {parcelle: parcelle.id}) }}" class="btn-show btn-show-map">
                    <span class="material-symbols-outlined" style="font-size:18px;">water_drop</span>
                    Irrigation
                </a>
                <a href="{{ path('parcelle_edit', {id: parcelle.id}) }}" class="btn-show btn-show-edit">
                    <span class="material-symbols-outlined" style="font-size:18px;">edit</span>
                    Edit
                </a>
                <button type="button"
                        class="btn-show btn-show-danger open-delete-modal"
                        data-delete-url="{{ path('parcelle_delete', {id: parcelle.id}) }}"
                        data-delete-token="{{ csrf_token('delete' ~ parcelle.id) }}"
                        data-delete-name="{{ parcelle.nom|e('html_attr') }}">
                    <span class="material-symbols-outlined" style="font-size:18px;">delete</span>
                    Delete
                </button>
                <a href="{{ path('parcelle_index') }}" class="btn-show btn-show-ghost">
                    <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span>
                    Back
                </a>
            </div>
        </header>

        <!-- Parcel Info Cards -->
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="bg-white rounded-xl p-6 shadow-sm">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary">location_on</span>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase text-on-surface-variant">Location</p>
                        <p class="text-lg font-bold text-primary">{{ parcelle.localisation }}</p>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-sm">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center">
                        <span class="material-symbols-outlined text-blue-600">straighten</span>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase text-on-surface-variant">Area</p>
                        <p class="text-lg font-bold text-blue-600">{{ parcelle.superficie|number_format(2) }} ha</p>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-sm">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-lg bg-orange-500/10 flex items-center justify-center">
                        <span class="material-symbols-outlined text-orange-600">landscape</span>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase text-on-surface-variant">Soil Type</p>
                        <p class="text-lg font-bold text-orange-600">{{ parcelle.typeSol ?? 'Not specified' }}</p>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-sm">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-lg bg-green-500/10 flex items-center justify-center">
                        <span class="material-symbols-outlined text-green-600">info</span>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase text-on-surface-variant">Status</p>
                        {% if parcelle.statut == 'Available' %}
                            <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-bold">{{ parcelle.statut }}</span>
                        {% elseif parcelle.statut == 'Occupied' %}
                            <span class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-sm font-bold">{{ parcelle.statut }}</span>
                        {% elseif parcelle.statut == 'Resting' %}
                            <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-bold">{{ parcelle.statut }}</span>
                        {% else %}
                            <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm font-bold">{{ parcelle.statut ?? 'N/A' }}</span>
                        {% endif %}
                    </div>
                </div>
            </div>
        </section>

        <!-- Image and Map Section -->
        <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Parcel Image -->
            <div class="bg-white rounded-xl p-6 shadow-sm">
                <h3 class="text-xl font-black text-primary tracking-tighter mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined">image</span>
                    Parcel Image
                </h3>
                {% if parcelle.image %}
                <div class="parcel-image-container" onclick="openLightbox()">
                    <img src="{{ path('parcelle_image', {id: parcelle.id}) }}" alt="{{ parcelle.nom }}" class="w-full h-64 object-cover rounded-xl">
                    <div class="parcel-image-overlay">
                        <span class="text-white font-bold flex items-center gap-2">
                            <span class="material-symbols-outlined">zoom_in</span>
                            Click to enlarge
                        </span>
                    </div>
                </div>
                {% else %}
                <div class="h-64 bg-surface-container-low rounded-xl flex flex-col items-center justify-center text-on-surface-variant">
                    <span class="material-symbols-outlined text-6xl opacity-30">hide_image</span>
                    <p class="mt-2 font-semibold">No image available</p>
                </div>
                {% endif %}
            </div>

            <!-- Map Location -->
            <div class="bg-white rounded-xl p-6 shadow-sm">
                <h3 class="text-xl font-black text-primary tracking-tighter mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined">map</span>
                    Location &amp; Area Visualization
                </h3>
                {% if parcelle.latitude and parcelle.longitude %}
                <div id="parcel-map" class="shadow-md border border-outline-variant/30"></div>
                <!-- Coordinates row -->
                <div class="mt-3 flex flex-wrap items-center gap-4 text-sm text-on-surface-variant">
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-base">my_location</span>
                        Lat: <strong class="text-primary ml-1">{{ parcelle.latitude }}</strong>
                    </span>
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-base">explore</span>
                        Lng: <strong class="text-primary ml-1">{{ parcelle.longitude }}</strong>
                    </span>
                </div>

                <!-- Area legend bar -->
                <div class="mt-3 flex items-center gap-3 px-4 py-3 rounded-xl text-sm
                    {% if parcelle.statut == 'Available' %}bg-emerald-50 border border-emerald-200
                    {% elseif parcelle.statut == 'Occupied' %}bg-orange-50 border border-orange-200
                    {% else %}bg-blue-50 border border-blue-200{% endif %}">

                    <!-- Mini circle icon -->
                    <div class="relative w-8 h-8 flex-shrink-0 flex items-center justify-center">
                        <div class="absolute inset-0 rounded-full opacity-20
                            {% if parcelle.statut == 'Available' %}bg-emerald-500
                            {% elseif parcelle.statut == 'Occupied' %}bg-orange-500
                            {% else %}bg-blue-500{% endif %}">
                        </div>
                        <div class="w-3.5 h-3.5 rounded-full border-2 border-dashed
                            {% if parcelle.statut == 'Available' %}border-emerald-500
                            {% elseif parcelle.statut == 'Occupied' %}border-orange-500
                            {% else %}border-blue-500{% endif %}">
                        </div>
                    </div>

                    <!-- Labels -->
                    <div class="flex-1 min-w-0">
                        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Shaded circle on map</p>
                        <div class="flex flex-wrap items-baseline gap-2 mt-0.5">
                            <span class="text-lg font-black
                                {% if parcelle.statut == 'Available' %}text-emerald-700
                                {% elseif parcelle.statut == 'Occupied' %}text-orange-700
                                {% else %}text-blue-700{% endif %}">
                                {{ parcelle.superficie|number_format(2) }} ha
                            </span>
                            <span class="text-xs text-gray-400">
                                = {{ (parcelle.superficie * 10000)|number_format(0) }} m²
                            </span>
                        </div>
                    </div>

                    <!-- Radius -->
                    <div class="text-right flex-shrink-0 hidden sm:block">
                        <p class="text-xs text-gray-400 uppercase tracking-wide">Circle radius</p>
                        <p class="font-bold text-gray-600 text-sm" id="areaRadiusDisplay">…</p>
                    </div>
                </div>
                {% else %}
                <div class="h-64 bg-surface-container-low rounded-xl flex flex-col items-center justify-center text-on-surface-variant">
                    <span class="material-symbols-outlined text-6xl opacity-30">location_off</span>
                    <p class="mt-2 font-semibold">No coordinates set</p>
                    <a href="{{ path('parcelle_edit', {id: parcelle.id}) }}" class="text-primary font-bold hover:underline mt-2">Add location</a>
                </div>
                {% endif %}
            </div>
        </section>

        <!-- Crop Recommendation Panel: integrated here because parcel detail is the point
             where agronomic decisions are made before creating or updating a crop plan. -->
        <section class="bg-white rounded-xl p-8 shadow-sm">
            <div class="flex flex-col lg:flex-row lg:items-start justify-between gap-6 mb-6">
                <div>
                    <h3 class="text-2xl font-black text-primary tracking-tighter flex items-center gap-2">
                        <span class="material-symbols-outlined">auto_awesome</span>
                        AI Crop Recommendation
                    </h3>
                    <p class="text-on-surface-variant mt-1">
                        Evaluate this parcel with soil and climate indicators to get a recommended crop,
                        confidence score, top 3 alternatives, and agronomic guidance.
                    </p>
                </div>
                <div class="bg-surface-container-low rounded-xl px-4 py-3 text-sm text-on-surface-variant min-w-[260px]">
                    <p class="font-bold text-primary mb-1">Model Summary</p>
                    <p>
                        <span class="font-semibold">Selected model:</span>
                        {{ recommendationModel.selected_model.name ?? 'N/A' }}
                        {% if recommendationModel.selected_model.model_class is defined %}
                            ({{ recommendationModel.selected_model.model_class }})
                        {% endif %}
                    </p>
                    <p>
                        <span class="font-semibold">Test accuracy:</span>
                        {% if recommendationModel.test_metrics.accuracy is defined %}
                            {{ (recommendationModel.test_metrics.accuracy * 100)|number_format(2) }}%
                        {% else %}
                            N/A
                        {% endif %}
                    </p>
                    <p>
                        <span class="font-semibold">Test macro F1:</span>
                        {% if recommendationModel.test_metrics.macro_f1 is defined %}
                            {{ recommendationModel.test_metrics.macro_f1|number_format(4) }}
                        {% else %}
                            N/A
                        {% endif %}
                    </p>
                </div>
            </div>

            <form id="cropRecommendationForm" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-7 gap-4">
                <div>
                    <label for="featureN" class="block text-xs font-bold uppercase text-on-surface-variant mb-1">N</label>
                    <input id="featureN" name="N" type="number" step="0.01" class="reco-input" placeholder="e.g. 90" required>
                </div>
                <div>
                    <label for="featureP" class="block text-xs font-bold uppercase text-on-surface-variant mb-1">P</label>
                    <input id="featureP" name="P" type="number" step="0.01" class="reco-input" placeholder="e.g. 42" required>
                </div>
                <div>
                    <label for="featureK" class="block text-xs font-bold uppercase text-on-surface-variant mb-1">K</label>
                    <input id="featureK" name="K" type="number" step="0.01" class="reco-input" placeholder="e.g. 43" required>
                </div>
                <div>
                    <label for="featureTemperature" class="block text-xs font-bold uppercase text-on-surface-variant mb-1">Temperature</label>
                    <input id="featureTemperature" name="temperature" type="number" step="0.01" class="reco-input" placeholder="deg C" required>
                </div>
                <div>
                    <label for="featureHumidity" class="block text-xs font-bold uppercase text-on-surface-variant mb-1">Humidity</label>
                    <input id="featureHumidity" name="humidity" type="number" step="0.01" class="reco-input" placeholder="%" required>
                </div>
                <div>
                    <label for="featurePh" class="block text-xs font-bold uppercase text-on-surface-variant mb-1">pH</label>
                    <input id="featurePh" name="ph" type="number" step="0.01" class="reco-input" placeholder="e.g. 6.5" required>
                </div>
                <div>
                    <label for="featureRainfall" class="block text-xs font-bold uppercase text-on-surface-variant mb-1">Rainfall</label>
                    <input id="featureRainfall" name="rainfall" type="number" step="0.01" class="reco-input" placeholder="mm" required>
                </div>

                <div class="sm:col-span-2 lg:col-span-4 xl:col-span-7 flex items-center gap-3 mt-1">
                    <button type="submit" id="runRecommendationBtn" class="btn-show btn-show-edit">
                        <span class="material-symbols-outlined" style="font-size:18px;">psychology</span>
                        Get Recommendation
                    </button>
                    <span class="text-xs text-on-surface-variant">
                        Parcel context: {{ parcelle.nom }}{% if parcelle.typeSol %} | Soil: {{ parcelle.typeSol }}{% endif %}
                    </span>
                </div>
            </form>

            <div id="recommendationLoading" class="hidden mt-5 flex items-center gap-3 text-on-surface-variant">
                <span class="material-symbols-outlined animate-spin">progress_activity</span>
                <span>Computing recommendation using the trained model...</span>
            </div>

            <div id="recommendationError" class="hidden mt-5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

            <div id="recommendationResult" class="hidden mt-6 space-y-6">
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
                    <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4">
                        <p class="text-xs uppercase tracking-wide text-emerald-700 font-bold">Recommended Crop</p>
                        <p id="recommendedCropLabel" class="text-2xl font-black text-emerald-800 mt-1">-</p>
                    </div>
                    <div class="rounded-xl border border-blue-200 bg-blue-50 p-4">
                        <p class="text-xs uppercase tracking-wide text-blue-700 font-bold">Confidence</p>
                        <p id="recommendationConfidence" class="text-2xl font-black text-blue-800 mt-1">-</p>
                    </div>
                    <div class="rounded-xl border border-orange-200 bg-orange-50 p-4">
                        <p class="text-xs uppercase tracking-wide text-orange-700 font-bold">Best Alternative</p>
                        <p id="inferenceModeLabel" class="text-2xl font-black text-orange-800 mt-1">-</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
                    <div class="xl:col-span-1 rounded-xl border border-outline-variant/30 bg-surface-container-low p-4">
                        <h4 class="font-black text-primary mb-3">Top 3 Crops</h4>
                        <div id="topPredictionsList" class="space-y-2 text-sm"></div>
                    </div>

                    <div class="xl:col-span-2 rounded-xl border border-outline-variant/30 bg-surface-container-low p-4">
                        <h4 class="font-black text-primary mb-2">Why this crop?</h4>
                        <p id="recommendationSummary" class="text-sm text-on-surface mb-4"></p>

                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                            <div>
                                <p class="text-xs uppercase font-bold text-emerald-700 mb-2">Supporting Factors</p>
                                <ul id="supportingFactorsList" class="text-sm text-on-surface space-y-1 list-disc pl-5"></ul>
                            </div>
                            <div>
                                <p class="text-xs uppercase font-bold text-amber-700 mb-2">Points to Monitor</p>
                                <ul id="limitingFactorsList" class="text-sm text-on-surface space-y-1 list-disc pl-5"></ul>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
                    <div class="rounded-xl border border-outline-variant/30 bg-surface-container-low p-4">
                        <h4 class="font-black text-primary mb-3">Feature Importance</h4>
                        <div id="featureImportanceList" class="space-y-3"></div>
                    </div>

                    <div class="rounded-xl border border-outline-variant/30 bg-surface-container-low p-4">
                        <h4 class="font-black text-primary mb-3">Agronomic Advice</h4>
                        <ul id="agronomicAdviceList" class="text-sm text-on-surface space-y-2 list-disc pl-5"></ul>
                    </div>
                </div>

                <div class="flex flex-wrap items-center gap-3">
                    <a id="createRecommendedCropBtn" href="{{ path('culture_new', {parcelleId: parcelle.id}) }}" class="btn-show btn-show-edit">
                        <span class="material-symbols-outlined" style="font-size:18px;">add_circle</span>
                        Create Crop Plan From Recommendation
                    </a>
                    <span class="text-xs text-on-surface-variant">The crop form will be prefilled with this parcel and the recommended crop name.</span>
                </div>
            </div>
        </section>

        <!-- Additional Details -->
        <section class="bg-white rounded-xl p-8 shadow-sm">
            <h3 class="text-2xl font-black text-primary tracking-tighter mb-6">Additional Information</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="p-4 bg-surface-container-low rounded-lg">
                    <p class="text-xs font-bold uppercase text-on-surface-variant mb-1">Creation Date</p>
                    <p class="text-lg font-semibold flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">calendar_today</span>
                        {{ parcelle.dateCreation ? parcelle.dateCreation|date('d M Y') : 'Not set' }}
                    </p>
                </div>
                <div class="p-4 bg-surface-container-low rounded-lg">
                    <p class="text-xs font-bold uppercase text-on-surface-variant mb-1">Latitude</p>
                    <p class="text-lg font-semibold flex items-center gap-2">
                        <span class="material-symbols-outlined text-blue-600">north</span>
                        {{ parcelle.latitude ?? 'Not set' }}
                    </p>
                </div>
                <div class="p-4 bg-surface-container-low rounded-lg">
                    <p class="text-xs font-bold uppercase text-on-surface-variant mb-1">Longitude</p>
                    <p class="text-lg font-semibold flex items-center gap-2">
                        <span class="material-symbols-outlined text-green-600">east</span>
                        {{ parcelle.longitude ?? 'Not set' }}
                    </p>
                </div>
                <div class="p-4 bg-surface-container-low rounded-lg">
                    <p class="text-xs font-bold uppercase text-on-surface-variant mb-1">Total Crops</p>
                    <p class="text-lg font-semibold flex items-center gap-2">
                        <span class="material-symbols-outlined text-orange-600">eco</span>
                        {{ parcelle.cultures|length }} crop(s)
                    </p>
                </div>
            </div>
        </section>

        <!-- Associated Crops -->
        <section class="bg-white rounded-xl shadow-sm overflow-hidden">
            <div class="p-6 border-b border-outline-variant/20">
                <h3 class="text-2xl font-black text-primary tracking-tighter">Associated Crops ({{ parcelle.cultures|length }})</h3>
            </div>
            {% if parcelle.cultures|length > 0 %}
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-surface-container-high text-on-surface-variant">
                            <th class="px-6 py-4 text-xs font-black uppercase">Crop Name</th>
                            <th class="px-6 py-4 text-xs font-black uppercase">Variety</th>
                            <th class="px-6 py-4 text-xs font-black uppercase">Planting Date</th>
                            <th class="px-6 py-4 text-xs font-black uppercase">Status</th>
                            <th class="px-6 py-4 text-xs font-black uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/10">
                        {% for culture in parcelle.cultures %}
                        <tr class="hover:bg-surface-container-low transition-colors">
                            <td class="px-6 py-4 font-bold text-primary">{{ culture.nomCulture }}</td>
                            <td class="px-6 py-4 text-on-surface-variant">{{ culture.variete ?? '-' }}</td>
                            <td class="px-6 py-4">{{ culture.datePlantation ? culture.datePlantation|date('d M Y') : '-' }}</td>
                            <td class="px-6 py-4">
                                {% if culture.statut == 'In Progress' %}
                                    <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold">In Progress</span>
                                {% elseif culture.statut == 'Planned' %}
                                    <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-bold">Planned</span>
                                {% elseif culture.statut == 'Harvested' %}
                                    <span class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-xs font-bold">Harvested</span>
                                {% else %}
                                    <span class="bg-gray-100 text-gray-600 px-3 py-1 rounded-full text-xs font-bold">{{ culture.statut ?? 'N/A' }}</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4">
                                <a href="{{ path('culture_show', {id: culture.id}) }}" class="text-blue-600 hover:underline font-semibold">View</a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div class="p-12 text-center text-on-surface-variant">
                <span class="material-symbols-outlined text-6xl opacity-30">eco</span>
                <p class="mt-4 text-lg font-semibold">No crops associated with this parcel</p>
                <a href="{{ path('culture_new', {parcelleId: parcelle.id}) }}" class="text-primary font-bold hover:underline">Add a crop →</a>
            </div>
            {% endif %}
        </section>
    </main>

    <footer class="md:ml-72 flex justify-between items-center px-12 py-8 bg-[#fbfbe2] border-t border-[#c3c9b9]/15">
        <p class="text-sm tracking-wide text-on-surface-variant">Elfirma © 2026</p>
    </footer>

    <!-- Image Lightbox -->
    {% if parcelle.image %}
    <div class="lightbox" id="imageLightbox" onclick="closeLightbox()">
        <span class="lightbox-close" onclick="closeLightbox()">&times;</span>
        <img src="{{ path('parcelle_image', {id: parcelle.id}) }}" alt="{{ parcelle.nom }}">
    </div>
    {% endif %}

    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script>
        // Dropdown toggle
        document.querySelectorAll('.dropdown > button').forEach(btn => {
            btn.addEventListener('click', function(e) {
                const menu = this.nextElementSibling;
                menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
            });
        });

        // Lightbox functions
        function openLightbox() {
            document.getElementById('imageLightbox').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            document.getElementById('imageLightbox').classList.remove('active');
            document.body.style.overflow = '';
        }

        // Close lightbox with Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeLightbox();
        });

        {% if parcelle.latitude and parcelle.longitude %}
        (function () {
            const parcelLat  = {{ parcelle.latitude }};
            const parcelLng  = {{ parcelle.longitude }};
            const areaHa     = {{ parcelle.superficie }};
            const parcelName = {{ parcelle.nom|json_encode|raw }};
            const statut     = {{ parcelle.statut|json_encode|raw }};

            // ── Derive circle radius from area ──────────────────────────────
            // 1 ha = 10 000 m²  →  circle area = π·r²  →  r = √(A/π)
            const areaM2      = areaHa * 10000;
            const trueRadius  = areaHa > 0 ? Math.sqrt(areaM2 / Math.PI) : 0;
            // Visual minimum 150 m so the circle is always visible on the map
            const visualRadius = Math.max(trueRadius, 150);
            const radiusM      = Math.round(trueRadius);

            // Show radius in the legend bar
            const radEl = document.getElementById('areaRadiusDisplay');
            if (radEl) radEl.textContent = radiusM > 0 ? '≈ ' + radiusM.toLocaleString() + ' m' : '—';

            // ── Status colour ────────────────────────────────────────────────
            const colorMap = { Available: '#10b981', Occupied: '#f97316', Resting: '#3b82f6' };
            const color    = colorMap[statut] || '#6b7280';

            // ── Map init — set a real view immediately so tiles start loading ─
            const map = L.map('parcel-map', { zoomSnap: 0.5 });

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);

            // Give the map a real starting view straight away (tiles begin
            // fetching before invalidateSize fires).
            map.setView([parcelLat, parcelLng], 13);

            // ── Scale bar ────────────────────────────────────────────────────
            L.control.scale({ imperial: false, position: 'bottomleft' }).addTo(map);

            // ── Everything that needs correct container size goes in here ────
            // delay 150 ms so the browser has finished painting the flex/grid
            // layout and Leaflet can measure the real pixel dimensions.
            setTimeout(function () {

                // Fix tile gaps caused by wrong initial container measurement
                map.invalidateSize();

                // ── Area circle ──────────────────────────────────────────────
                const areaCircle = L.circle([parcelLat, parcelLng], {
                    radius:      visualRadius,
                    color:       color,
                    fillColor:   color,
                    fillOpacity: 0.15,
                    weight:      2.5,
                    dashArray:   '10 6',
                    lineCap:     'round'
                }).addTo(map);

                // Permanent tooltip showing real area
                areaCircle.bindTooltip(
                    '<span style="color:' + color + ';font-weight:700;">' +
                        areaHa.toLocaleString() + ' ha' +
                    '</span>',
                    {
                        permanent:  true,
                        direction:  'top',
                        className:  'area-circle-tooltip',
                        offset:     [0, -6]
                    }
                );

                // Fit map to the circle, never exceeding zoom 15 so OSM
                // tiles always exist and the circle stays readable
                map.fitBounds(areaCircle.getBounds(), {
                    padding: [48, 48],
                    maxZoom: 15
                });

                // ── Pulsing pin marker ───────────────────────────────────────
                const pinIcon = L.divIcon({
                    className: '',
                    html:
                        '<div style="position:relative;width:32px;height:32px;">' +
                            '<div class="marker-ping" style="border:3px solid ' + color + ';border-radius:50%;width:32px;height:32px;top:0;left:0;position:absolute;"></div>' +
                            '<div style="' +
                                'position:absolute;top:2px;left:2px;' +
                                'width:28px;height:28px;' +
                                'background:#0a2200;' +
                                'border-radius:50% 50% 50% 0;' +
                                'transform:rotate(-45deg);' +
                                'border:3px solid white;' +
                                'box-shadow:0 4px 14px rgba(0,0,0,0.35);' +
                            '"></div>' +
                            '<div style="' +
                                'position:absolute;top:50%;left:50%;' +
                                'width:8px;height:8px;' +
                                'background:white;border-radius:50%;' +
                                'transform:translate(-50%,-54%);' +
                            '"></div>' +
                        '</div>',
                    iconSize:    [32, 32],
                    iconAnchor:  [16, 32],
                    popupAnchor: [0, -36]
                });

                const marker = L.marker([parcelLat, parcelLng], { icon: pinIcon }).addTo(map);

                // Rich popup
                marker.bindPopup(
                    '<div style="font-family:Inter,sans-serif;min-width:190px;">' +
                        '<div style="background:#0a2200;color:white;padding:8px 12px;margin:-12px -12px 10px -12px;border-radius:8px 8px 0 0;">' +
                            '<strong style="font-size:13px;">' + parcelName + '</strong>' +
                        '</div>' +
                        '<p style="margin:0 0 4px;font-size:12px;color:#555;">📍 {{ parcelle.localisation }}</p>' +
                        '<p style="margin:0 0 4px;font-size:12px;color:#555;">🌱 {{ parcelle.typeSol ?? "Unknown soil" }}</p>' +
                        '<div style="margin-top:8px;padding:6px 10px;background:' + color + '18;border-left:3px solid ' + color + ';border-radius:0 6px 6px 0;">' +
                            '<span style="font-size:14px;font-weight:800;color:#0a2200;">{{ parcelle.superficie|number_format(2) }} ha</span>' +
                            '<span style="font-size:11px;color:#888;margin-left:6px;">≈ ' + radiusM.toLocaleString() + ' m radius</span>' +
                        '</div>' +
                        '<p style="margin:8px 0 0;font-size:11px;color:#aaa;text-align:right;">' +
                            parcelLat.toFixed(5) + ', ' + parcelLng.toFixed(5) +
                        '</p>' +
                    '</div>',
                    { maxWidth: 240 }
                ).openPopup();

            }, 150); // end setTimeout

        })();
        {% endif %}
    </script>
    <script>
        (function () {
            const form = document.getElementById('cropRecommendationForm');
            if (!form) {
                return;
            }

            const endpoint = '{{ path('parcelle_recommendation', {id: parcelle.id}) }}';
            const createCropBaseUrl = '{{ path('culture_new') }}';
            const parcelId = {{ parcelle.id }};

            const loadingEl = document.getElementById('recommendationLoading');
            const errorEl = document.getElementById('recommendationError');
            const resultEl = document.getElementById('recommendationResult');
            const submitBtn = document.getElementById('runRecommendationBtn');

            const recommendedCropLabel = document.getElementById('recommendedCropLabel');
            const confidenceLabel = document.getElementById('recommendationConfidence');
            const inferenceModeLabel = document.getElementById('inferenceModeLabel');
            const topPredictionsList = document.getElementById('topPredictionsList');
            const summaryEl = document.getElementById('recommendationSummary');
            const supportingList = document.getElementById('supportingFactorsList');
            const limitingList = document.getElementById('limitingFactorsList');
            const importanceList = document.getElementById('featureImportanceList');
            const adviceList = document.getElementById('agronomicAdviceList');
            const createBtn = document.getElementById('createRecommendedCropBtn');

            const featureInputs = {
                N: document.getElementById('featureN'),
                P: document.getElementById('featureP'),
                K: document.getElementById('featureK'),
                temperature: document.getElementById('featureTemperature'),
                humidity: document.getElementById('featureHumidity'),
                ph: document.getElementById('featurePh'),
                rainfall: document.getElementById('featureRainfall'),
            };

            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/\"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function setLoadingState(isLoading) {
                if (loadingEl) {
                    loadingEl.classList.toggle('hidden', !isLoading);
                }
                if (submitBtn) {
                    submitBtn.disabled = isLoading;
                    submitBtn.classList.toggle('opacity-60', isLoading);
                    submitBtn.classList.toggle('cursor-not-allowed', isLoading);
                }
            }

            function hideError() {
                if (!errorEl) {
                    return;
                }
                errorEl.classList.add('hidden');
                errorEl.textContent = '';
            }

            function showError(message) {
                if (!errorEl) {
                    return;
                }
                errorEl.textContent = message;
                errorEl.classList.remove('hidden');
            }

            function collectFeatures() {
                const payload = {};
                Object.entries(featureInputs).forEach(([feature, input]) => {
                    if (!input || input.value === '') {
                        throw new Error(`Feature ${feature} is required.`);
                    }

                    const value = Number(input.value);
                    if (Number.isNaN(value)) {
                        throw new Error(`Feature ${feature} must be numeric.`);
                    }

                    payload[feature] = value;
                });

                return payload;
            }

            function renderTextList(target, items, emptyMessage) {
                if (!target) {
                    return;
                }

                if (!Array.isArray(items) || items.length === 0) {
                    target.innerHTML = `<li>${escapeHtml(emptyMessage)}</li>`;
                    return;
                }

                target.innerHTML = items
                    .map((item) => `<li>${escapeHtml(item)}</li>`)
                    .join('');
            }

            function renderTopPredictions(predictions) {
                if (!topPredictionsList) {
                    return;
                }

                if (!Array.isArray(predictions) || predictions.length === 0) {
                    topPredictionsList.innerHTML = '<p class="text-on-surface-variant">No prediction details available.</p>';
                    return;
                }

                topPredictionsList.innerHTML = predictions
                    .map((item, index) => {
                        const label = item && item.crop ? String(item.crop) : '-';
                        const probability = item && typeof item.probability === 'number'
                            ? (item.probability * 100).toFixed(2)
                            : '0.00';
                        return `
                            <div class="rounded-lg bg-white border border-outline-variant/20 px-3 py-2 flex items-center justify-between">
                                <span class="font-semibold text-primary">${index + 1}. ${escapeHtml(label)}</span>
                                <span class="text-on-surface-variant text-xs font-bold">${escapeHtml(probability)}%</span>
                            </div>
                        `;
                    })
                    .join('');
            }

            function renderFeatureImportance(rows) {
                if (!importanceList) {
                    return;
                }

                if (!Array.isArray(rows) || rows.length === 0) {
                    importanceList.innerHTML = '<p class="text-sm text-on-surface-variant">No feature importance available.</p>';
                    return;
                }

                const topRows = rows.slice(0, 6);
                importanceList.innerHTML = topRows
                    .map((row) => {
                        const feature = row && row.feature ? String(row.feature) : '-';
                        const importance = row && typeof row.importance === 'number' ? row.importance : 0;
                        const width = Math.max(2, Math.min(100, importance * 100));
                        return `
                            <div>
                                <div class="flex items-center justify-between text-xs mb-1">
                                    <span class="font-semibold text-on-surface">${escapeHtml(feature)}</span>
                                    <span class="text-on-surface-variant">${escapeHtml((importance * 100).toFixed(2))}%</span>
                                </div>
                                <div class="importance-track">
                                    <div class="importance-fill" style="width:${width}%"></div>
                                </div>
                            </div>
                        `;
                    })
                    .join('');
            }

            function renderResult(data) {
                const recommendedCrop = data && data.recommended_crop ? String(data.recommended_crop) : '-';
                const confidence = data && typeof data.confidence === 'number' ? `${(data.confidence * 100).toFixed(2)}%` : 'N/A';
                const bestAlternative = data && Array.isArray(data.top_predictions) && data.top_predictions[1]
                    ? String(data.top_predictions[1].crop).charAt(0).toUpperCase() + String(data.top_predictions[1].crop).slice(1)
                    : 'N/A';

                if (recommendedCropLabel) {
                    recommendedCropLabel.textContent = recommendedCrop;
                }
                if (confidenceLabel) {
                    confidenceLabel.textContent = confidence;
                }
                if (inferenceModeLabel) {
                    inferenceModeLabel.textContent = bestAlternative;
                }

                renderTopPredictions(data.top_predictions || []);

                if (summaryEl) {
                    summaryEl.textContent = data.explanation && data.explanation.summary
                        ? String(data.explanation.summary)
                        : 'No explanation available.';
                }

                renderTextList(
                    supportingList,
                    data.explanation && Array.isArray(data.explanation.supporting_factors)
                        ? data.explanation.supporting_factors
                        : [],
                    'No supporting factors were returned.'
                );
                renderTextList(
                    limitingList,
                    data.explanation && Array.isArray(data.explanation.limiting_factors)
                        ? data.explanation.limiting_factors
                        : [],
                    'No strong limiting factors detected.'
                );
                renderTextList(
                    adviceList,
                    Array.isArray(data.agronomic_advice) ? data.agronomic_advice : [],
                    'No additional agronomic advice provided.'
                );

                renderFeatureImportance(Array.isArray(data.feature_importance) ? data.feature_importance : []);

                if (createBtn) {
                    createBtn.href = `${createCropBaseUrl}?parcelleId=${parcelId}&prefillCrop=${encodeURIComponent(recommendedCrop)}`;
                }

                if (resultEl) {
                    resultEl.classList.remove('hidden');
                }
            }

            form.addEventListener('submit', async (event) => {
                event.preventDefault();
                hideError();

                let payload;
                try {
                    payload = collectFeatures();
                } catch (error) {
                    const message = error instanceof Error ? error.message : 'Invalid inputs.';
                    showError(message);
                    return;
                }

                setLoadingState(true);

                try {
                    const response = await fetch(endpoint, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest',
                        },
                        body: JSON.stringify({ features: payload }),
                    });

                    const data = await response.json();
                    if (!response.ok) {
                        throw new Error(data && data.error ? String(data.error) : 'Recommendation request failed.');
                    }

                    renderResult(data);
                } catch (error) {
                    const message = error instanceof Error
                        ? error.message
                        : 'Unable to compute recommendation right now.';
                    showError(message);
                } finally {
                    setLoadingState(false);
                }
            });
        })();
    </script>
    <!-- Delete Confirmation Modal -->
    <div id="deleteConfirmModal" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4">
        <div id="deleteModalBackdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
        <div class="relative bg-white rounded-3xl shadow-2xl w-full max-w-md p-8">
            <div class="flex justify-center mb-6">
                <div class="w-20 h-20 rounded-full bg-red-50 flex items-center justify-center">
                    <div class="w-14 h-14 rounded-full bg-red-100 flex items-center justify-center">
                        <span class="material-symbols-outlined text-red-500 text-3xl">delete_forever</span>
                    </div>
                </div>
            </div>
            <h3 class="text-2xl font-black text-gray-800 text-center mb-2">Delete Parcel?</h3>
            <p class="text-gray-500 text-center mb-1">You are about to permanently delete</p>
            <p id="deleteModalName" class="text-[#0a2200] font-bold text-center text-lg mb-6">"…"</p>
            <p class="text-gray-400 text-sm text-center mb-8">This action cannot be undone. All associated crops will lose their parcel reference.</p>
            <div class="flex gap-3">
                <button id="deleteModalCancel" type="button" class="flex-1 py-3 rounded-2xl bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold transition-colors">Cancel</button>
                <form id="deleteModalForm" method="POST" class="flex-1">
                    <input type="hidden" name="_token" id="deleteModalToken" value="">
                    <button type="submit" class="w-full py-3 rounded-2xl bg-red-500 hover:bg-red-600 text-white font-bold transition-colors flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-lg">delete_forever</span> Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
    <script>
        (function() {
            const modal = document.getElementById('deleteConfirmModal');
            const form = document.getElementById('deleteModalForm');
            const nameEl = document.getElementById('deleteModalName');
            const tokenEl = document.getElementById('deleteModalToken');
            const cancelBtn = document.getElementById('deleteModalCancel');
            const backdrop = document.getElementById('deleteModalBackdrop');
            function open(url, token, name) {
                form.action = url; tokenEl.value = token;
                nameEl.textContent = '"' + name + '"';
                modal.classList.remove('hidden'); modal.classList.add('flex');
                document.body.style.overflow = 'hidden';
            }
            function close() {
                modal.classList.add('hidden'); modal.classList.remove('flex');
                document.body.style.overflow = '';
            }
            document.addEventListener('click', e => { const b = e.target.closest('.open-delete-modal'); if (b) open(b.dataset.deleteUrl, b.dataset.deleteToken, b.dataset.deleteName); });
            cancelBtn?.addEventListener('click', close);
            backdrop?.addEventListener('click', close);
            document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
        })();
    </script>
