    overflow:  hidden;
}
.elf-sb-footer-link:hover {
    background: var(--sb-hover);
    color:      var(--sb-primary);
}
.elf-sb-footer-link:hover .material-symbols-outlined { color: var(--sb-primary); }

/* ── Mobile floating hamburger (injected by _nav_routes.html.twig) ─── */
.elf-sidebar-toggle {
    position:      fixed;
    bottom:        22px;
    right:         22px;
    z-index:       60;
    width:         52px;
    height:        52px;
    border-radius: 50%;
    background:    #0a2200;
    color:         #fff;
    border:        none;
    cursor:        pointer;
    display:       none;
    align-items:   center;
    justify-content: center;
    box-shadow:    0 4px 22px rgba(10,34,0,.32);
    transition:    background .2s, transform .18s, box-shadow .2s;
}
.elf-sidebar-toggle:hover   { background: #173901; transform: scale(1.07); }
.elf-sidebar-toggle:active  { transform: scale(0.94); }
.elf-sidebar-toggle .material-symbols-outlined { font-size: 23px; }
@media (max-width: 767px) { .elf-sidebar-toggle { display: flex; } }

</style>

{# ════════════════════════════════════════════════════════════════════════════
