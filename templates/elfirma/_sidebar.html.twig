{# ── Desktop collapse logic (JS drives inline styles for reliable sizing) ─── #}
<script>
(function () {
    var W   = 272;   /* expanded  px */
    var W2  = 68;    /* collapsed px */
    var KEY = 'elfSbCollapsed';

    var sidebar = document.querySelector('.elf-sidebar');
    var btn     = document.getElementById('elfSbToggle');
    var icon    = btn ? btn.querySelector('.material-symbols-outlined') : null;

    function isDesktop() { return window.innerWidth >= 768; }

    /* Apply collapsed / expanded state via inline styles (highest specificity) */
    function applyState(collapsed) {
        var desktop = isDesktop();

        /* ── sidebar width ── */
        if (sidebar) {
            sidebar.style.width = desktop ? (collapsed ? W2 + 'px' : W + 'px') : '';
        }

        /* ── body padding-left (replaces md:ml-64) ── */
        document.body.style.paddingLeft = desktop ? (collapsed ? W2 + 'px' : W + 'px') : '0';

        /* ── zero-out any remaining margin-left on <main> elements ── */
        if (desktop) {
            document.querySelectorAll('main, [class*="ml-64"]').forEach(function (el) {
                el.style.marginLeft = '0';
            });
        }

        /* ── visual CSS class (controls text opacity, header direction …) ── */
        if (collapsed && desktop) {
            document.body.classList.add('sb-collapsed');
        } else {
            document.body.classList.remove('sb-collapsed');
        }

        /* ── toggle button icon + label ── */
        if (icon) icon.textContent = collapsed ? 'chevron_right' : 'chevron_left';
        if (btn)  btn.title = collapsed ? 'Expand sidebar' : 'Collapse sidebar';
        if (btn)  btn.setAttribute('aria-label', btn.title);
    }

    /* Restore saved preference (sync script already stamped the class & padding,
       but we still call applyState to set the inline width on the aside) */
    applyState(localStorage.getItem(KEY) === '1');

    /* Click handler */
    if (btn) {
        btn.addEventListener('click', function () {
            var nowCollapsed = !document.body.classList.contains('sb-collapsed');
            applyState(nowCollapsed);
            localStorage.setItem(KEY, nowCollapsed ? '1' : '0');
            setTimeout(addTooltips, 50);
        });
    }

    /* Re-apply on resize */
    window.addEventListener('resize', function () {
        applyState(localStorage.getItem(KEY) === '1');
    });

    /* Tooltip data-label attributes for icon-only mode */
    function addTooltips() {
        document.querySelectorAll('.elf-side-link, .elf-side-link-group').forEach(function (el) {
            if (el.hasAttribute('data-label')) return;
            var lbl = el.querySelector('.elf-side-label');
            if (lbl) el.setAttribute('data-label', lbl.textContent.trim());
        });
    }

    /* Wait for _nav_routes.html.twig to finish building the nav */
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function () { setTimeout(addTooltips, 250); });
    } else {
        setTimeout(addTooltips, 250);
    }
})();
</script>
