<!-- ================= JAVASCRIPT ================= -->
<script>

// ===== UTILITIES =====

function showNotification(message, type = 'success') {
    const toast = document.getElementById('notificationToast');
    const messageEl = document.getElementById('notificationMessage');
    const iconEl = document.getElementById('toastIcon');
    
    messageEl.textContent = message;
    
    if (type === 'success') {
        toast.className = 'fixed bottom-6 right-6 px-6 py-4 rounded-lg shadow-xl z-50 max-w-sm flex items-center gap-2 bg-green-600 text-white animate-fade-in';
        iconEl.textContent = 'check_circle';
    } else if (type === 'error') {
        toast.className = 'fixed bottom-6 right-6 px-6 py-4 rounded-lg shadow-xl z-50 max-w-sm flex items-center gap-2 bg-red-600 text-white animate-fade-in';
        iconEl.textContent = 'error';
    } else {
        toast.className = 'fixed bottom-6 right-6 px-6 py-4 rounded-lg shadow-xl z-50 max-w-sm flex items-center gap-2 bg-blue-600 text-white animate-fade-in';
        iconEl.textContent = 'info';
    }
    
    toast.classList.remove('hidden');
    
    setTimeout(() => {
        toast.classList.add('hidden');
    }, 3500);
}

function saveSelectedEquipement(id) {
    localStorage.setItem('selectedEquipement', id);
}

function getSelectedEquipement() {
    return localStorage.getItem('selectedEquipement');
}

function restoreSelectedEquipement() {
    const selected = getSelectedEquipement();
    if (selected) {
        const radio = document.querySelector(`input[name="selectedEquipement"][value="${selected}"]`);
        if (radio) {
            radio.checked = true;
        }
    }
}

function calculateEquipementStats() {

    const equipements = document.querySelectorAll('.equipement-row');

    let total = equipements.length;
    let dispo = 0;
    let maintenance = 0;
    let panne = 0;

    equipements.forEach(e => {
        const etat = e.dataset.etat;

        if (etat === 'disponible') dispo++;
        else if (etat === 'maintenance') maintenance++;
        else if (etat === 'panne') panne++;
    });

    document.getElementById('stat-total').textContent = total;
    document.getElementById('stat-dispo').textContent = dispo;
    document.getElementById('stat-maintenance').textContent = maintenance;
    document.getElementById('stat-panne').textContent = panne;
}
document.addEventListener('DOMContentLoaded', function() {
    calculateEquipementStats();
});
// ===== SEARCH, FILTER & SORT =====

function applyFilters() {
    const searchTerm = document.getElementById('searchInput').value.toLowerCase();
    const filterEtat = document.getElementById('filterEtat').value;
    
    const rows = Array.from(document.querySelectorAll('.equipement-row'));
    let visibleRows = [];
    let filteredCount = 0;

    // FILTRER
    rows.forEach(row => {
        const nom = row.dataset.nom;
        const type = row.dataset.type;
        const desc = row.dataset.desc;
        const etat = row.dataset.etat;
        
        const matchesSearch = !searchTerm || nom.includes(searchTerm) || type.includes(searchTerm) || desc.includes(searchTerm);
        const matchesEtat = !filterEtat || etat === filterEtat;
        
        if (matchesSearch && matchesEtat) {
            row.style.display = '';
            visibleRows.push(row);
            filteredCount++;
        } else {
            row.style.display = 'none';
        }
    });


    // RÉAFFICHER LES LIGNES TRIÉES
    const tbody = document.getElementById('equipementTableBody');
    const emptyRow = document.getElementById('emptyRow');
    
    if (visibleRows.length === 0) {
        emptyRow.style.display = '';
    } else {
        emptyRow.style.display = 'none';
        visibleRows.forEach(row => {
            tbody.appendChild(row);
        });
    }

    // METTRE À JOUR LES STATS
    updateFilterInfo(filteredCount, rows.length);
}

function updateFilterInfo(visibleCount, totalCount) {
    const totalCountEl = document.getElementById('totalCount');
    const filterInfo = document.getElementById('filterInfo');
    const filterInfoText = document.getElementById('filterInfoText');
    
    totalCountEl.textContent = visibleCount;
    
    if (visibleCount < totalCount) {
        filterInfo.classList.remove('hidden');
        filterInfoText.textContent = `${visibleCount}/${totalCount} équipements affichés`;
    } else {
        filterInfo.classList.add('hidden');
    }
}

function resetFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('filterEtat').value = '';    
    document.querySelectorAll('.equipement-row').forEach(row => {
        row.style.display = '';
    });
    document.getElementById('emptyRow').style.display = 'none';
    document.getElementById('filterInfo').classList.add('hidden');
    document.getElementById('totalCount').textContent = '{{ equipements|length }}';
}

// ===== MODAL ÉQUIPEMENT =====

function openModal() {
    document.getElementById('equipementModal').classList.remove('hidden');
    document.getElementById('equipementModal').classList.add('flex');
    document.body.style.overflow = 'hidden';
}

function closeModal() {
    document.getElementById('equipementModal').classList.add('hidden');
    document.getElementById('equipementModal').classList.remove('flex');
    document.body.style.overflow = 'auto';
}

document.getElementById('equipementModal')?.addEventListener('click', function(e) {
    if (e.target === this) {
        closeModal();
    }
});

// ===== MODAL SUPPRESSION =====

let deleteId = null;

function openDeleteModal(id) {
    deleteId = id;
    document.getElementById('deleteModal').classList.remove('hidden');
    document.getElementById('deleteModal').classList.add('flex');
    document.body.style.overflow = 'hidden';
}

function closeDeleteModal() {
    deleteId = null;
    document.getElementById('deleteModal').classList.add('hidden');
    document.getElementById('deleteModal').classList.remove('flex');
    document.body.style.overflow = 'auto';
}

function confirmDelete() {
    if (!deleteId) return;
    
    fetch(`/equipements/${deleteId}/delete`, {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Content-Type': 'application/json'
        }
    })
    .then(response => {
        if (!response.ok) {
            throw new Error(`Erreur HTTP ${response.status}`);
        }
        return response.json();
    })
    .then(data => {
        if (data.success) {
            showNotification('✅ Équipement supprimé avec succès');
            closeDeleteModal();
            setTimeout(() => location.reload(), 600);
        } else {
            showNotification(data.message || 'Erreur lors de la suppression', 'error');
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        showNotification('❌ Erreur lors de la suppression', 'error');
    });
}

document.getElementById('deleteModal')?.addEventListener('click', function(e) {
    if (e.target === this) {
        closeDeleteModal();
    }
});

// ===== ÉDITION LIGNE =====

function editRow(id) {
    ['nom', 'type', 'date', 'etat', 'cout', 'desc'].forEach(field => {
        const textEl = document.getElementById('text-' + field + '-' + id);
        const inputEl = document.getElementById('input-' + field + '-' + id);
        const errorEl = document.getElementById('error-' + field + '-' + id);
        
        if (textEl) textEl.classList.add('hidden');
        if (inputEl) inputEl.classList.remove('hidden');
        if (errorEl) errorEl.classList.add('hidden');
    });

    document.getElementById('edit-' + id).classList.add('hidden');
    document.getElementById('save-' + id).classList.remove('hidden');
    document.getElementById('cancel-' + id).classList.remove('hidden');
}

function cancelEdit(id) {
    location.reload();
}

function validateEquipement(id) {
    const nomValue = document.getElementById('input-nom-' + id).value?.trim();
    const typeValue = document.getElementById('input-type-' + id).value?.trim();
    const dateValue = document.getElementById('input-date-' + id).value;
    const etatValue = document.getElementById('input-etat-' + id).value;
    const coutValue = document.getElementById('input-cout-' + id).value;
    const descValue = document.getElementById('input-desc-' + id).value?.trim();

    let hasErrors = false;

    // Validation NOM
    if (!nomValue || nomValue.length < 3 || nomValue.length > 100) {
        document.getElementById('error-nom-' + id).textContent = 'Le nom doit avoir entre 3 et 100 caractères';
        document.getElementById('error-nom-' + id).classList.remove('hidden');
        hasErrors = true;
    } else {
        document.getElementById('error-nom-' + id).classList.add('hidden');
    }

    // Validation TYPE
    if (!typeValue || typeValue.length < 3 || typeValue.length > 100) {
        document.getElementById('error-type-' + id).textContent = 'Le type doit avoir entre 3 et 100 caractères';
        document.getElementById('error-type-' + id).classList.remove('hidden');
        hasErrors = true;
    } else {
        document.getElementById('error-type-' + id).classList.add('hidden');
    }

    // Validation DATE
    if (!dateValue) {
        document.getElementById('error-date-' + id).textContent = 'La date est obligatoire';
        document.getElementById('error-date-' + id).classList.remove('hidden');
        hasErrors = true;
    } else {
        const selectedDate = new Date(dateValue);
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        
        if (selectedDate > today) {
            document.getElementById('error-date-' + id).textContent = 'La date ne peut pas être dans le futur';
            document.getElementById('error-date-' + id).classList.remove('hidden');
            hasErrors = true;
        } else {
            document.getElementById('error-date-' + id).classList.add('hidden');
        }
    }

    // Validation ETAT
    if (!etatValue) {
        document.getElementById('error-etat-' + id).textContent = 'L\'état est obligatoire';
        document.getElementById('error-etat-' + id).classList.remove('hidden');
        hasErrors = true;
    } else {
        document.getElementById('error-etat-' + id).classList.add('hidden');
    }

    // Validation COUT
    const coutNum = parseFloat(coutValue);
    if (!coutValue || isNaN(coutNum) || coutNum < 0) {
        document.getElementById('error-cout-' + id).textContent = 'Le coût doit être un nombre positif';
        document.getElementById('error-cout-' + id).classList.remove('hidden');
        hasErrors = true;
    } else {
        document.getElementById('error-cout-' + id).classList.add('hidden');
    }

    // Validation DESCRIPTION
    if (!descValue || descValue.length < 5 || descValue.length > 200) {
        document.getElementById('error-desc-' + id).textContent = 'La description doit avoir entre 5 et 200 caractères';
        document.getElementById('error-desc-' + id).classList.remove('hidden');
        hasErrors = true;
    } else {
        document.getElementById('error-desc-' + id).classList.add('hidden');
    }

    return !hasErrors;
}

function saveRow(id) {
    // Validation côté client avant envoi
    if (!validateEquipement(id)) {
        showNotification('Veuillez corriger les erreurs', 'error');
        return;
    }

    const data = {
        nomEq: document.getElementById('input-nom-' + id).value?.trim(),
        typeEq: document.getElementById('input-type-' + id).value?.trim(),
        dateAchat: document.getElementById('input-date-' + id).value,
        etat: document.getElementById('input-etat-' + id).value,
        coutAchat: parseFloat(document.getElementById('input-cout-' + id).value),
        descriptionEq: document.getElementById('input-desc-' + id).value?.trim()
    };

    fetch(`/equipements/${id}/edit`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify(data)
    })
    .then(response => {
        if (!response.ok) {
            throw new Error(`Erreur HTTP ${response.status}`);
        }
        return response.json();
    })
    .then(data => {
        if (data.success) {
            showNotification('✅ Équipement modifié avec succès');
            setTimeout(() => location.reload(), 600);
        } else {
            const errorMsg = Array.isArray(data.errors) ? data.errors.join(', ') : data.message;
            showNotification('❌ ' + errorMsg, 'error');
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        showNotification('❌ Erreur lors de la sauvegarde', 'error');
    });
}

// ===== MODAL MAINTENANCE =====

function openMaintenanceModal() {

    const modal = document.getElementById('maintenanceModal');

    modal.classList.remove('hidden');
    modal.classList.add('flex');

    document.body.style.overflow = 'hidden';
}

function closeMaintenanceModal() {
    document.getElementById('maintenanceModal').classList.add('hidden');
    document.getElementById('maintenanceModal').classList.remove('flex');
    document.body.style.overflow = 'auto';
}

document.getElementById('maintenanceModal')?.addEventListener('click', function(e) {
    if (e.target === this) {
        closeMaintenanceModal();
    }
});

// ===== EVENT LISTENERS POUR FILTRAGE DYNAMIQUE =====

document.getElementById('searchInput')?.addEventListener('input', applyFilters);
document.getElementById('filterEtat')?.addEventListener('change', applyFilters);
document.getElementById('sortBy')?.addEventListener('change', applyFilters);

// ===== INITIALISATION =====

document.addEventListener("DOMContentLoaded", function() {
    restoreSelectedEquipement();
});

</script>

