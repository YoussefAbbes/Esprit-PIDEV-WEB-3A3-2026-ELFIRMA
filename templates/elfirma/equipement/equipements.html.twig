<script data-turbo="false">
document.querySelectorAll('.analyse-btn').forEach(btn => {
    btn.addEventListener('click', function () {

        const id = this.dataset.id;

        const aiModal = document.getElementById('ai-modal');
        const aiContent = document.getElementById('ai-content');

        if (!aiModal || !aiContent) {
            console.error('ai-modal or ai-content elements not found');
            return;
        }

        aiModal.classList.remove('hidden');
        aiContent.innerHTML = "⏳ Analysis in progress...";

        fetch('/analyse/' + id)
            .then(res => res.json())
            .then(data => {

                let riskColor = "green";
                let riskText = "Low";

                if (data.risk == 2) {
                    riskColor = "red";
                    riskText = "High";
                } else if (data.risk == 1) {
                    riskColor = "orange";
                    riskText = "Medium";
                }

                let analysisHtml = data.analysis.map(a => `<li>${a}</li>`).join('');
                let recHtml = data.recommendations.map(r => `<li>${r}</li>`).join('');

                const equipementNameEl = document.getElementById('ai-equipement-name');
                if (equipementNameEl) {
                    equipementNameEl.innerText = data.nom || 'Equipment';
                }

                aiContent.innerHTML = `
                    
                    <!-- 📊 SCORE -->
                    <div class="bg-white p-4 rounded-xl shadow border">
                        <p class="text-sm text-gray-500 mb-2">📊 Health score</p>
                        <p class="text-2xl font-bold text-blue-600">${data.score}%</p>
                    </div>

                    <!-- ⚠️ RISQUE -->
                    <div class="bg-white p-4 rounded-xl shadow border">
                        <p class="text-sm text-gray-500 mb-2">⚠️ Risk level</p>
                        <p class="font-bold text-${riskColor}-600">${riskText}</p>
                    </div>

                    <!-- 📊 ANALYSE -->
                    <div class="bg-white p-4 rounded-xl shadow border">
                        <p class="font-bold mb-2">📊 Analysis</p>
                        <ul class="list-disc pl-5 text-sm text-gray-700">
                            ${analysisHtml}
                        </ul>
                    </div>

                    <!-- 🔧 RECOMMANDATIONS -->
                    <div class="bg-white p-4 rounded-xl shadow border">
                        <p class="font-bold mb-2">🔧 Recommendations</p>
                        <ul class="list-disc pl-5 text-sm text-gray-700">
                            ${recHtml}
                        </ul>
                    </div>

                `;
            })
            .catch(err => {
                if (aiContent) {
                    aiContent.innerHTML = "❌ Error during analysis";
                }
                console.error('Error during analysis:', err);
            });
    });
});

function closeAIModalAi() {
    document.getElementById('ai-modal').classList.add('hidden');
}
</script>

<script data-turbo="false">
function openPrediction(id) {

    const modal = document.getElementById('prediction-modal');
    const content = document.getElementById('modal-content');

    if (!modal || !content) {
        console.error('Prediction modal not found');
        return;
    }

    fetch('{{ path('predict_maintenance', {id: 0}) }}'.replace('0', id))
        .then(res => res.json())
        .then(data => {

            // 🟢 CAS 1 : Aucune maintenance
            if (data.status === 'NO_MAINTENANCE') {

                content.innerHTML = `
                    <div class="bg-green-100 border border-green-400 p-5 rounded-xl text-center">
                        <p class="text-green-700 font-bold text-lg">
                            ${data.message}
                        </p>
                    </div>
                `;

                modal.classList.remove('hidden');
                return;
            }

            // 🔴 CAS 2 : erreur
            if (data.error) {

                content.innerHTML = `
                    <div class="bg-red-100 border border-red-400 p-5 rounded-xl text-center">
                        <p class="text-red-600 font-semibold">
                            ${data.error}
                        </p>
                    </div>
                `;

                modal.classList.remove('hidden');
                return;
            }

            // ✅ CAS 3 : prédiction normale

            // � Equipement name
            const equipementNameEl = document.getElementById('equipement-name');
            if (equipementNameEl) {
                equipementNameEl.innerText = data.nomEq || 'Equipment';
            }

            // 📅 Date
            const predictedDateEl = document.getElementById('predicted-date');
            if (predictedDateEl) {
                predictedDateEl.innerText = data.predictedDate.substring(0,10);
            }

            // ⏳ Jours
            const daysRemainingEl = document.getElementById('days-remaining');
            if (daysRemainingEl) {
                daysRemainingEl.innerText = data.daysRemaining;
            }

            // ⚠️ Risk
            const riskCard = document.getElementById('risk-card');
            const riskText = document.getElementById('risk-text');

            if (!riskCard || !riskText) {
                console.error('risk-card or risk-text elements not found');
                modal.classList.remove('hidden');
                return;
            }

            let color = "";
            let bg = "";

            switch (data.riskLevel) {
                case "CRITIQUE":
                    bg = "bg-red-100 border-red-400";
                    color = "text-red-700";
                    break;
                case "HAUT":
                    bg = "bg-orange-100 border-orange-400";
                    color = "text-orange-700";
                    break;
                case "MOYEN":
                    bg = "bg-yellow-100 border-yellow-400";
                    color = "text-yellow-700";
                    break;
                default:
                    bg = "bg-green-100 border-green-400";
                    color = "text-green-700";
            }

            riskCard.className = `p-4 rounded-xl border ${bg}`;
            riskText.className = `text-sm font-semibold ${color}`;
            riskText.innerText = data.riskLevel;

            modal.classList.remove('hidden');
        })
        .catch(error => {
            console.error("Error:", error);

            const modalContent = document.getElementById('modal-content');
            const predictionModal = document.getElementById('prediction-modal');

            if (modalContent) {
                modalContent.innerHTML = `
                    <div class="bg-red-100 border border-red-400 p-5 rounded-xl text-center">
                        <p class="text-red-600">Server error</p>
                    </div>
                `;
            }

            if (predictionModal) {
                predictionModal.classList.remove('hidden');
            }
        });
}

function closePredictionModal() {
    document.getElementById('prediction-modal').classList.add('hidden');
}
</script>

