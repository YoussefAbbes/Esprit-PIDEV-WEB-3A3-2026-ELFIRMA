
{% extends 'baseback.html.twig' %}

{% block body %}

<!-- Main Content -->
<main class="flex-1 min-h-screen bg-[#fbfbe2]">
<!-- HEADER -->
<header class="sticky top-0 z-30 bg-white border-b border-gray-100 flex justify-between items-center w-full px-8 py-3">
    <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-3xl text-[#0a2200]">handyman</span>
        <h2 class="text-2xl font-black text-[#0a2200]">Equipment Management</h2>
    </div>
    <a href="{{ path('elfirma_page', {module: 'tableau-de-bord'}) }}" class="text-sm text-gray-600 hover:text-gray-900 transition">Website</a>
</header>

<div class="px-8 py-5 space-y-5">

<!-- FLASH MESSAGES -->
{% if app.flashes('success') %}
    {% for message in app.flashes('success') %}
    <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-800 rounded-lg flex items-center gap-3">
        <span class="material-symbols-outlined text-green-600">check_circle</span>
        <span>{{ message }}</span>
    </div>
    {% endfor %}
{% endif %}

{% if app.flashes('error') %}
    {% for message in app.flashes('error') %}
    <div class="mb-4 p-4 bg-red-50 border border-red-200 text-red-800 rounded-lg flex items-center gap-3">
        <span class="material-symbols-outlined text-red-600">error</span>
        <span>{{ message }}</span>
    </div>
    {% endfor %}
{% endif %}

<!-- Action Bar -->
<section class="flex justify-between items-center gap-6 mb-1">
    <div>
        <h3 class="text-2xl font-bold text-[#0a2200]">Equipment Park</h3>
        <p class="text-gray-600 mt-0.5 text-sm"><strong id="totalCount">{{ equipements|length }}</strong> items</p>
    </div>

    <div class="flex gap-3">
        <button onclick="openModal()"
            class="px-5 py-2.5 bg-[#116530] text-white rounded-lg flex items-center gap-2 hover:bg-[#0d4a1f] transition-colors text-sm font-medium">
            <span class="material-symbols-outlined text-[18px]">add</span>
            Add equipment
        </button>

        <button onclick="openMaintenanceModal()"
            class="px-5 py-2.5 bg-[#934b19] text-white rounded-lg flex items-center gap-2 hover:bg-[#7a3a10] transition-colors text-sm font-medium">
            <span class="material-symbols-outlined text-[18px]">event</span>
            Schedule maintenance
        </button>
    </div>
</section>

<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-5">

    <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-gray-600 text-sm font-medium">Total Equipment</p>
                <h2 id="stat-total" class="text-3xl font-bold text-[#0a2200] mt-2">0</h2>
            </div>
            <span class="material-symbols-outlined text-[#116530] text-4xl">inventory_2</span>
        </div>
    </div>

    <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-gray-600 text-sm font-medium">Available</p>
                <h2 id="stat-dispo" class="text-3xl font-bold text-green-700 mt-2">0</h2>
            </div>
            <span class="material-symbols-outlined text-green-600 text-4xl">check_circle</span>
        </div>
    </div>

    <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-gray-600 text-sm font-medium">In Maintenance</p>
                <h2 id="stat-maintenance" class="text-3xl font-bold text-yellow-700 mt-2">0</h2>
            </div>
            <span class="material-symbols-outlined text-yellow-600 text-4xl">build</span>
        </div>
    </div>

    <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-gray-600 text-sm font-medium">Critical</p>
                <h2 id="stat-panne" class="text-3xl font-bold text-red-700 mt-2">0</h2>
            </div>
            <span class="material-symbols-outlined text-red-600 text-4xl">warning</span>
        </div>
    </div>

</div>

<!-- SEARCH & FILTER BAR -->
<div class="flex flex-wrap items-center gap-2 mb-5">

    <!-- SEARCH -->
    <div class="relative flex-1 min-w-[220px]">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-[20px]">
            search
        </span>

        <input type="text" id="searchInput"
               placeholder="Search equipment..."
               class="w-full pl-10 pr-4 py-2 text-sm rounded-lg border border-gray-200 bg-white
                      focus:ring-2 focus:ring-[#116530] focus:border-transparent outline-none transition">
    </div>

    <!-- STATUS FILTER -->
    <select id="filterEtat"
            class="px-4 py-2 text-sm rounded-lg border border-gray-200 bg-white
                   focus:ring-2 focus:ring-[#116530] focus:border-transparent outline-none transition">

        <option value="">All Status</option>
        <option value="disponible">Available</option>
        <option value="maintenance">In Maintenance</option>
        <option value="panne">Critical</option>

    </select>

    <!-- CURRENCY -->
    <div class="flex items-center gap-2 bg-white border border-gray-200 px-3 py-1.5 rounded-lg">

        <span class="material-symbols-outlined text-gray-600 text-[18px]">
            currency_exchange
        </span>

        <select id="currencySelect"
                class="text-sm rounded border-0 bg-white text-gray-700 font-medium
                       focus:ring-2 focus:ring-[#116530] outline-none transition px-1">

            <option value="TND">TND (د.ت)</option>
            <option value="USD">USD ($)</option>
            <option value="EUR">EUR (€)</option>
            <option value="AUD">AUD (A$)</option>

        </select>

    </div>

    <!-- RESET -->
    <button onclick="resetFilters()"
            class="p-2 rounded-lg hover:bg-gray-100 transition" title="Reset filters">

        <span class="material-symbols-outlined text-gray-600">
            refresh
        </span>

    </button>

    <!-- INFO -->
    <div id="filterInfo"
         class="hidden items-center gap-1.5 text-xs text-gray-600 ml-2">

        <span class="material-symbols-outlined text-blue-500 text-[16px]">
            info
        </span>

        <span id="filterInfoText"></span>

    </div>

</div>

<!-- TABLE -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
<div class="overflow-x-auto">
<table class="w-full text-left border-collapse">

<thead class="bg-gray-50 border-b border-gray-200">
<tr>
    <th class="px-6 py-3 text-sm font-semibold text-gray-700">Name</th>
    <th class="px-6 py-3 text-sm font-semibold text-gray-700">Type</th>
    <th class="px-6 py-3 text-sm font-semibold text-gray-700">Date Purchased</th>
    <th class="px-6 py-3 text-sm font-semibold text-gray-700">Status</th>
    <th class="px-6 py-3 text-sm font-semibold text-gray-700">Cost</th>
    <th class="px-6 py-3 text-sm font-semibold text-gray-700">Description</th>
    <th class="px-6 py-3 text-sm font-semibold text-gray-700">Actions</th>
</tr>
</thead>

<tbody id="equipementTableBody">

{% for eq in equipements %}
<tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors equipement-row
    {% if eq.etat.value == 'panne' %}bg-red-50{% endif %}"
    data-nom="{{ eq.nomEq|lower }}"
    data-type="{{ eq.typeEq|lower }}"
    data-date="{{ eq.dateAchat|date('Y-m-d') }}"
    data-etat="{{ eq.etat.value }}"
    data-cout="{{ eq.coutAchat }}"
    data-desc="{{ eq.descriptionEq|lower }}">


    <!-- NOM -->
    <td class="px-6 py-4">
        <span id="text-nom-{{ eq.idEq }}" class="font-medium text-gray-900">{{ eq.nomEq }}</span>
        <input id="input-nom-{{ eq.idEq }}" value="{{ eq.nomEq }}"
               class="hidden border p-2 rounded w-full focus:ring-2 focus:ring-[#116530]"
               minlength="3" maxlength="100">
        <small id="error-nom-{{ eq.idEq }}" class="text-red-600 hidden text-xs block mt-1"></small>
    </td>

    <!-- TYPE -->
    <td class="px-6 py-4">
        <span id="text-type-{{ eq.idEq }}" class="text-gray-700">{{ eq.typeEq }}</span>
        <input id="input-type-{{ eq.idEq }}" value="{{ eq.typeEq }}"
               class="hidden border p-2 rounded w-full focus:ring-2 focus:ring-[#116530]"
               minlength="3" maxlength="100">
        <small id="error-type-{{ eq.idEq }}" class="text-red-600 hidden text-xs block mt-1"></small>
    </td>

    <!-- DATE -->
    <td class="px-6 py-4">
        <span id="text-date-{{ eq.idEq }}" class="text-gray-700">
            {{ eq.dateAchat ? eq.dateAchat|date('d/m/Y') : 'N/A' }}
        </span>
        <input type="date" id="input-date-{{ eq.idEq }}"
               value="{{ eq.dateAchat ? eq.dateAchat|date('Y-m-d') : '' }}"
               class="hidden border p-2 rounded w-full focus:ring-2 focus:ring-[#116530]">
        <small id="error-date-{{ eq.idEq }}" class="text-red-600 hidden text-xs block mt-1"></small>
    </td>

    <!-- ETAT -->
    <td class="px-6 py-4">
        <span id="text-etat-{{ eq.idEq }}" class="px-3 py-1 rounded text-sm font-medium
            {% if eq.etat.value == 'panne' %}
                bg-red-600 text-white
            {% elseif eq.etat.value == 'disponible' %}
                bg-green-100 text-green-800
            {% elseif eq.etat.value == 'maintenance' %}
                bg-yellow-100 text-yellow-800
            {% endif %}">

            {% if eq.etat.value == 'panne' %}
                Critique ⚠️
            {% else %}
                {{ eq.etat.value|capitalize }}
            {% endif %}
        </span>

        <select id="input-etat-{{ eq.idEq }}" class="hidden border p-2 rounded w-full focus:ring-2 focus:ring-blue-500">
            <option value="disponible" {% if eq.etat.value == 'disponible' %}selected{% endif %}>Disponible</option>
            <option value="maintenance" {% if eq.etat.value == 'maintenance' %}selected{% endif %}>Maintenance</option>
            <option value="panne" {% if eq.etat.value == 'panne' %}selected{% endif %}>En panne</option>
        </select>
        <small id="error-etat-{{ eq.idEq }}" class="text-red-600 hidden"></small>
    </td>

    <!-- COUT -->
    <td class="px-6 py-4 font-mono text-gray-700">
        <span class="price"
            data-base="{{ eq.coutAchat }}"
            id="text-cout-{{ eq.idEq }}">
            {{ eq.coutAchat|number_format(2, ',', ' ') }} TND
        </span>

        <input type="number" step="0.01"
            id="input-cout-{{ eq.idEq }}"
            value="{{ eq.coutAchat }}"
            class="hidden border p-2 rounded w-full focus:ring-2 focus:ring-[#116530]"
            min="0">

        <small id="error-cout-{{ eq.idEq }}" class="text-red-600 hidden text-xs block mt-1"></small>
    </td>

    <!-- DESCRIPTION -->
    <td class="px-6 py-4 max-w-xs">
        <span id="text-desc-{{ eq.idEq }}" class="truncate block text-gray-700 text-sm" title="{{ eq.descriptionEq }}">
            {{ eq.descriptionEq }}
        </span>
        <textarea id="input-desc-{{ eq.idEq }}" maxlength="200"
                  class="hidden border p-2 rounded w-full focus:ring-2 focus:ring-[#116530]"
                  rows="2" minlength="5">{{ eq.descriptionEq }}</textarea>
        <small id="error-desc-{{ eq.idEq }}" class="text-red-600 hidden text-xs block mt-1"></small>
    </td>

    <!-- ACTIONS -->
    <td class="px-6 py-4 flex gap-1">
        <button onclick="editRow({{ eq.idEq }})"
                id="edit-{{ eq.idEq }}"
                class="p-2 rounded-lg text-blue-600 hover:bg-blue-50 transition-colors"
                title="Edit">
            <span class="material-symbols-outlined text-[18px]">edit</span>
        </button>

        <button onclick="openDeleteModal({{ eq.idEq }})"
                class="p-2 rounded-lg text-red-600 hover:bg-red-50 transition-colors"
                title="Delete">
            <span class="material-symbols-outlined text-[18px]">delete</span>
        </button>

        <button onclick="generateImage({{ eq.idEq }})"
                class="p-2 rounded-lg text-purple-600 hover:bg-purple-50 transition-colors"
                title="Generate image">
            <span class="material-symbols-outlined text-[18px]">image</span>
        </button>

        <a href="{{ path('maintenance_list', { equipement: eq.idEq }) }}"
           class="p-2 rounded-lg text-amber-600 hover:bg-amber-50 transition-colors inline-flex"
           title="View maintenance">
            <span class="material-symbols-outlined text-[18px]">build</span>
        </a>

        <button onclick="saveRow({{ eq.idEq }})"
                id="save-{{ eq.idEq }}"
                class="hidden p-2 rounded-lg text-green-600 hover:bg-green-50 transition-colors"
                title="Save">
            <span class="material-symbols-outlined text-[18px]">check</span>
        </button>

        <button onclick="cancelEdit({{ eq.idEq }})"
                id="cancel-{{ eq.idEq }}"
                class="hidden p-2 rounded-lg text-red-600 hover:bg-red-50 transition-colors"
                title="Cancel">
            <span class="material-symbols-outlined text-[18px]">close</span>
        </button>

        <button onclick="openPrediction({{ eq.idEq }})"
                class="p-2 rounded-lg text-indigo-600 hover:bg-indigo-50 transition-colors"
                title="Maintenance prediction">
            <span class="material-symbols-outlined text-[18px]">insights</span>
        </button>

        <button class="analyse-btn p-2 rounded-lg text-indigo-600 hover:bg-indigo-50 transition-colors"
                data-id="{{ eq.idEq }}"
                title="AI Analysis">
            <span class="material-symbols-outlined text-[18px]">analytics</span>
        </button>
    </td>
</tr>
{% else %}
<tr id="emptyRow">
    <td colspan="9" class="text-center py-12 text-gray-500">
        <span class="material-symbols-outlined text-5xl block mb-3 text-gray-300">inbox</span>
        <p class="text-lg">No equipment found</p>
    </td>
</tr>
{% endfor %}

</tbody>
</table>
</div>
</div>

<div class="space-y-6 mt-8">

    <!-- AI DASHBOARD -->
    <div>
        <h2 class="text-2xl font-bold text-[#0a2200] mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined">insights</span>
            Equipment Health Dashboard
        </h2>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 flex justify-center">
            <div class="w-[400px] h-[400px]">
                {{ render_chart(chart) }}
            </div>
        </div>
        <div class="mt-4 text-sm text-gray-600 space-y-1 bg-blue-50 p-4 rounded-lg border border-blue-100">
            <p>🟢 <strong>Low Risk:</strong> Equipment is in good condition</p>
            <p>🟠 <strong>Medium Risk:</strong> Monitoring is required</p>
            <p>🔴 <strong>High Risk:</strong> Urgent intervention recommended</p>
        </div>
    </div>

    <!-- MAINTENANCE TRENDS -->
    <div>
        <h2 class="text-2xl font-bold text-[#0a2200] mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined">trending_up</span>
            Maintenance Trends
        </h2>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 flex justify-center">
            <div class="w-[600px] h-[400px]">
                {{ render_chart(chartMaint) }}
            </div>
        </div>
    </div>

</div>

</div>
</main>

<!-- ================= NOTIFICATION TOAST ================= -->
<div id="notificationToast" class="fixed bottom-6 right-6 px-6 py-4 rounded-lg shadow-xl hidden z-50 max-w-sm flex items-center gap-2 animate-fade-in">
    <span class="material-symbols-outlined" id="toastIcon">check_circle</span>
    <span id="notificationMessage">Operation successful</span>
</div>


<div id="ai-modal"
     class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50">

    <div class="bg-white w-[650px] rounded-2xl shadow-2xl overflow-hidden animate-scale">

        <!-- HEADER -->
        <div class="bg-gradient-to-r from-indigo-600 to-blue-600 p-6 text-white flex justify-between items-center">
            <div>
                <h2 class="text-lg font-bold flex items-center gap-2">
                    <span class="material-symbols-outlined">smart_toy</span>
                    AI Equipment Analysis
                </h2>
                <p id="ai-equipement-name" class="text-sm opacity-90 mt-1"></p>
            </div>
            <button onclick="closeAIModalAi()" class="text-white hover:bg-white/20 p-1 rounded-lg transition">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <!-- CONTENT -->
        <div id="ai-content" class="p-6 space-y-5 bg-white">

            <!-- LOADER -->
            <div id="ai-loader" class="text-center py-8">
                <div class="inline-block">
                    <div class="spinner mb-3"></div>
                    <p class="text-gray-600">Analyzing equipment...</p>
                </div>
            </div>

        </div>

    </div>
</div>


<!-- ================= MODAL AJOUTER ÉQUIPEMENT ================= -->
<div id="equipementModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden items-center justify-center z-50 p-4">
<div class="bg-white rounded-2xl p-8 w-full max-w-[500px] max-h-[90vh] overflow-y-auto shadow-2xl">

<div class="flex justify-between items-center mb-6 pb-4 border-b border-gray-200">
    <h2 class="text-xl font-bold flex items-center gap-2 text-[#0a2200]">
        <span class="material-symbols-outlined">add_circle</span>
        Add Equipment
    </h2>
    <button onclick="closeModal()" class="text-gray-500 hover:text-gray-700 hover:bg-gray-100 p-1 rounded-lg transition">
        <span class="material-symbols-outlined">close</span>
    </button>
</div>

{{ form_start(form, {
    'action': path('app_equipement_new'),
    'method': 'POST',
    'attr': {
        'novalidate': 'novalidate',
        'id': 'equipementForm',
        'class': 'space-y-4'
    }
}) }}

<!-- NOM -->
<div>
    {{ form_label(form.nomEq, 'Equipment name', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
    {{ form_widget(form.nomEq, {
        'attr': {
            'class': 'w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#116530] focus:border-transparent ' ~ (form.nomEq.vars.errors|length ? 'border-red-500 bg-red-50' : 'border-gray-300 bg-white'),
            'placeholder': 'e.g., Forklift #1',
            'minlength': '3',
            'maxlength': '100'
        }
    }) }}
    {% if form.nomEq.vars.errors|length %}
        <div class="text-red-600 text-sm mt-1 flex items-start gap-2">
            <span class="material-symbols-outlined text-base flex-shrink-0 mt-0.5">error</span>
            <div>
                {% for error in form.nomEq.vars.errors %}
                    <p>{{ error.message }}</p>
                {% endfor %}
            </div>
        </div>
    {% endif %}
</div>

<!-- TYPE -->
<div>
    {{ form_label(form.typeEq, 'Type', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
    {{ form_widget(form.typeEq, {
        'attr': {
            'class': 'w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#116530] focus:border-transparent ' ~ (form.typeEq.vars.errors|length ? 'border-red-500 bg-red-50' : 'border-gray-300 bg-white'),
            'placeholder': 'e.g., Forklift',
            'minlength': '3',
            'maxlength': '100'
        }
    }) }}
    {% if form.typeEq.vars.errors|length %}
        <div class="text-red-600 text-sm mt-1 flex items-start gap-2">
            <span class="material-symbols-outlined text-base flex-shrink-0 mt-0.5">error</span>
            <div>
                {% for error in form.typeEq.vars.errors %}
                    <p>{{ error.message }}</p>
                {% endfor %}
            </div>
        </div>
    {% endif %}
</div>

<!-- DATE ACHAT -->
<div>
    {{ form_label(form.dateAchat, 'Purchase date', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
    {{ form_widget(form.dateAchat, {
        'attr': {
            'class': 'w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#116530] focus:border-transparent ' ~ (form.dateAchat.vars.errors|length ? 'border-red-500 bg-red-50' : 'border-gray-300 bg-white')
        }
    }) }}
    {% if form.dateAchat.vars.errors|length %}
        <div class="text-red-600 text-sm mt-1 flex items-start gap-2">
            <span class="material-symbols-outlined text-base flex-shrink-0 mt-0.5">error</span>
            <div>
                {% for error in form.dateAchat.vars.errors %}
                    <p>{{ error.message }}</p>
                {% endfor %}
            </div>
        </div>
    {% endif %}
</div>

<!-- ETAT -->
<div>
    {{ form_label(form.etat, 'Status', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
    {{ form_widget(form.etat, {
        'attr': {
            'class': 'w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#116530] focus:border-transparent ' ~ (form.etat.vars.errors|length ? 'border-red-500 bg-red-50' : 'border-gray-300 bg-white')
        }
    }) }}
    {% if form.etat.vars.errors|length %}
        <div class="text-red-600 text-sm mt-1 flex items-start gap-2">
            <span class="material-symbols-outlined text-base flex-shrink-0 mt-0.5">error</span>
            <div>
                {% for error in form.etat.vars.errors %}
                    <p>{{ error.message }}</p>
                {% endfor %}
            </div>
        </div>
    {% endif %}
</div>

<!-- COUT ACHAT -->
<div>
    {{ form_label(form.coutAchat, 'Purchase cost (€)', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
    {{ form_widget(form.coutAchat, {
        'attr': {
            'class': 'w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#116530] focus:border-transparent ' ~ (form.coutAchat.vars.errors|length ? 'border-red-500 bg-red-50' : 'border-gray-300 bg-white'),
            'placeholder': '0.00',
            'step': '0.01',
            'min': '0'
        }
    }) }}
    {% if form.coutAchat.vars.errors|length %}
        <div class="text-red-600 text-sm mt-1 flex items-start gap-2">
            <span class="material-symbols-outlined text-base flex-shrink-0 mt-0.5">error</span>
            <div>
                {% for error in form.coutAchat.vars.errors %}
                    <p>{{ error.message }}</p>
                {% endfor %}
            </div>
        </div>
    {% endif %}
</div>

<!-- DESCRIPTION -->
<div>
    {{ form_label(form.descriptionEq, 'Description', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
    {{ form_widget(form.descriptionEq, {
        'attr': {
            'class': 'w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#116530] focus:border-transparent ' ~ (form.descriptionEq.vars.errors|length ? 'border-red-500 bg-red-50' : 'border-gray-300 bg-white'),
