<script>
(function () {

    const navItems = [
        {
            label: "User Management",
            icon: "group",
            href: "{{ path('user_page') }}"
        },
        {
            label: "Field Management",
            icon: "agriculture",
            href: "{{ path('elfirma_page', { module: 'parcelles-cultures' }) }}"
        },

        {
            label: "Livestock & Animals Management",
            icon: "pets",
            children: [
                {
                    label: "Livestock",
                    href: "{{ path('elfirma_livestock') }}"
                },
                {
                    label: "Animals",
                    href: "{{ path('elfirma_animals') }}"
                }
            ]
        },

        {
            label: "Product Management",
            icon: "shopping_basket",
            href: "{{ path('elfirma_page', { module: 'produits-commandes' }) }}",
            children: [
                {
                    label: "Products",
                    href: "{{ path('elfirma_products') }}"
                },
                {
                    label: "Catalog",
                    href: "{{ path('elfirma_categories') }}"
                }
            ]
        },

        {
            label: "Equipment Management",
            icon: "handyman",
            href: "{{ path('app_equipement_index') }}"
        },

        {
            label: "Contract Management",
            icon: "contract",
            href: "{{ path('elfirma_page', { module: 'fournisseurs-contrats' }) }}",
            children: [
                {
                    label: "Suppliers",
                    href: "{{ path('fournisseur_page') }}"
                },
                {
                    label: "Contracts",
                    href: "{{ path('contrat_page') }}"
                },
                {
                    label: "Meetings",
                    href: "{{ path('meetings_page') }}"
                },
                {
                    label: "Supplier Analytics",
                    href: "{{ path('supplier_analytics') }}"
                }
            ]
        }
    ];

    const englishReplacements = [
        ["Gestion Agricole", "Farm Management"],
        ["Tableau de Bord", "Dashboard"],
        ["Utilisateurs", "Users"],
        ["Parcelles & Cultures", "Fields & Crops"],
        ["Animaux & Élevages", "Livestock & Animals"],
        ["Animaux & Elevages", "Livestock & Animals"],
        ["Produits & Commandes", "Products & Orders"],
        ["Équipements & Maintenance", "Equipment & Maintenance"],
        ["Equipements & Maintenance", "Equipment & Maintenance"],
        ["Fournisseurs & Contrats", "Suppliers & Contracts"],
        ["Réclamations", "Claims"],
        ["Reclamations", "Claims"],
        ["Aide", "Help"],
        ["Déconnexion", "Logout"],
        ["Support Technique", "Technical Support"],
        ["Mentions Légales", "Legal Notice"],
        ["Confidentialité", "Privacy"],
        ["Nouvelle Saison", "New Season"],
        ["Ajouter un utilisateur", "Add user"],
        ["Ajouter une parcelle", "Add field"],
        ["Ajouter un animal", "Add animal"],
        ["Nouveau contrat", "New contract"],
        ["Ajouter un fournisseur", "Add supplier"],
        ["Rechercher", "Search"],
        ["Voir tout", "View all"],
        ["Maintenance", "Maintenance"],
        ["Récolte", "Harvest"],
        ["Sélectionnez", "Select"],
        ["Ouvrir le module dans Symfony", "Open module in Symfony"],
        ["Huile", "Oil"],
        ["Frais", "Fresh"],
        ["Transformé", "Processed"],
        ["Biologique", "Organic"],
        ["Séché", "Dried"],
        ["Conditionné", "Packaged"],
        ["Économique", "Economy"],
        ["Certifié", "Certified"],
        ["Disponible", "Available"],
        ["Rupture", "Out of Stock"],
        ["Expiré", "Expired"]
    ];

    const normalizePath = (value) => (value || "").replace(/\/$/, "") || "/";
    const isMobile = () => window.matchMedia("(max-width: 767px)").matches;
    const currentUrl = new URL(window.location.href);

    // ✅ FIX SAFE URL + active logic
    const isHrefActive = (href) => {
        try {
            const target = new URL(href, window.location.origin);

            if (normalizePath(target.pathname) !== normalizePath(currentUrl.pathname)) {
                return false;
            }

            const targetView = target.searchParams.get("view");
            const currentView = currentUrl.searchParams.get("view");

            if (!targetView) return true;

            if (targetView === "livestock" && !currentView) return true;

            return targetView === currentView;
        } catch (e) {
            return false;
        }
    };

    const mountDropdownStyles = () => {
        if (document.getElementById("elf-side-dropdown-style")) return;

        const style = document.createElement("style");
        style.id = "elf-side-dropdown-style";
        style.textContent = `
            .elf-side-group { width: 100%; }

            .elf-side-link,
            .elf-side-link-group {
                width: 100%;
                text-align: left;
            }

            .elf-side-link-group {
                border: 0;
                background: transparent;
                display: grid;
                grid-template-columns: minmax(0, 1fr) 1.25rem;
                align-items: center;
                gap: 0.6rem;
                padding-right: 1rem;
            }

            .elf-side-link-group .elf-side-link-main {
                display: grid;
                grid-template-columns: 1.55rem minmax(0, 1fr);
                align-items: center;
                gap: 0.9rem;
                min-width: 0;
            }

            .elf-side-submenu {
                display: none;
                flex-direction: column;
                gap: 0.35rem;
                margin: 0.25rem 0 0.3rem 1.2rem;
                padding-right: 0.9rem;
            }

            .elf-side-submenu.is-open {
                display: flex;
            }

            .elf-side-sublink {
                color: #475240;
                text-decoration: none;
                font-weight: 700;
                padding: 0.55rem 0.9rem;
                border-radius: 9999px;
            }

            .elf-side-sublink:hover {
                background: rgba(188, 197, 175, 0.34);
            }

            .elf-side-sublink.is-active {
                background: #116530;
                color: white;
            }
        `;
        document.head.appendChild(style);
    };

    const mountMaterialSymbols = () => {
        if (document.getElementById("elf-material-symbols-font")) return;

        const link = document.createElement("link");
        link.id = "elf-material-symbols-font";
        link.rel = "stylesheet";
        link.href = "https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,550,0,0";
        document.head.appendChild(link);
    };

    const translateValue = (value) => {
        if (!value) return value;

        return englishReplacements.reduce((acc, rep) => {
            return acc.split(rep[0]).join(rep[1]);
        }, value);
    };

    const applyEnglishLocalization = () => {
        document.documentElement.lang = "en";

        document.querySelectorAll("[placeholder]").forEach((el) => {
            el.placeholder = translateValue(el.placeholder);
        });

        const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
        let node;

        while ((node = walker.nextNode())) {
            if (node.parentElement && !node.parentElement.closest("script, style")) {
                const translated = translateValue(node.nodeValue);
                if (translated !== node.nodeValue) {
                    node.nodeValue = translated;
                }
            }
        }
    };

    const isSidebar = document.querySelector("aside, body > nav");
    if (!isSidebar) return;

    const buildSideNavigation = (container) => {
        container.innerHTML = "";
        mountDropdownStyles();

        navItems.forEach((item) => {

            if (item.children?.length) {
                const group = document.createElement("div");
                group.className = "elf-side-group";

                const isActive = item.children.some(c => isHrefActive(c.href));

                const button = document.createElement("button");
                button.className = "elf-side-link-group" + (isActive ? " is-active" : "");
                button.innerHTML = `
                    <span class="elf-side-link-main">
                        <span class="material-symbols-outlined">${item.icon}</span>
                        <span class="elf-side-label">${item.label}</span>
                    </span>
                    <span class="material-symbols-outlined">expand_more</span>
                `;

                const submenu = document.createElement("div");
                submenu.className = "elf-side-submenu" + (isActive ? " is-open" : "");

                item.children.forEach(child => {
                    const a = document.createElement("a");
                    a.className = "elf-side-sublink" + (isHrefActive(child.href) ? " is-active" : "");
                    a.href = child.href;
                    a.textContent = child.label;
                    submenu.appendChild(a);
                });

                button.addEventListener("click", () => {
                    document.querySelectorAll(".elf-side-submenu").forEach(m => {
                        if (m !== submenu) m.classList.remove("is-open");
                    });
                    submenu.classList.toggle("is-open");
                });

                group.appendChild(button);
                group.appendChild(submenu);
                container.appendChild(group);
                return;
            }

            const link = document.createElement("a");
            link.className = "elf-side-link" + (isHrefActive(item.href) ? " is-active" : "");
            link.href = item.href;
            link.innerHTML = `
                <span class="material-symbols-outlined">${item.icon}</span>
                <span class="elf-side-label">${item.label}</span>
            `;
            container.appendChild(link);
        });
    };

    mountMaterialSymbols();
    applyEnglishLocalization();

    const container = document.querySelector("aside nav, body > nav") || isSidebar;
    buildSideNavigation(container);

})();
</script>