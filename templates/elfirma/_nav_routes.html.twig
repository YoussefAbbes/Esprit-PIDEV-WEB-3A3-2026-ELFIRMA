<script>
(function () {
    const navItems = [
        {
            label: "User Management",
            icon: "group",
            href: "{{ path('user_page') }}"
        },
        {
            label: "Field Management",
            icon: "agriculture",
            children: [
                {
                    label: "Parcels",
                    href: "{{ path('parcelle_index') }}"
                },
                {
                    label: "Crops",
                    href: "{{ path('culture_index') }}"
                }
            ]
        },
        {
            label: "Livestock & Animals Management",
            icon: "pets",
            children: [
                {
                    label: "Livestock",
                    href: "{{ path('elfirma_livestock') }}"
                },
                {
                    label: "Animals",
                    href: "{{ path('elfirma_animals') }}"
                },
                {
                    label: "Vaccination",
                    href: "{{ path('elfirma_vaccinations') }}"
                },
                {
                    label: "Map",
                    href: "{{ path('elfirma_livestock_map') }}"
                },
                {
                    label: "Chatbot",
                    href: "{{ path('elfirma_chatbot') }}"
                },
                {
                    label: "Conception 3D",
                    href: "{{ path('elfirma_3d_conception') }}"
                }
            ]
        },
        {
            label: "Product Management",
            icon: "shopping_basket",
            children: [
                {
                    label: "Products",
                    href: "{{ path('elfirma_products') }}"
                },
                {
                    label: "Categories",
                    href: "{{ path('elfirma_categories') }}"
                },
                {
                    label: "Orders",
                    href: "{{ path('app_admin_commandes') }}"
                }
            ]
        },
        {
            label: "Equipment Management",
            icon: "handyman",
            href: "{{ path('app_equipement_index') }}"
        },
         {
            label: "Contract Management",
            icon: "contract",
            children: [
                {
                    label: "Suppliers",
                    href: "{{ path('fournisseur_page') }}"
                },
                {
                    label: "Contracts",
                    href: "{{ path('contrat_page') }}"
                },
                {
                    label: "Meetings",
                    href: "{{ path('meetings_page') }}"
                },
                {
                    label: "Supplier Analytics",
                    href: "{{ path('supplier_analytics') }}"
                }
            ]
        }
        
    ];

    const englishReplacements = [
        ["Gestion Agricole", "Farm Management"],
        ["Tableau de Bord", "Dashboard"],
        ["Utilisateurs", "Users"],
        ["Parcelles & Cultures", "Fields & Crops"],
        ["Animaux & Élevages", "Livestock"],
        ["Animaux & Elevages", "Livestock"],
        ["Produits & Commandes", "Products & Orders"],
        ["Équipements & Maintenance", "Equipment & Maintenance"],
        ["Equipements & Maintenance", "Equipment & Maintenance"],
        ["Fournisseurs & Contrats", "Suppliers & Contracts"],
        ["Réclamations", "Claims"],
        ["Reclamations", "Claims"],
        ["Aide", "Help"],
        ["Déconnexion", "Logout"],
        ["Support Technique", "Technical Support"],
        ["Mentions Légales", "Legal Notice"],
        ["Confidentialité", "Privacy"],
        ["Nouvelle Saison", "New Season"],
        ["Ajouter un utilisateur", "Add user"],
        ["Ajouter une parcelle", "Add field"],
        ["Ajouter un animal", "Add animal"],
        ["Nouveau contrat", "New contract"],
        ["Ajouter un fournisseur", "Add supplier"],
        ["Rechercher", "Search"],
        ["Voir tout", "View all"],
        ["Maintenance", "Maintenance"],
        ["Récolte", "Harvest"],
        ["Sélectionnez", "Select"],
        ["Ouvrir le module dans Symfony", "Open module in Symfony"],
        ["Huile", "Oil"],
        ["Frais", "Fresh"],
        ["Transformé", "Processed"],
        ["Biologique", "Organic"],
        ["Séché", "Dried"],
        ["Conditionné", "Packaged"],
        ["Économique", "Economy"],
        ["Certifié", "Certified"],
        ["Disponible", "Available"],
        ["Rupture", "Out of Stock"],
        ["Expiré", "Expired"]
    ];

    const normalizePath = (value) => (value || "").replace(/\/$/, "") || "/";
    const isMobile = () => window.matchMedia("(max-width: 767px)").matches;
    const currentUrl = new URL(window.location.href);

    const isHrefActive = (href) => {
        const target = new URL(href, window.location.origin);
        if (normalizePath(target.pathname) !== normalizePath(currentUrl.pathname)) {
            return false;
        }

        const targetView = target.searchParams.get("view");
        const currentView = currentUrl.searchParams.get("view");

        if (!targetView) {
            return true;
        }

        // Default to livestock when no view query is specified.
        if (targetView === "livestock" && !currentView) {
            return true;
        }

        return targetView === currentView;
    };

    const mountDropdownStyles = () => {
        if (document.getElementById("elf-side-dropdown-style")) {
            return;
        }

        const style = document.createElement("style");
        style.id = "elf-side-dropdown-style";
        style.textContent = `
            .elf-side-group {
                width: 100%;
            }
            .elf-side-link,
            .elf-side-link-group {
                width: 100%;
                text-align: left;
            }
            .elf-side-link-group {
                border: 0;
                background: transparent;
                display: grid;
                grid-template-columns: minmax(0, 1fr) 1.25rem;
                align-items: center;
                gap: 0.6rem;
                padding-right: 1rem;
            }
            .elf-side-link-group .elf-side-link-main {
                display: grid;
                grid-template-columns: 1.55rem minmax(0, 1fr);
                align-items: center;
                gap: 0.9rem;
                min-width: 0;
            }
            .elf-side-link > .elf-side-label,
            .elf-side-link-group .elf-side-label {
                display: block;
                min-width: 0;
                line-height: 1.28;
                white-space: normal;
                overflow-wrap: anywhere;
                word-break: break-word;
            }
            .elf-side-link > .material-symbols-outlined,
            .elf-side-link-group .material-symbols-outlined {
                flex-shrink: 0;
            }
            .elf-side-submenu {
                display: none;
                flex-direction: column;
                gap: 0.35rem;
                margin: 0.25rem 0 0.3rem 1.2rem;
                padding-right: 0.9rem;
            }
            .elf-side-submenu.is-open {
                display: flex;
            }
            .elf-side-sublink {
                color: var(--elf-on-surface-variant, #475240);
                text-decoration: none;
                font-weight: 700;
                padding: 0.55rem 0.9rem;
                border-radius: 9999px;
                line-height: 1.28;
                white-space: pre-line;
                overflow-wrap: anywhere;
                word-break: break-word;
                transition: background-color 0.2s ease, color 0.2s ease;
            }
            .elf-side-sublink:hover {
                background: rgba(188, 197, 175, 0.34);
                color: var(--elf-primary, #116530);
            }
            .elf-side-sublink.is-active {
                background: linear-gradient(135deg, var(--elf-primary, #116530), var(--elf-primary-strong, #0c4a23));
                color: #f8faef;
            }
        `;

        document.head.appendChild(style);
    };

    const mountMaterialSymbols = () => {
        if (document.getElementById("elf-material-symbols-font")) {
            return;
        }

        const link = document.createElement("link");
        link.id = "elf-material-symbols-font";
        link.rel = "stylesheet";
        link.href = "https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,550,0,0";
        document.head.appendChild(link);
    };

    const translateValue = (value) => {
        if (!value) {
            return value;
        }

        return englishReplacements.reduce((accumulator, replacement) => {
            return accumulator.split(replacement[0]).join(replacement[1]);
        }, value);
    };

    const applyEnglishLocalization = () => {
        document.documentElement.lang = "en";

        document.querySelectorAll("[placeholder]").forEach((element) => {
            element.placeholder = translateValue(element.placeholder);
        });

        const textWalker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
        let textNode = textWalker.nextNode();

        while (textNode) {
            const parent = textNode.parentElement;

            if (parent && !parent.closest("script, style")) {
                const translated = translateValue(textNode.nodeValue);
                if (translated !== textNode.nodeValue) {
                    textNode.nodeValue = translated;
                }
            }

            textNode = textWalker.nextNode();
        }
    };

    const syncToggleIcon = (button) => {
        if (!button) {
            return;
        }

        const icon = button.querySelector(".material-symbols-outlined");
        if (!icon) {
            return;
        }

        if (isMobile()) {
            icon.textContent = document.body.classList.contains("elf-sidebar-open") ? "close" : "menu";
            return;
        }

        icon.textContent = document.body.classList.contains("elf-sidebar-collapsed") ? "menu_open" : "menu";
    };

    const mountSidebarToggle = () => {
        if (document.querySelector(".elf-sidebar-toggle")) {
            return;
        }

        const toggle = document.createElement("button");
        toggle.type = "button";
        toggle.className = "elf-sidebar-toggle";
        toggle.setAttribute("aria-label", "Show or hide sidebar");
        toggle.innerHTML = '<span class="material-symbols-outlined">menu</span>';

        const overlay = document.createElement("div");
        overlay.className = "elf-sidebar-overlay";

        const closeSidebar = () => {
            document.body.classList.remove("elf-sidebar-open");
            syncToggleIcon(toggle);
        };

        toggle.addEventListener("click", () => {
            if (isMobile()) {
                document.body.classList.toggle("elf-sidebar-open");
                syncToggleIcon(toggle);
                return;
            }

            document.body.classList.toggle("elf-sidebar-collapsed");
            syncToggleIcon(toggle);
        });

        overlay.addEventListener("click", closeSidebar);

        window.addEventListener("resize", () => {
            if (!isMobile()) {
                document.body.classList.remove("elf-sidebar-open");
            }
            syncToggleIcon(toggle);
        });

        document.addEventListener("keydown", (event) => {
            if (event.key === "Escape") {
                closeSidebar();
            }
        });

        document.body.appendChild(overlay);
        document.body.appendChild(toggle);
        syncToggleIcon(toggle);
    };

    const buildSideNavigation = (container) => {
        container.classList.add("elf-side-links");
        container.innerHTML = "";

        mountDropdownStyles();

        navItems.forEach((item) => {
            if (Array.isArray(item.children) && item.children.length) {
                const group = document.createElement("div");
                group.className = "elf-side-group";

                const childActive = item.children.some((child) => isHrefActive(child.href));

                const groupButton = document.createElement("button");
                groupButton.type = "button";
                groupButton.className = "elf-side-link elf-side-link-group" + (childActive ? " is-active" : "");
                groupButton.innerHTML =
                    '<span class="elf-side-link-main"><span class="material-symbols-outlined">' + item.icon + '</span><span class="elf-side-label">' + item.label + '</span></span>' +
                    '<span class="material-symbols-outlined">expand_more</span>';

                const subMenu = document.createElement("div");
                subMenu.className = "elf-side-submenu" + (childActive ? " is-open" : "");

                item.children.forEach((child) => {
                    const subLink = document.createElement("a");
                    const isChildActive = isHrefActive(child.href);
                    subLink.className = "elf-side-sublink" + (isChildActive ? " is-active" : "");
                    subLink.href = child.href;
                    subLink.textContent = child.label;
                    subMenu.appendChild(subLink);
                });

                groupButton.addEventListener("click", () => {
                    subMenu.classList.toggle("is-open");
                });

                group.appendChild(groupButton);
                group.appendChild(subMenu);
                container.appendChild(group);
                return;
            }

            const link = document.createElement("a");
            const isActive = isHrefActive(item.href);
            link.className = "elf-side-link" + (isActive ? " is-active" : "");
            link.href = item.href;
            link.innerHTML = '<span class="material-symbols-outlined">' + item.icon + '</span><span class="elf-side-label">' + item.label + "</span>";
            container.appendChild(link);
        });
    };

    const sideRoots = Array.from(document.querySelectorAll("aside, body > nav")).filter((root) => {
        const tagName = root.tagName.toLowerCase();

        if (tagName === "nav" && root.parentElement === document.body) {
            return true;
        }

        if (tagName !== "aside") {
            return false;
        }

        const className = root.className || "";
        return className.includes("fixed") || className.includes("left-0");
    });

    if (!sideRoots.length) {
        return;
    }

    document.body.classList.add("elf-has-sidebar");

    mountMaterialSymbols();
    applyEnglishLocalization();

    sideRoots.forEach((root) => {
        root.querySelectorAll("button").forEach((button) => {
            const label = (button.textContent || "").toLowerCase();
            if (label.includes("nouvelle") || label.includes("new season")) {
                button.remove();
            }
        });

        const container = root.querySelector("nav") || root;
        buildSideNavigation(container);
            });

    mountSidebarToggle();
})();
</script>

