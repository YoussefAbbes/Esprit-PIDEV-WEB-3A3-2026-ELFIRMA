<!DOCTYPE html>
<html class="light" lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <link href="{{ asset('styles/elfirma-theme.css') }}" rel="stylesheet"/>
  <title>Elfirma - Supplier Analytics</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Open_Sans:wght@400;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "surface-container-low": "#f5f5dc",
            "outline-variant": "#c3c9b9",
            "surface-container-highest": "#e4e4cc",
            "error": "#ba1a1a",
            "inverse-primary": "#a8d389",
            "on-surface": "#1b1d0e",
            "primary-fixed-dim": "#a8d389",
            "surface-container-high": "#eaead1",
            "on-primary-fixed-variant": "#2c4f15",
            "on-secondary-container": "#753502",
            "outline": "#73796c",
            "inverse-surface": "#303221",
            "on-secondary-fixed": "#321200",
            "on-tertiary": "#ffffff",
            "surface-tint": "#43682b",
            "on-surface-variant": "#43493d",
            "on-secondary": "#ffffff",
            "on-background": "#1b1d0e",
            "background": "#fbfbe2",
            "inverse-on-surface": "#f2f2d9",
            "surface-bright": "#fbfbe2",
            "secondary-fixed-dim": "#ffb68c",
            "on-primary": "#ffffff",
            "on-error": "#ffffff",
            "on-tertiary-container": "#cc83af",
            "on-secondary-fixed-variant": "#753401",
            "tertiary-fixed": "#ffd8ec",
            "on-tertiary-fixed": "#39042c",
            "surface-container": "#efefd7",
            "tertiary-container": "#541c43",
            "surface-variant": "#e4e4cc",
            "surface": "#fbfbe2",
            "on-primary-container": "#7ca560",
            "on-primary-fixed": "#0a2100",
            "secondary-fixed": "#ffdbc9",
            "tertiary-fixed-dim": "#fdafde",
            "primary-fixed": "#c3efa3",
            "tertiary": "#3a052d",
            "secondary": "#934b19",
            "primary-container": "#173901",
            "surface-dim": "#dbdcc3",
            "secondary-container": "#fc9f66",
            "surface-container-lowest": "#ffffff",
            "primary": "#0a2200",
            "error-container": "#ffdad6",
            "on-error-container": "#93000a",
            "on-tertiary-fixed-variant": "#6d3259"
          },
          "borderRadius": {
            "DEFAULT": "1rem",
            "lg": "2rem",
            "xl": "3rem",
            "full": "9999px"
          },
          "fontFamily": {
            "headline": ["Inter"],
            "body": ["Open Sans"],
            "label": ["Inter"]
          }
        }
      }
    }
  </script>
  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    body {
      font-family: 'Open Sans', sans-serif;
    }
    h1, h2, h3, .headline {
      font-family: 'Inter', sans-serif;
    }

    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .kpi-card {
      animation: slideIn 0.5s ease-out;
      transition: all 0.3s ease;
    }

    .kpi-card:hover {
      transform: translateY(-4px);
    }

    .supplier-card {
      animation: slideIn 0.5s ease-out;
      transition: all 0.3s ease;
    }

    .supplier-card:hover {
      transform: translateY(-4px);
    }

    .star-bar {
      transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .sentiment-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 700;
    }
    .pill-positive  { background: #dcfce7; color: #166534; }
    .pill-neutral   { background: #f3f4f6; color: #374151; }
    .pill-negative  { background: #fee2e2; color: #991b1b; }

    .health-excellent  { background: #dcfce7; color: #166534; border: 1px solid #86efac; }
    .health-good       { background: #dbeafe; color: #1e40af; border: 1px solid #93c5fd; }
    .health-improvement { background: #fef9c3; color: #854d0e; border: 1px solid #fde047; }
    .health-poor       { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
    .health-nodata     { background: #f3f4f6; color: #374151; border: 1px solid #d1d5db; }

    .filter-btn.active {
      background: #43682b !important;
      color: white !important;
      border: none !important;
    }

    @media (max-width: 768px) {
      body {
        flex-direction: column;
      }
    }
  </style>
</head>
<body class="bg-surface text-on-surface min-h-screen flex">

  <!-- SideNavBar (Authority: _nav_routes.html.twig) -->
  <aside class="h-screen w-72 fixed left-0 top-0 bg-surface-container-low text-primary flex flex-col py-8 pr-4 font-headline font-semibold z-40">
    <div class="px-8 mb-8">
      <h1 class="text-3xl font-black tracking-tighter text-primary">Elfirma</h1>
      <p class="text-xs font-label text-on-surface-variant uppercase tracking-widest opacity-70">Gestion Agricole</p>
    </div>
    <nav class="flex-grow space-y-1"></nav>
  </aside>

  <!-- Main Content -->
  <div class="flex-1 ml-72 flex flex-col bg-gradient-to-b from-surface-bright via-surface to-surface-container-lowest">

    <!-- Hero Section -->
    <div class="py-8 px-8 bg-gradient-to-br from-surface-bright via-surface to-surface-container-low shadow-md">
      <div class="max-w-7xl mx-auto">
        <!-- AI Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 mb-4 bg-white/80 backdrop-blur-sm border border-outline-variant rounded-full shadow-sm">
          <span class="material-symbols-outlined text-primary" style="font-size: 20px;">psychology</span>
          <span class="text-xs font-bold text-primary uppercase tracking-wider">AI-Powered Intelligence</span>
        </div>

        <!-- Main Title -->
        <h1 class="text-5xl font-black mb-3 text-primary tracking-tight">Supplier Intelligence</h1>

        <!-- Subtitle -->
        <p class="text-lg font-semibold text-on-surface-variant mb-2">
          Advanced AI-powered analysis of supplier ratings & performance
        </p>
        <p class="text-sm text-outline inline-flex items-center gap-2">
          <span class="material-symbols-outlined" style="font-size: 18px;">model_training</span>
          Powered by Random Forest + TF-IDF + Sentiment Analysis
        </p>
      </div>
    </div>

    <!-- Main Content Container -->
    <div class="flex-grow overflow-auto px-8 py-8">
      <div class="max-w-7xl mx-auto">

        <!-- Loading State -->
        <div id="analytics-loading" class="text-center py-20">
          <div class="mb-8 flex justify-center">
            <div style="position: relative; width: 120px; height: 120px;">
              <div style="position: absolute; inset: 0; border: 4px solid transparent; border-top-color: #43682b; border-right-color: #a8d389; border-radius: 50%; animation: spin 1s linear infinite;"></div>
              <div style="position: absolute; inset: 16px; border: 4px solid transparent; border-bottom-color: #43682b; border-left-color: #a8d389; border-radius: 50%; animation: spin 1s linear reverse;"></div>
              <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;">
                <span class="material-symbols-outlined text-primary" style="font-size: 48px; animation: pulse 2s ease-in-out infinite;">psychology</span>
              </div>
            </div>
          </div>
          <h2 class="text-2xl font-bold text-primary mb-2">Analyzing supplier data with AI...</h2>
          <p class="text-sm text-on-surface-variant">Running Random Forest classification and sentiment extraction</p>
        </div>

        <!-- Error State -->
        <div id="analytics-error" style="display: none;">
          <div class="bg-gradient-to-br from-red-50 to-red-100 rounded-2xl p-8 max-w-2xl mx-auto border-2 border-red-400 shadow-md">
            <div class="text-center">
              <span class="material-symbols-outlined text-red-900 mx-auto block mb-4" style="font-size: 72px;">error</span>
              <h3 class="text-2xl font-bold text-red-900 mb-3">Could not connect to AI Service</h3>
              <p class="text-red-800 mb-6 leading-relaxed">
                The Python FastAPI analytics server is not running. Please start it to enable advanced supplier analysis.
              </p>

              <!-- Troubleshooting -->
              <div class="bg-white/50 rounded-xl p-4 mb-6 text-left">
                <h4 class="font-bold text-primary mb-3 flex items-center gap-2">
                  <span class="material-symbols-outlined">build</span>
                  Troubleshooting Steps
                </h4>
                <ol class="text-sm text-on-surface-variant space-y-2">
                  <li>1. Open a terminal in the project directory</li>
                  <li>2. Navigate to the chatbot_ai folder</li>
                  <li>3. Run the command:</li>
                </ol>
                <code class="block mt-3 p-3 bg-primary text-white rounded-lg font-bold text-xs">py -3.13 main.py</code>
              </div>

              <div class="flex gap-3 justify-center flex-wrap">
                <button onclick="location.reload()" class="px-6 py-3 bg-primary text-white font-bold rounded-full flex items-center gap-2 hover:shadow-lg transition">
                  <span class="material-symbols-outlined">refresh</span>
                  Retry
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Main Content - Analytics Data -->
        <div id="analytics-content" style="display: none;">

          <!-- Filter & Sort Panel -->
          <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-4 mb-8 border border-outline-variant shadow-md sticky top-0 z-30">
            <div class="flex flex-col md:flex-row gap-4 items-center">
              <!-- Search -->
              <div class="flex-1 relative">
                <input type="text" id="supplier-search" placeholder="Search suppliers..."
                  class="w-full px-4 py-2 pl-10 border border-outline-variant rounded-full focus:outline-none focus:border-primary transition"
                  style="border-radius: 999px;">
                <span class="material-symbols-outlined absolute left-3 top-2.5 text-on-surface-variant">search</span>
              </div>

              <!-- Filter Buttons -->
              <div class="flex gap-2 flex-wrap justify-end">
                <button onclick="filterSuppliers('all')" class="px-4 py-2 text-sm font-bold rounded-full filter-btn active bg-primary text-white border-0" data-filter="all">All</button>
                <button onclick="filterSuppliers('excellent')" class="px-4 py-2 text-sm font-bold rounded-full filter-btn bg-white border-2 border-green-400 text-green-700" data-filter="excellent">Excellent</button>
                <button onclick="filterSuppliers('good')" class="px-4 py-2 text-sm font-bold rounded-full filter-btn bg-white border-2 border-blue-400 text-blue-700" data-filter="good">Good</button>
                <button onclick="filterSuppliers('needswork')" class="px-4 py-2 text-sm font-bold rounded-full filter-btn bg-white border-2 border-yellow-400 text-yellow-700" data-filter="needswork">Needs Work</button>
              </div>
            </div>
          </div>

          <!-- Summary Statistics Grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8" id="summary-cards"></div>

          <!-- Main Supplier Cards -->
          <div id="supplier-cards" class="space-y-4 mb-8"></div>

          <!-- Footer -->
          <div class="text-center py-8 border-t border-outline-variant">
            <p class="text-sm text-on-surface-variant inline-flex items-center gap-2">
              <span class="material-symbols-outlined" style="font-size: 18px;">update</span>
              Data updated in real-time • AI Confidence Threshold: 75%
            </p>
          </div>

        </div>
      </div>
    </div>

  </div>

  <!-- Navigation routes injector -->
  {% include 'elfirma/_nav_routes.html.twig' %}

  <script>
    document.addEventListener('DOMContentLoaded', async () => {
      const loadingEl = document.getElementById('analytics-loading');
      const errorEl   = document.getElementById('analytics-error');
      const contentEl = document.getElementById('analytics-content');

      function healthClass(label) {
        if (label === 'Excellent')         return 'health-excellent';
        if (label === 'Good')              return 'health-good';
        if (label === 'Needs Improvement') return 'health-improvement';
        if (label === 'Poor')              return 'health-poor';
        return 'health-nodata';
      }

      function healthIcon(label) {
        if (label === 'Excellent')         return 'sentiment_very_satisfied';
        if (label === 'Good')              return 'sentiment_satisfied';
        if (label === 'Needs Improvement') return 'sentiment_dissatisfied';
        if (label === 'Poor')              return 'sentiment_very_dissatisfied';
        return 'help';
      }

      function renderStars(avg) {
        let html = '';
        for (let i = 1; i <= 5; i++) {
          const filled = i <= Math.round(avg);
          html += `<span class="material-symbols-outlined inline-block" style="color: ${filled ? '#fde047' : '#d1d5db'}; font-size: 18px; font-variation-settings: 'FILL' ${filled ? 1 : 0};">star</span>`;
        }
        return html;
      }

      function animateCounter(element, target, duration = 1500) {
        let current = 0;
        const increment = target / (duration / 16);
        const timer = setInterval(() => {
          current += increment;
          if (current >= target) {
            element.textContent = target;
            clearInterval(timer);
          } else {
            element.textContent = Math.floor(current);
          }
        }, 16);
      }

      window.filterSuppliers = function(filter) {
        const cardsEl = document.getElementById('supplier-cards');
        const cards = cardsEl.querySelectorAll('.supplier-card');

        document.querySelectorAll('.filter-btn').forEach(btn => {
          btn.classList.remove('active');
          btn.classList.remove('bg-primary', 'text-white');
          btn.classList.add('bg-white', 'border-2', 'text-gray-700');
        });

        const btn = document.querySelector(`[data-filter="${filter}"]`);
        btn.classList.add('active', 'bg-primary', 'text-white');
        btn.classList.remove('bg-white', 'border-2', 'text-gray-700');

        cards.forEach(card => {
          if (filter === 'all') {
            card.style.display = 'block';
          } else {
            const health = card.dataset.health.toLowerCase();
            card.style.display = health === filter ? 'block' : 'none';
          }
        });
      };

      document.getElementById('supplier-search')?.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase();
        const cardsEl = document.getElementById('supplier-cards');
        const cards = cardsEl.querySelectorAll('.supplier-card');

        cards.forEach(card => {
          const name = card.dataset.name.toLowerCase();
          card.style.display = name.includes(query) ? 'block' : 'none';
        });
      });

      try {
        const apiPath = '{{ path("api_supplier_analytics") }}';
        console.log('Fetching from:', apiPath);

        const res  = await fetch(apiPath);
        console.log('Response status:', res.status);

        const data = await res.json();
        console.log('Data received:', data);

        if (data.error) {
          throw new Error(data.error);
        }

        if (!data.results || data.results.length === 0) {
          throw new Error('No supplier data returned');
        }

        loadingEl.style.display = 'none';
        contentEl.style.display = 'block';

        const results = data.results;

        // Summary cards
        const total      = results.length;
        const excellent  = results.filter(r => r.health.label === 'Excellent').length;
        const good       = results.filter(r => r.health.label === 'Good').length;
        const needswork  = results.filter(r => r.health.label === 'Needs Improvement').length;
        const avgConfidence = (results.reduce((sum, r) => sum + r.health.confidence, 0) / results.length * 100).toFixed(0);

        document.getElementById('summary-cards').innerHTML = `
          <div class="kpi-card bg-white rounded-2xl p-6 border-l-4 border-primary shadow-md hover:shadow-lg">
            <p class="text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2">Suppliers Analyzed</p>
            <p class="text-4xl font-black text-primary"><span class="counter">${total}</span></p>
          </div>

          <div class="kpi-card bg-green-50 rounded-2xl p-6 border-l-4 border-green-600 shadow-md hover:shadow-lg">
            <p class="text-xs font-bold text-green-700 uppercase tracking-wider mb-2">Excellent Health</p>
            <p class="text-4xl font-black text-green-700"><span class="counter">${excellent}</span></p>
          </div>

          <div class="kpi-card bg-yellow-50 rounded-2xl p-6 border-l-4 border-yellow-600 shadow-md hover:shadow-lg">
            <p class="text-xs font-bold text-yellow-700 uppercase tracking-wider mb-2">Needs Improvement</p>
            <p class="text-4xl font-black text-yellow-700"><span class="counter">${needswork}</span></p>
          </div>

          <div class="kpi-card bg-blue-50 rounded-2xl p-6 border-l-4 border-blue-600 shadow-md hover:shadow-lg">
            <p class="text-xs font-bold text-blue-700 uppercase tracking-wider mb-2">AI Confidence</p>
            <p class="text-4xl font-black text-blue-700"><span class="counter">${avgConfidence}</span>%</p>
          </div>
        `;

        document.querySelectorAll('.counter').forEach(el => {
          const value = parseInt(el.textContent);
          animateCounter(el, value);
        });

        // Supplier cards
        const cardsEl = document.getElementById('supplier-cards');

        results.forEach((supplier, idx) => {
          const hClass = healthClass(supplier.health.label);
          const hIcon  = healthIcon(supplier.health.label);
          const sent   = supplier.sentiment_breakdown;
          const total  = supplier.total_reviews;
          const healthLabelClass = supplier.health.label === 'Excellent' ? 'excellent' :
                                    supplier.health.label === 'Good' ? 'good' :
                                    supplier.health.label === 'Needs Improvement' ? 'needswork' : 'poor';

          let starBarsHtml = '';
          for (let s = 5; s >= 1; s--) {
            const count = supplier.star_distribution[s] || 0;
            const pct   = total > 0 ? Math.round((count / total) * 100) : 0;
            const colors = ['', 'bg-red-500', 'bg-yellow-500', 'bg-yellow-400', 'bg-blue-500', 'bg-green-500'];
            starBarsHtml += `
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs font-bold text-on-surface-variant" style="width: 30px;">${s}★</span>
                <div class="flex-1 bg-outline-variant rounded-full h-2">
                  <div class="h-2 ${colors[s]} rounded-full star-bar" style="width: ${pct}%;"></div>
                </div>
                <span class="text-xs font-bold text-on-surface-variant" style="width: 40px; text-align: right;">${pct}%</span>
              </div>`;
          }

          let topicsHtml = '';
          if (Object.keys(supplier.top_complaints).length > 0) {
            topicsHtml = Object.entries(supplier.top_complaints)
              .slice(0, 3)
              .map(([topic, count]) => `
                <div class="bg-red-50 border border-red-200 rounded-lg p-2 mb-2 flex justify-between items-center text-xs">
                  <span>⚠ ${topic}</span>
                  <span class="bg-red-500 text-white px-2 py-1 rounded text-xs font-bold">${count}</span>
                </div>`
              ).join('');
          } else {
            topicsHtml = `<p class="text-xs text-green-700 font-semibold py-2">✓ No major complaints</p>`;
          }

          const keywordsHtml = supplier.top_keywords.length > 0
            ? supplier.top_keywords.slice(0, 4).map(k =>
                `<span class="inline-block bg-outline-variant text-on-surface px-3 py-1 rounded-full text-xs font-bold mb-2 mr-2 border border-outline">${k}</span>`
              ).join('')
            : '<span class="text-xs text-on-surface-variant">No keywords</span>';

          const trendDirection = supplier.avg_stars > 4 ? '📈 Improving' : supplier.avg_stars < 2.5 ? '📉 Declining' : '→ Stable';

          const cardHtml = `
            <div class="supplier-card bg-white rounded-2xl overflow-hidden border border-outline-variant shadow-md hover:shadow-lg"
                 data-health="${healthLabelClass}"
                 data-name="${supplier.supplier_name}"
                 style="animation-delay: ${idx * 50}ms;">

              <!-- Card Header -->
              <div class="bg-gradient-to-r from-surface-bright to-surface-container-low p-6">
                <div class="flex justify-between items-start mb-4">
                  <div class="flex-1">
                    <h4 class="text-2xl font-black text-primary mb-1">${supplier.supplier_name}</h4>
                    <p class="text-xs text-on-surface-variant">
                      <span class="material-symbols-outlined inline" style="font-size: 16px;">info</span>
                      ID #${supplier.supplier_id} · ${supplier.total_reviews} reviews
                    </p>
                  </div>
                  <div class="text-right">
                    <span class="inline-block px-3 py-1 rounded-full text-xs font-bold ${hClass}">
                      <span class="material-symbols-outlined inline" style="font-size: 16px; vertical-align: middle;">${hIcon}</span>
                      ${supplier.health.label}
                    </span>
                  </div>
                </div>

                <div class="flex items-center gap-2 mb-2">
                  <div class="flex gap-1">${renderStars(supplier.avg_stars)}</div>
                  <span class="font-black text-primary">${supplier.avg_stars.toFixed(1)}</span>
                  <span class="text-xs text-on-surface-variant">/ 5.0</span>
                  <span class="text-xs font-bold text-on-surface-variant ml-auto">${trendDirection}</span>
                </div>

                <div class="text-right">
                  <p class="text-xs text-on-surface-variant mb-1">AI Confidence</p>
                  <p class="font-black text-primary">${(supplier.health.confidence * 100).toFixed(0)}%</p>
                </div>
              </div>

              <!-- Card Body -->
              <div class="p-6 grid grid-cols-1 md:grid-cols-4 gap-4">
                <!-- Rating Distribution -->
                <div>
                  <h6 class="text-xs uppercase font-bold text-on-surface-variant tracking-wider mb-3">
                    <span class="material-symbols-outlined inline" style="font-size: 16px;">bar_chart</span>
                    Rating Distribution
                  </h6>
                  <div>${starBarsHtml}</div>
                </div>

                <!-- Sentiment Analysis -->
                <div>
                  <h6 class="text-xs uppercase font-bold text-on-surface-variant tracking-wider mb-3">
                    <span class="material-symbols-outlined inline" style="font-size: 16px;">sentiment_satisfied</span>
                    Sentiment
                  </h6>
                  <div class="space-y-2 mb-4">
                    <div class="flex justify-between">
                      <span class="sentiment-pill pill-positive">😊</span>
                      <span class="font-bold text-green-600">${sent.Positive}%</span>
                    </div>
                    <div class="flex justify-between">
                      <span class="sentiment-pill pill-neutral">😐</span>
                      <span class="font-bold text-gray-600">${sent.Neutral}%</span>
                    </div>
                    <div class="flex justify-between">
                      <span class="sentiment-pill pill-negative">😟</span>
                      <span class="font-bold text-red-600">${sent.Negative}%</span>
                    </div>
                  </div>

                  <h6 class="text-xs uppercase font-bold text-on-surface-variant tracking-wider mb-2 mt-4">
                    <span class="material-symbols-outlined inline" style="font-size: 16px;">tag</span>
                    Keywords
                  </h6>
                  <div class="text-xs">${keywordsHtml}</div>
                </div>

                <!-- Issues -->
                <div>
                  <h6 class="text-xs uppercase font-bold text-on-surface-variant tracking-wider mb-3">
                    <span class="material-symbols-outlined inline" style="font-size: 16px;">warning_amber</span>
                    Common Issues
                  </h6>
                  <div>${topicsHtml}</div>
                </div>

                <!-- AI Recommendation -->
                <div class="bg-surface-bright rounded-xl p-4 border-2 border-surface-variant">
                  <h6 class="text-xs uppercase font-bold text-on-surface-variant tracking-wider mb-2">
                    <span class="material-symbols-outlined inline" style="font-size: 16px;">psychology</span>
                    AI Recommendation
                  </h6>
                  <p class="text-xs text-on-surface leading-relaxed">${supplier.recommendation}</p>
                </div>
              </div>
            </div>
          `;

          cardsEl.innerHTML += cardHtml;
        });

        document.querySelector('[data-filter="all"]').classList.add('active');

      } catch (err) {
        console.error('Analytics error:', err);
        loadingEl.style.display = 'none';
        errorEl.style.display = 'block';
      }

    });
  </script>

</body>
</html>
