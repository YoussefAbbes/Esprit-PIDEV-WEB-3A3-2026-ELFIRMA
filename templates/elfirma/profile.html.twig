<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>

  <!-- Bootstrap CSS -->
  <link href="{{ asset('assets/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
  <link href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}" rel="stylesheet">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400;1,500;1,600;1,700;1,800&family=Marcellus:wght@400&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

  <title>User Profile - EL FIRMA</title>
  <style>
    :root {
      --primary-color: #116530;
      --primary-dark: #0c4a23;
      --accent-color: #5e9c3d;
      --light-bg: #f8faf5;
      --card-bg: #ffffff;
      --text-dark: #1a2d1f;
      --text-gray: #666666;
      --border-color: #e0e5d9;
    }

    * {
      font-family: 'Open Sans', sans-serif;
    }

    body {
      background-color: var(--light-bg);
      color: var(--text-dark);
      min-height: 100vh;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    .navbar-custom {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
      box-shadow: 0 2px 8px rgba(17, 101, 48, 0.15);
    }

    .profile-header {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
      padding: 3rem 2rem 2rem 2rem;
      color: white;
      border-radius: 16px;
      margin-bottom: 2rem;
      box-shadow: 0 15px 40px rgba(17, 101, 48, 0.2);
      transform: translateY(-5px);
      position: relative;
      overflow: visible;
    }

    .profile-avatar {
      width: 180px;
      height: 180px;
      border: 6px solid white;
      border-radius: 50%;
      object-fit: cover;
      box-shadow: 0 12px 35px rgba(17, 101, 48, 0.35), 0 8px 16px rgba(0, 0, 0, 0.15);
      margin: -100px auto 0;
      display: block;
      background: white;
      position: relative;
      z-index: 10;
    }

    .info-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      transition: all 0.3s ease;
      margin-bottom: 1.5rem;
    }

    .info-card:hover {
      box-shadow: 0 4px 12px rgba(17, 101, 48, 0.1);
      border-color: var(--accent-color);
    }

    .info-card .label {
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--primary-color);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.5rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .info-card .value {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--text-dark);
    }

    .badge-role {
      padding: 0.6rem 1.2rem;
      border-radius: 50px;
      font-weight: 700;
      font-size: 0.9rem;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      letter-spacing: 0.3px;
    }

    .badge-employee {
      background-color: #e8f5e9;
      color: #2e7d32;
    }

    .badge-client {
      background-color: #fff3e0;
      color: #e65100;
    }

    .badge-admin {
      background-color: #f3e5f5;
      color: #6a1b9a;
    }

    .table-custom {
      background: var(--card-bg);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
      border: 1px solid var(--border-color);
    }

    .table-custom thead {
      background-color: #f5f9f3;
      border-bottom: 2px solid var(--border-color);
    }

    .table-custom thead th {
      color: var(--text-dark);
      font-weight: 700;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 1.25rem 1rem;
      border: none;
    }

    .table-custom tbody td {
      padding: 1.25rem 1rem;
      border-bottom: 1px solid var(--border-color);
      vertical-align: middle;
    }

    .table-custom tbody tr:hover {
      background-color: #fafaf8;
    }

    .badge-status {
      padding: 0.5rem 1rem;
      border-radius: 50px;
      font-weight: 600;
      font-size: 0.75rem;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .badge-pending {
      background-color: #fff3cd;
      color: #856404;
    }

    .badge-reviewed {
      background-color: #d4edda;
      color: #155724;
    }

    .btn-action {
      padding: 0.5rem 0.75rem;
      border-radius: 8px;
      border: none;
      background: none;
      cursor: pointer;
      transition: all 0.2s ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .btn-edit {
      color: var(--primary-color);
    }

    .btn-edit:hover {
      background-color: rgba(17, 101, 48, 0.1);
    }

    .btn-delete {
      color: #d32f2f;
    }

    .btn-delete:hover {
      background-color: rgba(211, 47, 47, 0.1);
    }

    .empty-state {
      text-align: center;
      padding: 3rem 1.5rem;
      color: var(--text-gray);
    }

    .empty-state .material-symbols-outlined {
      font-size: 4rem;
      color: var(--border-color);
      margin-bottom: 1rem;
    }

    .modal-custom {
      background-color: rgba(0, 0, 0, 0.5);
    }

    .modal-content-custom {
      border-radius: 12px;
      border: 1px solid var(--border-color);
    }

    .modal-header-custom {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
      color: white;
      border-radius: 12px 12px 0 0;
      padding: 1.5rem;
      border: none;
    }

    .modal-body-custom {
      padding: 2rem;
    }

    .form-control-custom {
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 0.75rem 1rem;
      font-size: 0.95rem;
    }

    .form-control-custom:focus {
      border-color: var(--primary-color);
      box-shadow: 0 0 0 3px rgba(17, 101, 48, 0.1);
    }

    .btn-primary-custom {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
      color: white;
      border: none;
      border-radius: 8px;
      padding: 0.75rem 1.5rem;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .btn-primary-custom:hover {
      box-shadow: 0 4px 12px rgba(17, 101, 48, 0.3);
      transform: translateY(-2px);
    }

    .profile-header h1 {
      position: relative;
      z-index: 1;
    }

    .profile-header .text-center {
      position: relative;
      z-index: 1;
    }
  </style>
</head>
<body>

<!-- Navigation Bar -->
<nav class="navbar navbar-expand-lg navbar-custom sticky-top">
  <div class="container-fluid px-4">
    <a class="navbar-brand fw-bold" href="/home" style="color: white; font-size: 1.5rem;">
      <i class="bi bi-arrow-left me-2"></i>EL FIRMA
    </a>
    <button class="btn btn-light" onclick="window.history.back()">
      <i class="material-symbols-outlined">arrow_back</i> Back
    </button>
  </div>
</nav>

<!-- Main Content -->
<div class="container-fluid py-5">
  <div class="row justify-content-center">
    <div class="col-lg-10">

      <!-- Profile Header Section -->
      <div class="profile-header">
        <!-- Avatar and Basic Info -->
        <div class="text-center">
          {% set photo = user.imageU %}
          {% if photo is null or photo == '' or photo == 'default.JPG' %}
            <div class="profile-avatar mx-auto d-flex align-items-center justify-content-center" style="background: white; font-size: 3rem; color: var(--primary-color);">
              <i class="material-symbols-outlined" style="font-size: 5rem;">person</i>
            </div>
          {% elseif photo starts with 'uploads/' %}
            <img src="{{ asset(photo) }}" class="profile-avatar mx-auto">
          {% else %}
            <img src="{{ asset('uploads/users/' ~ photo) }}" class="profile-avatar mx-auto">
          {% endif %}

          <h2 class="mt-4 mb-2" style="font-size: 2rem; font-weight: 800; letter-spacing: -0.5px;">{{ user.prenomU }} {{ user.nomU }}</h2>

          <div class="mt-3">
            {% if user.roleU == 'employee' %}
              <span class="badge-role badge-employee">
                <i class="material-symbols-outlined" style="font-size: 1.1rem;">person_check</i>
                <span>Employee</span>
              </span>
            {% elseif user.roleU == 'client' %}
              <span class="badge-role badge-client">
                <i class="material-symbols-outlined" style="font-size: 1.1rem;">person</i>
                <span>Client</span>
              </span>
            {% elseif user.roleU == 'admin' %}
              <span class="badge-role badge-admin">
                <i class="material-symbols-outlined" style="font-size: 1.1rem;">shield_admin</i>
                <span>Administrator</span>
              </span>
            {% else %}
              <span class="badge-role" style="background-color: rgba(255, 255, 255, 0.2); color: white;">
                <i class="material-symbols-outlined" style="font-size: 1.1rem;">badge</i>
                <span>{{ user.roleU|capitalize }}</span>
              </span>
            {% endif %}
          </div>
        </div>
      </div>

      <!-- Profile Information Cards -->
      <div class="row mb-5">
        <div class="col-md-6">
          <div class="info-card">
            <div class="label">
              <i class="material-symbols-outlined">mail</i>
              Email Address
            </div>
            <div class="value" style="word-break: break-all;">{{ user.emailU }}</div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="info-card">
            <div class="label">
              <i class="material-symbols-outlined">person</i>
              Full Name
            </div>
            <div class="value">{{ user.prenomU }} {{ user.nomU }}</div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="info-card">
            <div class="label">
              <i class="material-symbols-outlined">calendar_today</i>
              Member Since
            </div>
            <div class="value">
              {% if user.dateCreationU %}
                {{ user.dateCreationU|date('F d, Y') }}
              {% else %}
                Not available
              {% endif %}
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="info-card">
            <div class="label">
              <i class="material-symbols-outlined">badge</i>
              Account Type
            </div>
            <div class="value">
              {% if user.roleU == 'employee' %}
                <span class="badge-role badge-employee">Employee</span>
              {% elseif user.roleU == 'client' %}
                <span class="badge-role badge-client">Client</span>
              {% elseif user.roleU == 'admin' %}
                <span class="badge-role badge-admin">Admin</span>
              {% else %}
                <span class="badge-role" style="background-color: rgba(17, 101, 48, 0.1); color: var(--primary-color);">{{ user.roleU|capitalize }}</span>
              {% endif %}
            </div>
          </div>
        </div>
      </div>

      <!-- Complaints Section -->
      <div class="mb-5">
        <div class="d-flex align-items-center gap-3 mb-4">
          <i class="material-symbols-outlined" style="font-size: 2rem; color: var(--primary-color);">edit_note</i>
          <h3 style="margin: 0; font-size: 1.5rem; font-weight: 700; color: var(--text-dark);">My Complaints</h3>
        </div>

        <div class="table-custom">
          {% if complaints|length > 0 %}
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead>
                  <tr>
                    <th>Type</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {% for complaint in complaints %}
                  <tr data-complaint-id="{{ complaint.getIdrU() }}">
                    <td>
                      <span style="display: inline-flex; align-items: center; gap: 0.5rem; background-color: rgba(17, 101, 48, 0.1); color: var(--primary-color); padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.85rem; font-weight: 600;">
                        <i class="material-symbols-outlined" style="font-size: 1rem;">flag</i>
                        {{ complaint.getTypeReclamationU() }}
                      </span>
                    </td>
                    <td>
                      <strong>{{ complaint.getTitreU() }}</strong>
                    </td>
                    <td>
                      <small>{{ complaint.getDescriptionU()|slice(0, 30) }}{% if complaint.getDescriptionU()|length > 30 %}...{% endif %}</small>
                    </td>
                    <td>
                      <small class="text-muted">
                        {% if complaint.getDateReclamationU() %}
                          {{ complaint.getDateReclamationU()|date('d M, Y') }}
                        {% else %}
                          N/A
                        {% endif %}
                      </small>
                    </td>
                    <td>
                      {% if complaint.getStatutU() == 'pending' %}
                        <span class="badge-status badge-pending">
                          <i class="material-symbols-outlined" style="font-size: 0.9rem;">schedule</i>
                          Pending
                        </span>
                      {% elseif complaint.getStatutU() == 'reviewed' %}
                        <span class="badge-status badge-reviewed">
                          <i class="material-symbols-outlined" style="font-size: 0.9rem;">check_circle</i>
                          Reviewed
                        </span>
                      {% else %}
                        <span class="badge-status badge-reviewed">
                          <i class="material-symbols-outlined" style="font-size: 0.9rem;">info</i>
                          {{ complaint.getStatutU()|capitalize }}
                        </span>
                      {% endif %}
                    </td>
                    <td class="text-center">
                      <div style="display: flex; gap: 0.5rem; justify-content: center;">
                        <button class="btn-action btn-edit edit-complaint-btn" data-complaint-id="{{ complaint.getIdrU() }}" data-complaint-type="{{ complaint.getTypeReclamationU() }}" data-complaint-title="{{ complaint.getTitreU() }}" data-complaint-description="{{ complaint.getDescriptionU() }}" title="Edit complaint">
                          <i class="material-symbols-outlined">edit</i>
                        </button>
                        <button class="btn-action btn-delete delete-complaint-btn" data-complaint-id="{{ complaint.getIdrU() }}" title="Delete complaint">
                          <i class="material-symbols-outlined">delete</i>
                        </button>
                      </div>
                    </td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% else %}
            <div class="empty-state">
              <i class="material-symbols-outlined">assignment</i>
              <h5 class="mt-3 mb-2 fw-bold">No Complaints Yet</h5>
              <p class="text-muted">You haven't submitted any complaints.</p>
            </div>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Edit Complaint Modal -->
<div class="modal modal-custom fade" id="editComplaintModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content modal-content-custom">
      <div class="modal-header-custom d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0 fs-4 fw-bold">
            <i class="material-symbols-outlined me-2">edit_note</i>Edit Complaint
          </h5>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body-custom">
        <form id="editComplaintForm" class="needs-validation">
          <input type="hidden" id="editComplaintId" name="complaint_id">

          <!-- Type -->
          <div class="mb-4">
            <label for="editComplaintType" class="form-label fw-bold mb-2" style="color: var(--primary-color);">
              <i class="material-symbols-outlined me-2" style="font-size: 1.1rem;">category</i>Complaint Type
            </label>
            <select id="editComplaintType" name="type" class="form-control-custom form-control" required>
              <option value="Product Issue">Product Issue</option>
              <option value="Service Issue">Service Issue</option>
              <option value="Delivery Problem">Delivery Problem</option>
              <option value="Quality Concern">Quality Concern</option>
              <option value="Other">Other</option>
            </select>
            <div class="complaint-error-message text-danger small mt-1" id="editComplaintTypeError"></div>
          </div>

          <!-- Title -->
          <div class="mb-4">
            <label for="editComplaintTitle" class="form-label fw-bold mb-2" style="color: var(--primary-color);">
              <i class="material-symbols-outlined me-2" style="font-size: 1.1rem;">title</i>Title
            </label>
            <input type="text" id="editComplaintTitle" name="titre" class="form-control-custom form-control" placeholder="Complaint title" maxlength="100" required>
            <small class="text-muted d-block mt-1">Max. 100 characters</small>
            <div class="complaint-error-message text-danger small mt-1" id="editComplaintTitleError"></div>
          </div>

          <!-- Description -->
          <div class="mb-4">
            <label for="editComplaintDescription" class="form-label fw-bold mb-2" style="color: var(--primary-color);">
              <i class="material-symbols-outlined me-2" style="font-size: 1.1rem;">description</i>Description
            </label>
            <textarea id="editComplaintDescription" name="description" rows="4" class="form-control-custom form-control" placeholder="Describe your complaint" maxlength="500" required></textarea>
            <small class="text-muted d-block mt-1">Max. 500 characters</small>
            <div class="complaint-error-message text-danger small mt-1" id="editComplaintDescriptionError"></div>
          </div>

          <!-- Buttons -->
          <div class="d-flex gap-3 pt-3 border-top">
            <button type="button" class="btn btn-light flex-1" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary-custom flex-1">
              <i class="material-symbols-outlined me-2" style="font-size: 1rem;">save</i>Update
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Delete Complaint Modal -->
<div class="modal modal-custom fade" id="deleteComplaintModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content modal-content-custom">
      <div class="modal-header-custom d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #d32f2f, #c62828);">
        <div>
          <h5 class="mb-0 fs-4 fw-bold">
            <i class="material-symbols-outlined me-2">delete_forever</i>Delete Complaint
          </h5>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body-custom">
        <div style="background-color: #ffebee; border: 2px solid #ffcdd2; border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem; display: flex; gap: 1rem;">
          <i class="material-symbols-outlined text-danger" style="font-size: 2rem; flex-shrink: 0;">warning</i>
          <div>
            <strong class="d-block mb-2">Are you sure?</strong>
            <p class="mb-0 text-muted small">This action cannot be undone. The complaint will be permanently deleted from your profile.</p>
          </div>
        </div>

        <div class="d-flex gap-3 pt-2 border-top">
          <button type="button" class="btn btn-light flex-1" data-bs-dismiss="modal">Cancel</button>
          <button type="button" id="confirmDeleteComplaintBtn" class="btn btn-danger flex-1">
            <i class="material-symbols-outlined me-2" style="font-size: 1rem;">delete</i>Delete
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .complaint-error-message {
    display: none;
  }

  .form-control:invalid,
  .form-select:invalid {
    border-color: #d32f2f;
  }

  .form-control:invalid:focus,
  .form-select:invalid:focus {
    border-color: #d32f2f;
    box-shadow: 0 0 0 0.25rem rgba(211, 47, 47, 0.25);
  }

  .btn-light {
    background-color: #f0f0f0;
    border-color: #f0f0f0;
    color: var(--text-dark);
  }

  .btn-light:hover {
    background-color: #e0e0e0;
    border-color: #e0e0e0;
  }
</style>

<script src="{{ asset('assets/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
<script>
  let currentEditingComplaintId = null;
  let currentDeletingComplaintId = null;
  const editComplaintModal = new bootstrap.Modal(document.getElementById('editComplaintModal'));
  const deleteComplaintModal = new bootstrap.Modal(document.getElementById('deleteComplaintModal'));

  // Edit button click
  document.addEventListener('click', function(e) {
    if (e.target.closest('.edit-complaint-btn')) {
      const btn = e.target.closest('.edit-complaint-btn');
      currentEditingComplaintId = btn.dataset.complaintId;

      document.getElementById('editComplaintId').value = btn.dataset.complaintId;
      document.getElementById('editComplaintType').value = btn.dataset.complaintType;
      document.getElementById('editComplaintTitle').value = btn.dataset.complaintTitle;
      document.getElementById('editComplaintDescription').value = btn.dataset.complaintDescription;

      // Clear errors
      document.querySelectorAll('.complaint-error-message').forEach(el => {
        el.textContent = '';
        el.style.display = 'none';
      });

      editComplaintModal.show();
    }
  });

  // Delete button click
  document.addEventListener('click', function(e) {
    if (e.target.closest('.delete-complaint-btn')) {
      const btn = e.target.closest('.delete-complaint-btn');
      currentDeletingComplaintId = btn.dataset.complaintId;
      deleteComplaintModal.show();
    }
  });

  // Edit form submission
  document.getElementById('editComplaintForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    document.querySelectorAll('.complaint-error-message').forEach(el => {
      el.textContent = '';
      el.style.display = 'none';
    });

    const type = document.getElementById('editComplaintType').value;
    const titre = document.getElementById('editComplaintTitle').value;
    const description = document.getElementById('editComplaintDescription').value;

    const formData = new FormData();
    formData.append('complaint_id', currentEditingComplaintId);
    formData.append('type', type);
    formData.append('titre', titre);
    formData.append('description', description);

    try {
      const response = await fetch('{{ path("elfirma_update_complaint") }}', {
        method: 'POST',
        body: formData
      });

      const data = await response.json();

      if (data.success) {
        alert('Complaint updated successfully!');
        location.reload();
      } else {
        if (data.errors) {
          for (const [field, message] of Object.entries(data.errors)) {
            const errorEl = document.getElementById('editComplaint' + field.charAt(0).toUpperCase() + field.slice(1) + 'Error');
            if (errorEl) {
              errorEl.textContent = message;
              errorEl.style.display = 'block';
            }
          }
        }
      }
    } catch (error) {
      console.error('Error:', error);
      alert('An error occurred');
    }
  });

  // Delete confirmation
  document.getElementById('confirmDeleteComplaintBtn').addEventListener('click', async () => {
    const formData = new FormData();
    formData.append('complaint_id', currentDeletingComplaintId);

    try {
      const response = await fetch('{{ path("elfirma_delete_complaint") }}', {
        method: 'POST',
        body: formData
      });

      const data = await response.json();

      if (data.success) {
        alert('Complaint deleted successfully!');
        location.reload();
      } else {
        alert('Error deleting complaint');
      }
    } catch (error) {
      console.error('Error:', error);
      alert('An error occurred');
    }
  });
</script>

</body>
</html>
