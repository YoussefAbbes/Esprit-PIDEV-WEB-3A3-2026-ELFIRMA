// RATINGS FUNCTIONALITY
// ============================================================

let ratingChart = null;

// Load supplier ratings via API
function loadSupplierRatings(supplierId) {
  fetch(`/api/supplier/${supplierId}/ratings-data`)
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        displayRatings(data);
      } else {
        console.error('Error loading ratings:', data.message);
        showRatingsEmpty();
      }
    })
    .catch(error => {
      console.error('Error fetching ratings:', error);
      showRatingsEmpty();
    });
}

// Display ratings in the UI
function displayRatings(data) {
  const section = document.getElementById('ratingsSection');
  const supplierInfo = document.getElementById('ratingsSupplierInfo');
  const avgRatingValue = document.getElementById('averageRatingValue');
  const avgStarsDisplay = document.getElementById('averageStarsDisplay');
  const totalReviewsCount = document.getElementById('totalReviewsCount');
  const chartsContainer = document.getElementById('chartsContainer');
  const ratingsTableContainer = document.getElementById('ratingsTableContainer');
  const ratingsTableBody = document.getElementById('ratingsTableBody');
  const ratingsEmptyState = document.getElementById('ratingsEmptyState');
  const ratingStatsCard = document.getElementById('ratingStatsCard');

  // Show ratings section
  section.style.display = '';

  // Update header info
  supplierInfo.textContent = `${data.total_reviews} reviews from customers`;
  avgRatingValue.textContent = data.average_rating.toFixed(1);
  totalReviewsCount.textContent = `${data.total_reviews} Review${data.total_reviews !== 1 ? 's' : ''}`;

  // Display average stars
  avgStarsDisplay.innerHTML = '';
  for (let i = 0; i < 5; i++) {
    const filled = i < Math.round(data.average_rating);
    const star = document.createElement('span');
    star.className = `material-symbols-outlined ${filled ? 'text-[#FFB800]' : 'text-[#ddd]'}`;
    star.textContent = 'star';
    avgStarsDisplay.appendChild(star);
  }

  // Show/hide stats card
  if (data.total_reviews > 0) {
    ratingStatsCard.style.display = '';
    chartsContainer.style.display = 'grid';
    ratingsEmptyState.style.display = 'none';

    // Update chart
    updateRatingChart(data.star_distribution);

    // Update star breakdown
    updateStarBreakdown(data.star_distribution);

    // Display ratings table
    if (data.ratings.length > 0) {
      ratingsTableContainer.style.display = '';
      ratingsTableBody.innerHTML = data.ratings.map(rating => `
        <tr class="hover:bg-[#f5f5dc]/50 transition-colors">
          <td class="px-6 py-4">
            <div class="flex gap-0.5">
              ${Array(5).fill().map((_, i) => `
                <span class="material-symbols-outlined text-sm ${i < rating.stars ? 'text-[#FFB800]' : 'text-[#ddd]'}">star</span>
              `).join('')}
            </div>
            <p class="text-xs text-[#4f6b38] mt-1">${rating.stars}.0/5.0</p>
          </td>
          <td class="px-6 py-4">
            <p class="font-semibold text-[#0a2200]">User #${rating.user_id}</p>
          </td>
          <td class="px-6 py-4">
            <p class="text-sm text-[#355025] line-clamp-2">${rating.comment || 'No comment'}</p>
          </td>
          <td class="px-6 py-4 text-sm text-[#4f6b38]">
            ${rating.date}
          </td>
          <td class="px-6 py-4 text-center">
            <button class="text-primary hover:bg-primary/10 rounded p-1 transition-colors" title="Read full review">
              <span class="material-symbols-outlined text-base">expand_more</span>
            </button>
          </td>
        </tr>
      `).join('');
    } else {
      ratingsTableContainer.style.display = 'none';
    }
  } else {
    ratingStatsCard.style.display = 'none';
    chartsContainer.style.display = 'none';
    ratingsTableContainer.style.display = 'none';
    ratingsEmptyState.style.display = '';
  }
}

// Show empty ratings state
function showRatingsEmpty() {
  const section = document.getElementById('ratingsSection');
  const ratingsEmptyState = document.getElementById('ratingsEmptyState');
  const ratingStatsCard = document.getElementById('ratingStatsCard');
  const chartsContainer = document.getElementById('chartsContainer');
  const ratingsTableContainer = document.getElementById('ratingsTableContainer');

  section.style.display = '';
  ratingsEmptyState.style.display = '';
  ratingStatsCard.style.display = 'none';
  chartsContainer.style.display = 'none';
  ratingsTableContainer.style.display = 'none';
}

// Update rating distribution chart
function updateRatingChart(starDistribution) {
  const ctx = document.getElementById('ratingDistributionChart');
  if (!ctx) return;

  // Destroy existing chart if it exists
  if (ratingChart) {
    ratingChart.destroy();
  }

  const labels = starDistribution.map(s => `${s.stars}⭐`).reverse();
  const data = starDistribution.map(s => s.count).reverse();
  const colors = ['#10b981', '#3b82f6', '#f59e0b', '#ef4444', '#8b5cf6'];

  ratingChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{
        label: 'Number of Reviews',
        data: data,
        backgroundColor: colors,
        borderRadius: 6,
        borderSkipped: false
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: { display: false }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: { stepSize: 1 }
        }
      }
    }
  });
}

// Update star breakdown display
function updateStarBreakdown(starDistribution) {
  const container = document.getElementById('starBreakdown');
  container.innerHTML = starDistribution.map(stat => `
    <div class="flex items-center justify-between bg-white rounded-lg p-3 border border-[#dce7cd]">
      <div class="flex items-center gap-2">
        <span class="text-[#FFB800] font-bold">${stat.stars}</span>
        <span class="material-symbols-outlined text-sm text-[#FFB800]">star</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-20 h-2 bg-[#e5e7eb] rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-[#FFB800] to-[#fcd34d]" style="width: ${stat.percentage}%"></div>
        </div>
        <span class="text-xs font-bold text-[#4f6b38] w-8 text-right">${stat.percentage}%</span>
      </div>
    </div>
  `).join('');
}

// ==================== MAP INITIALIZATION ====================

let addMap = null;
let editMap = null;
let addMarker = null;
let editMarker = null;

// Initialize map when modal is opened
function initializeAddMap() {
  if (addMap) return; // Already initialized

  setTimeout(() => {
    const mapContainer = document.getElementById('mapContainer');
    if (!mapContainer) return;

    addMap = L.map('mapContainer').setView([35.8, 10.2], 6); // Tunisia center coordinates
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors',
      maxZoom: 19
    }).addTo(addMap);

    addMap.invalidateSize();
  }, 100);
}

function initializeEditMap() {
  if (editMap) return; // Already initialized

  setTimeout(() => {
    const mapContainer = document.getElementById('editMapContainer');
    if (!mapContainer) return;

    editMap = L.map('editMapContainer').setView([35.8, 10.2], 6); // Tunisia center coordinates
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors',
      maxZoom: 19
    }).addTo(editMap);

    editMap.invalidateSize();
  }, 100);
}

// Geocode address for add form
document.getElementById('adresse').addEventListener('blur', async function() {
  const address = this.value.trim();
  if (!address) {
    document.getElementById('addressStatus').textContent = 'Enter an address to see location';
    return;
  }

  document.getElementById('addressStatus').textContent = 'Geocoding...';

  try {
    const response = await fetch('{{ path("api_geocode_address") }}', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ address: address })
    });

    const data = await response.json();

    if (data.success) {
      document.getElementById('latitude').value = data.latitude;
      document.getElementById('longitude').value = data.longitude;
      document.getElementById('addressStatus').textContent = '✓ Location found';

      // Initialize and update map
      if (!addMap) initializeAddMap();

      setTimeout(() => {
        if (addMap) {
          addMap.setView([data.latitude, data.longitude], 13);
          if (addMarker) addMap.removeLayer(addMarker);
          addMarker = L.marker([data.latitude, data.longitude])
            .bindPopup('<strong>' + data.display_name + '</strong>')
            .addTo(addMap);
        }
      }, 100);
    } else {
      document.getElementById('addressStatus').textContent = '✗ ' + (data.error || 'Location not found');
      document.getElementById('latitude').value = '';
      document.getElementById('longitude').value = '';
    }
  } catch (error) {
    console.error('Geocoding error:', error);
    document.getElementById('addressStatus').textContent = '✗ Error geocoding address';
  }
});

