  // Image to PDF button handler
  const imageToTextBtn = document.getElementById('imageToTextBtn');
  const imageFile = document.getElementById('imageFile');
  const imageToTextProcessing = document.getElementById('imageToTextProcessing');
  const imageToTextSuccess = document.getElementById('imageToTextSuccess');
  const imageToTextError = document.getElementById('imageToTextError');
  const extractedTextPreview = document.getElementById('extractedTextPreview');
  const imageToTextErrorMsg = document.getElementById('imageToTextErrorMsg');

  imageToTextBtn.addEventListener('click', async function(e) {
    e.preventDefault();

    // Check if image is selected
    if (!imageFile.files || !imageFile.files[0]) {
      Swal.fire({
        icon: 'warning',
        title: 'No Image Selected',
        text: 'Please select an image file to extract text from.',
        confirmButtonColor: '#116530'
      });
      return;
    }

    const supplierId = document.getElementById('supplierId').value;
    const supplierNameElements = document.querySelector('tbody tr[data-supplier-id="' + supplierId + '"] td:first-child');
    const supplierName = supplierNameElements ? supplierNameElements.textContent.trim() : 'Unknown';

    // Show processing state
    imageToTextProcessing.classList.remove('hidden');
    imageToTextSuccess.classList.add('hidden');
    imageToTextError.classList.add('hidden');
    const originalText = imageToTextBtn.innerHTML;
    imageToTextBtn.disabled = true;

    try {
      // Create FormData for file upload
      const formData = new FormData();
      formData.append('image_file', imageFile.files[0]);
      formData.append('supplier_id', supplierId);
      formData.append('supplier_name', supplierName);

      // Send request to convert image to PDF
      const response = await fetch('{{ path("elfirma_image_to_pdf") }}', {
        method: 'POST',
        body: formData
      });

      const jsonData = await response.json();

      if (!response.ok || !jsonData.success) {
        throw new Error(jsonData.error || jsonData.message || 'Failed to process image');
      }

      // Store the generated PDF path in hidden field
      document.getElementById('generatedPdfFile').value = jsonData.pdf_file;
      document.getElementById('generatedPdfIndicator').classList.remove('hidden');

      // Display extracted text preview
      extractedTextPreview.textContent = jsonData.extracted_text.substring(0, 500) + (jsonData.extracted_text.length > 500 ? '...' : '');

      // Hide processing, show success
      imageToTextProcessing.classList.add('hidden');
      imageToTextSuccess.classList.remove('hidden');

      // Show success message
      Swal.fire({
        icon: 'success',
        title: 'Success!',
        text: 'Text extracted from image and PDF generated. Now click "Create Contract" to save it.',
        confirmButtonColor: '#116530'
      });

    } catch (error) {
      console.error('Error converting image to PDF:', error);
      imageToTextErrorMsg.textContent = error.message || 'Failed to process image. Please try again.';

      // Hide processing, show error
      imageToTextProcessing.classList.add('hidden');
      imageToTextError.classList.remove('hidden');

      Swal.fire({
        icon: 'error',
        title: 'Error',
        text: error.message || 'Failed to process image. Please try again.',
        confirmButtonColor: '#116530'
      });
    } finally {
      // Reset button state
      imageToTextBtn.disabled = false;
      imageToTextBtn.innerHTML = originalText;
    }
  });

  // Form submission
  addContractForm.addEventListener('submit', async function(e) {
    e.preventDefault();

    // Clear previous errors
    document.querySelectorAll('#addContractForm .error-field').forEach(el => {
      el.classList.remove('error-field');
    });
    document.querySelectorAll('[id$="Error"]').forEach(el => {
      el.textContent = '';
      el.style.display = 'none';
    });

    // Validate before submission
    let hasErrors = false;
    const dateDebutValidation = validateDateDebut(dateDebutField.value);
    const dateFinValidation = validateDateFin(dateFinField.value, dateDebutField.value);
    const typeValidation = validateContractType(contractTypeField.value);
    const statusValidation = validateContractStatus(contractStatusField.value);

    if (!dateDebutValidation.valid) {
      updateFieldValidation('dateDebut', false, dateDebutValidation.message);
      hasErrors = true;
    }
    if (!dateFinValidation.valid) {
      updateFieldValidation('dateFin', false, dateFinValidation.message);
      hasErrors = true;
    }
    if (!typeValidation.valid) {
      updateFieldValidation('contractType', false, typeValidation.message);
      hasErrors = true;
    }
    if (!statusValidation.valid) {
      updateFieldValidation('contractStatus', false, statusValidation.message);
      hasErrors = true;
    }

    if (hasErrors) {
      return;
    }

    const formData = new FormData(addContractForm);

    // If a PDF was generated, add the generated_pdf_file field to formData
    const generatedPdfFile = document.getElementById('generatedPdfFile').value;
    if (generatedPdfFile) {
      formData.set('generated_pdf_file', generatedPdfFile);
    }

    try {
      const response = await fetch('{{ path("elfirma_add_contract") }}', {
        method: 'POST',
        body: formData
      });

      const data = await response.json();

      if (data.success) {
        alert('Contract created successfully!');
        contractModal.classList.add('hidden');
        window.location.reload();
      } else {
        // Display errors from backend
        if (data.errors) {
          for (const [field, message] of Object.entries(data.errors)) {
            const input = document.getElementById(field === 'date_debut' ? 'dateDebut' : field === 'date_fin' ? 'dateFin' : field === 'type' ? 'contractType' : field === 'statut' ? 'contractStatus' : field === 'pdf_file' ? 'pdfFile' : field);
            const errorEl = document.getElementById((field === 'date_debut' ? 'dateDebut' : field === 'date_fin' ? 'dateFin' : field === 'type' ? 'contractType' : field === 'statut' ? 'contractStatus' : field === 'pdf_file' ? 'pdfFile' : field) + 'Error');
            if (input) input.classList.add('error-field');
            if (errorEl) {
              errorEl.textContent = message;
              errorEl.style.display = 'block';
            }
          }
        }
      }
    } catch (error) {
      console.error('Error:', error);
      alert('An error occurred while creating the contract');
    }
  });

