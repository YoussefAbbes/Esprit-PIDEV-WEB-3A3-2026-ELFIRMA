            </div>
          </td>
        </tr>
      `;
    });

    tableHTML += `
        </tbody>
      </table>
    `;

    container.innerHTML = tableHTML;
  }

  // Validation functions for contract
  function validateDateDebut(value) {
    if (value.trim() === '') {
      return { valid: false, message: 'Start date is required' };
    }
    return { valid: true, message: '' };
  }

  function validateDateFin(value, dateDebutValue) {
    if (value.trim() === '') {
      return { valid: false, message: 'End date is required' };
    }
    if (dateDebutValue && value <= dateDebutValue) {
      return { valid: false, message: 'End date must be after start date' };
    }
    return { valid: true, message: '' };
  }

  function validateContractType(value) {
    if (value === '') {
      return { valid: false, message: 'Please select a contract type' };
    }
    return { valid: true, message: '' };
  }

  function validateContractStatus(value) {
    if (value === '') {
      return { valid: false, message: 'Please select a status' };
    }
    return { valid: true, message: '' };
  }

  // Real-time validation
  dateDebutField.addEventListener('change', function() {
    const validation = validateDateDebut(this.value);
    updateFieldValidation('dateDebut', validation.valid, validation.message);
    // Also validate end date if it has a value
    if (dateFinField.value) {
      const finValidation = validateDateFin(dateFinField.value, this.value);
      updateFieldValidation('dateFin', finValidation.valid, finValidation.message);
    }
  });

  dateFinField.addEventListener('change', function() {
    const validation = validateDateFin(this.value, dateDebutField.value);
    updateFieldValidation('dateFin', validation.valid, validation.message);
  });

  contractTypeField.addEventListener('change', function() {
    const validation = validateContractType(this.value);
    updateFieldValidation('contractType', validation.valid, validation.message);
  });

  contractStatusField.addEventListener('change', function() {
    const validation = validateContractStatus(this.value);
    updateFieldValidation('contractStatus', validation.valid, validation.message);
  });

  // Close contract modal
  closeContractModalBtn.addEventListener('click', function() {
    contractModal.classList.add('hidden');
    addContractForm.reset();
  });

  cancelContractBtn.addEventListener('click', function() {
    contractModal.classList.add('hidden');
    addContractForm.reset();
  });

  // Generate PDF button handler
  const generateContractPdfBtn = document.getElementById('generateContractPdfBtn');
  generateContractPdfBtn.addEventListener('click', async function(e) {
    e.preventDefault();

    // Validate form data
    const supplierId = document.getElementById('supplierId').value;
    const dateDebut = document.getElementById('dateDebut').value;
    const dateFin = document.getElementById('dateFin').value;
    const contractType = document.getElementById('contractType').value;
    const contractStatus = document.getElementById('contractStatus').value;

    if (!supplierId || !dateDebut || !dateFin) {
      Swal.fire({
        icon: 'warning',
        title: 'Incomplete Form',
        text: 'Please fill in all required fields (Supplier, Start Date, End Date)',
        confirmButtonColor: '#116530'
      });
      return;
    }

    // Show loading state
    const originalText = generateContractPdfBtn.innerHTML;
    generateContractPdfBtn.disabled = true;
    generateContractPdfBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">autorenew</span> Generating...';

    try {
      // Send request to generate PDF
      const response = await fetch('{{ path("generate_contract_pdf") }}', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          supplier_id: supplierId,
          date_debut: dateDebut,
          date_fin: dateFin,
          type: contractType,
          statut: contractStatus
        })
      });

      const jsonData = await response.json();

      if (!response.ok || !jsonData.success) {
        throw new Error(jsonData.message || 'Failed to generate PDF');
      }

      // Store the generated PDF path in hidden field
      document.getElementById('generatedPdfFile').value = jsonData.pdf_file;

      // Show indicator that PDF was generated
      document.getElementById('generatedPdfIndicator').classList.remove('hidden');

      // Show success message
      Swal.fire({
        icon: 'success',
        title: 'PDF Generated!',
        text: 'PDF has been generated. Now click "Create Contract" to save it to the database.',
        confirmButtonColor: '#116530'
      });

    } catch (error) {
      console.error('Error generating PDF:', error);
      Swal.fire({
        icon: 'error',
        title: 'Error',
        text: error.message || 'Failed to generate PDF. Please try again.',
        confirmButtonColor: '#116530'
      });
    } finally {
      // Reset button state
      generateContractPdfBtn.disabled = false;
      generateContractPdfBtn.innerHTML = originalText;
    }
  });

