              <button class="edit-contract-btn p-2 hover:bg-surface-variant rounded-full transition-colors text-primary" data-contract-id="${contract.id}" data-contract-type="${contract.type}" data-contract-debut="${contract.date_debut}" data-contract-fin="${contract.date_fin}" data-contract-statut="${contract.statut}" type="button">
