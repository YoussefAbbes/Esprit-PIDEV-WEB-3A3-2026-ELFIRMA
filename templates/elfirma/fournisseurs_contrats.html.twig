    const cancelScheduleMeetingBtn = document.getElementById('cancelScheduleMeetingBtn');
    const closeScheduleMeetingModalBtn = document.getElementById('closeScheduleMeetingModalBtn');
    let currentSchedulingSupplierId = null;

    // Schedule Meeting Button Listeners
    document.querySelectorAll('.schedule-meeting-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        currentSchedulingSupplierId = this.dataset.supplierId;
        const supplierName = this.dataset.supplierName;
        const supplierEmail = this.dataset.supplierEmail;

        // Populate modal with supplier info
        document.getElementById('meetingSupplierId').value = currentSchedulingSupplierId;
        document.getElementById('meetingSupplierName').textContent = supplierName;

        // Set minimum datetime to now
        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        document.getElementById('meetingDateTime').min = now.toISOString().slice(0, 16);

        // Clear any previous values and errors
        document.getElementById('meetingDateTime').value = '';
        document.getElementById('meetingDateTimeError').textContent = '';
        document.getElementById('meetingDateTimeError').style.display = 'none';

        scheduleMeetingModal.classList.remove('hidden');
      });
    });

    // Close modal buttons
    cancelScheduleMeetingBtn?.addEventListener('click', function() {
      scheduleMeetingModal.classList.add('hidden');
    });

    closeScheduleMeetingModalBtn?.addEventListener('click', function() {
      scheduleMeetingModal.classList.add('hidden');
    });

    // Handle form submission
    confirmScheduleMeetingBtn?.addEventListener('click', async function(e) {
      e.preventDefault();

      // Validate form
      const meetingDateTime = document.getElementById('meetingDateTime').value;
      const dateTimeErrorEl = document.getElementById('meetingDateTimeError');

      if (!meetingDateTime) {
        dateTimeErrorEl.textContent = 'Meeting date and time are required';
        dateTimeErrorEl.style.display = 'block';
        return;
      }

      // Disable button and show loading state
      confirmScheduleMeetingBtn.disabled = true;
      confirmScheduleMeetingBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">hourglass_bottom</span> Scheduling...';

      try {
        const formData = new FormData();
        formData.append('supplier_id', currentSchedulingSupplierId);
        formData.append('meeting_datetime', meetingDateTime);

        const response = await fetch('{{ path("elfirma_schedule_meeting") }}', {
          method: 'POST',
          body: formData
        });

        const data = await response.json();

        if (data.success) {
          // Show success message
          let successMessage = 'The meeting has been scheduled successfully!';
          let successIcon = 'success';

          if (!data.email_sent) {
            successMessage += '\n\n⚠️ Note: Email delivery is pending. Verify the sender email is registered in SendGrid.';
            if (data.email_error) {
              successMessage += '\n\nError: ' + data.email_error;
            }
            successIcon = 'warning';
          } else {
            successMessage += '\n\nAn invitation email has been sent to the supplier.';
          }

          await Swal.fire({
            icon: successIcon,
            title: 'Meeting Scheduled!',
            text: successMessage,
            confirmButtonText: 'OK'
          });

          // Close modal and reload page
          scheduleMeetingModal.classList.add('hidden');
          window.location.reload();
        } else {
          // Show error
          if (data.errors) {
            if (data.errors.datetime) {
              dateTimeErrorEl.textContent = data.errors.datetime;
              dateTimeErrorEl.style.display = 'block';
            } else {
              const firstError = Object.values(data.errors)[0];
              Swal.fire({
                icon: 'error',
                title: 'Error',
                text: firstError || data.message || 'An error occurred while scheduling the meeting'
              });
            }
          } else {
            Swal.fire({
              icon: 'error',
              title: 'Error',
              text: data.message || 'An error occurred while scheduling the meeting'
            });
          }
        }
      } catch (error) {
        console.error('Error:', error);
        Swal.fire({
          icon: 'error',
          title: 'Error',
          text: 'An unexpected error occurred while scheduling the meeting'
        });
      } finally {
        // Re-enable button
        confirmScheduleMeetingBtn.disabled = false;
        confirmScheduleMeetingBtn.innerHTML = '<span class="material-symbols-outlined">videocam</span> Schedule';
      }
    });
  });

