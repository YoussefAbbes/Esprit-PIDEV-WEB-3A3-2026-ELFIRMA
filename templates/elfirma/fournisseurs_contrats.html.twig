            '#73796c', // Inactive - outline neutral
            '#ba1a1a'  // Suspended - error red
          ],
          borderColor: [
            '#0a2200', // Active border darker
            '#475240', // Inactive border darker
            '#8a1515'  // Suspended border darker
          ],
          borderWidth: 2.5,
          borderRadius: 10,
          spacing: 3
        }]
      };

      const chart = new Chart(ctx, {
        type: 'doughnut',
        data: chartData,
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                font: {
                  family: "'Inter', sans-serif",
                  size: 13,
                  weight: '600'
                },
                color: '#43493d',
                padding: 20,
                usePointStyle: true,
                pointStyle: 'circle'
              }
            },
            tooltip: {
              backgroundColor: 'rgba(10, 34, 0, 0.9)',
              titleFont: {
                family: "'Inter', sans-serif",
                size: 14,
                weight: '700'
              },
              bodyFont: {
                family: "'Open Sans', sans-serif",
                size: 13
              },
              padding: 12,
              titleColor: '#fbfbe2',
              bodyColor: '#fbfbe2',
              borderColor: 'rgba(210, 226, 201, 0.3)',
              borderWidth: 1,
              displayColors: true,
              callbacks: {
                label: function(context) {
                  const total = context.dataset.data.reduce((a, b) => a + b, 0);
                  const percentage = total > 0 ? Math.round((context.parsed / total) * 100) : 0;
                  return context.label + ': ' + context.parsed + ' (' + percentage + '%)';
                }
              }
            }
          }
        }
      });
    }

    // SUPPLIERS SORT FUNCTIONALITY
    const supplierSortSelect = document.getElementById('supplierSortSelect');
    const supplierTableBody = document.getElementById('supplierTableBody');

    if (supplierSortSelect) {
      supplierSortSelect.addEventListener('change', function() {
        const rows = Array.from(supplierTableBody.querySelectorAll('tr.supplier-row'));
        const sortValue = this.value;

        rows.sort((a, b) => {
          let comparison = 0;

          if (sortValue === 'name-asc') {
            const nameA = a.querySelector('td:nth-child(1)').textContent.toLowerCase();
            const nameB = b.querySelector('td:nth-child(1)').textContent.toLowerCase();
            comparison = nameA.localeCompare(nameB);
          } else if (sortValue === 'name-desc') {
            const nameA = a.querySelector('td:nth-child(1)').textContent.toLowerCase();
            const nameB = b.querySelector('td:nth-child(1)').textContent.toLowerCase();
            comparison = nameB.localeCompare(nameA);
          } else if (sortValue === 'type-asc') {
            const typeA = a.getAttribute('data-supplier-type');
            const typeB = b.getAttribute('data-supplier-type');
            comparison = typeA.localeCompare(typeB);
          } else if (sortValue === 'status') {
            const statusOrder = { 'Active': 0, 'Inactive': 1, 'Suspended': 2 };
            const statusA = a.querySelector('td:nth-child(6)').textContent.trim();
            const statusB = b.querySelector('td:nth-child(6)').textContent.trim();
            comparison = (statusOrder[statusA] || 999) - (statusOrder[statusB] || 999);
          }

          return comparison;
        });

        rows.forEach(row => supplierTableBody.appendChild(row));
      });
    }

    // CONTRACTS SORT FUNCTIONALITY
    const contractSortSelect = document.getElementById('contractSortSelect');

    if (contractSortSelect) {
      contractSortSelect.addEventListener('change', function() {
        const contractsTableContainer = document.getElementById('contractsTableContainer');
        const contractTable = contractsTableContainer.querySelector('table');

        if (!contractTable) return;

        const rows = Array.from(contractTable.querySelectorAll('tbody tr.contract-row'));
        const sortValue = this.value;

        rows.sort((a, b) => {
          let comparison = 0;

          if (sortValue === 'date-desc') {
            const dateA = new Date(a.getAttribute('data-contract-end-date') || 0);
            const dateB = new Date(b.getAttribute('data-contract-end-date') || 0);
            comparison = dateB - dateA;
          } else if (sortValue === 'date-asc') {
            const dateA = new Date(a.getAttribute('data-contract-end-date') || 0);
            const dateB = new Date(b.getAttribute('data-contract-end-date') || 0);
            comparison = dateA - dateB;
          } else if (sortValue === 'status') {
            const statusOrder = { 'Active': 0, 'Inactive': 1, 'Expired': 2 };
            const statusA = a.getAttribute('data-contract-status') || 'Inactive';
            const statusB = b.getAttribute('data-contract-status') || 'Inactive';
            comparison = (statusOrder[statusA] || 999) - (statusOrder[statusB] || 999);
          } else if (sortValue === 'supplier') {
            const supplierA = (a.getAttribute('data-supplier-name') || '').toLowerCase();
            const supplierB = (b.getAttribute('data-supplier-name') || '').toLowerCase();
            comparison = supplierA.localeCompare(supplierB);
          } else if (sortValue === 'type-asc') {
            const typeA = (a.getAttribute('data-contract-type') || '').toLowerCase();
            const typeB = (b.getAttribute('data-contract-type') || '').toLowerCase();
            comparison = typeA.localeCompare(typeB);
          } else if (sortValue === 'type-desc') {
            const typeA = (a.getAttribute('data-contract-type') || '').toLowerCase();
            const typeB = (b.getAttribute('data-contract-type') || '').toLowerCase();
            comparison = typeB.localeCompare(typeA);
          }

          return comparison;
        });

        const tbody = contractTable.querySelector('tbody');
        rows.forEach(row => tbody.appendChild(row));
      });
    }

    // Add animation styles if not already present
    if (!document.getElementById('sort-animation-styles')) {
      const style = document.createElement('style');
      style.id = 'sort-animation-styles';
      style.textContent = `
        @keyframes slideIn {
          from {
            opacity: 0;
            transform: translateY(10px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }
        .supplier-row {
          animation: slideIn 0.3s ease-out;
        }
        @keyframes popUp {
          0% {
            opacity: 0;
            transform: scale(0.9);
          }
          100% {
            opacity: 1;
            transform: scale(1);
          }
        }
        .stats-appear {
          animation: popUp 0.5s ease-out;
        }
        .stats-appear.delay-1 {
          animation-delay: 0.1s;
        }
        .stats-appear.delay-2 {
          animation-delay: 0.2s;
        }
        .stats-appear.delay-3 {
          animation-delay: 0.3s;
        }
      `;
      document.head.appendChild(style);
    }
  });

</script>

</main>
