<!-- Modal JavaScript -->
<script>
  // Validation Functions
  function validateType(value) {
    if (value.length > 50) {
      return { valid: false, message: 'Max. 50 characters' };
    }
    if (value.trim() === '') {
      return { valid: false, message: 'Supplier type is required' };
    }
    return { valid: true, message: '' };
  }

  function validateDescription(value) {
    if (value.length > 100) {
      return { valid: false, message: 'Max. 100 characters' };
    }
    if (value.trim() === '') {
      return { valid: false, message: 'Description is required' };
    }
    return { valid: true, message: '' };
  }

  function validateAdresse(value) {
    if (value.trim() === '') {
      return { valid: false, message: 'Address is required' };
    }
    // Address must contain at least one letter
    if (!/[a-zA-Z]/.test(value)) {
      return { valid: false, message: 'Address must contain at least one letter (e.g., 123 marsa or marsa)' };
    }
    return { valid: true, message: '' };
  }

  function validateTel(value) {
    if (value.trim() === '') {
      return { valid: false, message: 'Telephone is required' };
    }
    if (!/^\d{8}$/.test(value)) {
      return { valid: false, message: 'Must be exactly 8 digits (only numbers)' };
    }
    return { valid: true, message: '' };
  }

  function validateEmail(value) {
    if (value.trim() === '') {
      return { valid: false, message: 'Email is required' };
    }
    // Simple email validation: name@domain.com
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(value)) {
      return { valid: false, message: 'Invalid email format (e.g., name@domain.com)' };
    }
    return { valid: true, message: '' };
  }

  function validateStatut(value) {
    if (value === '') {
      return { valid: false, message: 'Please select a status' };
    }
    return { valid: true, message: '' };
  }

  // Update field styles and error message
  function updateFieldValidation(fieldId, isValid, message = '') {
    const field = document.getElementById(fieldId);
    const errorEl = document.getElementById(fieldId + 'Error');

    if (isValid) {
      field.classList.remove('error-field');
      if (errorEl) {
        errorEl.textContent = '';
        errorEl.style.display = 'none';
      }
    } else {
      field.classList.add('error-field');
      if (errorEl) {
        errorEl.textContent = message;
        errorEl.style.display = 'block';
      }
    }
  }

  // Modal Control
  const addSupplierBtn = document.getElementById('addSupplierBtn');
  const addSupplierModal = document.getElementById('addSupplierModal');
  const closeSupplierModalBtn = document.getElementById('closeSupplierModalBtn');
  const cancelSupplierBtn = document.getElementById('cancelSupplierBtn');
  const addSupplierForm = document.getElementById('addSupplierForm');

  // Get all form fields
  const typeField = document.getElementById('type');
  const descriptionField = document.getElementById('description');
  const adresseField = document.getElementById('adresse');
  const telField = document.getElementById('tel');
  const emailField = document.getElementById('email');
  const statutField = document.getElementById('statut');

  // Open Modal
  addSupplierBtn.addEventListener('click', function() {
    addSupplierModal.classList.remove('hidden');
    addSupplierForm.reset();
    // Reset error states
    document.querySelectorAll('[id$="Error"]').forEach(el => {
      el.textContent = '';
      el.style.display = 'none';
    });
    document.querySelectorAll('.error-field').forEach(el => {
      el.classList.remove('error-field');
    });
  });

  // Close Modal
  closeSupplierModalBtn.addEventListener('click', function() {
    addSupplierModal.classList.add('hidden');
  });

  cancelSupplierBtn.addEventListener('click', function() {
    addSupplierModal.classList.add('hidden');
  });

  // Close on backdrop click
  addSupplierModal.addEventListener('click', function(e) {
    if (e.target === addSupplierModal) {
      addSupplierModal.classList.add('hidden');
    }
  });

  // Real-time validation
  typeField.addEventListener('input', function() {
    const validation = validateType(this.value);
    updateFieldValidation('type', validation.valid, validation.message);
  });

  descriptionField.addEventListener('input', function() {
    const validation = validateDescription(this.value);
    updateFieldValidation('description', validation.valid, validation.message);
  });

  adresseField.addEventListener('input', function() {
    const validation = validateAdresse(this.value);
    updateFieldValidation('adresse', validation.valid, validation.message);
  });

  telField.addEventListener('input', function() {
    const validation = validateTel(this.value);
    updateFieldValidation('tel', validation.valid, validation.message);
  });

  emailField.addEventListener('input', function() {
    const validation = validateEmail(this.value);
    updateFieldValidation('email', validation.valid, validation.message);
  });

  statutField.addEventListener('change', function() {
    const validation = validateStatut(this.value);
    updateFieldValidation('statut', validation.valid, validation.message);
  });

  // Form Submission
  addSupplierForm.addEventListener('submit', async function(e) {
    e.preventDefault();

    // Clear previous errors
    document.querySelectorAll('.error-field').forEach(el => {
      el.classList.remove('error-field');
    });
    document.querySelectorAll('.error-message-supplier').forEach(el => {
      el.textContent = '';
      el.style.display = 'none';
    });

    // Get form data
    const formData = new FormData(addSupplierForm);

    try {
      const response = await fetch('{{ path("elfirma_add_supplier") }}', {
        method: 'POST',
        body: formData
      });

      const data = await response.json();

      if (data.success) {
        alert('Supplier created successfully!');
        addSupplierModal.classList.add('hidden');

        // Store supplier ID for contract creation
        const supplierId = data.id || null;
        if (supplierId) {
          // Show SweetAlert confirmation dialog
          Swal.fire({
            title: 'Add Contract?',
            text: 'Would you like to add a contract for this supplier?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Yes, Add Contract',
            cancelButtonText: 'No, Not Now',
            confirmButtonColor: '#116530',
            cancelButtonColor: '#6c757d',
            reverseButtons: true
          }).then((result) => {
            if (result.isConfirmed) {
              // Open contract modal with supplier ID
              document.getElementById('supplierId').value = supplierId;
              document.getElementById('contractModal').classList.remove('hidden');
            } else {
              window.location.reload();
            }
          });
        } else {
          window.location.reload();
        }
      } else {
        // Display errors
        if (data.errors) {
          for (const [field, message] of Object.entries(data.errors)) {
            const input = document.getElementById(field);
            const errorEl = document.getElementById(field + 'Error');
            if (input) input.classList.add('error-field');
            if (errorEl) {
              errorEl.textContent = message;
              errorEl.style.display = 'block';
            }
          }
        }
      }
    } catch (error) {
      console.error('Error:', error);
      alert('An error occurred while creating the supplier');
    }
  });

  // Edit Supplier Functionality
  const editSupplierModal = document.getElementById('editSupplierModal');
  const editSupplierForm = document.getElementById('editSupplierForm');
  const closeEditModalBtn = document.getElementById('closeEditModalBtn');
  const cancelEditBtn = document.getElementById('cancelEditBtn');

  let currentEditingSupplierId = null;

  // Get edit form fields
  const editTypeField = document.getElementById('editType');
  const editDescriptionField = document.getElementById('editDescription');
  const editAdresseField = document.getElementById('editAdresse');
  const editTelField = document.getElementById('editTel');
  const editEmailField = document.getElementById('editEmail');
  const editStatutField = document.getElementById('editStatut');

  // Real-time validation for edit form
  editTypeField.addEventListener('input', function() {
    const validation = validateType(this.value);
    updateFieldValidation('editType', validation.valid, validation.message);
  });

  editDescriptionField.addEventListener('input', function() {
    const validation = validateDescription(this.value);
    updateFieldValidation('editDescription', validation.valid, validation.message);
  });

  editAdresseField.addEventListener('input', function() {
    const validation = validateAdresse(this.value);
    updateFieldValidation('editAdresse', validation.valid, validation.message);
  });

  editTelField.addEventListener('input', function() {
    const validation = validateTel(this.value);
    updateFieldValidation('editTel', validation.valid, validation.message);
  });

  editEmailField.addEventListener('input', function() {
    const validation = validateEmail(this.value);
    updateFieldValidation('editEmail', validation.valid, validation.message);
  });

  editStatutField.addEventListener('change', function() {
    const validation = validateStatut(this.value);
    updateFieldValidation('editStatut', validation.valid, validation.message);
  });

  // Edit button listeners
  document.querySelectorAll('.edit-supplier-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const row = this.closest('tr');
      const supplierId = this.dataset.supplierId;

      // Get data from table row
      const cells = row.querySelectorAll('td');
      const type = cells[0].textContent.trim();
      const description = cells[1].textContent.trim();
      const address = cells[2].textContent.trim();
      const email = cells[3].textContent.trim();
      const telephone = cells[4].textContent.trim();
      const status = cells[5].querySelector('span').textContent.trim();

      // Populate form
      document.getElementById('editType').value = type;
      document.getElementById('editDescription').value = description;
      document.getElementById('editAdresse').value = address;
      document.getElementById('editTel').value = telephone;
      document.getElementById('editEmail').value = email;
      document.getElementById('editStatut').value = status;

      // Clear previous errors
      document.querySelectorAll('[id^="edit"][id$="Error"]').forEach(el => {
        el.textContent = '';
        el.style.display = 'none';
      });
      document.querySelectorAll('#editSupplierForm .error-field').forEach(el => {
        el.classList.remove('error-field');
      });

      currentEditingSupplierId = supplierId;
      editSupplierModal.classList.remove('hidden');
    });
  });

  closeEditModalBtn?.addEventListener('click', function() {
    editSupplierModal.classList.add('hidden');
  });

  cancelEditBtn?.addEventListener('click', function() {
    editSupplierModal.classList.add('hidden');
  });

  editSupplierModal?.addEventListener('click', function(e) {
    if (e.target === editSupplierModal) {
      editSupplierModal.classList.add('hidden');
    }
  });

  // Edit form submission
  editSupplierForm?.addEventListener('submit', async function(e) {
    e.preventDefault();

    // Clear previous errors
    document.querySelectorAll('#editSupplierForm .error-field').forEach(el => {
      el.classList.remove('error-field');
    });
    document.querySelectorAll('[id^="edit"][id$="Error"]').forEach(el => {
      el.textContent = '';
      el.style.display = 'none';
    });

    const formData = new FormData();
    formData.append('supplier_id', currentEditingSupplierId);
    formData.append('type', document.getElementById('editType').value);
    formData.append('description', document.getElementById('editDescription').value);
    formData.append('adresse', document.getElementById('editAdresse').value);
    formData.append('tel', document.getElementById('editTel').value);
    formData.append('email', document.getElementById('editEmail').value);
    formData.append('statut', document.getElementById('editStatut').value);

    try {
      const response = await fetch('{{ path("elfirma_update_supplier") }}', {
        method: 'POST',
        body: formData
      });

      const data = await response.json();

      if (data.success) {
        alert('Supplier updated successfully!');
        editSupplierModal.classList.add('hidden');
        window.location.reload();
      } else {
        // Display errors from backend
        if (data.errors) {
          for (const [field, message] of Object.entries(data.errors)) {
            const fieldId = 'edit' + field.charAt(0).toUpperCase() + field.slice(1);
            const input = document.getElementById(fieldId);
            const errorEl = document.getElementById(fieldId + 'Error');
            if (input) input.classList.add('error-field');
            if (errorEl) {
              errorEl.textContent = message;
              errorEl.style.display = 'block';
            }
          }
        }
      }
    } catch (error) {
      console.error('Error:', error);
      alert('An error occurred while updating the supplier');
    }
  });

  // Delete Supplier Functionality
  const deleteConfirmModal = document.getElementById('deleteConfirmModal');
  const confirmDeleteBtn = document.getElementById('confirmDeleteBtn');
  const cancelDeleteBtn = document.getElementById('cancelDeleteBtn');
  const closeDeleteModalBtn = document.getElementById('closeDeleteModalBtn');

  let currentDeletingSupplierId = null;

  // Delete button listeners
  document.querySelectorAll('.delete-supplier-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      currentDeletingSupplierId = this.dataset.supplierId;
      deleteConfirmModal.classList.remove('hidden');
    });
  });

  closeDeleteModalBtn?.addEventListener('click', function() {
    deleteConfirmModal.classList.add('hidden');
  });

  cancelDeleteBtn?.addEventListener('click', function() {
    deleteConfirmModal.classList.add('hidden');
  });

  deleteConfirmModal?.addEventListener('click', function(e) {
    if (e.target === deleteConfirmModal) {
      deleteConfirmModal.classList.add('hidden');
    }
  });

  confirmDeleteBtn?.addEventListener('click', async function() {
    const formData = new FormData();
    formData.append('supplier_id', currentDeletingSupplierId);

    console.log('Deleting supplier ID:', currentDeletingSupplierId);

    try {
      const response = await fetch('{{ path("elfirma_delete_supplier") }}', {
        method: 'POST',
        body: formData
      });

      console.log('Delete response status:', response.status);
      const data = await response.json();
      console.log('Delete response data:', data);

      if (data.success) {
        alert('Supplier deleted successfully!');
        deleteConfirmModal.classList.add('hidden');
        window.location.reload();
      } else {
        alert('Error deleting supplier: ' + (data.message || 'Unknown error'));
      }
    } catch (error) {
      console.error('Error:', error);
      alert('An error occurred while deleting the supplier: ' + error.message);
    }
  });

  // Contract Form Functionality
  const contractModal = document.getElementById('contractModal');
  const addContractForm = document.getElementById('addContractForm');
  const closeContractModalBtn = document.getElementById('closeContractModalBtn');
  const cancelContractBtn = document.getElementById('cancelContractBtn');

  // Get contract form fields
  const dateDebutField = document.getElementById('dateDebut');
  const dateFinField = document.getElementById('dateFin');
  const contractTypeField = document.getElementById('contractType');
  const contractStatusField = document.getElementById('contractStatus');
  const pdfFileField = document.getElementById('pdfFile');

  // Supplier Row Click Handler - Display Contracts
  let currentSelectedSupplierId = null;
  document.querySelectorAll('tbody tr').forEach(row => {
    row.style.cursor = 'pointer';
    row.addEventListener('click', async function(e) {
      // Don't trigger if clicking edit/delete buttons
      if (e.target.closest('button')) return;

      const supplierId = this.querySelector('.edit-supplier-btn')?.dataset.supplierId;
      if (!supplierId) return;

      currentSelectedSupplierId = supplierId;

      // Highlight selected row
      document.querySelectorAll('tbody tr').forEach(r => {
        r.style.backgroundColor = '';
      });
      this.style.backgroundColor = 'rgba(67, 104, 43, 0.1)';

      // Fetch contracts
      try {
        const currentContractSort = document.getElementById('contractSortSelect')?.value || 'date-desc';
        const response = await fetch(`{{ path('elfirma_get_supplier_contracts') }}?supplier_id=${supplierId}&sort=${encodeURIComponent(currentContractSort)}`);
        const data = await response.json();

        if (data.success && data.contracts) {
          displayContracts(data.contracts, supplierId);
        } else {
          displayContracts([], supplierId);
        }
      } catch (error) {
        console.error('Error fetching contracts:', error);
        displayContracts([], supplierId);
      }

      // Also load ratings for this supplier
      loadSupplierRatings(supplierId);
    });
  });

  function displayContracts(contracts, supplierId) {
    const container = document.getElementById('contractsTableContainer');
    const addContractQuickBtn = document.getElementById('addContractQuickBtn');

    if (contracts.length === 0) {
      addContractQuickBtn.style.display = 'inline-flex';
      addContractQuickBtn.onclick = function() {
        document.getElementById('supplierId').value = supplierId;
        document.getElementById('contractModal').classList.remove('hidden');
      };

      container.innerHTML = `
        <div class="text-center py-12">
          <span class="material-symbols-outlined text-5xl text-outline mb-4 block">description</span>
          <p class="text-on-surface-variant font-semibold">No contracts found for this supplier</p>
        </div>
      `;
      return;
    }

    addContractQuickBtn.style.display = 'inline-flex';
    addContractQuickBtn.onclick = function() {
      document.getElementById('supplierId').value = supplierId;
      document.getElementById('contractModal').classList.remove('hidden');
    };

    let tableHTML = `
      <table class="w-full text-left border-separate border-spacing-y-3">
        <thead>
          <tr class="text-on-surface-variant text-xs uppercase tracking-widest font-bold">
            <th class="px-6 py-4">Type</th>
            <th class="px-6 py-4">Start Date</th>
            <th class="px-6 py-4">End Date</th>
            <th class="px-6 py-4">Status</th>
            <th class="px-6 py-4">PDF</th>
            <th class="px-6 py-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
    `;

    contracts.forEach(contract => {
      const statusClass = contract.statut === 'Active'
        ? 'bg-primary-fixed text-on-primary-fixed'
        : 'bg-surface-variant text-on-surface-variant';

      const statusIcon = contract.statut === 'Active'
        ? '<span class="w-2 h-2 rounded-full bg-on-primary-fixed animate-pulse"></span>'
        : '<span class="material-symbols-outlined text-[14px]">pause_circle</span>';

      const pdfLink = contract.pdf_file
        ? `<a href="/${contract.pdf_file}" target="_blank" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-primary text-on-primary hover:opacity-80 transition-all text-xs font-semibold">
            <span class="material-symbols-outlined text-sm">picture_as_pdf</span>
            Download
          </a>`
        : '<span class="text-on-surface-variant text-sm">—</span>';

      const typeText = contract.type === 'annual' ? 'Annual' : 'Monthly';

      tableHTML += `
        <tr class="bg-surface-container-lowest hover:bg-surface transition-colors contract-row" data-contract-status="${contract.statut}" data-supplier-name="${contract.supplier_name || ''}" data-contract-end-date="${contract.date_fin}" data-contract-start-date="${contract.date_debut}" data-contract-type="${contract.type}">
          <td class="px-6 py-5 rounded-l-2xl border-none">
            <span class="font-bold text-primary">${typeText}</span>
          </td>
          <td class="px-6 py-5 text-sm text-on-surface">
            ${new Date(contract.date_debut).toLocaleDateString()}
          </td>
          <td class="px-6 py-5 text-sm text-on-surface">
            ${new Date(contract.date_fin).toLocaleDateString()}
          </td>
          <td class="px-6 py-5">
            <span class="px-4 py-1.5 rounded-full text-xs font-bold flex items-center gap-2 w-fit ${statusClass}">
              ${statusIcon}
              ${contract.statut}
            </span>
          </td>
          <td class="px-6 py-5">
            ${pdfLink}
          </td>
          <td class="px-6 py-5 rounded-r-2xl text-right">
