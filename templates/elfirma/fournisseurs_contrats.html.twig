// ==================== MAIN SUPPLIERS MAP ====================

let mainMap = null;
let supplierMarkers = {};
const supplierRows = document.querySelectorAll('tr[data-supplier-id]');
const suppliersData = [];

// Collect supplier data from table
supplierRows.forEach(row => {
  suppliersData.push({
    id: row.getAttribute('data-supplier-id'),
    type: row.getAttribute('data-supplier-type'),
    address: row.getAttribute('data-supplier-address'),
    status: row.getAttribute('data-supplier-status'),
    email: row.getAttribute('data-supplier-email'),
    phone: row.getAttribute('data-supplier-phone')
  });
});

// Get marker color based on status
function getMarkerColor(status) {
  if (status === 'Active') return 'emerald';
  if (status === 'Suspended') return 'red';
  return 'gray';
}

// Initialize main map
function initializeMainMap() {
  if (mainMap) return;

  mainMap = L.map('suppliersMap').setView([35.8, 10.2], 6); // Tunisia center
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors',
    maxZoom: 19
  }).addTo(mainMap);

  // Geocode and pin all suppliers
  geocodeSuppliers();
}

// Geocode all suppliers and pin them on map
async function geocodeSuppliers() {
  console.log('Starting to geocode ' + suppliersData.length + ' suppliers...');
  const mapContainer = document.getElementById('mainMapSection');

  for (const supplier of suppliersData) {
    if (!supplier.address) continue;

    try {
      const response = await fetch('{{ path("api_geocode_address") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ address: supplier.address })
      });

      const data = await response.json();

      if (data.success && mainMap) {
        const markerColor = getMarkerColor(supplier.status);
        const markerColorMap = {
          'emerald': '#10b981',
          'red': '#ef4444',
          'gray': '#6b7280'
        };

        // Create custom marker
        const markerHtml = `
          <div style="
            background-color: ${markerColorMap[markerColor]};
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            box-shadow: 0 2px 8px rgba(0,0,0,0.3);
            border: 3px solid white;
          ">
            <span class="material-symbols-outlined" style="font-size: 18px;">location_on</span>
          </div>
        `;

        const customIcon = L.divIcon({
          html: markerHtml,
          iconSize: [32, 32],
          className: 'custom-marker'
        });

        const marker = L.marker([data.latitude, data.longitude], { icon: customIcon });

        // Popup content
        const popupContent = `
          <div style="min-width: 250px;">
            <h4 style="margin: 0 0 8px 0; font-weight: bold; color: #0a2200; font-size: 14px;">
              ${supplier.type}
            </h4>
            <div style="font-size: 12px; color: #43493d; line-height: 1.6;">
              <p style="margin: 4px 0;"><strong>Status:</strong>
                <span style="
                  display: inline-block;
                  padding: 2px 8px;
                  border-radius: 4px;
                  background-color: ${supplier.status === 'Active' ? '#d1fae5' : (supplier.status === 'Suspended' ? '#fee2e2' : '#f3f4f6')};
                  color: ${supplier.status === 'Active' ? '#065f46' : (supplier.status === 'Suspended' ? '#7f1d1d' : '#374151')};
                  font-weight: 600;
                ">
                  ${supplier.status}
                </span>
              </p>
              <p style="margin: 4px 0;"><strong>Address:</strong> ${data.display_name}</p>
              ${supplier.email ? '<p style="margin: 4px 0;"><strong>Email:</strong> ' + supplier.email + '</p>' : ''}
              ${supplier.phone ? '<p style="margin: 4px 0;"><strong>Phone:</strong> ' + supplier.phone + '</p>' : ''}
            </div>
          </div>
        `;

        marker.bindPopup(popupContent);
        marker.addTo(mainMap);
        supplierMarkers[supplier.id] = marker;

        console.log('Pinned supplier: ' + supplier.type + ' at ' + data.latitude + ', ' + data.longitude);
      }
    } catch (error) {
      console.error('Error geocoding supplier:', supplier.type, error);
    }

    // Small delay to avoid overwhelming the API
    await new Promise(resolve => setTimeout(resolve, 300));
  }

  console.log('Geocoding complete. ' + Object.keys(supplierMarkers).length + ' suppliers pinned.');

  // Fit map to all markers
  if (Object.keys(supplierMarkers).length > 0) {
    const group = new L.featureGroup(Object.values(supplierMarkers));
    mainMap.fitBounds(group.getBounds(), { padding: [50, 50] });
  }
}

// Toggle map view
document.getElementById('toggleMapView').addEventListener('click', function() {
  const mapSection = document.getElementById('mainMapSection');
  const mapLegend = document.getElementById('mapLegend');
  const toggleText = document.getElementById('toggleMapText');

  if (mapSection.classList.contains('hidden')) {
    mapSection.classList.remove('hidden');
    mapLegend.classList.remove('hidden');
    toggleText.textContent = 'Hide Map';
    this.style.backgroundColor = '#173901';

    setTimeout(() => {
      if (mainMap) {
        mainMap.invalidateSize();
      }
    }, 100);
  } else {
    mapSection.classList.add('hidden');
    mapLegend.classList.add('hidden');
    toggleText.textContent = 'Show Map';
    this.style.backgroundColor = '#0a2200';
  }
});

// Initialize main map on page load
document.addEventListener('DOMContentLoaded', function() {
  setTimeout(() => {
    if (!mainMap && document.getElementById('suppliersMap')) {
      initializeMainMap();
    }
  }, 500);
});

