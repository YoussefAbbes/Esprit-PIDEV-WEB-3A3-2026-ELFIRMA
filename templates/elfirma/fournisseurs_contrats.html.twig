    document.getElementById('contractInactiveCount').textContent = contractInactiveCount;
    document.getElementById('contractExpiringCount').textContent = contractExpiringCount;
    document.getElementById('contractExpiredCount').textContent = contractExpiredCount;

    // Create Chart.js Doughnut Chart
    const ctx = document.getElementById('supplierStatusChart');
    if (ctx) {
      const chartData = {
        labels: ['Active', 'Inactive', 'Suspended'],
        datasets: [{
          data: [activeCount, inactiveCount, suspendedCount],
