<input id="tableSearchInput" class="w-full bg-surface-container-low border-2 border-surface-variant rounded-xl py-3 pl-12 pr-4 text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="Search suppliers by type, description, email, phone..."/>
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
</div>

<div class="overflow-x-auto">
<table class="w-full text-left border-separate border-spacing-y-3" id="suppliersTable">
<thead>
<tr class="text-on-surface-variant text-xs uppercase tracking-widest font-bold">
<th class="px-6 py-4">Type</th>
<th class="px-6 py-4">Description</th>
<th class="px-6 py-4">Address</th>
<th class="px-6 py-4">Email</th>
<th class="px-6 py-4">Telephone</th>
<th class="px-6 py-4">Status</th>
<th class="px-6 py-4 text-right">Actions</th>
</tr>
</thead>
<tbody id="supplierTableBody">
{% if suppliers is defined and suppliers|length > 0 %}
  {% for supplier in suppliers %}
    <tr class="supplier-row bg-surface-container-lowest hover:bg-surface transition-colors"
        data-supplier-id="{{ supplier.getIdF() }}"
        data-supplier-type="{{ supplier.getTypeF()|lower }}"
        data-supplier-description="{{ supplier.getDescriptionF()|lower }}"
        data-supplier-address="{{ supplier.getAdresseF()|lower }}"
        data-supplier-email="{{ supplier.getEmailF()|lower }}"
        data-supplier-phone="{{ supplier.getTelF()|lower }}"
        data-supplier-status="{{ supplier.getStatutF() }}">
      <td class="px-6 py-5 rounded-l-2xl border-none">
        <span class="font-bold text-primary">{{ supplier.getTypeF() }}</span>
      </td>
      <td class="px-6 py-5 text-sm text-on-surface">
        {{ supplier.getDescriptionF() ?? 'N/A' }}
      </td>
      <td class="px-6 py-5 text-sm text-on-surface">
        {{ supplier.getAdresseF() ?? 'N/A' }}
      </td>
      <td class="px-6 py-5 text-sm text-on-surface">
        {{ supplier.getEmailF() ?? 'N/A' }}
      </td>
      <td class="px-6 py-5 text-sm text-on-surface">
        {{ supplier.getTelF() ?? 'N/A' }}
      </td>
      <td class="px-6 py-5">
        <span class="px-4 py-1.5 rounded-full text-xs font-bold flex items-center gap-2 w-fit {% if supplier.getStatutF() == 'Active' %}bg-primary-fixed text-on-primary-fixed{% elseif supplier.getStatutF() == 'Inactive' %}bg-surface-variant text-on-surface-variant{% else %}bg-error text-on-error{% endif %}">
          {% if supplier.getStatutF() == 'Active' %}
            <span class="w-2 h-2 rounded-full bg-on-primary-fixed animate-pulse"></span>
          {% elseif supplier.getStatutF() == 'Suspended' %}
            <span class="material-symbols-outlined text-[14px]">block</span>
          {% else %}
            <span class="material-symbols-outlined text-[14px]">pause_circle</span>
          {% endif %}
          {{ supplier.getStatutF() }}
        </span>
      </td>
      <td class="px-6 py-5 rounded-r-2xl text-right">
        <div class="flex items-center justify-end gap-2">
          <button class="edit-supplier-btn p-2 hover:bg-surface-variant rounded-full transition-colors text-primary" data-supplier-id="{{ supplier.getIdF() }}" type="button">
            <span class="material-symbols-outlined">edit</span>
          </button>
          <button class="delete-supplier-btn p-2 hover:bg-error/10 rounded-full transition-colors text-error" data-supplier-id="{{ supplier.getIdF() }}" type="button">
            <span class="material-symbols-outlined">delete</span>
          </button>
        </div>
      </td>
    </tr>
  {% endfor %}
{% else %}
  <tr>
    <td colspan="7" class="px-6 py-12 text-center">
      <div class="flex flex-col items-center justify-center">
        <span class="material-symbols-outlined text-4xl text-outline mb-4">inventory_2</span>
        <p class="text-on-surface-variant font-semibold">No suppliers found</p>
      </div>
    </td>
  </tr>
{% endif %}
</tbody>
</table>
</div>
</section>

<!-- Contracts Table Section -->
