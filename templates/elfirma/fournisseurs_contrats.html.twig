<!-- Add Contract Modal -->
<div id="contractModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-[#fbfbe2] dark:bg-[#173901] rounded-2xl shadow-2xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
    <!-- Modal Header -->
    <div class="sticky top-0 flex justify-between items-center p-8 border-b border-outline-variant/20 bg-[#fbfbe2] dark:bg-[#173901]">
      <div>
        <h2 class="text-3xl font-black text-primary">Add New Contract</h2>
        <p class="text-sm text-on-surface-variant mt-1">Fill in the details to create a new supplier contract</p>
      </div>
      <button id="closeContractModalBtn" class="p-2 rounded-full hover:bg-surface-container-highest transition-colors">
        <span class="material-symbols-outlined text-2xl text-on-surface">close</span>
      </button>
    </div>

    <!-- Modal Body -->
    <form id="addContractForm" class="p-8 space-y-6">
      <input type="hidden" id="supplierId" name="id_f">

      <!-- Start Date -->
      <div>
        <label for="dateDebut" class="block font-semibold text-primary mb-2">Start Date</label>
        <input type="date" id="dateDebut" name="date_debut" class="w-full px-4 py-3 bg-surface-container-low border-2 border-outline-variant/30 rounded-xl focus:border-primary focus:outline-none transition-colors">
        <p class="text-xs text-on-surface-variant mt-1">Select the contract start date</p>
        <div class="error-message-supplier" id="dateDebutError"></div>
      </div>

      <!-- End Date -->
      <div>
        <label for="dateFin" class="block font-semibold text-primary mb-2">End Date</label>
        <input type="date" id="dateFin" name="date_fin" class="w-full px-4 py-3 bg-surface-container-low border-2 border-outline-variant/30 rounded-xl focus:border-primary focus:outline-none transition-colors">
        <p class="text-xs text-on-surface-variant mt-1">End date must be after start date</p>
        <div class="error-message-supplier" id="dateFinError"></div>
      </div>

      <!-- Contract Type -->
      <div>
        <label for="contractType" class="block font-semibold text-primary mb-2">Contract Type</label>
        <div class="relative">
