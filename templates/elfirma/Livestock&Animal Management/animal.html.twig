</div>

<script>
(function () {
    const normalize = function (value) {
        return String(value || '').trim().toLowerCase();
    };

    const table = document.getElementById('animal-table');
    const tableBody = document.getElementById('animal-table-body');
    const searchInput = document.getElementById('animal-search-input');
    const searchError = document.getElementById('animal-search-error');
    const typeFilter = document.getElementById('animal-type-filter');
    const statusFilter = document.getElementById('animal-status-filter');
    const noResultsRow = document.getElementById('animal-no-results');
    const statsUpdated = document.getElementById('animal-stats-updated');
    const totalStat = document.getElementById('animal-total-stat');
    const healthyStat = document.getElementById('animal-healthy-stat');
    const sickTreatmentStat = document.getElementById('animal-sick-treatment-stat');
    const forSaleStat = document.getElementById('animal-for-sale-stat');
    const statsTabButtons = Array.from(document.querySelectorAll('.js-animal-stats-tab'));
    const chartTitle = document.getElementById('animal-chart-title');
    const quickTitle = document.getElementById('animal-quick-title');
    const quickList = document.getElementById('animal-quick-list');
    const statsCanvas = document.getElementById('animal-stats-chart');

    if (searchInput && searchError) {
        const urlParams = new URLSearchParams(window.location.search);
        const initialSearchTerm = (urlParams.get('search') || '').trim();

        searchInput.addEventListener('input', function () {
            searchError.classList.add('hidden');

            if (searchInput.value.trim() !== '' || initialSearchTerm === '') {
                return;
            }

            // If search was active and user clears it, restore initial table.
            urlParams.delete('search');
            if (!urlParams.has('view')) {
                urlParams.set('view', 'animal');
            }

            const queryString = urlParams.toString();
            const targetUrl = queryString !== ''
                ? (window.location.pathname + '?' + queryString)
                : (window.location.pathname + '?view=animal');

            if (window.location.href !== targetUrl) {
                window.location.href = targetUrl;
            }
        });
    }

    if (table && tableBody && searchInput && typeFilter && statusFilter) {
        const rows = Array.from(tableBody.querySelectorAll('tr[data-row="animal"]'));
        const sortButtons = Array.from(table.querySelectorAll('.js-animal-sort'));
        const chartPalette = ['#16a34a', '#f59e0b', '#ef4444', '#3b82f6', '#8b5cf6', '#14b8a6'];
        let activeTab = 'status';
        let statsChart = null;
        let sortState = { key: null, direction: 'asc', type: 'text' };

        const normalizeHealthLabel = function (value) {
            const normalized = normalize(value);

            if (['healthy', 'health', 'sain', 'bonne sante'].includes(normalized)) {
                return 'Healthy';
            }
            if (['under treatment', 'en traitement', 'treatment'].includes(normalized)) {
                return 'Under Treatment';
            }
            if (['sick', 'malade'].includes(normalized)) {
                return 'Sick';
            }

            return value ? String(value).trim() : 'Unknown';
        };

        const normalizeStatusLabel = function (value) {
            const normalized = normalize(value);

            if (normalized === 'retained') {
                return 'Retained';
            }
            if (normalized === 'for sale') {
                return 'For Sale';
            }
            if (normalized === 'pending decision') {
                return 'Pending Decision';
            }

            return value ? String(value).trim() : 'Unknown';
        };

        const fillFilterOptions = function (selectElement, key) {
            const uniqueValues = Array.from(new Set(rows
                .map(function (row) { return row.dataset[key] || ''; })
                .filter(function (value) { return normalize(value) !== ''; })))
                .sort(function (a, b) { return a.localeCompare(b, undefined, { sensitivity: 'base' }); });

            uniqueValues.forEach(function (value) {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = value;
                selectElement.appendChild(option);
            });
        };

        const compareRows = function (rowA, rowB, key, type, direction) {
            const factor = direction === 'asc' ? 1 : -1;
            const valueA = rowA.dataset[key] || '';
            const valueB = rowB.dataset[key] || '';

            if (type === 'number') {
                return (Number(valueA) - Number(valueB)) * factor;
            }

            return valueA.localeCompare(valueB, undefined, { sensitivity: 'base' }) * factor;
        };

        const renderSortIndicators = function () {
            sortButtons.forEach(function (button) {
                const key = button.dataset.sortKey || '';
                const indicator = table.querySelector('[data-sort-indicator="' + key + '"]');
                button.classList.remove('is-active');

                if (indicator) {
                    indicator.innerHTML = '&uarr;&darr;';
                }

                if (sortState.key === key) {
                    button.classList.add('is-active');
                    if (indicator) {
                        indicator.innerHTML = sortState.direction === 'asc' ? '&uarr;' : '&darr;';
                    }
                }
            });
        };

        const applyFilters = function () {
            const selectedType = normalize(typeFilter.value);
            const selectedStatus = normalize(statusFilter.value);
            let visibleCount = 0;

            rows.forEach(function (row) {
                const matchesType = selectedType === '' || normalize(row.dataset.type) === selectedType;
                const matchesStatus = selectedStatus === '' || normalize(row.dataset.status) === selectedStatus;
                const isVisible = matchesType && matchesStatus;

                row.classList.toggle('hidden', !isVisible);
                if (isVisible) {
                    visibleCount += 1;
                }
            });

            if (noResultsRow) {
                noResultsRow.classList.toggle('hidden', visibleCount > 0 || rows.length === 0);
            }
        };

        const sortRows = function () {
            if (!sortState.key) {
                return;
            }

            const sortedRows = rows.slice().sort(function (rowA, rowB) {
                return compareRows(rowA, rowB, sortState.key, sortState.type, sortState.direction);
            });

            sortedRows.forEach(function (row) {
                tableBody.appendChild(row);
            });

            if (noResultsRow) {
                tableBody.appendChild(noResultsRow);
            }
        };

        const buildStatsModel = function (visibleRows) {
            const model = {
                total: visibleRows.length,
                health: { Healthy: 0, 'Under Treatment': 0, Sick: 0 },
                status: { Retained: 0, 'For Sale': 0, 'Pending Decision': 0 },
                typeHealth: {},
            };

            visibleRows.forEach(function (row) {
                const type = (row.dataset.type || 'Unknown').trim() || 'Unknown';
                const health = normalizeHealthLabel(row.dataset.health || '');
                const status = normalizeStatusLabel(row.dataset.status || '');

                if (model.health[health] === undefined) {
                    model.health[health] = 0;
                }
                model.health[health] += 1;

                if (model.status[status] === undefined) {
                    model.status[status] = 0;
                }
                model.status[status] += 1;

                if (!model.typeHealth[type]) {
                    model.typeHealth[type] = { Healthy: 0, 'Under Treatment': 0, Sick: 0 };
                }
                if (model.typeHealth[type][health] === undefined) {
                    model.typeHealth[type][health] = 0;
                }
                model.typeHealth[type][health] += 1;
            });

            return model;
        };

        const renderQuickList = function (items, total) {
            if (!quickList) {
                return;
            }

            quickList.innerHTML = '';

            if (items.length === 0) {
                const emptyState = document.createElement('p');
                emptyState.className = 'text-sm text-slate-500';
                emptyState.textContent = 'No statistics available for current filters.';
                quickList.appendChild(emptyState);
                return;
            }

            items.forEach(function (item, index) {
                const percentage = total > 0 ? (item.value / total) * 100 : 0;

                const block = document.createElement('div');
                block.className = 'rounded-xl border border-slate-100 bg-slate-50 px-3 py-2';

                const row = document.createElement('div');
                row.className = 'flex items-center justify-between gap-2';

                const left = document.createElement('span');
                left.className = 'text-sm font-bold text-slate-800';
                left.textContent = item.label;

                const right = document.createElement('span');
                right.className = 'text-sm font-black';
                right.style.color = item.color;
                right.textContent = item.value + ' (' + percentage.toFixed(0) + '%)';

                row.appendChild(left);
                row.appendChild(right);

                const track = document.createElement('div');
                track.className = 'mt-2 h-1.5 rounded-full bg-slate-200';

                const fill = document.createElement('div');
                fill.className = 'h-1.5 rounded-full';
                fill.style.width = Math.max(0, Math.min(percentage, 100)).toFixed(1) + '%';
                fill.style.backgroundColor = item.color || chartPalette[index % chartPalette.length];

                track.appendChild(fill);
                block.appendChild(row);
                block.appendChild(track);
                quickList.appendChild(block);
            });
        };

        const renderTabVisualState = function () {
            statsTabButtons.forEach(function (button) {
                const isActive = button.dataset.tab === activeTab;

                button.classList.toggle('bg-white', isActive);
                button.classList.toggle('text-emerald-700', isActive);
                button.classList.toggle('border-emerald-500', isActive);
                button.classList.toggle('shadow-sm', isActive);

                button.classList.toggle('bg-slate-100', !isActive);
                button.classList.toggle('text-slate-600', !isActive);
                button.classList.toggle('border-transparent', !isActive);
            });
        };

        const renderChart = function (model) {
            if (!statsCanvas || typeof Chart === 'undefined') {
                return;
            }

            if (statsChart) {
                statsChart.destroy();
            }

            const total = model.total;

            if (activeTab === 'health') {
                if (chartTitle) {
                    chartTitle.textContent = 'Health status by category';
                }
                if (quickTitle) {
                    quickTitle.textContent = 'Health quick view';
                }

                const typeLabels = Object.keys(model.typeHealth);
                const healthyData = typeLabels.map(function (label) { return model.typeHealth[label].Healthy || 0; });
                const treatmentData = typeLabels.map(function (label) { return model.typeHealth[label]['Under Treatment'] || 0; });
                const sickData = typeLabels.map(function (label) { return model.typeHealth[label].Sick || 0; });

                statsChart = new Chart(statsCanvas, {
                    type: 'bar',
                    data: {
                        labels: typeLabels,
                        datasets: [
                            { label: 'Healthy', data: healthyData, backgroundColor: '#16a34a', borderRadius: 6 },
                            { label: 'Under Treatment', data: treatmentData, backgroundColor: '#f59e0b', borderRadius: 6 },
                            { label: 'Sick', data: sickData, backgroundColor: '#ef4444', borderRadius: 6 },
                        ],
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: 'top' },
                        },
                        scales: {
                            y: { beginAtZero: true, ticks: { precision: 0 } },
                        },
                    },
                });

                renderQuickList([
                    { label: 'Healthy', value: model.health.Healthy || 0, color: '#16a34a' },
                    { label: 'Under Treatment', value: model.health['Under Treatment'] || 0, color: '#f59e0b' },
                    { label: 'Sick', value: model.health.Sick || 0, color: '#ef4444' },
                ], total);

                return;
            }

            if (activeTab === 'decision') {
                if (chartTitle) {
                    chartTitle.textContent = 'Animals by decision status';
                }
                if (quickTitle) {
                    quickTitle.textContent = 'Status quick view';
                }

                const labels = ['Retained', 'For Sale', 'Pending Decision'];
                const values = labels.map(function (label) { return model.status[label] || 0; });
                const colors = ['#16a34a', '#f59e0b', '#ef4444'];

                statsChart = new Chart(statsCanvas, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Animals',
                            data: values,
                            backgroundColor: colors,
                            borderRadius: 8,
                            borderSkipped: false,
                        }],
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: 'bottom' },
                        },
                        scales: {
                            y: { beginAtZero: true, ticks: { precision: 0 } },
                        },
                    },
                });

                renderQuickList([
                    { label: 'Retained', value: model.status.Retained || 0, color: '#16a34a' },
                    { label: 'For Sale', value: model.status['For Sale'] || 0, color: '#f59e0b' },
                    { label: 'Pending Decision', value: model.status['Pending Decision'] || 0, color: '#ef4444' },
                ], total);

                return;
            }

            if (chartTitle) {
                chartTitle.textContent = 'Distribution by decision status';
            }
            if (quickTitle) {
                quickTitle.textContent = 'Detail by status';
            }

            const statusLabels = ['Retained', 'For Sale', 'Pending Decision'];
            const statusValues = statusLabels.map(function (label) { return model.status[label] || 0; });
            const statusColors = ['#16a34a', '#f59e0b', '#ef4444'];

            statsChart = new Chart(statsCanvas, {
                type: 'doughnut',
                data: {
                    labels: statusLabels,
                    datasets: [{
                        data: statusValues,
                        backgroundColor: statusColors,
                        borderColor: '#ffffff',
                        borderWidth: 2,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' },
                    },
                },
            });

            renderQuickList([
                { label: 'Retained', value: model.status.Retained || 0, color: '#16a34a' },
                { label: 'For Sale', value: model.status['For Sale'] || 0, color: '#f59e0b' },
                { label: 'Pending Decision', value: model.status['Pending Decision'] || 0, color: '#ef4444' },
            ], total);
        };

        const refreshStatistics = function () {
            // Keep statistics independent from table filters.
            const model = buildStatsModel(rows);

            if (totalStat) {
                totalStat.textContent = String(model.total);
            }
            if (healthyStat) {
                healthyStat.textContent = String(model.health.Healthy || 0);
            }
            if (sickTreatmentStat) {
                const combinedAttention = (model.health.Sick || 0) + (model.health['Under Treatment'] || 0);
                sickTreatmentStat.textContent = String(combinedAttention);
            }
            if (forSaleStat) {
                forSaleStat.textContent = String(model.status['For Sale'] || 0);
            }
            if (statsUpdated) {
                const now = new Date();
                const hh = String(now.getHours()).padStart(2, '0');
                const mm = String(now.getMinutes()).padStart(2, '0');
                statsUpdated.textContent = 'Updated: ' + hh + ':' + mm;
            }

            renderChart(model);
        };

        fillFilterOptions(typeFilter, 'type');
        fillFilterOptions(statusFilter, 'status');

        typeFilter.addEventListener('change', applyFilters);
        statusFilter.addEventListener('change', applyFilters);

        sortButtons.forEach(function (button) {
            button.addEventListener('click', function () {
                const key = button.dataset.sortKey || '';
                const type = button.dataset.sortType || 'text';

                if (sortState.key === key) {
                    sortState.direction = sortState.direction === 'asc' ? 'desc' : 'asc';
                } else {
                    sortState.key = key;
                    sortState.direction = 'asc';
                }

                sortState.type = type;
                sortRows();
                renderSortIndicators();
                applyFilters();
            });
        });

        statsTabButtons.forEach(function (button) {
            button.addEventListener('click', function () {
                activeTab = button.dataset.tab || 'status';
                renderTabVisualState();
                refreshStatistics();
            });
        });

        applyFilters();
        renderTabVisualState();
        refreshStatistics();
    }

    const dnaForm = document.querySelector('form[data-dna-detect-url]');
    const dnaButton = document.getElementById('dna-detect-btn');
    const dnaResultBox = document.getElementById('dna-detect-result');
    const dnaResultBadge = document.getElementById('dna-detect-result-badge');
    const dnaResultGender = document.getElementById('dna-detect-result-gender');
    const dnaResultSequence = document.getElementById('dna-detect-result-sequence');
    const dnaEditButton = document.getElementById('dna-edit-btn');
    const dnaInputPanel = document.getElementById('dna-input-panel');
    const animalGenderSelect = document.getElementById('animal-gender-select');
    const animalTypeInput = document.getElementById('animal-type-input');
    const bioPanels = Array.from(document.querySelectorAll('.bio-panel'));
    const bioControls = Array.from(document.querySelectorAll('.js-bio-input'));

    if (dnaForm && dnaButton && dnaResultBox && dnaResultBadge && dnaResultGender && dnaResultSequence && dnaEditButton && dnaInputPanel && animalGenderSelect && animalTypeInput && bioPanels.length > 0 && bioControls.length > 0) {
        const detectUrl = dnaForm.dataset.dnaDetectUrl || '';

        const normalizeType = function (value) {
            const normalized = normalize(value);

            if (['poultry', 'poule', 'poulet', 'chicken', 'hen', 'rooster'].includes(normalized)) {
                return 'poultry';
            }
            if (['bovin', 'cow', 'cattle', 'bull', 'vache'].includes(normalized)) {
                return 'bovin';
            }
            if (['sheep', 'mouton', 'ram', 'ewe', 'brebis'].includes(normalized)) {
                return 'sheep';
            }
            if (['pig', 'cochon', 'porc', 'swine', 'boar', 'sow'].includes(normalized)) {
                return 'pig';
            }

            return normalized !== '' ? 'other' : '';
        };

        const getActiveType = function () {
            return normalizeType(animalTypeInput.value);
        };

        const setPanelVisibility = function () {
            const activeType = getActiveType();
            const isUndetermined = normalize(animalGenderSelect.value) === 'undetermined';

            bioPanels.forEach(function (panel) {
                panel.classList.add('hidden');
            });

            if (!isUndetermined || !activeType) {
                dnaInputPanel.classList.add('hidden');
                return;
            }

            dnaInputPanel.classList.remove('hidden');
            const panel = document.getElementById('bio-panel-' + activeType);
            if (panel) {
                panel.classList.remove('hidden');
            }
        };

        const collectBioChoices = function () {
            const activePanel = document.getElementById('bio-panel-' + getActiveType());
            const choiceMap = {};
            if (activePanel) {
                activePanel.querySelectorAll('select.js-bio-input').forEach(function (select) {
                    choiceMap[select.id] = select.value;
                });
            }

            choiceMap.bioBody = document.getElementById('bio-body-select') ? document.getElementById('bio-body-select').value : '';
            choiceMap.bioNeck = document.getElementById('bio-neck-select') ? document.getElementById('bio-neck-select').value : '';
            choiceMap.bioSecondary = document.getElementById('bio-secondary-select') ? document.getElementById('bio-secondary-select').value : '';
            choiceMap.bioGenital = document.getElementById('bio-genital-select') ? document.getElementById('bio-genital-select').value : '';
            choiceMap.bioBehavior = document.getElementById('bio-behavior-select') ? document.getElementById('bio-behavior-select').value : '';

            return choiceMap;
        };

        const renderDetection = function (payload) {
            if (!payload || payload.success !== true) {
                dnaResultBox.classList.remove('hidden');
                dnaResultBadge.textContent = 'Undetermined';
                dnaResultBadge.className = 'inline-flex items-center rounded-full px-3 py-1 text-xs font-black uppercase tracking-wide bg-slate-100 text-slate-700';
                dnaResultGender.textContent = 'Undetermined';
                dnaResultSequence.textContent = '';
                animalGenderSelect.value = 'Undetermined';
                setPanelVisibility();
                return;
            }

            dnaResultBox.classList.remove('hidden');
            const sexLabel = payload.sex || 'Undetermined';
            const detectedLabel = payload.detected_gender || 'Undetermined';
            const sequence = String(payload.dna_sequence || '');

            dnaResultBadge.textContent = sexLabel;
            dnaResultBadge.className = 'inline-flex items-center rounded-full px-3 py-1 text-xs font-black uppercase tracking-wide ' + (sexLabel === 'Male' ? 'bg-blue-100 text-blue-700' : (sexLabel === 'Female' ? 'bg-pink-100 text-pink-700' : 'bg-slate-100 text-slate-700'));
            dnaResultGender.textContent = detectedLabel;
            dnaResultSequence.textContent = sequence;

            animalGenderSelect.value = sexLabel === 'Male' ? 'Male' : (sexLabel === 'Female' ? 'Female' : 'Undetermined');
            setPanelVisibility();
        };

        const runDetection = async function () {
            const bioChoices = collectBioChoices();
            const type = normalizeType(animalTypeInput.value);
            const currentGender = normalize(animalGenderSelect.value);

            if (!type) {
                dnaResultBox.classList.remove('hidden');
                return;
            }

            if (currentGender !== '' && currentGender !== 'undetermined') {
                dnaResultBox.classList.remove('hidden');
                return;
            }

            dnaButton.disabled = true;
            dnaResultBox.classList.remove('hidden');

            try {
                const query = new URLSearchParams({
                    type: type,
                    body: bioChoices.bioBody,
                    neck: bioChoices.bioNeck,
                    secondary: bioChoices.bioSecondary,
                    genital: bioChoices.bioGenital,
                    behavior: bioChoices.bioBehavior,
                    panel_data: JSON.stringify(bioChoices),
                });

                const response = await fetch(detectUrl + '?' + query.toString(), {
                    headers: { 'Accept': 'application/json' },
                    credentials: 'same-origin',
                });
                const payload = await response.json();
                renderDetection(payload);
            } catch (error) {
                dnaResultBox.classList.remove('hidden');
            } finally {
                dnaButton.disabled = false;
            }
        };

        dnaButton.addEventListener('click', runDetection);
        animalTypeInput.addEventListener('input', setPanelVisibility);
        animalGenderSelect.addEventListener('change', setPanelVisibility);
        dnaEditButton.addEventListener('click', function () {
            animalGenderSelect.value = 'Undetermined';
            setPanelVisibility();
            dnaInputPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        setPanelVisibility();

    }

    const modal = document.getElementById('delete-confirm-modal');
    const title = document.getElementById('delete-modal-title');
    const text = document.getElementById('delete-modal-text');
    const confirmBtn = document.getElementById('delete-modal-confirm');
    const cancelBtn = document.getElementById('delete-modal-cancel');
    const deleteForms = document.querySelectorAll('.js-delete-form');

    if (!modal || !title || !text || !confirmBtn || !cancelBtn || !deleteForms.length) {
        return;
    }

    let pendingForm = null;

    const closeModal = function () {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        pendingForm = null;
    };

    deleteForms.forEach(function (form) {
        form.addEventListener('submit', function (event) {
            event.preventDefault();
            pendingForm = form;

            const label = form.dataset.deleteLabel || 'Animal';
            title.textContent = 'Delete: ' + label;
            text.textContent = 'Are you sure you want to delete this animal? This action cannot be undone.';

            modal.classList.remove('hidden');
            modal.classList.add('flex');
        });
    });

    confirmBtn.addEventListener('click', function () {
        if (pendingForm) {
            pendingForm.submit();
        }
    });

    cancelBtn.addEventListener('click', closeModal);

    modal.addEventListener('click', function (event) {
        if (event.target === modal) {
            closeModal();
        }
    });

    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape' && !modal.classList.contains('hidden')) {
            closeModal();
        }
    });
})();
</script>

