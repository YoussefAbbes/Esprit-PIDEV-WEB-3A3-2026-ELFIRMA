<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Animal Management</title>
    <link rel="stylesheet" href="{{ asset('styles/elfirma-theme.css') }}">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=DM+Sans:wght@300;400;500;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --animal-forest: #0d3320;
            --animal-moss: #1a5c37;
            --animal-fern: #2d8653;
            --animal-sage: #86c49a;
            --animal-mist: #eaf4ed;
            --animal-cream: #faf8f3;
            --animal-ink: #111a14;
            --animal-smoke: #6b7c71;
            --animal-shadow-sm: 0 6px 18px rgba(13, 51, 32, 0.08);
            --animal-shadow-md: 0 18px 40px rgba(13, 51, 32, 0.12);
            --animal-shadow-lg: 0 28px 72px rgba(13, 51, 32, 0.18);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background:
                radial-gradient(circle at top left, rgba(45, 134, 83, 0.08) 0%, transparent 32%),
                linear-gradient(180deg, #f7fbf8 0%, #eef5ef 100%);
            color: var(--animal-ink);
        }

        .animal-catalog-hero {
            position: relative;
            overflow: hidden;
            border-radius: 28px;
            border: 1px solid rgba(45, 134, 83, 0.14);
            background:
                radial-gradient(circle at top right, rgba(45, 134, 83, 0.08), transparent 36%),
                radial-gradient(circle at bottom left, rgba(200, 168, 75, 0.08), transparent 38%),
                linear-gradient(135deg, #ffffff 0%, #f7fbf8 100%);
            box-shadow: var(--animal-shadow-lg);
        }

        .animal-catalog-hero::before {
            content: "";
            position: absolute;
            inset: auto -80px -80px auto;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(45, 134, 83, 0.14) 0%, rgba(45, 134, 83, 0) 68%);
            pointer-events: none;
        }

        .animal-hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border-radius: 999px;
            padding: 7px 16px;
            background: linear-gradient(135deg, var(--animal-forest) 0%, var(--animal-moss) 100%);
            color: #f1f8f3;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            box-shadow: var(--animal-shadow-sm);
        }

        .animal-hero-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2.4rem, 4.6vw, 4.3rem);
            line-height: 1.02;
            letter-spacing: -0.03em;
            color: var(--animal-forest);
            margin: 0;
        }

        .animal-hero-title em {
            color: var(--animal-fern);
            font-style: italic;
        }

        .animal-hero-copy {
            color: var(--animal-smoke);
            line-height: 1.75;
            font-size: 15px;
            max-width: 44rem;
        }

        .animal-pill-row {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .animal-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border-radius: 999px;
            border: 1px solid rgba(45, 134, 83, 0.18);
            background: #ffffff;
            padding: 8px 14px;
            font-size: 13px;
            font-weight: 700;
            color: var(--animal-moss);
            box-shadow: var(--animal-shadow-sm);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .animal-pill:hover {
            transform: translateY(-2px);
            box-shadow: var(--animal-shadow-md);
        }

        .animal-hero-image {
            position: relative;
            border-radius: 24px;
            overflow: hidden;
            min-height: 360px;
            border: 1px solid rgba(45, 134, 83, 0.16);
            box-shadow: var(--animal-shadow-lg);
        }

        .animal-hero-image img {
            width: 100%;
            height: 100%;
            min-height: 360px;
            object-fit: cover;
            object-position: center center;
            display: block;
            transition: transform 6s ease;
        }

        .animal-catalog-hero:hover .animal-hero-image img {
            transform: scale(1.04);
        }

        .animal-hero-chip {
            position: absolute;
            left: 18px;
            bottom: 18px;
            background: rgba(13, 51, 32, 0.86);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 16px;
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            backdrop-filter: blur(8px);
            box-shadow: var(--animal-shadow-md);
        }

        .animal-hero-chip .chip-emoji {
            font-size: 1.6rem;
            line-height: 1;
        }

        .animal-hero-kpis {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 12px;
        }

        .animal-mini-kpi {
            border-radius: 18px;
            border: 1px solid rgba(45, 134, 83, 0.14);
            background: linear-gradient(160deg, #ffffff 0%, #f2faf4 100%);
            padding: 16px 14px;
            box-shadow: var(--animal-shadow-sm);
        }

        .animal-mini-kpi span {
            display: block;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 800;
            color: var(--animal-smoke);
        }

        .animal-mini-kpi strong {
            display: block;
            margin-top: 6px;
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.5rem;
            line-height: 1;
            color: var(--animal-forest);
        }

        .animal-ticker {
            background: var(--animal-forest);
            color: #f3f8f4;
            overflow: hidden;
            white-space: nowrap;
            padding: 10px 0;
        }

        .animal-ticker-track {
            display: inline-block;
            animation: animal-ticker-move 26s linear infinite;
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .animal-ticker-track span { margin: 0 2rem; }
        .animal-ticker-track .dot { color: var(--animal-sage); opacity: 0.85; }

        @keyframes animal-ticker-move {
            from { transform: translateX(0); }
            to { transform: translateX(-50%); }
        }

        .animal-ribbon {
            background: linear-gradient(135deg, var(--animal-forest) 0%, var(--animal-moss) 100%);
            padding: 26px 0;
        }

        .animal-ribbon-inner {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
            justify-content: center;
        }

        .animal-ribbon-card {
            min-width: 112px;
            border-radius: 18px;
            border: 1px solid rgba(255,255,255,0.16);
            background: rgba(255,255,255,0.08);
            color: #fff;
            text-align: center;
            padding: 16px 18px;
            box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03);
            transition: transform 0.2s ease, background 0.2s ease;
        }

        .animal-ribbon-card:hover {
            transform: translateY(-4px);
            background: rgba(255,255,255,0.14);
        }

        .animal-ribbon-emoji {
            display: block;
            font-size: 2rem;
            margin-bottom: 6px;
            line-height: 1;
        }

        .animal-ribbon-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 800;
            color: #cfe8d4;
        }

        .animal-catalog-workbench {
            padding: 66px 0 80px;
            background: linear-gradient(180deg, #f6faf7 0%, #eef5ef 100%);
        }

        .animal-workbench-title {
            font-family: 'Cormorant Garamond', serif;
            color: var(--animal-forest);
            font-size: clamp(2rem, 3vw, 3rem);
            font-weight: 700;
            text-align: center;
            margin-bottom: 8px;
        }

        .animal-workbench-sub {
            text-align: center;
            color: var(--animal-smoke);
            margin-bottom: 34px;
        }

        .animal-sidebar,
        .animal-detail-panel {
            border-radius: 24px;
            border: 1px solid rgba(45, 134, 83, 0.14);
            background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(245,250,246,0.98) 100%);
            box-shadow: var(--animal-shadow-md);
        }

        .animal-sidebar {
            padding: 24px;
            position: sticky;
            top: 22px;
        }

        .animal-detail-panel {
            padding: 30px;
            position: relative;
            overflow: hidden;
        }

        .animal-detail-panel::before {
            content: "";
            position: absolute;
            top: -42px;
            right: -42px;
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(45, 134, 83, 0.08) 0%, rgba(45, 134, 83, 0) 70%);
            pointer-events: none;
        }

        .animal-list-item {
            border-radius: 14px;
            border: 1px solid rgba(45, 134, 83, 0.12);
            background: #fff;
            box-shadow: var(--animal-shadow-sm);
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

        .animal-list-item:hover {
            transform: translateX(3px);
            border-color: rgba(45, 134, 83, 0.3);
            box-shadow: var(--animal-shadow-md);
        }

        .animal-stats-band {
            border-radius: 26px;
            background: linear-gradient(135deg, var(--animal-forest) 0%, var(--animal-moss) 100%);
            box-shadow: var(--animal-shadow-lg);
        }

        .elf-sidebar-toggle,
        .elf-sidebar-overlay {
            display: none !important;
        }

        .delete-modal-card {
            border: 2px solid #ef4444;
            background: #fce7e7;
        }

        .delete-icon-btn {
            width: 2.5rem;
            height: 2.5rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #ef4444;
            border-radius: 0.75rem;
            background: #fff;
            color: #ef4444;
            transition: background-color 0.2s ease, box-shadow 0.2s ease;
        }

        .delete-icon-btn:hover {
            background: #fef2f2;
            box-shadow: 0 8px 18px -12px rgba(220, 38, 38, 0.65);
        }

        .table-sort-btn {
            width: 100%;
            display: inline-flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.4rem;
            font-weight: 800;
            color: #f7fff9;
            text-align: left;
        }

        .table-sort-btn .sort-indicator {
            font-size: 0.85rem;
            opacity: 0.85;
            line-height: 1;
        }

        .table-sort-btn.is-active .sort-indicator {
            opacity: 1;
        }

        .management-form-modal {
            transform-origin: center top;
        }

        @media (max-height: 880px) {
            .management-form-modal {
                transform: scale(0.94);
            }
        }

        @media (max-height: 780px) {
            .management-form-modal {
                transform: scale(0.88);
            }
        }

        @media (max-width: 991px) {
            .animal-hero-kpis {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .animal-sidebar {
                position: static;
            }
        }

        @media (max-width: 575px) {
            .animal-hero-kpis {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen overflow-x-hidden">
<aside class="hidden md:flex flex-col h-screen w-72 fixed left-0 top-0 bg-white border-r border-slate-200 py-8 pr-4 z-40">
    <div class="px-8 mb-8">
        <h1 class="text-3xl font-black text-slate-900 tracking-tight">Elfirma</h1>
        <p class="text-slate-500 text-sm">Gestion Agricole</p>
    </div>
    <nav class="flex-1 space-y-1">
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Tableau de Bord</a>
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Utilisateurs</a>
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Parcelles & Cultures</a>
        <a class="flex items-center px-8 py-3 rounded-r-full bg-slate-900 text-white" href="#">Animaux & Elevages</a>
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Produits & Commandes</a>
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Equipements & Maintenance</a>
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Fournisseurs & Contrats</a>
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Reclamations</a>
    </nav>
</aside>

<main class="md:ml-72 min-h-screen p-3 md:p-4">
    <div class="max-w-7xl mx-auto">
        <section class="animal-catalog-hero mb-4 p-4 md:p-6">
            <div class="grid gap-6 lg:grid-cols-2 lg:items-center">
                <div class="space-y-5">
                    <div class="animal-hero-badge">Premium Animal Intelligence</div>
                    <div>
                        <h2 class="animal-hero-title">Curated animal<br><em>intelligence</em> for clients</h2>
                        <p class="animal-hero-copy mt-4">
                            This catalog transforms animal records into a polished narrative: gender, health, age, status, and seasonal strategy in one coherent experience.
                        </p>
                    </div>
                    <div class="animal-pill-row">
                        <span class="animal-pill">🔍 Smart filtering</span>
                        <span class="animal-pill">📊 Live health</span>
                        <span class="animal-pill">🌦️ Seasonal view</span>
                        <span class="animal-pill">🧬 DNA clues</span>
                    </div>
                    <div class="animal-hero-kpis">
                        <article class="animal-mini-kpi">
                            <span>Total animals</span>
                            <strong>{{ animals|length }}</strong>
                        </article>
                        <article class="animal-mini-kpi">
                            <span>Healthy</span>
                            <strong>{{ animal_stats.healthy_animals|default(0) }}</strong>
                        </article>
                        <article class="animal-mini-kpi">
                            <span>For sale</span>
                            <strong id="animal-for-sale-stat-hero">{{ animal_stats.for_sale_animals|default(0) }}</strong>
                        </article>
                    </div>
                </div>

                <div class="animal-hero-image">
                    <img src="{{ asset('assets/img/farm-animals-real.jpg') }}" alt="Livestock overview">
                    <div class="animal-hero-chip">
                        <span class="chip-emoji">🌿</span>
                        <div>
                            <div style="font-size:12px;opacity:.72;font-weight:600;">EL FIRMA Certified</div>
                            <div style="font-size:14px;font-weight:800;">Premium Farm Network</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="animal-ticker mb-4 rounded-full">
            <div class="animal-ticker-track">
                <span>Animal records</span><span class="dot">✦</span>
                <span>Health insights</span><span class="dot">✦</span>
                <span>Gender detection</span><span class="dot">✦</span>
                <span>Production stats</span><span class="dot">✦</span>
                <span>EL FIRMA</span><span class="dot">✦</span>
                <span>Animal records</span><span class="dot">✦</span>
                <span>Health insights</span><span class="dot">✦</span>
                <span>Gender detection</span><span class="dot">✦</span>
                <span>Production stats</span><span class="dot">✦</span>
                <span>EL FIRMA</span><span class="dot">✦</span>
            </div>
        </div>

        <div class="animal-ribbon mb-4 rounded-3xl">
            <div class="animal-ribbon-inner">
                <div class="animal-ribbon-card"><span class="animal-ribbon-emoji">🐄</span><div class="animal-ribbon-label">Bovin</div></div>
                <div class="animal-ribbon-card"><span class="animal-ribbon-emoji">🐑</span><div class="animal-ribbon-label">Sheep</div></div>
                <div class="animal-ribbon-card"><span class="animal-ribbon-emoji">🐔</span><div class="animal-ribbon-label">Poultry</div></div>
                <div class="animal-ribbon-card"><span class="animal-ribbon-emoji">🐐</span><div class="animal-ribbon-label">Goat</div></div>
                <div class="animal-ribbon-card"><span class="animal-ribbon-emoji">🐖</span><div class="animal-ribbon-label">Pig</div></div>
                <div class="animal-ribbon-card"><span class="animal-ribbon-emoji">🦆</span><div class="animal-ribbon-label">Duck</div></div>
            </div>
        </div>

        <section class="animal-stats-band rounded-3xl p-4 md:p-5 text-white">
            <div class="mb-3 px-1 flex items-center justify-between gap-2">
                <div>
                    <h2 class="text-2xl md:text-3xl font-black tracking-tight text-white">Animal Management</h2>
                    <p class="text-emerald-100/90 text-sm md:text-base">Welcome to Animal Management</p>
                </div>
                <span class="text-sm text-emerald-100/90">{{ animals|length }} animal(s)</span>
            </div>

            <section class="mb-4 rounded-3xl bg-white/10 border border-white/15 backdrop-blur-sm p-4 md:p-5 shadow-lg">
                <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
                    <div>
                        <h3 class="text-2xl md:text-3xl font-black tracking-tight">Animal Statistics</h3>
                        <p class="text-emerald-100/90 text-sm md:text-base mt-1">Dashboard - Statuses - Animal Health</p>
                    </div>
                    <p id="animal-stats-updated" class="text-emerald-100/90 text-sm italic">Updated: --:--</p>
                </div>

                <div class="mt-5 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-3">
                    <article class="rounded-2xl border border-emerald-300/35 bg-white/15 p-4 backdrop-blur-sm shadow-sm">
                        <p class="text-emerald-100 text-sm font-semibold">Total Animals</p>
                        <p id="animal-total-stat" class="mt-2 text-3xl md:text-4xl font-black leading-none">{{ animal_stats.total_animals|default(0) }}</p>
                        <p class="mt-2 text-xs text-emerald-100/90">registered animals</p>
                    </article>
                    <article class="rounded-2xl border border-emerald-300/35 bg-white/15 p-4 backdrop-blur-sm shadow-sm">
                        <p class="text-emerald-100 text-sm font-semibold">Healthy</p>
                        <p id="animal-healthy-stat" class="mt-2 text-3xl md:text-4xl font-black leading-none text-amber-300">{{ animal_stats.healthy_animals|default(0) }}</p>
                        <p class="mt-2 text-xs text-emerald-100/90">animals in good health</p>
                    </article>
                    <article class="rounded-2xl border border-emerald-300/35 bg-white/15 p-4 backdrop-blur-sm shadow-sm">
                        <p class="text-emerald-100 text-sm font-semibold">Sick / Treatment</p>
                        <p id="animal-sick-treatment-stat" class="mt-2 text-3xl md:text-4xl font-black leading-none">0</p>
