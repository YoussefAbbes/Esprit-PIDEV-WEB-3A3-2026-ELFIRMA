<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farm Assistant</title>
    <link rel="stylesheet" href="{{ asset('styles/elfirma-theme.css') }}">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .elf-sidebar-toggle,
        .elf-sidebar-overlay {
            display: none !important;
        }

        .chat-scroll {
            scrollbar-width: thin;
            scrollbar-color: #cbd5e1 #f8fafc;
        }

        .chat-scroll::-webkit-scrollbar {
            width: 10px;
        }

        .chat-scroll::-webkit-scrollbar-track {
            background: #f8fafc;
        }

        .chat-scroll::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 999px;
        }

        .thinking-dot {
            width: 0.45rem;
            height: 0.45rem;
            border-radius: 999px;
            background: #2f855a;
            animation: thinking-bounce 0.9s infinite ease-in-out;
        }

        .thinking-dot:nth-child(2) {
            animation-delay: 0.15s;
        }

        .thinking-dot:nth-child(3) {
            animation-delay: 0.3s;
        }

        @keyframes thinking-bounce {
            0%, 80%, 100% {
                transform: scale(0.65);
                opacity: 0.6;
            }
            40% {
                transform: scale(1);
                opacity: 1;
            }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen overflow-x-hidden">
<aside class="hidden md:flex flex-col h-screen w-72 fixed left-0 top-0 bg-white border-r border-slate-200 py-8 pr-4 z-40">
    <div class="px-8 mb-8">
        <h1 class="text-3xl font-black text-slate-900 tracking-tight">Elfirma</h1>
        <p class="text-slate-500 text-sm">Farm Management</p>
    </div>
    <nav class="flex-1 space-y-1">
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Dashboard</a>
    </nav>
</aside>

<main class="md:ml-72 min-h-screen p-3 md:p-4">
    <div class="max-w-7xl mx-auto">
        <section class="rounded-2xl border border-emerald-200 bg-[#edf3ee] p-3 md:p-4 shadow-sm">
            <header class="mb-3 px-1">
                <h2 class="text-2xl md:text-3xl font-black tracking-tight text-emerald-800">Farm Assistant</h2>
                <p class="text-slate-600 text-sm md:text-base mt-1">Ask questions about livestock, vaccination, and farm data</p>
            </header>

            <section class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
                <div id="chat-feed" class="chat-scroll h-[58vh] min-h-[420px] overflow-y-auto p-4 md:p-5 space-y-3 bg-slate-50/70">
                    <div id="chat-empty-state" class="rounded-2xl border border-emerald-200 bg-emerald-50 p-5 text-emerald-900">
                        <div class="flex items-start gap-3">
                            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white border border-emerald-200 text-emerald-700" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path d="M8 10h8"/><path d="M8 14h5"/><path d="M5 5h14v11H8l-3 3V5z"/></svg>
                            </span>
                            <div>
                                <p class="font-extrabold text-lg leading-tight">Welcome to Farm Assistant</p>
                                <p class="mt-1 text-sm text-emerald-800">Start with a question like: "Which vaccinations are due this week?"</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="border-t border-slate-200 bg-white p-3 md:p-4">
                    <form id="chat-form" class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-3 items-center">
                        <label for="chat-query" class="sr-only">Your message</label>
                        <input
                            id="chat-query"
                            type="text"
                            maxlength="2000"
                            placeholder="Ask about livestock, vaccinations, or records..."
                            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-300"
                            autocomplete="off"
                            required
                        >
                        <button
                            id="chat-send"
                            type="submit"
                            class="inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-700 hover:bg-emerald-800 text-white px-5 py-3 font-bold disabled:cursor-not-allowed disabled:opacity-60"
                        >
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4" aria-hidden="true"><path d="M22 2 11 13"/><path d="m22 2-7 20-4-9-9-4 20-7z"/></svg>
                            <span>Send</span>
                        </button>
                    </form>
                    <p class="mt-2 text-xs text-slate-500">Press Enter to send</p>
                </div>
            </section>
        </section>
    </div>
</main>

<script>
(function () {
    const endpoint = "{{ path('api_chat') }}";

    const form = document.getElementById("chat-form");
    const input = document.getElementById("chat-query");
    const sendButton = document.getElementById("chat-send");
    const feed = document.getElementById("chat-feed");
    const emptyState = document.getElementById("chat-empty-state");

    if (!form || !input || !sendButton || !feed) {
        return;
    }

    let isLoading = false;

    const removeEmptyState = () => {
        if (emptyState && emptyState.parentNode) {
            emptyState.parentNode.removeChild(emptyState);
        }
    };

    const scrollToLatest = () => {
        feed.scrollTop = feed.scrollHeight;
    };

    const setLoading = (loading) => {
        isLoading = loading;
        input.disabled = loading;
        sendButton.disabled = loading;
        sendButton.querySelector("span").textContent = loading ? "Sending..." : "Send";
    };

    const createMessageCard = (role) => {
        const wrapper = document.createElement("div");
        wrapper.className = role === "user" ? "flex justify-end" : "flex justify-start";

        const card = document.createElement("article");
        card.className = role === "user"
            ? "max-w-[88%] rounded-2xl border border-emerald-300 bg-emerald-50 px-4 py-3 shadow-sm"
            : "max-w-[92%] rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm";

        wrapper.appendChild(card);
        return { wrapper, card };
    };

    const createHeading = (label, role) => {
        const heading = document.createElement("p");
        heading.className = role === "user"
            ? "text-xs font-extrabold uppercase tracking-wide text-emerald-700"
            : "text-xs font-extrabold uppercase tracking-wide text-slate-500";
        heading.textContent = label;
        return heading;
    };

    const appendUserMessage = (text) => {
        removeEmptyState();
        const { wrapper, card } = createMessageCard("user");

        card.appendChild(createHeading("You", "user"));

        const content = document.createElement("p");
        content.className = "mt-1 text-sm md:text-base text-slate-800 whitespace-pre-line";
        content.textContent = text;
        card.appendChild(content);

        feed.appendChild(wrapper);
        scrollToLatest();
    };

    const buildSourceLabel = (source, index) => {
        const sourceFile = String(source && source.source_file ? source.source_file : "Source " + (index + 1));
        const fileName = sourceFile.split(/[\\/]/).pop() || sourceFile;
        const section = String(source && source.section ? source.section : "Reference");
        const confidence = String(source && source.confidence ? source.confidence : "n/a");
        const scoreValue = source && (typeof source.score === "number" || typeof source.score === "string")
            ? Number(source.score)
            : null;
        const score = scoreValue !== null && Number.isFinite(scoreValue) ? scoreValue.toFixed(2) : null;

        const chunks = [fileName, section, "Confidence: " + confidence];
        if (score !== null) {
            chunks.push("Score: " + score);
        }

        return chunks.join(" - ");
    };

    const appendSummaryChips = (container, payload) => {
        const chips = [];

        const topConfidence = payload && payload.confidence_summary && payload.confidence_summary.top_confidence
            ? String(payload.confidence_summary.top_confidence)
            : "";
        const chunkCount = payload && payload.evidence_summary && Number.isFinite(Number(payload.evidence_summary.chunk_count))
            ? Number(payload.evidence_summary.chunk_count)
            : null;
        const sourceCount = payload && payload.evidence_summary && Number.isFinite(Number(payload.evidence_summary.source_count))
            ? Number(payload.evidence_summary.source_count)
            : null;

        if (topConfidence !== "") {
            chips.push("Top confidence: " + topConfidence);
        }
        if (chunkCount !== null) {
            chips.push("Evidence chunks: " + chunkCount);
        }
        if (sourceCount !== null) {
            chips.push("Sources used: " + sourceCount);
        }

        if (chips.length === 0) {
            return;
        }

        const section = document.createElement("div");
        section.className = "mt-3 border-t border-slate-200 pt-3";

        const title = document.createElement("p");
        title.className = "text-xs font-bold uppercase tracking-wide text-slate-500";
        title.textContent = "Response quality";
        section.appendChild(title);

        const row = document.createElement("div");
        row.className = "mt-2 flex flex-wrap gap-2";

        chips.forEach((label) => {
            const chip = document.createElement("span");
            chip.className = "inline-flex items-center rounded-full border border-slate-300 bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700";
            chip.textContent = label;
            row.appendChild(chip);
        });

        section.appendChild(row);
        container.appendChild(section);
    };

    const appendSources = (container, sources) => {
        if (!Array.isArray(sources) || sources.length === 0) {
            return;
        }

        const section = document.createElement("div");
        section.className = "mt-3 border-t border-slate-200 pt-3";

        const title = document.createElement("p");
        title.className = "text-xs font-bold uppercase tracking-wide text-slate-500";
        title.textContent = "Sources";
        section.appendChild(title);

        const list = document.createElement("div");
        list.className = "mt-2 space-y-2";

        sources.slice(0, 4).forEach((source, index) => {
            const item = document.createElement("div");
            item.className = "rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-700";
            item.textContent = buildSourceLabel(source, index);
            list.appendChild(item);
        });

        section.appendChild(list);
        container.appendChild(section);
    };

    const appendAssistantMessage = (payload) => {
        removeEmptyState();
        const { wrapper, card } = createMessageCard("assistant");

        card.appendChild(createHeading("Farm Assistant", "assistant"));

        const content = document.createElement("p");
        content.className = "mt-1 text-sm md:text-base text-slate-800 whitespace-pre-line";
        content.textContent = String(payload && payload.answer_text ? payload.answer_text : "No answer was returned.");
        card.appendChild(content);

        appendSources(card, payload && payload.sources ? payload.sources : []);
        appendSummaryChips(card, payload || {});

        feed.appendChild(wrapper);
        scrollToLatest();
    };

    const appendErrorMessage = (message) => {
        removeEmptyState();
        const { wrapper, card } = createMessageCard("assistant");

        card.className = "max-w-[92%] rounded-2xl border border-red-300 bg-red-50 px-4 py-3 shadow-sm";
        card.appendChild(createHeading("Farm Assistant", "assistant"));

        const content = document.createElement("p");
        content.className = "mt-1 text-sm md:text-base text-red-700";
        content.textContent = message;
        card.appendChild(content);

        feed.appendChild(wrapper);
        scrollToLatest();
    };

    const appendThinkingCard = () => {
        removeEmptyState();
        const { wrapper, card } = createMessageCard("assistant");

        card.appendChild(createHeading("Farm Assistant", "assistant"));

        const row = document.createElement("div");
        row.className = "mt-2 inline-flex items-center gap-2 text-sm font-semibold text-emerald-700";

        const dots = document.createElement("span");
        dots.className = "inline-flex items-center gap-1";
        dots.innerHTML = '<span class="thinking-dot"></span><span class="thinking-dot"></span><span class="thinking-dot"></span>';

        const label = document.createElement("span");
        label.textContent = "Thinking...";

        row.appendChild(dots);
        row.appendChild(label);
        card.appendChild(row);

        feed.appendChild(wrapper);
        scrollToLatest();

        return wrapper;
    };

    const sendQuery = async (query) => {
        const response = await fetch(endpoint, {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({ query })
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok) {
            const message = data && typeof data.message === "string" && data.message.trim() !== ""
                ? data.message
                : "The assistant is temporarily unavailable. Please try again.";
            throw new Error(message);
        }

        return data;
    };

    form.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (isLoading) {
            return;
        }

        const query = String(input.value || "").trim();
        if (query === "") {
            return;
        }

        appendUserMessage(query);
        input.value = "";

        const thinkingNode = appendThinkingCard();
        setLoading(true);

        try {
            const payload = await sendQuery(query);
            if (thinkingNode.parentNode) {
                thinkingNode.parentNode.removeChild(thinkingNode);
            }
            appendAssistantMessage(payload);
        } catch (error) {
            if (thinkingNode.parentNode) {
                thinkingNode.parentNode.removeChild(thinkingNode);
            }

            const message = error instanceof Error && error.message
                ? error.message
                : "An unexpected error occurred while contacting Farm Assistant.";
            appendErrorMessage(message);
        } finally {
            setLoading(false);
            input.focus();
        }
    });
})();
</script>

{{ include('elfirma/_nav_routes.html.twig') }}
</body>
</html>
