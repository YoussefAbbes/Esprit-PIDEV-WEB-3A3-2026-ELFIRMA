<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Livestock Management</title>
    <link rel="stylesheet" href="{{ asset('styles/elfirma-theme.css') }}">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .elf-sidebar-toggle,
        .elf-sidebar-overlay {
            display: none !important;
        }

        .delete-modal-card {
            border: 2px solid #ef4444;
            background: #fce7e7;
        }

        .delete-icon-btn {
            width: 2.5rem;
            height: 2.5rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #ef4444;
            border-radius: 0.75rem;
            background: #fff;
            color: #ef4444;
            transition: background-color 0.2s ease, box-shadow 0.2s ease;
        }

        .delete-icon-btn:hover {
            background: #fef2f2;
            box-shadow: 0 8px 18px -12px rgba(220, 38, 38, 0.65);
        }

        .table-sort-btn {
            width: 100%;
            display: inline-flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.4rem;
            font-weight: 800;
            color: #f7fff9;
            text-align: left;
        }

        .table-sort-btn .sort-indicator {
            font-size: 0.85rem;
            opacity: 0.85;
            line-height: 1;
        }

        .table-sort-btn.is-active .sort-indicator {
            opacity: 1;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 h-screen overflow-hidden">
<aside class="hidden md:flex flex-col h-screen w-72 fixed left-0 top-0 bg-white border-r border-slate-200 py-8 pr-4 z-40">
    <div class="px-8 mb-8">
        <h1 class="text-3xl font-black text-slate-900 tracking-tight">Elfirma</h1>
        <p class="text-slate-500 text-sm">Gestion Agricole</p>
    </div>
    <nav class="flex-1 space-y-1">
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Tableau de Bord</a>
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Utilisateurs</a>
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Parcelles & Cultures</a>
        <a class="flex items-center px-8 py-3 rounded-r-full bg-slate-900 text-white" href="#">Animaux & Elevages</a>
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Produits & Commandes</a>
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Equipements & Maintenance</a>
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Fournisseurs & Contrats</a>
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Reclamations</a>
    </nav>
</aside>

<main class="md:ml-72 h-screen overflow-hidden p-3 md:p-4">
    <div class="h-full max-w-7xl mx-auto">
        <section class="h-full rounded-2xl border border-emerald-200 bg-[#edf3ee] p-3 md:p-4 shadow-sm flex flex-col overflow-hidden">
            <div class="mb-3 px-1 flex items-center justify-between gap-2">
                <div>
                    <h2 class="text-2xl md:text-3xl font-black tracking-tight text-emerald-800">Livestock Management</h2>
                    <p class="text-slate-600 text-sm md:text-base">Welcome to Livestock Management</p>
                </div>
                <span class="text-sm text-slate-600">{{ elevages|length }} livestock(s)</span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                <article class="rounded-xl border-2 border-emerald-500 bg-emerald-100/45 p-4">
                    <p class="text-emerald-800 font-bold text-lg leading-none">Total Livestock</p>
                    <p class="mt-2 text-emerald-600 font-black text-4xl leading-none">{{ livestock_stats.total_livestock|default(0) }}</p>
                </article>
                <article class="rounded-xl border-2 border-emerald-500 bg-emerald-100/45 p-4">
                    <p class="text-emerald-800 font-bold text-lg leading-none">Clean Livestock</p>
                    <p class="mt-2 text-emerald-600 font-black text-4xl leading-none">{{ livestock_stats.clean_livestock|default(0) }}</p>
                </article>
            </div>

            <div class="mb-3 flex items-center justify-end gap-2">
                <a href="{{ path('elfirma_page', { module: 'animaux-elevages' }) }}?view=livestock&add=1" class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-700 hover:bg-emerald-800 text-white" title="Add Livestock" aria-label="Add Livestock">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-6 h-6" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                    <span class="sr-only">Add Livestock</span>
                </a>
            </div>

            <div class="mb-3 grid grid-cols-1 md:grid-cols-3 gap-3">
                <form id="livestock-search-form" method="get" action="{{ path('elfirma_page', { module: 'animaux-elevages' }) }}" class="md:col-span-1">
                    <input type="hidden" name="view" value="livestock">
                    <input id="livestock-search-input" name="search" value="{{ search_term|default('') }}" type="text" autocomplete="off" placeholder="Search livestock..." class="w-full rounded-full border border-slate-300 bg-white px-5 py-3 text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-300">
                </form>
                <select id="livestock-type-filter" class="rounded-xl border border-slate-300 bg-white px-5 py-3 text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-300">
                    <option value="">All Type</option>
                </select>
                <select id="livestock-state-filter" class="rounded-xl border border-slate-300 bg-white px-5 py-3 text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-300">
                    <option value="">All State</option>
                </select>
            </div>
            <p id="livestock-search-error" class="mb-3 text-sm text-red-600 font-semibold {{ search_error is defined and search_error ? '' : 'hidden' }}">{{ search_error|default('Search can contain letters and spaces only') }}</p>

            <section class="rounded-xl border border-slate-300 bg-white shadow-sm overflow-hidden flex-1 min-h-0">
                <div class="overflow-auto">
                    <table id="livestock-table" class="w-full text-sm min-w-[720px] border-separate border-spacing-0">
                        <thead>
                        <tr class="bg-emerald-500">
                            <th class="py-3 px-3 border-r border-emerald-400/80 last:border-r-0"><button type="button" class="table-sort-btn js-livestock-sort" data-sort-key="type" data-sort-type="text">Type <span class="sort-indicator" data-sort-indicator="type">&uarr;&darr;</span></button></th>
                            <th class="py-3 px-3 border-r border-emerald-400/80 last:border-r-0"><button type="button" class="table-sort-btn js-livestock-sort" data-sort-key="state" data-sort-type="text">State <span class="sort-indicator" data-sort-indicator="state">&uarr;&darr;</span></button></th>
                            <th class="py-3 px-3 border-r border-emerald-400/80 last:border-r-0"><button type="button" class="table-sort-btn js-livestock-sort" data-sort-key="capacity" data-sort-type="number">Capacity <span class="sort-indicator" data-sort-indicator="capacity">&uarr;&darr;</span></button></th>
                            <th class="py-3 px-3 border-r border-emerald-400/80 last:border-r-0"><button type="button" class="table-sort-btn js-livestock-sort" data-sort-key="count" data-sort-type="number">Animal Count <span class="sort-indicator" data-sort-indicator="count">&uarr;&darr;</span></button></th>
                            <th class="py-3 px-3 border-r border-emerald-400/80 last:border-r-0"><button type="button" class="table-sort-btn js-livestock-sort" data-sort-key="production" data-sort-type="text">Production <span class="sort-indicator" data-sort-indicator="production">&uarr;&darr;</span></button></th>
                            <th class="py-3 px-3 font-extrabold text-center border-r border-emerald-400/80 last:border-r-0" style="color:#f7fff9;">Actions</th>
                        </tr>
                        </thead>
                        <tbody id="livestock-table-body">
                        {% for item in elevages %}
                            {% set state = item.etat_elevage|default('')|lower %}
                            <tr class="hover:bg-emerald-50/35 transition-colors" data-row="livestock" data-type="{{ item.type_elevage|default('')|e('html_attr') }}" data-state="{{ item.etat_elevage|default('')|e('html_attr') }}" data-capacity="{{ item.capacite|default(0) }}" data-count="{{ item.nombre_animaux|default(0) }}" data-production="{{ item.production|default('')|e('html_attr') }}">
                                <td class="py-3 px-3 font-semibold text-slate-800 border-b border-r border-emerald-100">{{ item.type_elevage }}</td>
                                <td class="py-3 px-3 font-semibold border-b border-r border-emerald-100 {{ state in ['clean', 'cleaning', 'propre'] ? 'text-emerald-600' : (state in ['dirty', 'sale'] ? 'text-red-500' : (state in ['under cleaning'] ? 'text-amber-600' : 'text-slate-700')) }}">{{ item.etat_elevage }}</td>
                                <td class="py-3 px-3 font-semibold text-slate-700 border-b border-r border-emerald-100">{{ item.capacite }}</td>
                                <td class="py-3 px-3 font-semibold text-slate-700 border-b border-r border-emerald-100">{{ item.nombre_animaux }}</td>
                                <td class="py-3 px-3 font-semibold text-slate-700 border-b border-r border-emerald-100">{{ item.production }}</td>
                                <td class="py-3 px-3 border-b border-emerald-100">
                                    <div class="flex items-center justify-center gap-3">
                                        <a href="{{ path('elfirma_page', { module: 'animaux-elevages' }) }}?view=livestock&edit={{ item.id_elevage }}" class="inline-flex h-10 w-10 items-center justify-center rounded-xl border-2 border-emerald-500 text-emerald-600 hover:bg-emerald-50" title="Edit">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 1 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
                                        </a>

                                        <form method="post" action="{{ path('livestock_delete') }}" class="js-delete-form" data-delete-kind="livestock" data-delete-label="{{ item.type_elevage|default('Livestock')|e('html_attr') }}">
                                            <input type="hidden" name="id_elevage" value="{{ item.id_elevage }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('livestock_delete') }}">
                                            <button type="submit" class="delete-icon-btn" title="Delete">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="6" class="py-6 px-3 text-slate-500 text-center border-b border-emerald-100">No livestock found.</td></tr>
                        {% endfor %}
                            <tr id="livestock-no-results" class="hidden"><td colspan="6" class="py-6 px-3 text-slate-500 text-center border-b border-emerald-100">No matching livestock found.</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            {% if show_add_form or edit_livestock %}
                {% set is_edit_mode = edit_livestock is not null %}
                {% set flash_form_errors = app.flashes('form_errors') %}
                {% set form_errors = flash_form_errors is not empty ? flash_form_errors|last : {} %}
                {% set flash_form_input = app.flashes('form_input') %}
                {% set form_input = flash_form_input is not empty ? flash_form_input|last : {} %}

                {% set current_type_elevage = form_input.type_elevage is defined ? form_input.type_elevage : (is_edit_mode ? edit_livestock.type_elevage : '') %}
                {% set current_etat_elevage = form_input.etat_elevage is defined ? form_input.etat_elevage : (is_edit_mode ? edit_livestock.etat_elevage : 'Clean') %}
                {% set current_capacite = form_input.capacite is defined ? form_input.capacite : (is_edit_mode ? edit_livestock.capacite : '') %}
                {% set current_production = form_input.production is defined ? form_input.production : (is_edit_mode ? edit_livestock.production : '') %}

                {% set default_states = ['Cleaning', 'Dirty', 'Under Cleaning'] %}
                {% set state_options = default_states %}
                {% for dynamic_state in livestock_states %}
                    {% set normalized_dynamic_state = dynamic_state|trim|lower %}
                    {% if normalized_dynamic_state != 'under treatment' and normalized_dynamic_state != 'en traitement' and dynamic_state not in state_options %}
                        {% set state_options = state_options|merge([dynamic_state]) %}
                    {% endif %}
                {% endfor %}

                <div class="fixed inset-0 z-[120] bg-slate-900/35 backdrop-blur-[1px] flex items-center justify-center p-3">
                    <div class="w-full max-w-xl max-h-[90vh] overflow-auto rounded-2xl border-2 border-emerald-600 bg-[#cfe3cf] shadow-2xl">
                        <div class="p-4 md:p-5">
                            <div class="flex items-center justify-end">
                                <a href="{{ path('elfirma_page', { module: 'animaux-elevages' }) }}?view=livestock" class="text-slate-800 hover:text-slate-900 text-3xl leading-none" aria-label="Close">&times;</a>
                            </div>

                            <h3 class="text-center text-2xl md:text-3xl font-black tracking-wide text-emerald-800">{{ is_edit_mode ? 'EDIT LIVESTOCK' : 'CREATE NEW LIVESTOCK' }}</h3>
                            <div class="h-px bg-emerald-300 mt-4 mb-5"></div>

                            {% if form_errors._form is defined %}
                                <p class="mb-3 text-sm text-red-600 font-semibold">{{ form_errors._form }}</p>
                            {% endif %}

                            <form method="post" action="{{ path(is_edit_mode ? 'livestock_update' : 'livestock_create') }}" class="space-y-3">
                                <input type="hidden" name="_token" value="{{ csrf_token(is_edit_mode ? 'livestock_update' : 'livestock_create') }}">
                                {% if is_edit_mode %}
                                    <input type="hidden" name="id_elevage" value="{{ edit_livestock.id_elevage }}">
                                {% endif %}

                                <div class="grid grid-cols-1 md:grid-cols-5 items-center gap-3">
                                    <label class="md:col-span-1 text-emerald-800 text-lg md:text-xl font-bold">Type:</label>
                                    <input name="type_elevage" value="{{ current_type_elevage }}" placeholder="Ex: Cattle, Sheep..." class="md:col-span-4 rounded-xl border-2 border-emerald-600 bg-white px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-emerald-500">
                                    {% if form_errors.type_elevage is defined %}
                                        <p class="md:col-span-4 md:col-start-2 text-sm text-red-600">{{ form_errors.type_elevage }}</p>
                                    {% endif %}
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-5 items-center gap-3">
                                    <label class="md:col-span-1 text-emerald-800 text-lg md:text-xl font-bold">State:</label>
                                    <select name="etat_elevage" class="md:col-span-4 rounded-xl border-2 border-emerald-400 bg-white px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-emerald-500">
                                        {% for state_option in state_options %}
                                            <option value="{{ state_option }}" {{ current_etat_elevage == state_option ? 'selected' : '' }}>{{ state_option }}</option>
                                        {% endfor %}
                                    </select>
                                    {% if form_errors.etat_elevage is defined %}
                                        <p class="md:col-span-4 md:col-start-2 text-sm text-red-600">{{ form_errors.etat_elevage }}</p>
                                    {% endif %}
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-5 items-center gap-3">
                                    <label class="md:col-span-1 text-emerald-800 text-lg md:text-xl font-bold">Capacity:</label>
                                    <input name="capacite" value="{{ current_capacite }}" placeholder="Ex: 100" class="md:col-span-4 rounded-xl border-2 border-emerald-400 bg-white px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-emerald-500">
                                    {% if form_errors.capacite is defined %}
                                        <p class="md:col-span-4 md:col-start-2 text-sm text-red-600">{{ form_errors.capacite }}</p>
                                    {% endif %}
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-5 items-center gap-3">
                                    <label class="md:col-span-1 text-emerald-800 text-lg md:text-xl font-bold">Animals:</label>
                                    <div class="md:col-span-4">
                                        <input value="{{ is_edit_mode ? edit_livestock.nombre_animaux : 0 }}" readonly class="w-full rounded-xl border-2 border-emerald-300 bg-emerald-50 px-3 py-2.5 text-base text-emerald-900">
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-5 items-center gap-3">
                                    <label class="md:col-span-1 text-emerald-800 text-lg md:text-xl font-bold">Production:</label>
                                    <input name="production" value="{{ current_production }}" placeholder="Ex: Milk, Meat, Wool..." class="md:col-span-4 rounded-xl border-2 border-emerald-400 bg-white px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-emerald-500">
                                    {% if form_errors.production is defined %}
                                        <p class="md:col-span-4 md:col-start-2 text-sm text-red-600">{{ form_errors.production }}</p>
                                    {% endif %}
                                </div>

                                <div class="pt-2 flex items-center justify-center gap-5">
                                    <button type="submit" class="h-14 w-14 rounded-xl bg-emerald-500 hover:bg-emerald-600 text-white shadow-[0_8px_18px_-8px_rgba(16,127,61,0.65)] flex items-center justify-center" title="Save">
                                        {% if is_edit_mode %}
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-7 h-7" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 1 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
                                        {% else %}
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-7 h-7" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                                        {% endif %}
                                    </button>
                                    <a href="{{ path('elfirma_page', { module: 'animaux-elevages' }) }}?view=livestock" class="h-14 w-14 rounded-xl bg-red-500 hover:bg-red-600 text-white shadow-[0_8px_18px_-8px_rgba(220,38,38,0.75)] flex items-center justify-center" title="Cancel">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-7 h-7" aria-hidden="true"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            {% endif %}
        </section>
    </div>
</main>

<div id="delete-confirm-modal" class="fixed inset-0 z-[130] hidden items-center justify-center p-3 bg-black/35">
    <div class="delete-modal-card w-full max-w-md rounded-2xl shadow-2xl flex items-center">
        <div class="p-4 md:p-5 text-center">
            <h3 class="text-2xl md:text-3xl font-black text-red-700">Confirm Deletion</h3>
            <div class="mt-3 h-px bg-red-300"></div>

            <div class="mt-5 flex justify-center">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-11 h-11 text-red-600" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>

            <p id="delete-modal-title" class="mt-4 text-2xl md:text-3xl font-black text-red-700">Delete: Item</p>
            <p id="delete-modal-text" class="mt-4 text-lg md:text-xl text-red-600">Are you sure you want to delete this livestock? This action cannot be undone.</p>

            <div class="mt-6 flex items-center justify-center gap-4">
                <button id="delete-modal-confirm" type="button" class="delete-icon-btn" title="Delete">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                </button>
                <button id="delete-modal-cancel" type="button" class="h-11 w-11 rounded-xl bg-gray-400 hover:bg-gray-500 text-white shadow-[0_8px_18px_-8px_rgba(107,114,128,0.75)] flex items-center justify-center" title="Cancel">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="w-5 h-5" aria-hidden="true"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    const normalize = function (value) {
        return String(value || '').trim().toLowerCase();
    };

    const table = document.getElementById('livestock-table');
    const tableBody = document.getElementById('livestock-table-body');
    const searchInput = document.getElementById('livestock-search-input');
    const searchError = document.getElementById('livestock-search-error');
    const typeFilter = document.getElementById('livestock-type-filter');
    const stateFilter = document.getElementById('livestock-state-filter');
    const noResultsRow = document.getElementById('livestock-no-results');

    if (searchInput && searchError) {
        searchInput.addEventListener('input', function () {
            searchError.classList.add('hidden');
        });
    }

    if (table && tableBody && searchInput && typeFilter && stateFilter) {
        const rows = Array.from(tableBody.querySelectorAll('tr[data-row="livestock"]'));
        const sortButtons = Array.from(table.querySelectorAll('.js-livestock-sort'));
        let sortState = { key: null, direction: 'asc', type: 'text' };

        const fillFilterOptions = function (selectElement, key) {
            const uniqueValues = Array.from(new Set(rows
                .map(function (row) { return row.dataset[key] || ''; })
                .filter(function (value) { return normalize(value) !== ''; })))
                .sort(function (a, b) { return a.localeCompare(b, undefined, { sensitivity: 'base' }); });

            uniqueValues.forEach(function (value) {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = value;
                selectElement.appendChild(option);
            });
        };

        const compareRows = function (rowA, rowB, key, type, direction) {
            const factor = direction === 'asc' ? 1 : -1;
            const valueA = rowA.dataset[key] || '';
            const valueB = rowB.dataset[key] || '';

            if (type === 'number') {
                return (Number(valueA) - Number(valueB)) * factor;
            }

            return valueA.localeCompare(valueB, undefined, { sensitivity: 'base' }) * factor;
        };

        const renderSortIndicators = function () {
            sortButtons.forEach(function (button) {
                const key = button.dataset.sortKey || '';
                const indicator = table.querySelector('[data-sort-indicator="' + key + '"]');
                button.classList.remove('is-active');

                if (indicator) {
                    indicator.innerHTML = '&uarr;&darr;';
                }

                if (sortState.key === key) {
                    button.classList.add('is-active');
                    if (indicator) {
                        indicator.innerHTML = sortState.direction === 'asc' ? '&uarr;' : '&darr;';
                    }
                }
            });
        };

        const applyFilters = function () {
            const selectedType = normalize(typeFilter.value);
            const selectedState = normalize(stateFilter.value);
            let visibleCount = 0;

            rows.forEach(function (row) {
                const matchesType = selectedType === '' || normalize(row.dataset.type) === selectedType;
                const matchesState = selectedState === '' || normalize(row.dataset.state) === selectedState;
                const isVisible = matchesType && matchesState;

                row.classList.toggle('hidden', !isVisible);
                if (isVisible) {
                    visibleCount += 1;
                }
            });

            if (noResultsRow) {
                noResultsRow.classList.toggle('hidden', visibleCount > 0 || rows.length === 0);
            }
        };

        const sortRows = function () {
            if (!sortState.key) {
                return;
            }

            const sortedRows = rows.slice().sort(function (rowA, rowB) {
                return compareRows(rowA, rowB, sortState.key, sortState.type, sortState.direction);
            });

            sortedRows.forEach(function (row) {
                tableBody.appendChild(row);
            });

            if (noResultsRow) {
                tableBody.appendChild(noResultsRow);
            }
        };

        fillFilterOptions(typeFilter, 'type');
        fillFilterOptions(stateFilter, 'state');

        typeFilter.addEventListener('change', applyFilters);
        stateFilter.addEventListener('change', applyFilters);

        sortButtons.forEach(function (button) {
            button.addEventListener('click', function () {
                const key = button.dataset.sortKey || '';
                const type = button.dataset.sortType || 'text';

                if (sortState.key === key) {
                    sortState.direction = sortState.direction === 'asc' ? 'desc' : 'asc';
                } else {
                    sortState.key = key;
                    sortState.direction = 'asc';
                }

                sortState.type = type;
                sortRows();
                renderSortIndicators();
                applyFilters();
            });
        });

        applyFilters();
    }

    const modal = document.getElementById('delete-confirm-modal');
    const title = document.getElementById('delete-modal-title');
    const text = document.getElementById('delete-modal-text');
    const confirmBtn = document.getElementById('delete-modal-confirm');
    const cancelBtn = document.getElementById('delete-modal-cancel');
    const deleteForms = document.querySelectorAll('.js-delete-form');

    if (!modal || !title || !text || !confirmBtn || !cancelBtn || !deleteForms.length) {
        return;
    }

    let pendingForm = null;

    const closeModal = function () {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        pendingForm = null;
    };

    deleteForms.forEach(function (form) {
        form.addEventListener('submit', function (event) {
            event.preventDefault();
            pendingForm = form;

            const label = form.dataset.deleteLabel || 'Livestock';
            title.textContent = 'Delete: ' + label;
            text.textContent = 'Are you sure you want to delete this livestock? This action cannot be undone.';

            modal.classList.remove('hidden');
            modal.classList.add('flex');
        });
    });

    confirmBtn.addEventListener('click', function () {
        if (pendingForm) {
            pendingForm.submit();
        }
    });

    cancelBtn.addEventListener('click', closeModal);

    modal.addEventListener('click', function (event) {
        if (event.target === modal) {
            closeModal();
        }
    });

    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape' && !modal.classList.contains('hidden')) {
            closeModal();
        }
    });
})();
</script>

