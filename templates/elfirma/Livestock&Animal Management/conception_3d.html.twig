<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Conception 3D Habitat - Livestock</title>
    <link rel="stylesheet" href="{{ asset('styles/elfirma-theme.css') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="{{ asset('assets/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
    <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
    <style>
        :root {
            --paper: #ffffff;
            --paper-soft: #f7fbf6;
            --forest: #1f6f43;
            --forest-deep: #124b2f;
            --soil: #9a5b2d;
            --mint: #d8f1df;
            --line: #d7e5da;
            --text: #132218;
            --muted: #5a6b60;
        }

        .elf-sidebar-toggle,
        .elf-sidebar-overlay {
            display: none !important;
        }

        .page-body {
            font-family: 'Manrope', sans-serif;
            background:
                radial-gradient(920px 320px at 8% -15%, rgba(31, 111, 67, 0.16), transparent 66%),
                radial-gradient(640px 300px at 95% -18%, rgba(154, 91, 45, 0.12), transparent 72%),
                linear-gradient(180deg, #fcfefc 0%, #f7faf8 100%);
            color: var(--text);
            position: relative;
        }

        .page-body::before {
            content: '';
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image:
                repeating-linear-gradient(45deg, rgba(18, 75, 47, 0.02) 0, rgba(18, 75, 47, 0.02) 1px, transparent 1px, transparent 11px);
            opacity: 0.7;
            z-index: -1;
        }

        .sidebar-shell {
            background: rgba(255, 255, 255, 0.92);
            border-right: 1px solid rgba(203, 225, 208, 0.95);
            backdrop-filter: blur(10px);
        }

        .brand-title,
        .page-title,
        .panel-title {
            font-family: 'Sora', sans-serif;
            letter-spacing: -0.02em;
        }

        .hero-shell {
            position: relative;
            overflow: hidden;
            border: 1px solid #cde3d3;
            border-radius: 1.6rem;
            background: linear-gradient(138deg, #ffffff 0%, #f7fcf7 48%, #fffaf5 100%);
            box-shadow: 0 24px 48px rgba(16, 34, 24, 0.08);
        }

        .hero-shell::after {
            content: '';
            position: absolute;
            right: -90px;
            top: -100px;
            width: 260px;
            height: 260px;
            border-radius: 999px;
            background: radial-gradient(circle, rgba(31, 111, 67, 0.16) 0%, rgba(31, 111, 67, 0.03) 55%, transparent 70%);
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            border: 1px solid #d2ead8;
            border-radius: 999px;
            background: #f4fbf6;
            color: #155632;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.11em;
            padding: 5px 12px;
        }

        .hero-lead {
            color: var(--muted);
            max-width: 78ch;
        }

        .hero-metrics {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.65rem;
            margin: 1rem 0 1.2rem;
            position: relative;
            z-index: 2;
        }

        .hero-metric {
            border: 1px solid #d9e8dd;
            border-radius: 0.95rem;
            background: rgba(255, 255, 255, 0.88);
            padding: 0.75rem 0.85rem;
            box-shadow: 0 10px 22px rgba(16, 34, 24, 0.05);
        }

        .hero-metric .label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #5d6a60;
        }

        .hero-metric .value {
            display: block;
            margin-top: 0.22rem;
            font-size: 1.06rem;
            font-weight: 800;
            color: #1a3223;
        }

        .hero-metric .value.is-ok {
            color: #166534;
        }

        .hero-metric .value.is-ko {
            color: #9f1239;
        }

        .panel-card {
            border: 1px solid var(--line);
            border-radius: 1.3rem;
            background: var(--paper);
            box-shadow: 0 16px 34px rgba(16, 34, 24, 0.06);
            animation: panel-enter 0.55s ease both;
            contain: layout paint;
        }

        .panel-card:nth-of-type(2) {
            animation-delay: 0.08s;
        }

        .livestock-list {
            max-height: min(64vh, 620px);
            overflow: auto;
            padding-right: 6px;
            display: grid;
            gap: 0.82rem;
            scrollbar-width: thin;
            scrollbar-color: #bfdac6 transparent;
        }

        .livestock-list::-webkit-scrollbar {
            width: 8px;
        }

        .livestock-list::-webkit-scrollbar-thumb {
            background: #bfdac6;
            border-radius: 999px;
        }

        .livestock-item {
            border: 1px solid #d6e7da;
            border-radius: 1rem;
            background: #ffffff;
            padding: 0.92rem;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
            animation: item-rise 0.42s ease both;
            animation-delay: calc(var(--stagger, 0) * 58ms);
            content-visibility: auto;
            contain-intrinsic-size: 144px;
        }

        .livestock-item:hover {
            transform: translateY(-2px);
            border-color: #b9d8c1;
            box-shadow: 0 12px 24px rgba(16, 34, 24, 0.08);
        }

        .livestock-item.is-active {
            border-color: #18864f;
            background: linear-gradient(180deg, #f4fcf7 0%, #ffffff 100%);
            box-shadow: inset 0 0 0 1px #18864f, 0 14px 26px rgba(18, 75, 47, 0.1);
        }

        .livestock-badge {
            border: 1px solid #cde7d5;
            background: #f1f9f4;
            color: #166534;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            padding: 3px 8px;
        }

        .habitat-cta {
            border: 1px solid rgba(23, 98, 61, 0.6);
            background: linear-gradient(135deg, #17653f 0%, #2f8f5f 100%);
            color: #ffffff;
            box-shadow: 0 10px 18px rgba(23, 98, 61, 0.22);
            transition: transform 0.18s ease, filter 0.18s ease, box-shadow 0.18s ease;
        }

        .habitat-cta:hover {
            transform: translateY(-1px);
            filter: saturate(1.08);
            box-shadow: 0 14px 20px rgba(23, 98, 61, 0.25);
        }

        .habitat-cta:disabled {
            box-shadow: none;
        }

        .habitat-cta.is-generating {
            background: linear-gradient(135deg, #145232 0%, #1f7a4c 100%);
            animation: pulse-chip 1.1s ease-in-out infinite;
        }

        .field-control {
            border: 1px solid #c8d8cc;
            border-radius: 0.85rem;
            background: linear-gradient(180deg, #ffffff 0%, #f8fcf9 100%);
            color: #243b2f;
            font-weight: 600;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .field-control:focus {
            outline: none;
            border-color: #86c8a0;
            box-shadow: 0 0 0 3px rgba(120, 190, 146, 0.2);
        }

        .viewer-stage {
            position: relative;
            border: 1px solid #d6e3ec;
            border-radius: 1rem;
            background:
                radial-gradient(380px 170px at 15% 0%, rgba(15, 118, 110, 0.1), transparent 70%),
                linear-gradient(180deg, #f8fbff 0%, #eff5fb 100%);
            padding: 0.55rem;
            overflow: hidden;
        }

        .viewer-stage::before {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
            background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.38) 45%, transparent 100%);
            z-index: 1;
        }

        .viewer-stage.is-cinematic {
            border-color: #cdd7f0;
            background:
                radial-gradient(520px 240px at 16% 8%, rgba(251, 191, 36, 0.16), transparent 70%),
                radial-gradient(380px 210px at 87% 0%, rgba(59, 130, 246, 0.18), transparent 72%),
                linear-gradient(180deg, #eef3ff 0%, #e4ecff 100%);
            box-shadow: inset 0 0 0 1px rgba(147, 197, 253, 0.22), 0 20px 40px rgba(30, 58, 138, 0.12);
        }

        .viewer-stage.is-cinematic::after {
            content: '';
            position: absolute;
            inset: -12% -22%;
            pointer-events: none;
            z-index: 1;
            background: conic-gradient(from 210deg, rgba(251, 191, 36, 0.1), rgba(59, 130, 246, 0.12), rgba(251, 191, 36, 0.06));
            filter: blur(26px);
            opacity: 0.9;
            animation: cinema-drift 8s ease-in-out infinite alternate;
        }

        .viewer-stage.is-signature {
            border-color: #c7d2fe;
            background:
                radial-gradient(560px 250px at 16% 0%, rgba(252, 211, 77, 0.2), transparent 70%),
                radial-gradient(520px 260px at 92% 4%, rgba(56, 189, 248, 0.16), transparent 75%),
                linear-gradient(180deg, #e9efff 0%, #e3ebff 100%);
            box-shadow: inset 0 0 0 1px rgba(165, 180, 252, 0.28), 0 22px 46px rgba(30, 64, 175, 0.16);
        }

        .viewer-stage.is-signature::after {
            content: '';
            position: absolute;
            inset: -10% -18%;
            pointer-events: none;
            z-index: 1;
            background: radial-gradient(circle at 30% 20%, rgba(251, 191, 36, 0.22), transparent 62%), radial-gradient(circle at 74% 28%, rgba(59, 130, 246, 0.24), transparent 65%);
            filter: blur(22px);
            opacity: 0.94;
            animation: signature-drift 7.5s ease-in-out infinite alternate;
        }

        .viewer-loading {
            position: absolute;
            top: 0.85rem;
            right: 0.9rem;
            z-index: 6;
            border: 1px solid #c8dfd1;
            background: rgba(250, 255, 251, 0.95);
            color: #175a35;
            border-radius: 999px;
            padding: 0.36rem 0.75rem;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.05em;
            animation: pulse-chip 1.2s ease-in-out infinite;
        }

        .viewer-toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
            margin-bottom: 0.75rem;
        }

        .viewer-button {
            border: 1px solid #cadad0;
            border-radius: 999px;
            background: linear-gradient(180deg, #ffffff 0%, #f7fbf8 100%);
            color: #1d4830;
            padding: 0.36rem 0.75rem;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            transition: border-color 0.2s ease, transform 0.2s ease, background-color 0.2s ease;
        }

        .viewer-button:hover {
            transform: translateY(-1px);
            border-color: #9ac9ab;
        }

        .viewer-button.is-active {
            border-color: #1b7b4a;
            background: #edf9f1;
            color: #165234;
        }

        .viewer-button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .viewer-empty {
            border: 1px dashed #bfccd8;
            border-radius: 0.88rem;
            background: rgba(248, 251, 255, 0.9);
            padding: 2.6rem 1rem;
            text-align: center;
            color: #516072;
            font-size: 0.86rem;
            font-weight: 600;
        }

        model-viewer {
            position: relative;
            z-index: 2;
            width: 100%;
            height: min(56vh, 530px);
            min-height: 340px;
            background: linear-gradient(180deg, #f8fbff 0%, #eef3f8 100%);
            border: 1px solid #d7e1ec;
            border-radius: 0.9rem;
        }

        .status-pill {
            border: 1px solid #cde6d5;
            background: #f3fbf6;
            color: #14532d;
            box-shadow: 0 8px 15px rgba(20, 83, 45, 0.08);
        }

        .status-pill.error {
            border-color: #fecaca;
            background: #fff1f2;
            color: #991b1b;
        }

        #prompt-box {
            white-space: pre-wrap;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 12px;
            line-height: 1.45;
            max-height: 180px;
            overflow: auto;
            border: 1px solid #d7e1dc;
            background: #f9fcfa;
            border-radius: 0.9rem;
        }

        #selected-livestock {
            border: 1px solid #d4e6d9;
            border-radius: 999px;
            background: #f4fbf6;
            color: #1e4f34;
            padding: 0.48rem 0.8rem;
            display: inline-flex;
            align-items: center;
            font-weight: 700;
        }

        #meta {
            border: 1px solid #d9e4dd;
            border-radius: 0.95rem;
            background: #f9fcfa;
        }

        @keyframes panel-enter {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes item-rise {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes pulse-chip {
            0%,
            100% {
                transform: scale(1);
                opacity: 0.9;
            }
            50% {
                transform: scale(1.03);
                opacity: 1;
            }
        }

        @keyframes cinema-drift {
            from {
                transform: translate3d(-12px, -4px, 0) rotate(0.4deg);
            }
            to {
                transform: translate3d(10px, 6px, 0) rotate(-0.6deg);
            }
        }

        @keyframes signature-drift {
            from {
                transform: translate3d(-8px, -7px, 0) scale(0.995);
            }
            to {
                transform: translate3d(12px, 8px, 0) scale(1.005);
            }
        }

        @media (max-width: 960px) {
            .hero-metrics {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .hero-shell {
                border-radius: 1.25rem;
            }

            .page-title {
                font-size: 1.7rem;
                line-height: 1.2;
            }

            model-viewer {
                min-height: 290px;
                height: 44vh;
            }

            .viewer-toolbar {
                gap: 0.35rem;
            }

            .studio-controls {
                grid-template-columns: 1fr;
            }

            .viewer-button {
                font-size: 10px;
                padding: 0.32rem 0.58rem;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation: none !important;
                transition: none !important;
                scroll-behavior: auto !important;
            }
        }

