<body class="page-body min-h-screen overflow-x-hidden">
{% include 'elfirma/_admin_sidebar.html.twig' with { 'current_module': 'animaux-elevages' } %}

<main class="main-shell">
    <div class="max-w-7xl mx-auto">
        <section class="hero-shell p-4 md:p-6">
            <header class="mb-4 relative z-[2]">
                <p class="eyebrow">ELFIRMA 3D STUDIO</p>
                <h2 class="page-title text-2xl md:text-4xl font-extrabold mt-2 text-emerald-900">Conception 3D Habitat</h2>
                    <p class="hero-lead text-sm md:text-base mt-2">Le livestock represente l emplacement de vie des animaux (etable, ecurie, bergerie, poulailler...). Selectionne un livestock puis clique sur Generer pour creer un rendu 3D plus immersif et realiste de cet habitat.</p>
                </header>

            <div class="hero-metrics">
                <article class="hero-metric">
                    <span class="label">Livestock disponibles</span>
                    <span class="value">{{ livestock_list|length }}</span>
                </article>
                <article class="hero-metric">
                    <span class="label">Mode conception</span>
                    <span class="value">Habitat agricole</span>
                </article>
                <article class="hero-metric">
                    <span class="label">Etat API 3D</span>
                    <span class="value {% if is_3d_configured %}is-ok{% else %}is-ko{% endif %}">{% if is_3d_configured %}Active{% else %}Inactive{% endif %}</span>
                </article>
            </div>

            {% if not is_3d_configured %}
                <div class="no-credits-banner">
                    <span class="icon">⚙️</span>
                    <div>
                        <strong>Configuration API 3D manquante</strong>
                        <p>Vérifiez les variables <code>TRIPO3D_API_KEY</code>, <code>TRIPO3D_API_BASE_URL</code> et <code>TRIPO3D_TIMEOUT</code> dans le fichier <code>.env</code>.</p>
                    </div>
                </div>
            {% endif %}
            <div class="no-credits-banner hidden" id="no-credits-banner">
                <span class="icon">💳</span>
                <div>
                    <strong>Crédits Tripo3D insuffisants</strong>
                    <p>Votre compte Tripo3D n'a plus de crédits. Rechargez votre solde sur <a href="https://platform.tripo3d.ai" target="_blank" rel="noopener">platform.tripo3d.ai</a> pour continuer à générer des modèles 3D.</p>
                </div>
            </div>

            <div class="studio-grid">
                <section class="panel-card p-4 md:p-5">
                    <h3 class="panel-title text-xl font-black text-slate-800">Livestock disponibles</h3>
                    <p class="mt-1 text-sm text-slate-600">Aucun upload requis: generation automatique de l habitat depuis type, etat, capacite et production.</p>

                    {% if livestock_list is empty %}
                        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 px-4 py-6 text-sm text-slate-600">
                            Aucun livestock trouve dans la base.
                        </div>
                    {% else %}
                        <div class="livestock-list mt-4" id="livestock-list">
                            {% for item in livestock_list %}
                                <article class="livestock-item" style="--stagger: {{ loop.index0 }};" data-livestock-id="{{ item.id_elevage|default(0) }}">
                                    <div class="flex items-start justify-between gap-3">
                                        <div>
                                            <p class="text-base font-black text-slate-800">{{ item.type_elevage|default('Livestock') }}</p>
                                            <p class="text-xs text-slate-500">ID {{ item.id_elevage|default(0) }}</p>
                                        </div>
                                        <span class="livestock-badge">{{ item.etat_elevage|default('N/A') }}</span>
                                    </div>

                                    <div class="mt-2 text-xs text-slate-600 space-y-1">
                                        <p>Production: <strong>{{ item.production|default('N/A') }}</strong></p>
                                        <p>Capacite: <strong>{{ item.capacite|default(0) }}</strong> | Animaux: <strong>{{ item.nombre_animaux|default(0) }}</strong></p>
                                    </div>

                                    <button
                                        type="button"
                                        class="js-generate-3d habitat-cta mt-3 w-full inline-flex items-center justify-center rounded-xl px-4 py-2.5 text-sm font-bold disabled:opacity-60 disabled:cursor-not-allowed"
                                        data-livestock-id="{{ item.id_elevage|default(0) }}"
                                        data-livestock-label="{{ (item.type_elevage|default('Livestock')) ~ ' #' ~ (item.id_elevage|default(0)) }}"
                                    >
                                        Generer habitat 3D
                                    </button>
                                </article>
                            {% endfor %}
                        </div>
                    {% endif %}

                    <div id="status" class="status-pill hidden mt-4 rounded-xl px-3 py-2 text-sm font-semibold"></div>
                </section>

                <section class="panel-card p-4 md:p-5">
                    <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
                        <h3 class="panel-title text-xl font-black text-slate-800">Resultat Habitat 3D</h3>
                        <a id="download-link" class="hidden inline-flex items-center rounded-lg border border-emerald-300 bg-emerald-50 px-3 py-1.5 text-sm font-bold text-emerald-800" href="#" download>
                            Telecharger .glb
                        </a>
                    </div>

                    <div class="viewer-toolbar" id="viewer-toolbar">
                        <button type="button" class="viewer-button js-viewer-preset" data-preset="hero" disabled>Hero</button>
                        <button type="button" class="viewer-button js-viewer-preset" data-preset="detail" disabled>Detail</button>
                        <button type="button" class="viewer-button js-viewer-preset" data-preset="front" disabled>Facade</button>
                        <button type="button" class="viewer-button js-viewer-preset" data-preset="isometric" disabled>Isometrique</button>
                        <button type="button" class="viewer-button js-viewer-preset" data-preset="top" disabled>Toit</button>
                        <button type="button" class="viewer-button" id="viewer-reset" disabled>Reset</button>
                        <button type="button" class="viewer-button" id="viewer-fullscreen" disabled>Plein ecran</button>
                    </div>

                    <div class="viewer-stage mb-3" id="viewer-stage">
                        <div id="viewer-loading" class="viewer-loading hidden">Generation 3D en cours...</div>

                        <div id="viewer-empty" class="viewer-empty">
                            Le modele d habitat apparaitra ici apres generation.
                        </div>

                        <model-viewer
                            id="viewer"
                            class="hidden"
                            loading="lazy"
                            reveal="auto"
                            camera-controls
                            auto-rotate
                            auto-rotate-delay="1200"
                            rotation-per-second="10deg"
                            interaction-prompt="auto"
                            interaction-prompt-threshold="0"
                            camera-orbit="26deg 64deg 118%"
                            min-camera-orbit="auto 5deg 35%"
                            max-camera-orbit="auto 89deg 260%"
                            field-of-view="26deg"
                            min-field-of-view="10deg"
                            max-field-of-view="46deg"
                            shadow-intensity="1.58"
                            shadow-softness="0.9"
                            exposure="1.18"
                            tone-mapping="aces"
                            environment-image="neutral"
                            disable-pan
                            ar
                        ></model-viewer>
                    </div>

                    <div id="meta" class="hidden mt-3 px-3 py-2 text-sm text-slate-700"></div>
                    <div id="prompt-box" class="hidden mt-3 px-3 py-2 text-slate-700"></div>
                </section>
            </div>
        </section>
    </div>
</main>

<script>
(function () {
    const endpoint = "{{ path('api_livestock_3d_generate') }}";
    const csrfToken = "{{ csrf_token('livestock_3d_generate') }}";
    const canGenerate3D = {{ is_3d_configured ? 'true' : 'false' }};
    const noCreditsBanner = document.getElementById('no-credits-banner');
    const generateButtons = Array.from(document.querySelectorAll('.js-generate-3d'));
    const livestockCards = Array.from(document.querySelectorAll('.livestock-item[data-livestock-id]'));
    const status = document.getElementById('status');
    const viewerStage = document.getElementById('viewer-stage');
    const viewer = document.getElementById('viewer');
    const viewerPresetButtons = Array.from(document.querySelectorAll('.js-viewer-preset'));
    const viewerResetButton = document.getElementById('viewer-reset');
    const viewerFullscreenButton = document.getElementById('viewer-fullscreen');
    const viewerLoading = document.getElementById('viewer-loading');
    const viewerEmpty = document.getElementById('viewer-empty');
    const meta = document.getElementById('meta');
    const promptBox = document.getElementById('prompt-box');
    const downloadLink = document.getElementById('download-link');

    if (!status || !viewerStage || !viewer || !viewerResetButton || !viewerFullscreenButton || !viewerLoading || !viewerEmpty || !meta || !promptBox || !downloadLink) {
        return;
    }

    if (generateButtons.length === 0) {
        return;
    }

    const cameraPresets = {
        hero: '26deg 64deg 118%',
        detail: '44deg 70deg 78%',
        front: '0deg 75deg 128%',
        isometric: '38deg 68deg 135%',
        top: '0deg 14deg 185%'
    };

    let activeRequestController = null;
    let requestSequence = 0;
    let activePreset = 'hero';

    const getDefaultPresetForMode = () => 'hero';

    const resetResultPanel = () => {
        viewer.removeAttribute('src');
        viewer.classList.add('hidden');

        viewerLoading.classList.add('hidden');
        viewerLoading.textContent = 'Generation 3D en cours...';

        viewerEmpty.textContent = 'Le modele d habitat apparaitra ici apres generation.';
        viewerEmpty.classList.remove('hidden');

        downloadLink.removeAttribute('href');
        downloadLink.classList.add('hidden');

        meta.textContent = '';
        meta.classList.add('hidden');

        promptBox.textContent = '';
        promptBox.classList.add('hidden');

        setViewerToolsEnabled(false);
    };

    const showStatus = (message, isError) => {
        status.textContent = message;
        status.classList.remove('hidden', 'error');
        if (isError) {
            status.classList.add('error');
        }
    };

    const setViewerToolsEnabled = (enabled) => {
        viewerPresetButtons.forEach((button) => {
            button.disabled = !enabled;
        });
        viewerResetButton.disabled = !enabled;
        viewerFullscreenButton.disabled = !enabled;
    };

    const setActivePreset = (presetName) => {
        activePreset = presetName;
        viewerPresetButtons.forEach((button) => {
            button.classList.toggle('is-active', String(button.getAttribute('data-preset')) === presetName);
        });
    };

    const applyCameraPreset = (presetName) => {
        const orbit = cameraPresets[presetName];
        if (!orbit) {
            return;
        }

        viewer.setAttribute('camera-orbit', orbit);
        setActivePreset(presetName);
    };

    const applyRenderMode = () => {
        viewerStage.classList.remove('is-cinematic');
        viewerStage.classList.add('is-signature');
        viewer.setAttribute('auto-rotate', '');
        viewer.setAttribute('auto-rotate-delay', '700');
        viewer.setAttribute('rotation-per-second', '10deg');
        viewer.setAttribute('shadow-softness', '1');
        viewer.setAttribute('field-of-view', '24deg');
        viewer.setAttribute('tone-mapping', 'aces');
        viewer.setAttribute('environment-image', 'neutral');
        viewer.setAttribute('interaction-prompt', 'auto');
    };

    applyRenderMode();
    setViewerToolsEnabled(false);

    viewer.addEventListener('load', () => {
        viewerLoading.classList.add('hidden');
        setViewerToolsEnabled(true);
        applyCameraPreset(activePreset);
        showStatus('Habitat 3D pret.', false);
    });

    viewer.addEventListener('error', () => {
        viewerLoading.classList.add('hidden');
        setViewerToolsEnabled(false);
        viewer.classList.add('hidden');
        viewerEmpty.textContent = 'Le modele a ete genere, mais son affichage a echoue. Reessaie la generation.';
        viewerEmpty.classList.remove('hidden');
        showStatus('Echec d affichage 3D dans le viewer.', true);
    });

    viewerPresetButtons.forEach((button) => {
        button.addEventListener('click', () => {
            if (button.disabled) {
                return;
            }

            applyCameraPreset(String(button.getAttribute('data-preset') || 'isometric'));
        });
    });

    viewerResetButton.addEventListener('click', () => {
        if (viewerResetButton.disabled) {
            return;
        }

        applyCameraPreset(getDefaultPresetForMode());
        if (typeof viewer.jumpCameraToGoal === 'function') {
            viewer.jumpCameraToGoal();
        }
    });

    viewerFullscreenButton.addEventListener('click', async () => {
        if (viewerFullscreenButton.disabled) {
            return;
        }

        try {
            if (document.fullscreenElement) {
                await document.exitFullscreen();
                return;
            }

            if (typeof viewerStage.requestFullscreen === 'function') {
                await viewerStage.requestFullscreen();
            }
        } catch (error) {
            showStatus('Impossible d ouvrir le plein ecran sur ce navigateur.', true);
        }
    });

    if (!canGenerate3D) {
        generateButtons.forEach((button) => {
            button.disabled = true;
        });
        showStatus('Configuration API 3D manquante. Contacte l administrateur.', true);
        return;
    }

    const setButtonsLoading = (loading, activeButton) => {
        generateButtons.forEach((button) => {
            const isActive = button === activeButton;
            button.disabled = loading;
            if (loading && isActive) {
                button.textContent = 'Generation...';
                button.classList.add('is-generating');
            } else if (!loading) {
                button.textContent = 'Generer habitat 3D';
                button.classList.remove('is-generating');
            } else {
                button.classList.remove('is-generating');
            }
        });
    };

    const setActiveLivestock = (livestockId) => {
        livestockCards.forEach((card) => {
            if (String(card.getAttribute('data-livestock-id')) === String(livestockId)) {
                card.classList.add('is-active');
            } else {
                card.classList.remove('is-active');
            }
        });
    };

    const requestGeneration = async (button) => {
        const livestockId = String(button.getAttribute('data-livestock-id') || '');

        if (livestockId === '' || livestockId === '0') {
            showStatus('Livestock invalide.', true);
            return;
        }

        if (activeRequestController) {
            activeRequestController.abort();
        }

        const requestController = new AbortController();
        activeRequestController = requestController;
        requestSequence += 1;
        const currentRequest = requestSequence;

        setButtonsLoading(true, button);
        setActiveLivestock(livestockId);
        resetResultPanel();
        applyRenderMode();
        showStatus('Generation de l habitat 3D en cours...', false);
        viewerLoading.textContent = 'Generation 3D en cours...';
        viewerLoading.classList.remove('hidden');

        try {
            const payload = new FormData();
            payload.append('_token', csrfToken);
            payload.append('livestock_id', livestockId);

            const response = await fetch(endpoint, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: payload,
                signal: requestController.signal,
            });

            if (currentRequest !== requestSequence) {
                return;
            }

            let data = null;
            try {
                data = await response.json();
            } catch (jsonError) {
                data = null;
            }

            if (!response.ok || !data || !data.ok) {
                const message = data && data.message ? data.message : 'La generation 3D a echoue.';
                const isNoCredits = message.toLowerCase().includes('credit') || message.includes('403') || response.status === 402;
                if (noCreditsBanner) {
                    noCreditsBanner.classList.toggle('hidden', !isNoCredits);
                }
                viewerEmpty.textContent = isNoCredits
                    ? 'Crédits insuffisants. Rechargez votre solde Tripo3D.'
                    : 'Génération impossible : ' + message;
                showStatus(message, true);
                return;
            }
            if (noCreditsBanner) {
                noCreditsBanner.classList.add('hidden');
            }

            const modelUrl = String(data.model_url || '');
            if (modelUrl === '') {
                viewerEmpty.textContent = 'Generation incomplete: aucune URL du modele n a ete retournee.';
                showStatus('Generation terminee, mais aucune URL de modele d habitat n a ete retournee.', true);
                return;
            }

            viewer.src = modelUrl + '?v=' + Date.now();
            applyCameraPreset(activePreset);
            viewerLoading.textContent = 'Modele cree. Chargement visuel...';
            viewer.classList.remove('hidden');
            viewerEmpty.classList.add('hidden');

            downloadLink.href = modelUrl;
            downloadLink.setAttribute('download', String(data.file_name || 'livestock-model.glb'));
            downloadLink.classList.remove('hidden');

            meta.textContent =
                'Fichier: ' + String(data.file_name || '-') +
                ' | Taille: ' + String(data.file_size_bytes || 0) +
                ' | Type habitat: ' + String(data.livestock_type || '-');
            meta.classList.remove('hidden');

            const prompt = String(data.prompt || '');
            if (prompt !== '') {
                promptBox.textContent = prompt;
                promptBox.classList.remove('hidden');
            }

            showStatus('Habitat 3D genere avec succes.', false);
        } catch (error) {
            if (error && error.name === 'AbortError') {
                return;
            }

            viewerEmpty.textContent = 'Erreur reseau. Verifie la connexion et reessaie la generation.';
            showStatus('Erreur reseau pendant la generation de l habitat 3D.', true);
        } finally {
            if (activeRequestController === requestController) {
                activeRequestController = null;
            }

            if (currentRequest === requestSequence) {
                if (!viewer.getAttribute('src')) {
                    viewerLoading.classList.add('hidden');
                }
                setButtonsLoading(false, button);
            }
        }
    };

    generateButtons.forEach((button) => {
        button.addEventListener('click', () => {
            requestGeneration(button);
        });
    });
})();
</script>

{{ include('elfirma/_nav_routes.html.twig') }}
<script src="{{ asset('assets/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
</body>
