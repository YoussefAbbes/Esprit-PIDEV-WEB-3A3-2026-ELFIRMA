<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Conception 3D Habitat - Livestock</title>
    <link rel="stylesheet" href="{{ asset('styles/elfirma-theme.css') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
    <style>
        :root {
            --paper: #ffffff;
            --paper-soft: #f7fbf6;
            --forest: #1f6f43;
            --forest-deep: #124b2f;
            --soil: #9a5b2d;
            --mint: #d8f1df;
            --line: #d7e5da;
            --text: #132218;
            --muted: #5a6b60;
        }

        .elf-sidebar-toggle,
        .elf-sidebar-overlay {
            display: none !important;
        }

        .page-body {
            font-family: 'Manrope', sans-serif;
            background:
                radial-gradient(920px 320px at 8% -15%, rgba(31, 111, 67, 0.16), transparent 66%),
                radial-gradient(640px 300px at 95% -18%, rgba(154, 91, 45, 0.12), transparent 72%),
                linear-gradient(180deg, #fcfefc 0%, #f7faf8 100%);
            color: var(--text);
            position: relative;
        }

        .page-body::before {
            content: '';
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image:
                repeating-linear-gradient(45deg, rgba(18, 75, 47, 0.02) 0, rgba(18, 75, 47, 0.02) 1px, transparent 1px, transparent 11px);
            opacity: 0.7;
            z-index: -1;
        }

        .sidebar-shell {
            background: rgba(255, 255, 255, 0.92);
            border-right: 1px solid rgba(203, 225, 208, 0.95);
            backdrop-filter: blur(10px);
        }

        .brand-title,
        .page-title,
        .panel-title {
            font-family: 'Sora', sans-serif;
            letter-spacing: -0.02em;
        }

        .hero-shell {
            position: relative;
            overflow: hidden;
            border: 1px solid #cde3d3;
            border-radius: 1.6rem;
            background: linear-gradient(138deg, #ffffff 0%, #f7fcf7 48%, #fffaf5 100%);
            box-shadow: 0 24px 48px rgba(16, 34, 24, 0.08);
        }

        .hero-shell::after {
            content: '';
            position: absolute;
            right: -90px;
            top: -100px;
            width: 260px;
            height: 260px;
            border-radius: 999px;
            background: radial-gradient(circle, rgba(31, 111, 67, 0.16) 0%, rgba(31, 111, 67, 0.03) 55%, transparent 70%);
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            border: 1px solid #d2ead8;
            border-radius: 999px;
            background: #f4fbf6;
            color: #155632;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.11em;
            padding: 5px 12px;
        }

        .hero-lead {
            color: var(--muted);
            max-width: 78ch;
        }

        .hero-metrics {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.65rem;
            margin: 1rem 0 1.2rem;
            position: relative;
            z-index: 2;
        }

        .hero-metric {
            border: 1px solid #d9e8dd;
            border-radius: 0.95rem;
            background: rgba(255, 255, 255, 0.88);
            padding: 0.75rem 0.85rem;
            box-shadow: 0 10px 22px rgba(16, 34, 24, 0.05);
        }

        .hero-metric .label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #5d6a60;
        }

        .hero-metric .value {
            display: block;
            margin-top: 0.22rem;
            font-size: 1.06rem;
            font-weight: 800;
            color: #1a3223;
        }

        .hero-metric .value.is-ok {
            color: #166534;
        }

        .hero-metric .value.is-ko {
            color: #9f1239;
        }

        .panel-card {
            border: 1px solid var(--line);
            border-radius: 1.3rem;
            background: var(--paper);
            box-shadow: 0 16px 34px rgba(16, 34, 24, 0.06);
            animation: panel-enter 0.55s ease both;
            contain: layout paint;
        }

        .panel-card:nth-of-type(2) {
            animation-delay: 0.08s;
        }

        .livestock-list {
            max-height: min(64vh, 620px);
            overflow: auto;
            padding-right: 6px;
            display: grid;
            gap: 0.82rem;
            scrollbar-width: thin;
            scrollbar-color: #bfdac6 transparent;
        }

        .livestock-list::-webkit-scrollbar {
            width: 8px;
        }

        .livestock-list::-webkit-scrollbar-thumb {
            background: #bfdac6;
            border-radius: 999px;
        }

        .livestock-item {
            border: 1px solid #d6e7da;
            border-radius: 1rem;
            background: #ffffff;
            padding: 0.92rem;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
            animation: item-rise 0.42s ease both;
            animation-delay: calc(var(--stagger, 0) * 58ms);
            content-visibility: auto;
            contain-intrinsic-size: 144px;
        }

        .livestock-item:hover {
            transform: translateY(-2px);
            border-color: #b9d8c1;
            box-shadow: 0 12px 24px rgba(16, 34, 24, 0.08);
        }

        .livestock-item.is-active {
            border-color: #18864f;
            background: linear-gradient(180deg, #f4fcf7 0%, #ffffff 100%);
            box-shadow: inset 0 0 0 1px #18864f, 0 14px 26px rgba(18, 75, 47, 0.1);
        }

        .livestock-badge {
            border: 1px solid #cde7d5;
            background: #f1f9f4;
            color: #166534;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            padding: 3px 8px;
        }

        .habitat-cta {
            border: 1px solid rgba(23, 98, 61, 0.6);
            background: linear-gradient(135deg, #17653f 0%, #2f8f5f 100%);
            color: #ffffff;
            box-shadow: 0 10px 18px rgba(23, 98, 61, 0.22);
            transition: transform 0.18s ease, filter 0.18s ease, box-shadow 0.18s ease;
        }

        .habitat-cta:hover {
            transform: translateY(-1px);
            filter: saturate(1.08);
            box-shadow: 0 14px 20px rgba(23, 98, 61, 0.25);
        }

        .habitat-cta:disabled {
            box-shadow: none;
        }

        .habitat-cta.is-generating {
            background: linear-gradient(135deg, #145232 0%, #1f7a4c 100%);
            animation: pulse-chip 1.1s ease-in-out infinite;
        }

        .field-control {
            border: 1px solid #c8d8cc;
            border-radius: 0.85rem;
            background: linear-gradient(180deg, #ffffff 0%, #f8fcf9 100%);
            color: #243b2f;
            font-weight: 600;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .field-control:focus {
            outline: none;
            border-color: #86c8a0;
            box-shadow: 0 0 0 3px rgba(120, 190, 146, 0.2);
        }

        .viewer-stage {
            position: relative;
            border: 1px solid #d6e3ec;
            border-radius: 1rem;
            background:
                radial-gradient(380px 170px at 15% 0%, rgba(15, 118, 110, 0.1), transparent 70%),
                linear-gradient(180deg, #f8fbff 0%, #eff5fb 100%);
            padding: 0.55rem;
            overflow: hidden;
        }

        .viewer-stage::before {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
            background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.38) 45%, transparent 100%);
            z-index: 1;
        }

        .viewer-stage.is-cinematic {
            border-color: #cdd7f0;
            background:
                radial-gradient(520px 240px at 16% 8%, rgba(251, 191, 36, 0.16), transparent 70%),
                radial-gradient(380px 210px at 87% 0%, rgba(59, 130, 246, 0.18), transparent 72%),
                linear-gradient(180deg, #eef3ff 0%, #e4ecff 100%);
            box-shadow: inset 0 0 0 1px rgba(147, 197, 253, 0.22), 0 20px 40px rgba(30, 58, 138, 0.12);
        }

        .viewer-stage.is-cinematic::after {
            content: '';
            position: absolute;
            inset: -12% -22%;
            pointer-events: none;
            z-index: 1;
            background: conic-gradient(from 210deg, rgba(251, 191, 36, 0.1), rgba(59, 130, 246, 0.12), rgba(251, 191, 36, 0.06));
            filter: blur(26px);
            opacity: 0.9;
            animation: cinema-drift 8s ease-in-out infinite alternate;
        }

        .viewer-stage.is-signature {
            border-color: #c7d2fe;
            background:
                radial-gradient(560px 250px at 16% 0%, rgba(252, 211, 77, 0.2), transparent 70%),
                radial-gradient(520px 260px at 92% 4%, rgba(56, 189, 248, 0.16), transparent 75%),
                linear-gradient(180deg, #e9efff 0%, #e3ebff 100%);
            box-shadow: inset 0 0 0 1px rgba(165, 180, 252, 0.28), 0 22px 46px rgba(30, 64, 175, 0.16);
        }

        .viewer-stage.is-signature::after {
            content: '';
            position: absolute;
            inset: -10% -18%;
            pointer-events: none;
            z-index: 1;
            background: radial-gradient(circle at 30% 20%, rgba(251, 191, 36, 0.22), transparent 62%), radial-gradient(circle at 74% 28%, rgba(59, 130, 246, 0.24), transparent 65%);
            filter: blur(22px);
            opacity: 0.94;
            animation: signature-drift 7.5s ease-in-out infinite alternate;
        }

        .viewer-loading {
            position: absolute;
            top: 0.85rem;
            right: 0.9rem;
            z-index: 6;
            border: 1px solid #c8dfd1;
            background: rgba(250, 255, 251, 0.95);
            color: #175a35;
            border-radius: 999px;
            padding: 0.36rem 0.75rem;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.05em;
            animation: pulse-chip 1.2s ease-in-out infinite;
        }

        .viewer-toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
            margin-bottom: 0.75rem;
        }

        .studio-controls {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr)) auto;
            gap: 0.6rem;
            align-items: end;
            margin-bottom: 0.78rem;
            padding: 0.58rem;
            border: 1px solid #d6e2f8;
            border-radius: 0.9rem;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(241, 246, 255, 0.96) 100%);
            position: relative;
            z-index: 2;
        }

        .studio-control {
            display: grid;
            gap: 0.26rem;
        }

        .studio-control > span {
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.04em;
            color: #1f3d75;
            text-transform: uppercase;
        }

        .studio-control input[type='range'] {
            width: 100%;
            accent-color: #2b6cb0;
        }

        .studio-control strong {
            font-size: 11px;
            color: #1e3a8a;
            font-weight: 800;
        }

        .viewer-button {
            border: 1px solid #cadad0;
            border-radius: 999px;
            background: linear-gradient(180deg, #ffffff 0%, #f7fbf8 100%);
            color: #1d4830;
            padding: 0.36rem 0.75rem;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            transition: border-color 0.2s ease, transform 0.2s ease, background-color 0.2s ease;
        }

        .viewer-button:hover {
            transform: translateY(-1px);
            border-color: #9ac9ab;
        }

        .viewer-button.is-active {
            border-color: #1b7b4a;
            background: #edf9f1;
            color: #165234;
        }

        .viewer-button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .balance-row {
            margin-top: 0.72rem;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.45rem;
        }

        .balance-pill {
            display: inline-flex;
            align-items: center;
            border: 1px solid #cde5d3;
            border-radius: 999px;
            padding: 0.32rem 0.7rem;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.03em;
            background: #f2fbf4;
            color: #14532d;
        }

        .balance-pill.is-low {
            border-color: #fecaca;
            background: #fff1f2;
            color: #9f1239;
        }

        .balance-pill.is-unknown {
            border-color: #cbd5e1;
            background: #f8fafc;
            color: #334155;
        }

        .viewer-empty {
            border: 1px dashed #bfccd8;
            border-radius: 0.88rem;
            background: rgba(248, 251, 255, 0.9);
            padding: 2.6rem 1rem;
            text-align: center;
            color: #516072;
            font-size: 0.86rem;
            font-weight: 600;
        }

        model-viewer {
            position: relative;
            z-index: 2;
            width: 100%;
            height: min(56vh, 530px);
            min-height: 340px;
            background: linear-gradient(180deg, #f8fbff 0%, #eef3f8 100%);
            border: 1px solid #d7e1ec;
            border-radius: 0.9rem;
        }

        .status-pill {
            border: 1px solid #cde6d5;
            background: #f3fbf6;
            color: #14532d;
            box-shadow: 0 8px 15px rgba(20, 83, 45, 0.08);
        }

        .status-pill.error {
            border-color: #fecaca;
            background: #fff1f2;
            color: #991b1b;
        }

        #preview-image {
            position: relative;
            z-index: 2;
            width: 100%;
            max-height: 240px;
            object-fit: contain;
            border: 1px solid #d6e0ea;
            border-radius: 0.9rem;
            background: #f8fbff;
            padding: 9px;
        }

        #prompt-box {
            white-space: pre-wrap;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 12px;
            line-height: 1.45;
            max-height: 180px;
            overflow: auto;
            border: 1px solid #d7e1dc;
            background: #f9fcfa;
            border-radius: 0.9rem;
        }

        #selected-livestock {
            border: 1px solid #d4e6d9;
            border-radius: 999px;
            background: #f4fbf6;
            color: #1e4f34;
            padding: 0.48rem 0.8rem;
            display: inline-flex;
            align-items: center;
            font-weight: 700;
        }

        #meta {
            border: 1px solid #d9e4dd;
            border-radius: 0.95rem;
            background: #f9fcfa;
        }

        @keyframes panel-enter {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes item-rise {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes pulse-chip {
            0%,
            100% {
                transform: scale(1);
                opacity: 0.9;
            }
            50% {
                transform: scale(1.03);
                opacity: 1;
            }
        }

        @keyframes cinema-drift {
            from {
                transform: translate3d(-12px, -4px, 0) rotate(0.4deg);
            }
            to {
                transform: translate3d(10px, 6px, 0) rotate(-0.6deg);
            }
        }

        @keyframes signature-drift {
            from {
                transform: translate3d(-8px, -7px, 0) scale(0.995);
            }
            to {
                transform: translate3d(12px, 8px, 0) scale(1.005);
            }
        }

        @media (max-width: 960px) {
            .hero-metrics {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .hero-shell {
                border-radius: 1.25rem;
            }

            .page-title {
                font-size: 1.7rem;
                line-height: 1.2;
            }

            model-viewer {
                min-height: 290px;
                height: 44vh;
            }

            .viewer-toolbar {
                gap: 0.35rem;
            }

            .studio-controls {
                grid-template-columns: 1fr;
            }

            .viewer-button {
                font-size: 10px;
                padding: 0.32rem 0.58rem;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation: none !important;
                transition: none !important;
                scroll-behavior: auto !important;
            }
        }
    </style>
</head>
<body class="page-body min-h-screen overflow-x-hidden">
<aside class="sidebar-shell hidden md:flex flex-col h-screen w-72 fixed left-0 top-0 py-8 pr-4 z-40">
    <div class="px-8 mb-8">
        <h1 class="brand-title text-3xl font-black text-slate-900 tracking-tight">Elfirma</h1>
        <p class="text-slate-500 text-sm">Gestion Agricole</p>
    </div>
    <nav class="flex-1 space-y-1">
        <a class="flex items-center px-8 py-3 rounded-r-full" href="#">Tableau de Bord</a>
    </nav>
</aside>

<main class="md:ml-72 min-h-screen p-3 md:p-5">
    <div class="max-w-7xl mx-auto">
        <section class="hero-shell p-4 md:p-6">
            <header class="mb-4 relative z-[2]">
                <p class="eyebrow">ELFIRMA 3D STUDIO</p>
                <h2 class="page-title text-2xl md:text-4xl font-extrabold mt-2 text-emerald-900">Conception 3D Habitat</h2>
                <p class="hero-lead text-sm md:text-base mt-2">Le livestock represente l emplacement de vie des animaux (etable, ecurie, bergerie, poulailler...). Selectionne un livestock puis clique sur Generer pour creer un rendu 3D plus immersif et realiste de cet habitat.</p>
            </header>

            <div class="hero-metrics">
                <article class="hero-metric">
                    <span class="label">Livestock disponibles</span>
                    <span class="value">{{ livestock_list|length }}</span>
                </article>
                <article class="hero-metric">
                    <span class="label">Mode conception</span>
                    <span class="value">Habitat agricole</span>
                </article>
                <article class="hero-metric">
                    <span class="label">Etat API 3D</span>
                    <span class="value {% if is_3d_configured %}is-ok{% else %}is-ko{% endif %}">{% if is_3d_configured %}Active{% else %}Inactive{% endif %}</span>
                </article>
            </div>

            {% if not is_3d_configured %}
                <div class="mb-4 rounded-xl border border-amber-300 bg-amber-50 px-4 py-3 text-sm font-semibold text-amber-900">
                    Configuration API 3D manquante. Verifiez les variables STABILITY_3D_* dans le fichier .env.
                </div>
            {% endif %}

            <div class="grid grid-cols-1 xl:grid-cols-[420px_minmax(0,1fr)] gap-5">
                <section class="panel-card p-4 md:p-5">
                    <h3 class="panel-title text-xl font-black text-slate-800">Livestock disponibles</h3>
                    <p class="mt-1 text-sm text-slate-600">Aucun upload requis: generation automatique de l habitat depuis type, etat, capacite et production.</p>

                    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
                        <div>
                            <label for="texture_resolution" class="block text-sm font-bold text-slate-700 mb-1">Texture</label>
                            <select id="texture_resolution" name="texture_resolution" class="field-control w-full px-3 py-2.5">
                                <option value="2048" selected>2048 (ultra detail recommande)</option>
                                <option value="1024">1024 (equilibre)</option>
                                <option value="512">512</option>
                            </select>
                        </div>
                        <div>
                            <label for="remesh" class="block text-sm font-bold text-slate-700 mb-1">Remesh</label>
                            <select id="remesh" name="remesh" class="field-control w-full px-3 py-2.5">
                                <option value="none" selected>none (fidelite max recommande)</option>
                                <option value="triangle">triangle</option>
                                <option value="quad">quad</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label for="render_mode" class="block text-sm font-bold text-slate-700 mb-1">Mode rendu 3D</label>
                        <select id="render_mode" name="render_mode" class="field-control w-full px-3 py-2.5">
                            <option value="signature" selected>Signature (ultra premium)</option>
                            <option value="cinematic">Cinematique (extraordinaire)</option>
                            <option value="ultra">Ultra detail (realisme max)</option>
                            <option value="balanced">Equilibre</option>
                            <option value="eco">Eco (plus rapide)</option>
                        </select>
                    </div>

                    <div class="balance-row">
                        <button type="button" id="check-balance-btn" class="viewer-button">Voir solde API</button>
                        <span id="balance-pill" class="balance-pill is-unknown hidden">Solde inconnu</span>
                    </div>

                    {% if livestock_list is empty %}
                        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 px-4 py-6 text-sm text-slate-600">
                            Aucun livestock trouve dans la base.
                        </div>
                    {% else %}
                        <div class="livestock-list mt-4" id="livestock-list">
                            {% for item in livestock_list %}
                                <article class="livestock-item" style="--stagger: {{ loop.index0 }};" data-livestock-id="{{ item.id_elevage|default(0) }}">
                                    <div class="flex items-start justify-between gap-3">
                                        <div>
                                            <p class="text-base font-black text-slate-800">{{ item.type_elevage|default('Livestock') }}</p>
                                            <p class="text-xs text-slate-500">ID {{ item.id_elevage|default(0) }}</p>
                                        </div>
                                        <span class="livestock-badge">{{ item.etat_elevage|default('N/A') }}</span>
                                    </div>

                                    <div class="mt-2 text-xs text-slate-600 space-y-1">
                                        <p>Production: <strong>{{ item.production|default('N/A') }}</strong></p>
                                        <p>Capacite: <strong>{{ item.capacite|default(0) }}</strong> | Animaux: <strong>{{ item.nombre_animaux|default(0) }}</strong></p>
                                    </div>

                                    <button
                                        type="button"
                                        class="js-generate-3d habitat-cta mt-3 w-full inline-flex items-center justify-center rounded-xl px-4 py-2.5 text-sm font-bold disabled:opacity-60 disabled:cursor-not-allowed"
                                        data-livestock-id="{{ item.id_elevage|default(0) }}"
                                        data-livestock-label="{{ (item.type_elevage|default('Livestock')) ~ ' #' ~ (item.id_elevage|default(0)) }}"
                                    >
                                        Generer habitat 3D
                                    </button>
                                </article>
                            {% endfor %}
                        </div>
                    {% endif %}

                    <div id="status" class="status-pill hidden mt-4 rounded-xl px-3 py-2 text-sm font-semibold"></div>
                </section>

                <section class="panel-card p-4 md:p-5">
                    <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
                        <h3 class="panel-title text-xl font-black text-slate-800">Resultat Habitat 3D</h3>
                        <a id="download-link" class="hidden inline-flex items-center rounded-lg border border-emerald-300 bg-emerald-50 px-3 py-1.5 text-sm font-bold text-emerald-800" href="#" download>
                            Telecharger .glb
                        </a>
                    </div>

                    <div id="selected-livestock" class="mb-3 text-sm font-semibold">Aucun livestock selectionne.</div>

                    <div class="viewer-toolbar" id="viewer-toolbar">
                        <button type="button" class="viewer-button js-viewer-preset" data-preset="hero" disabled>Hero</button>
                        <button type="button" class="viewer-button js-viewer-preset" data-preset="detail" disabled>Detail</button>
                        <button type="button" class="viewer-button js-viewer-preset" data-preset="front" disabled>Facade</button>
                        <button type="button" class="viewer-button js-viewer-preset" data-preset="isometric" disabled>Isometrique</button>
                        <button type="button" class="viewer-button js-viewer-preset" data-preset="top" disabled>Toit</button>
                        <button type="button" class="viewer-button" id="viewer-reset" disabled>Reset</button>
                        <button type="button" class="viewer-button" id="viewer-fullscreen" disabled>Plein ecran</button>
                    </div>

                    <div class="studio-controls" id="studio-controls">
                        <label class="studio-control" for="viewer-exposure-range">
                            <span>Exposition studio</span>
                            <input id="viewer-exposure-range" type="range" min="0.8" max="1.35" step="0.01" value="1.18" disabled>
                            <strong id="viewer-exposure-value">1.18</strong>
                        </label>
                        <label class="studio-control" for="viewer-shadow-range">
                            <span>Intensite ombres</span>
                            <input id="viewer-shadow-range" type="range" min="0.6" max="1.8" step="0.01" value="1.58" disabled>
                            <strong id="viewer-shadow-value">1.58</strong>
                        </label>
                        <button type="button" class="viewer-button" id="viewer-reset-lighting" disabled>Auto Studio</button>
                    </div>

                    <div class="viewer-stage mb-3" id="viewer-stage">
                        <div id="viewer-loading" class="viewer-loading hidden">Generation 3D en cours...</div>

                        <div id="viewer-empty" class="viewer-empty">
                            Le modele d habitat apparaitra ici apres generation.
                        </div>

                        <img id="preview-image" class="hidden mb-3" alt="Preview image generated from livestock data">

                        <model-viewer
                            id="viewer"
                            class="hidden"
                            loading="lazy"
                            reveal="auto"
                            camera-controls
                            auto-rotate
                            auto-rotate-delay="1200"
                            rotation-per-second="10deg"
                            interaction-prompt="auto"
                            interaction-prompt-threshold="0"
                            camera-orbit="26deg 64deg 118%"
                            min-camera-orbit="auto 5deg 35%"
                            max-camera-orbit="auto 89deg 260%"
                            field-of-view="26deg"
                            min-field-of-view="10deg"
                            max-field-of-view="46deg"
                            shadow-intensity="1.58"
                            shadow-softness="0.9"
                            exposure="1.18"
                            tone-mapping="aces"
                            environment-image="neutral"
                            disable-pan
                            ar
                        ></model-viewer>
                    </div>

                    <div id="meta" class="hidden mt-3 px-3 py-2 text-sm text-slate-700"></div>
                    <div id="prompt-box" class="hidden mt-3 px-3 py-2 text-slate-700"></div>
                </section>
            </div>
        </section>
    </div>
</main>

<script>
(function () {
    const endpoint = "{{ path('api_livestock_3d_generate') }}";
    const balanceEndpoint = "{{ path('api_livestock_3d_balance') }}";
    const csrfToken = "{{ csrf_token('livestock_3d_generate') }}";
    const balanceCsrfToken = "{{ csrf_token('livestock_3d_balance') }}";
    const canGenerate3D = {{ is_3d_configured ? 'true' : 'false' }};
    const textureSelect = document.getElementById('texture_resolution');
    const remeshSelect = document.getElementById('remesh');
    const renderModeSelect = document.getElementById('render_mode');
    const checkBalanceButton = document.getElementById('check-balance-btn');
    const balancePill = document.getElementById('balance-pill');
    const generateButtons = Array.from(document.querySelectorAll('.js-generate-3d'));
    const livestockCards = Array.from(document.querySelectorAll('.livestock-item[data-livestock-id]'));
    const status = document.getElementById('status');
    const selectedLivestock = document.getElementById('selected-livestock');
    const viewerStage = document.getElementById('viewer-stage');
    const viewer = document.getElementById('viewer');
    const viewerPresetButtons = Array.from(document.querySelectorAll('.js-viewer-preset'));
    const viewerResetButton = document.getElementById('viewer-reset');
    const viewerFullscreenButton = document.getElementById('viewer-fullscreen');
    const viewerExposureRange = document.getElementById('viewer-exposure-range');
    const viewerShadowRange = document.getElementById('viewer-shadow-range');
    const viewerExposureValue = document.getElementById('viewer-exposure-value');
    const viewerShadowValue = document.getElementById('viewer-shadow-value');
    const viewerResetLightingButton = document.getElementById('viewer-reset-lighting');
    const previewImage = document.getElementById('preview-image');
    const viewerLoading = document.getElementById('viewer-loading');
    const viewerEmpty = document.getElementById('viewer-empty');
    const meta = document.getElementById('meta');
    const promptBox = document.getElementById('prompt-box');
    const downloadLink = document.getElementById('download-link');

    if (!textureSelect || !remeshSelect || !renderModeSelect || !checkBalanceButton || !balancePill || !status || !selectedLivestock || !viewerStage || !viewer || !viewerResetButton || !viewerFullscreenButton || !viewerExposureRange || !viewerShadowRange || !viewerExposureValue || !viewerShadowValue || !viewerResetLightingButton || !previewImage || !viewerLoading || !viewerEmpty || !meta || !promptBox || !downloadLink) {
        return;
    }

    if (generateButtons.length === 0) {
        return;
    }

    const cameraPresets = {
        hero: '26deg 64deg 118%',
        detail: '44deg 70deg 78%',
        front: '0deg 75deg 128%',
        isometric: '38deg 68deg 135%',
        top: '0deg 14deg 185%'
    };

    let activeRequestController = null;
    let requestSequence = 0;
    let activePreset = 'hero';

    const getDefaultPresetForMode = (mode) => {
        const normalizedMode = String(mode || '').toLowerCase();
        return normalizedMode === 'cinematic' || normalizedMode === 'signature' ? 'hero' : 'isometric';
    };

    const setStudioValues = (exposure, shadowIntensity) => {
        const exposureValue = Number(exposure);
        const shadowValue = Number(shadowIntensity);

        viewer.setAttribute('exposure', exposureValue.toFixed(2));
        viewer.setAttribute('shadow-intensity', shadowValue.toFixed(2));

        viewerExposureRange.value = exposureValue.toFixed(2);
        viewerShadowRange.value = shadowValue.toFixed(2);
        viewerExposureValue.textContent = exposureValue.toFixed(2);
        viewerShadowValue.textContent = shadowValue.toFixed(2);
    };

    const formatBytes = (bytes) => {
        if (!Number.isFinite(bytes) || bytes <= 0) {
            return '0 B';
        }

        const units = ['B', 'KB', 'MB', 'GB'];
        const exponent = Math.min(Math.floor(Math.log(bytes) / Math.log(1024)), units.length - 1);
        const value = bytes / Math.pow(1024, exponent);
        return value.toFixed(exponent === 0 ? 0 : 2) + ' ' + units[exponent];
    };

    const formatCredits = (value) => {
        if (!Number.isFinite(value)) {
            return '--';
        }

        const rounded = Math.round(value * 100) / 100;
        return Number.isInteger(rounded) ? String(rounded) : rounded.toFixed(2);
    };

    const renderBalancePill = (credits, state) => {
        balancePill.classList.remove('hidden', 'is-low', 'is-unknown');

        if (state === 'unknown') {
            balancePill.classList.add('is-unknown');
            balancePill.textContent = 'Solde inconnu';
            return;
        }

        if (state === 'low') {
            balancePill.classList.add('is-low');
            balancePill.textContent = 'Credits: ' + formatCredits(credits) + ' (insuffisant)';
            return;
        }

        balancePill.textContent = 'Credits: ' + formatCredits(credits);
    };

    const checkBalance = async () => {
        checkBalanceButton.disabled = true;
        const initialLabel = checkBalanceButton.textContent;
        checkBalanceButton.textContent = 'Verification...';

        try {
            const payload = new FormData();
            payload.append('_token', balanceCsrfToken);

            const response = await fetch(balanceEndpoint, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: payload,
            });

            let data = null;
            try {
                data = await response.json();
            } catch (jsonError) {
                data = null;
            }

            if (!response.ok || !data || !data.ok) {
                const message = data && data.message ? data.message : 'Impossible de verifier le solde API.';
                renderBalancePill(0, 'unknown');
                showStatus(message, true);
                return;
            }

            const credits = Number(data.credits || 0);
            if (Number.isFinite(credits) && credits > 0) {
                renderBalancePill(credits, 'ok');
                showStatus('Solde API verifie: credits disponibles (' + formatCredits(credits) + ').', false);
            } else {
                renderBalancePill(credits, 'low');
                showStatus('Credits insuffisants (' + formatCredits(credits) + '). Rechargez votre compte Stability.', true);
            }
        } catch (error) {
            renderBalancePill(0, 'unknown');
            showStatus('Erreur reseau pendant la verification du solde API.', true);
        } finally {
            checkBalanceButton.disabled = false;
            checkBalanceButton.textContent = initialLabel;
        }
    };

    const resetResultPanel = () => {
        previewImage.removeAttribute('src');
        previewImage.classList.add('hidden');

        viewer.removeAttribute('src');
        viewer.classList.add('hidden');

        viewerLoading.classList.add('hidden');
        viewerLoading.textContent = 'Generation 3D en cours...';

        viewerEmpty.textContent = 'Le modele d habitat apparaitra ici apres generation.';
        viewerEmpty.classList.remove('hidden');

        downloadLink.removeAttribute('href');
        downloadLink.classList.add('hidden');

        meta.textContent = '';
        meta.classList.add('hidden');

        promptBox.textContent = '';
        promptBox.classList.add('hidden');

        setViewerToolsEnabled(false);
        setActivePreset(getDefaultPresetForMode(renderModeSelect.value));
    };

    const showStatus = (message, isError) => {
        status.textContent = message;
        status.classList.remove('hidden', 'error');
        if (isError) {
            status.classList.add('error');
        }
    };

    const setViewerToolsEnabled = (enabled) => {
        viewerPresetButtons.forEach((button) => {
            button.disabled = !enabled;
        });
        viewerResetButton.disabled = !enabled;
        viewerFullscreenButton.disabled = !enabled;
        viewerExposureRange.disabled = !enabled;
        viewerShadowRange.disabled = !enabled;
        viewerResetLightingButton.disabled = !enabled;
    };

    const setActivePreset = (presetName) => {
        activePreset = presetName;
        viewerPresetButtons.forEach((button) => {
            button.classList.toggle('is-active', String(button.getAttribute('data-preset')) === presetName);
        });
    };

    const applyCameraPreset = (presetName) => {
        const orbit = cameraPresets[presetName];
        if (!orbit) {
            return;
        }

        viewer.setAttribute('camera-orbit', orbit);
        setActivePreset(presetName);
    };

    const applyRenderMode = (mode) => {
        const selectedMode = String(mode || 'signature');
        viewerStage.classList.toggle('is-cinematic', selectedMode === 'cinematic');
        viewerStage.classList.toggle('is-signature', selectedMode === 'signature');

        if (selectedMode === 'eco') {
            viewer.removeAttribute('auto-rotate');
            viewer.setAttribute('shadow-softness', '0.62');
            viewer.setAttribute('field-of-view', '36deg');
            viewer.setAttribute('tone-mapping', 'aces');
            viewer.setAttribute('environment-image', 'neutral');
            viewer.setAttribute('interaction-prompt', 'none');
            setStudioValues(0.95, 0.75);
            return;
        }

        if (selectedMode === 'signature') {
            viewer.setAttribute('auto-rotate', '');
            viewer.setAttribute('auto-rotate-delay', '700');
            viewer.setAttribute('rotation-per-second', '10deg');
            viewer.setAttribute('shadow-softness', '1');
            viewer.setAttribute('field-of-view', '24deg');
            viewer.setAttribute('tone-mapping', 'aces');
            viewer.setAttribute('environment-image', 'neutral');
            viewer.setAttribute('interaction-prompt', 'auto');
            setStudioValues(1.18, 1.58);
            return;
        }

        if (selectedMode === 'cinematic') {
            viewer.setAttribute('auto-rotate', '');
            viewer.setAttribute('auto-rotate-delay', '900');
            viewer.setAttribute('rotation-per-second', '12deg');
            viewer.setAttribute('shadow-softness', '1');
            viewer.setAttribute('field-of-view', '28deg');
            viewer.setAttribute('tone-mapping', 'aces');
            viewer.setAttribute('environment-image', 'neutral');
            viewer.setAttribute('interaction-prompt', 'auto');
            setStudioValues(1.12, 1.45);
            return;
        }

        if (selectedMode === 'ultra') {
            viewer.setAttribute('auto-rotate', '');
            viewer.setAttribute('shadow-softness', '0.95');
            viewer.setAttribute('field-of-view', '30deg');
            viewer.setAttribute('tone-mapping', 'aces');
            viewer.setAttribute('environment-image', 'neutral');
            viewer.setAttribute('interaction-prompt', 'auto');
            setStudioValues(1.06, 1.35);
            return;
        }

        viewer.setAttribute('auto-rotate', '');
        viewer.setAttribute('shadow-softness', '0.82');
        viewer.setAttribute('field-of-view', '32deg');
        viewer.setAttribute('tone-mapping', 'aces');
        viewer.setAttribute('environment-image', 'neutral');
        viewer.setAttribute('interaction-prompt', 'auto');
        setStudioValues(1, 1.1);
    };

    applyRenderMode(renderModeSelect.value);
    setActivePreset(getDefaultPresetForMode(renderModeSelect.value));
    setViewerToolsEnabled(false);

    renderModeSelect.addEventListener('change', () => {
        applyRenderMode(renderModeSelect.value);
        applyCameraPreset(getDefaultPresetForMode(renderModeSelect.value));
    });

    const handleStudioSliderInput = () => {
        const exposureValue = Number(viewerExposureRange.value || '1.0');
        const shadowValue = Number(viewerShadowRange.value || '1.0');
        setStudioValues(exposureValue, shadowValue);
    };

    viewerExposureRange.addEventListener('input', handleStudioSliderInput);
    viewerShadowRange.addEventListener('input', handleStudioSliderInput);
    viewerResetLightingButton.addEventListener('click', () => {
        if (viewerResetLightingButton.disabled) {
            return;
        }

        applyRenderMode(renderModeSelect.value);
    });

    viewer.addEventListener('load', () => {
        viewerLoading.classList.add('hidden');
        setViewerToolsEnabled(true);
        applyCameraPreset(activePreset);
        showStatus('Habitat 3D pret. Utilise Hero, Detail, Facade, Isometrique ou Toit.', false);
    });

    viewer.addEventListener('error', () => {
        viewerLoading.classList.add('hidden');
        setViewerToolsEnabled(false);
        viewer.classList.add('hidden');
        viewerEmpty.textContent = 'Le modele a ete genere, mais son affichage a echoue. Reessaie la generation.';
        viewerEmpty.classList.remove('hidden');
        showStatus('Echec d affichage 3D dans le viewer.', true);
    });

    viewerPresetButtons.forEach((button) => {
        button.addEventListener('click', () => {
            if (button.disabled) {
                return;
            }

            applyCameraPreset(String(button.getAttribute('data-preset') || 'isometric'));
        });
    });

    viewerResetButton.addEventListener('click', () => {
        if (viewerResetButton.disabled) {
            return;
        }

        applyCameraPreset(getDefaultPresetForMode(renderModeSelect.value));
        if (typeof viewer.jumpCameraToGoal === 'function') {
            viewer.jumpCameraToGoal();
        }
    });

    viewerFullscreenButton.addEventListener('click', async () => {
        if (viewerFullscreenButton.disabled) {
            return;
        }

        try {
            if (document.fullscreenElement) {
                await document.exitFullscreen();
                return;
            }

            if (typeof viewerStage.requestFullscreen === 'function') {
                await viewerStage.requestFullscreen();
            }
        } catch (error) {
            showStatus('Impossible d ouvrir le plein ecran sur ce navigateur.', true);
        }
    });

    if (!canGenerate3D) {
        generateButtons.forEach((button) => {
            button.disabled = true;
        });
        renderModeSelect.disabled = true;
        checkBalanceButton.disabled = true;
        renderBalancePill(0, 'unknown');
        showStatus('Configuration API 3D manquante. Contacte l administrateur.', true);
        return;
    }

    checkBalanceButton.addEventListener('click', () => {
        checkBalance();
    });

    checkBalance();

    const setButtonsLoading = (loading, activeButton) => {
        generateButtons.forEach((button) => {
            const isActive = button === activeButton;
            button.disabled = loading;
            if (loading && isActive) {
                button.textContent = 'Generation...';
                button.classList.add('is-generating');
            } else if (!loading) {
                button.textContent = 'Generer habitat 3D';
                button.classList.remove('is-generating');
            } else {
                button.classList.remove('is-generating');
            }
        });
    };

    const setActiveLivestock = (livestockId) => {
        livestockCards.forEach((card) => {
            if (String(card.getAttribute('data-livestock-id')) === String(livestockId)) {
                card.classList.add('is-active');
            } else {
                card.classList.remove('is-active');
            }
        });
    };

    const requestGeneration = async (button) => {
        const livestockId = String(button.getAttribute('data-livestock-id') || '');
        const livestockLabel = String(button.getAttribute('data-livestock-label') || ('Livestock #' + livestockId));

        if (livestockId === '' || livestockId === '0') {
            showStatus('Livestock invalide.', true);
            return;
        }

        if (activeRequestController) {
            activeRequestController.abort();
        }

        const requestController = new AbortController();
        activeRequestController = requestController;
        requestSequence += 1;
        const currentRequest = requestSequence;

        setButtonsLoading(true, button);
        setActiveLivestock(livestockId);
        resetResultPanel();
        applyRenderMode(renderModeSelect.value);
        selectedLivestock.textContent = 'Habitat en cours de generation: ' + livestockLabel;
        showStatus('Generation automatique de l image de reference puis de l habitat 3D...', false);
        viewerLoading.textContent = 'Generation 3D en cours...';
        viewerLoading.classList.remove('hidden');

        try {
            const payload = new FormData();
            payload.append('_token', csrfToken);
            payload.append('livestock_id', livestockId);
            payload.append('texture_resolution', String(textureSelect.value || '2048'));
            payload.append('remesh', String(remeshSelect.value || 'none'));
            payload.append('render_mode', String(renderModeSelect.value || 'signature'));

            const response = await fetch(endpoint, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: payload,
                signal: requestController.signal,
            });

            if (currentRequest !== requestSequence) {
                return;
            }

            let data = null;
            try {
                data = await response.json();
            } catch (jsonError) {
                data = null;
            }

            if (!response.ok || !data || !data.ok) {
                const message = data && data.message ? data.message : 'La generation 3D a echoue.';
                viewerEmpty.textContent = 'Generation impossible: ' + message;
                showStatus(message, true);
                return;
            }

            const modelUrl = String(data.model_url || '');
            const previewUrl = String(data.preview_url || '');
            if (modelUrl === '') {
                viewerEmpty.textContent = 'Generation incomplete: aucune URL du modele n a ete retournee.';
                showStatus('Generation terminee, mais aucune URL de modele d habitat n a ete retournee.', true);
                return;
            }

            if (previewUrl !== '') {
                previewImage.src = previewUrl + '?v=' + Date.now();
                previewImage.classList.remove('hidden');
            }

            const effectiveMode = String(data.render_mode || renderModeSelect.value || 'signature');
            applyRenderMode(effectiveMode);
            setActivePreset(getDefaultPresetForMode(effectiveMode));
            viewer.src = modelUrl + '?v=' + Date.now();
            applyCameraPreset(activePreset);
            viewerLoading.textContent = 'Modele cree. Chargement visuel...';
            viewer.classList.remove('hidden');
            viewerEmpty.classList.add('hidden');

            downloadLink.href = modelUrl;
            downloadLink.setAttribute('download', String(data.file_name || 'livestock-model.glb'));
            downloadLink.classList.remove('hidden');

            selectedLivestock.textContent = 'Habitat livestock: ' + livestockLabel;

            const generationOptions = data.generation_options && typeof data.generation_options === 'object'
                ? data.generation_options
                : null;
            const textureInfo = generationOptions ? String(generationOptions.texture_resolution || '-') : '-';
            const remeshInfo = generationOptions ? String(generationOptions.remesh || '-') : '-';
            const framingInfo = generationOptions ? String(generationOptions.foreground_ratio || '-') : '-';
            const guidanceInfo = generationOptions ? String(generationOptions.guidance_scale || '-') : '-';

            meta.textContent =
                'Fichier: ' + String(data.file_name || '-') +
                ' | Taille: ' + formatBytes(Number(data.file_size_bytes || 0)) +
                ' | Type habitat: ' + String(data.livestock_type || '-') +
                ' | Mode: ' + effectiveMode +
                ' | Texture: ' + textureInfo +
                ' | Remesh: ' + remeshInfo +
                ' | Framing: ' + framingInfo +
                ' | Guidance: ' + guidanceInfo;
            meta.classList.remove('hidden');

            const prompt = String(data.prompt || '');
            if (prompt !== '') {
                promptBox.textContent = prompt;
                promptBox.classList.remove('hidden');
            }

            showStatus('Habitat 3D genere avec succes.', false);
        } catch (error) {
            if (error && error.name === 'AbortError') {
                return;
            }

            viewerEmpty.textContent = 'Erreur reseau. Verifie la connexion et reessaie la generation.';
            showStatus('Erreur reseau pendant la generation de l habitat 3D.', true);
        } finally {
            if (activeRequestController === requestController) {
                activeRequestController = null;
            }

            if (currentRequest === requestSequence) {
                if (!viewer.getAttribute('src')) {
                    viewerLoading.classList.add('hidden');
                }
                setButtonsLoading(false, button);
            }
        }
    };

    generateButtons.forEach((button) => {
        button.addEventListener('click', () => {
            requestGeneration(button);
        });
    });
})();
</script>

{{ include('elfirma/_nav_routes.html.twig') }}
</body>
</html>
