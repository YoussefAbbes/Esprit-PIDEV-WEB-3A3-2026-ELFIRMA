      gap: 0.8rem;
      min-width: 280px;
      border-left: 4px solid var(--primary);
      transform: translateX(120%);
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .toast-custom.show { transform: translateX(0); }
    .toast-custom.error { border-color: #ef4444; }
    .toast-icon { font-size: 1.4rem; }
    .toast-success .toast-icon { color: var(--primary); }
    .toast-error .toast-icon { color: #ef4444; }
    .toast-text { font-weight: 600; font-size: 0.9rem; color: var(--text-dark); }

    /* Scroll top btn */
    .scroll-top-btn {
      position: fixed;
      bottom: 2rem;
      left: 2rem;
      width: 44px;
      height: 44px;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 4px 16px var(--shadow-green);
      transition: all 0.3s;
      opacity: 0;
      pointer-events: none;
      border: none;
      z-index: 100;
    }
    .scroll-top-btn.visible { opacity: 1; pointer-events: auto; }
    .scroll-top-btn:hover { transform: translateY(-4px); box-shadow: 0 8px 24px var(--shadow-green); }

    /* Responsive */
    @media (max-width: 768px) {
      .profile-hero { height: 260px; }
      .profile-card { padding: 2rem 1.5rem; }
      .profile-name { font-size: 1.5rem; }
      .stats-row { gap: 1.5rem; }
      .stat-divider { display: none; }
      .info-grid { grid-template-columns: 1fr 1fr; }
      .complaint-card { flex-direction: column; }
      .complaint-actions { flex-direction: row; align-self: flex-end; }
    }
    @media (max-width: 480px) {
      .info-grid { grid-template-columns: 1fr; }
      .profile-card-wrap { margin-top: -70px; }
    }
  </style>
</head>
<body>

<!-- ── NAVBAR ── -->
<nav class="navbar-custom d-flex justify-content-between align-items-center">
  <a href="/home" class="navbar-brand-text">
    <div class="logo-icon">
      <span class="material-symbols-outlined" style="color:white; font-size:1.2rem;">eco</span>
    </div>
    EL FIRMA
  </a>
  <button class="btn-back" onclick="window.history.back()">
    <span class="material-symbols-outlined" style="font-size:1rem;">arrow_back</span>
    Back
  </button>
</nav>

<!-- ── HERO ── -->
<div class="profile-hero">
  <div class="profile-hero-bg" id="heroBg"></div>
  <div class="profile-hero-overlay"></div>
  <div class="profile-hero-pattern"></div>

  <!-- Floating leaf decorations -->
  <div class="leaf-float leaf-1">
    <svg width="40" height="40" viewBox="0 0 100 100"><path d="M50 10 C80 10, 90 40, 50 90 C10 40, 20 10, 50 10Z"/></svg>
  </div>
  <div class="leaf-float leaf-2">
    <svg width="30" height="30" viewBox="0 0 100 100"><path d="M50 10 C80 10, 90 40, 50 90 C10 40, 20 10, 50 10Z"/></svg>
  </div>
  <div class="leaf-float leaf-3">
    <svg width="50" height="50" viewBox="0 0 100 100"><path d="M50 10 C80 10, 90 40, 50 90 C10 40, 20 10, 50 10Z"/></svg>
  </div>
  <div class="leaf-float leaf-4">
    <svg width="35" height="35" viewBox="0 0 100 100"><path d="M50 10 C80 10, 90 40, 50 90 C10 40, 20 10, 50 10Z"/></svg>
  </div>

  <div class="hero-text">
    <div class="hero-eyebrow">EL FIRMA Agricultural Platform</div>
    <h1 class="hero-title">My Profile</h1>
    <p class="hero-subtitle">Manage your account and activity</p>
  </div>
</div>

<!-- ── PROFILE CARD ── -->
<div class="profile-card-wrap">
  <div class="profile-card" data-aos="fade-up" data-aos-duration="700">

    <!-- Avatar -->
    <div class="avatar-wrap mx-auto mb-1" style="display:inline-block;">
      {% set photo = user.imageU %}
      {% if photo is null or photo == '' or photo == 'default.JPG' %}
        <div class="avatar-icon">
          <span class="material-symbols-outlined">person</span>
        </div>
      {% elseif photo starts with 'uploads/' %}
        <img src="{{ asset(photo) }}" class="profile-avatar" alt="{{ user.prenomU }}">
      {% else %}
        <img src="{{ asset('uploads/users/' ~ photo) }}" class="profile-avatar" alt="{{ user.prenomU }}">
      {% endif %}
      <div class="avatar-online-dot" title="Active"></div>
    </div>

    <!-- Name & Role -->
    <h2 class="profile-name mt-2">{{ user.prenomU }} {{ user.nomU }}</h2>
    <p class="profile-email-sub">{{ user.emailU }}</p>

    {% if user.roleU == 'employee' %}
      <span class="role-badge role-employee">
        <span class="material-symbols-outlined" style="font-size:1rem;">badge</span>
        Employee
      </span>
    {% elseif user.roleU == 'client' %}
      <span class="role-badge role-client">
        <span class="material-symbols-outlined" style="font-size:1rem;">person</span>
        Client
      </span>
    {% elseif user.roleU == 'admin' %}
      <span class="role-badge role-admin">
        <span class="material-symbols-outlined" style="font-size:1rem;">shield_person</span>
        Administrator
      </span>
    {% else %}
      <span class="role-badge role-default">
        <span class="material-symbols-outlined" style="font-size:1rem;">badge</span>
        {{ user.roleU|capitalize }}
      </span>
    {% endif %}

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-item">
        <div class="stat-number">{{ complaints|length }}</div>
        <div class="stat-label">Complaints</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        {% set pending = 0 %}
        {% for c in complaints %}{% if c.getStatutU() == 'pending' %}{% set pending = pending + 1 %}{% endif %}{% endfor %}
        <div class="stat-number">{{ pending }}</div>
        <div class="stat-label">Pending</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <div class="stat-number">
          {% if user.dateCreationU %}
            {{ ("now"|date("Y")) - (user.dateCreationU|date("Y")) }}y
          {% else %}—{% endif %}
        </div>
        <div class="stat-label">Member</div>
      </div>
    </div>

  </div>
</div>

<!-- ── MAIN CONTENT ── -->
<div class="main-content">

  <!-- Account Information -->
  <div data-aos="fade-up" data-aos-delay="100" style="margin-bottom:2.5rem;">
    <div class="section-heading">
      <div class="section-heading-icon">
        <span class="material-symbols-outlined">manage_accounts</span>
      </div>
      <div>
        <h3>Account Information</h3>
        <p>Your personal details and membership info</p>
      </div>
    </div>

    <div class="info-grid">
      <div class="info-card" data-aos="fade-up" data-aos-delay="120">
        <div class="info-card-icon">
          <span class="material-symbols-outlined">mail</span>
        </div>
        <div class="label">Email Address</div>
        <div class="value">{{ user.emailU }}</div>
      </div>

      <div class="info-card" data-aos="fade-up" data-aos-delay="160">
        <div class="info-card-icon">
          <span class="material-symbols-outlined">person</span>
        </div>
        <div class="label">First Name</div>
        <div class="value">{{ user.prenomU }}</div>
      </div>

      <div class="info-card" data-aos="fade-up" data-aos-delay="200">
        <div class="info-card-icon">
          <span class="material-symbols-outlined">person_outline</span>
        </div>
        <div class="label">Last Name</div>
        <div class="value">{{ user.nomU }}</div>
      </div>

      <div class="info-card" data-aos="fade-up" data-aos-delay="240">
        <div class="info-card-icon">
          <span class="material-symbols-outlined">calendar_month</span>
        </div>
        <div class="label">Member Since</div>
        <div class="value">
          {% if user.dateCreationU %}
            {{ user.dateCreationU|date('M d, Y') }}
          {% else %}
            Not available
          {% endif %}
        </div>
      </div>

      <div class="info-card" data-aos="fade-up" data-aos-delay="280">
        <div class="info-card-icon">
          <span class="material-symbols-outlined">admin_panel_settings</span>
        </div>
        <div class="label">Account Role</div>
        <div class="value" style="text-transform:capitalize;">{{ user.roleU }}</div>
      </div>

      <div class="info-card" data-aos="fade-up" data-aos-delay="320">
        <div class="info-card-icon">
          <span class="material-symbols-outlined">verified_user</span>
        </div>
        <div class="label">Account Status</div>
        <div class="value" style="display:flex;align-items:center;gap:0.5rem;">
          <span style="width:8px;height:8px;background:#22c55e;border-radius:50%;display:inline-block;"></span>
          Active
        </div>
      </div>
    </div>
  </div>

  <!-- Complaints Section -->
  <div class="complaints-section" data-aos="fade-up" data-aos-delay="150">
    <div class="section-heading">
      <div class="section-heading-icon">
        <span class="material-symbols-outlined">chat_bubble</span>
      </div>
      <div>
        <h3>My Complaints</h3>
        <p>{{ complaints|length }} complaint{% if complaints|length != 1 %}s{% endif %} submitted</p>
      </div>
    </div>

    {% if complaints|length > 0 %}
      {% for complaint in complaints %}
      <div class="complaint-card" data-aos="fade-left" data-aos-delay="{{ loop.index * 60 }}" data-complaint-id="{{ complaint.getIdrU() }}">

        <div class="complaint-type-icon">
          {% set icon = 'flag' %}
          {% if complaint.getTypeReclamationU() == 'Product Issue' %}{% set icon = 'inventory_2' %}
          {% elseif complaint.getTypeReclamationU() == 'Service Issue' %}{% set icon = 'build' %}
          {% elseif complaint.getTypeReclamationU() == 'Delivery Problem' %}{% set icon = 'local_shipping' %}
          {% elseif complaint.getTypeReclamationU() == 'Quality Concern' %}{% set icon = 'star_rate' %}
          {% endif %}
          <span class="material-symbols-outlined">{{ icon }}</span>
        </div>

        <div class="complaint-body">
          <span class="complaint-type-tag">{{ complaint.getTypeReclamationU() }}</span>
          <div class="complaint-title">{{ complaint.getTitreU() }}</div>
          <div class="complaint-desc">{{ complaint.getDescriptionU() }}</div>
          <div class="complaint-meta">
            <span class="complaint-date">
              <span class="material-symbols-outlined">schedule</span>
              {% if complaint.getDateReclamationU() %}
                {{ complaint.getDateReclamationU()|date('d M, Y') }}
              {% else %}
                N/A
              {% endif %}
            </span>
            {% if complaint.getStatutU() == 'pending' %}
              <span class="badge-status badge-pending">
                <span class="material-symbols-outlined" style="font-size:0.85rem;">hourglass_empty</span>
                Pending
              </span>
            {% elseif complaint.getStatutU() == 'reviewed' %}
              <span class="badge-status badge-reviewed">
                <span class="material-symbols-outlined" style="font-size:0.85rem;">check_circle</span>
                Reviewed
              </span>
            {% else %}
              <span class="badge-status badge-default">
                <span class="material-symbols-outlined" style="font-size:0.85rem;">info</span>
                {{ complaint.getStatutU()|capitalize }}
              </span>
            {% endif %}
          </div>
        </div>

        <div class="complaint-actions">
          <button class="btn-action btn-edit edit-complaint-btn"
            data-complaint-id="{{ complaint.getIdrU() }}"
            data-complaint-type="{{ complaint.getTypeReclamationU() }}"
            data-complaint-title="{{ complaint.getTitreU() }}"
            data-complaint-description="{{ complaint.getDescriptionU() }}"
            title="Edit complaint">
            <span class="material-symbols-outlined">edit</span>
          </button>
          <button class="btn-action btn-delete delete-complaint-btn"
            data-complaint-id="{{ complaint.getIdrU() }}"
            title="Delete complaint">
            <span class="material-symbols-outlined">delete</span>
          </button>
        </div>

      </div>
      {% endfor %}

    {% else %}
      <div class="empty-state" data-aos="zoom-in" data-aos-delay="200">
        <div class="empty-state-icon">
          <span class="material-symbols-outlined">inbox</span>
        </div>
        <h5>No Complaints Yet</h5>
        <p>You haven't submitted any complaints. Everything looks good!</p>
      </div>
    {% endif %}

  </div>
</div>

<!-- ── EDIT COMPLAINT MODAL ── -->
<div class="modal fade" id="editComplaintModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header-green">
        <div class="modal-header-title">
          <span class="material-symbols-outlined">edit_note</span>
          Edit Complaint
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body-pad">
        <form id="editComplaintForm">
          <input type="hidden" id="editComplaintId" name="complaint_id">

          <div class="form-group">
            <label class="form-label-custom">
              <span class="material-symbols-outlined" style="font-size:1rem;">category</span>
              Complaint Type
            </label>
            <select id="editComplaintType" name="type" class="form-control-custom" required>
              <option value="Product Issue">Product Issue</option>
              <option value="Service Issue">Service Issue</option>
              <option value="Delivery Problem">Delivery Problem</option>
              <option value="Quality Concern">Quality Concern</option>
              <option value="Other">Other</option>
            </select>
            <div class="error-msg" id="editComplaintTypeError"></div>
          </div>

          <div class="form-group">
            <label class="form-label-custom">
              <span class="material-symbols-outlined" style="font-size:1rem;">title</span>
              Title
            </label>
            <input type="text" id="editComplaintTitle" name="titre" class="form-control-custom" placeholder="Complaint title" maxlength="100" required>
            <div class="form-hint">Max. 100 characters</div>
            <div class="error-msg" id="editComplaintTitleError"></div>
          </div>

          <div class="form-group">
            <label class="form-label-custom">
              <span class="material-symbols-outlined" style="font-size:1rem;">description</span>
              Description
            </label>
            <textarea id="editComplaintDescription" name="description" rows="4" class="form-control-custom" placeholder="Describe your complaint in detail..." maxlength="500" required></textarea>
            <div class="form-hint">Max. 500 characters</div>
            <div class="error-msg" id="editComplaintDescriptionError"></div>
          </div>

          <div style="display:flex; gap:0.75rem; padding-top:1rem; border-top:1px solid var(--border);">
            <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn-modal-save" style="flex:1; justify-content:center;">
              <span class="material-symbols-outlined" style="font-size:1rem;">save</span>
              Save Changes
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- ── DELETE COMPLAINT MODAL ── -->
<div class="modal fade" id="deleteComplaintModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header-red">
        <div class="modal-header-title">
          <span class="material-symbols-outlined">delete_forever</span>
          Delete Complaint
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body-pad">
        <div class="delete-warning-box">
          <span class="material-symbols-outlined">warning</span>
          <div>
            <strong style="display:block; margin-bottom:0.4rem; color:var(--text-dark);">This action cannot be undone</strong>
            <p style="margin:0; font-size:0.875rem; color:var(--text-gray);">The complaint will be permanently removed from your profile and our records.</p>
          </div>
        </div>
        <div style="display:flex; gap:0.75rem;">
          <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Cancel</button>
          <button type="button" id="confirmDeleteComplaintBtn" class="btn-modal-delete" style="flex:1; justify-content:center;">
            <span class="material-symbols-outlined" style="font-size:1rem;">delete</span>
            Delete Complaint
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast-container-custom">
  <div class="toast-custom" id="toastMsg">
    <span class="material-symbols-outlined toast-icon" id="toastIcon">check_circle</span>
    <span class="toast-text" id="toastText">Action completed</span>
  </div>
</div>

<!-- Scroll-to-top button -->
<button class="scroll-top-btn" id="scrollTopBtn" onclick="window.scrollTo({top:0,behavior:'smooth'})">
  <span class="material-symbols-outlined" style="font-size:1.2rem;">keyboard_arrow_up</span>
</button>

<script src="{{ asset('assets/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
<script src="{{ asset('assets/vendor/aos/aos.js') }}"></script>
<script>
  AOS.init({ once: true, easing: 'ease-out-cubic', duration: 650 });

  // Hero background Ken Burns
  const heroBg = document.getElementById('heroBg');
  setTimeout(() => heroBg.classList.add('loaded'), 100);

  // Scroll top button
  const scrollBtn = document.getElementById('scrollTopBtn');
  window.addEventListener('scroll', () => {
    scrollBtn.classList.toggle('visible', window.scrollY > 300);
  });

  // Toast helper
  function showToast(msg, isError = false) {
    const toast = document.getElementById('toastMsg');
    const icon  = document.getElementById('toastIcon');
    const text  = document.getElementById('toastText');
    toast.className = 'toast-custom' + (isError ? ' error' : '');
    icon.className = 'material-symbols-outlined toast-icon';
    icon.textContent = isError ? 'error' : 'check_circle';
    icon.style.color = isError ? '#ef4444' : 'var(--primary)';
    text.textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3500);
  }

  // Modals
  let currentEditId   = null;
  let currentDeleteId = null;
  const editModal   = new bootstrap.Modal(document.getElementById('editComplaintModal'));
  const deleteModal = new bootstrap.Modal(document.getElementById('deleteComplaintModal'));

  // Edit
  document.addEventListener('click', e => {
    const btn = e.target.closest('.edit-complaint-btn');
    if (!btn) return;
    currentEditId = btn.dataset.complaintId;
    document.getElementById('editComplaintId').value          = btn.dataset.complaintId;
    document.getElementById('editComplaintType').value        = btn.dataset.complaintType;
    document.getElementById('editComplaintTitle').value       = btn.dataset.complaintTitle;
    document.getElementById('editComplaintDescription').value = btn.dataset.complaintDescription;
    document.querySelectorAll('.error-msg').forEach(el => { el.textContent = ''; el.style.display = 'none'; });
    editModal.show();
  });

  // Delete
  document.addEventListener('click', e => {
    const btn = e.target.closest('.delete-complaint-btn');
    if (!btn) return;
    currentDeleteId = btn.dataset.complaintId;
    deleteModal.show();
  });

  // Edit submit
  document.getElementById('editComplaintForm').addEventListener('submit', async e => {
    e.preventDefault();
    document.querySelectorAll('.error-msg').forEach(el => { el.textContent = ''; el.style.display = 'none'; });

    const fd = new FormData();
    fd.append('complaint_id', currentEditId);
    fd.append('type',         document.getElementById('editComplaintType').value);
    fd.append('titre',        document.getElementById('editComplaintTitle').value);
    fd.append('description',  document.getElementById('editComplaintDescription').value);

    try {
      const res  = await fetch('{{ path("elfirma_update_complaint") }}', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.success) {
        editModal.hide();
        showToast('Complaint updated successfully!');
        setTimeout(() => location.reload(), 900);
      } else if (data.errors) {
        for (const [field, msg] of Object.entries(data.errors)) {
          const el = document.getElementById('editComplaint' + field.charAt(0).toUpperCase() + field.slice(1) + 'Error');
          if (el) { el.textContent = msg; el.style.display = 'block'; }
        }
      }
    } catch { showToast('An error occurred. Please try again.', true); }
  });

  // Delete confirm
  document.getElementById('confirmDeleteComplaintBtn').addEventListener('click', async () => {
    const fd = new FormData();
    fd.append('complaint_id', currentDeleteId);
    try {
      const res  = await fetch('{{ path("elfirma_delete_complaint") }}', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.success) {
        deleteModal.hide();
        showToast('Complaint deleted successfully!');
        setTimeout(() => location.reload(), 900);
      } else {
        showToast('Error deleting complaint.', true);
      }
    } catch { showToast('An error occurred. Please try again.', true); }
  });
</script>

</body>
</html>
