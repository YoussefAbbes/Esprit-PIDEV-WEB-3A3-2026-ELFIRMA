# =============================================================================
# EL FIRMA — Environment variable template
# Copy this file to ".env.local" and fill in real values there (never commit it).
#   cp .env.example .env.local
# Real secrets must ONLY live in .env.local / real environment variables.
# =============================================================================

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_generate_a_random_32_char_hex
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# mysql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="mysql://root:@127.0.0.1:3306/personne"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# sync:// | doctrine://default?auto_setup=0 | redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=sync://
###< symfony/messenger ###

###> symfony/mailer ###
# e.g. sendgrid+api://SENDGRID_API_KEY@default  or  smtp://user:pass@smtp.host:587?encryption=tls
MAILER_DSN=null://null
MAILER_FROM=your-email@example.com
MAILER_DSN_OTHER=null://null
###< symfony/mailer ###

###> image / plant APIs ###
# https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key
# https://trefle.io
TREFLE_API_KEY=your_trefle_api_key
###< image / plant APIs ###

###> firebase ###
FIREBASE_CREDENTIALS_PATH=config/firebase_credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_URI=https://your-project-default-rtdb.firebaseio.com
###< firebase ###

###> Profanity Filter API (api-ninjas.com) ###
PROFANITY_FILTER_API_KEY=your_api_ninjas_key
###< Profanity Filter API ###

###> Zoho Meeting API ###
ZOHO_MEETING_EMAIL=your-zoho-email@example.com
ZOHO_MEETING_PASSWORD=your_zoho_password
###< Zoho Meeting API ###

###> Capacity alerts ###
CAPACITY_ALERT_THRESHOLD_PERCENT=85
CAPACITY_ALERT_TO_EMAIL=alerts-to@example.com
CAPACITY_ALERT_FROM_EMAIL=onboarding@resend.dev
CAPACITY_ALERT_SSL_VERIFY=1
###< Capacity alerts ###

###> Resend (email) ###
RESEND_API_BASE_URL=https://api.resend.com
RESEND_API_KEY=your_resend_api_key
###< Resend ###

###> Twilio (SMS) ###
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_API_KEY_SID=your_twilio_api_key_sid
TWILIO_API_KEY_SECRET=your_twilio_api_key_secret
TWILIO_FROM_PHONE=+10000000000
TWILIO_TO_PHONE=+10000000000
TWILIO_SSL_VERIFY=0
###< Twilio ###

###> Maps ###
MAPTILER_API_KEY=your_maptiler_api_key
###< Maps ###

###> RAG / LLM (chatbot) ###
RAG_PYTHON_PATH=.venv\\Scripts\\python.exe
RAG_CHAT_ENGINE_PATH=rag/scripts/chat_engine.py
RAG_DEFAULT_TOP_K=5
RAG_PROCESS_TIMEOUT=60
RAG_ENABLE_LLM=1
RAG_LLM_PROVIDER=gemini
RAG_LLM_MODEL=gemini-flash-latest
RAG_LLM_TIMEOUT_SECONDS=20
RAG_LLM_MAX_OUTPUT_TOKENS=1800
###< RAG / LLM ###

###> Tripo3D (3D model generation) ###
TRIPO3D_API_KEY=your_tripo3d_api_key
TRIPO3D_API_BASE_URL=https://api.tripo3d.ai
TRIPO3D_TIMEOUT=180
###< Tripo3D ###

###> USDA ###
USDA_API_KEY=your_usda_api_key
###< USDA ###

###> Face ID service ###
FACE_ID_PYTHON_BIN=scripts/faceid/.venv/Scripts/python.exe
FACE_ID_HOST=127.0.0.1
FACE_ID_PORT=8765
FACE_ID_THRESHOLD=0.28
###< Face ID service ###

###> OAuth — Google ###
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
###< OAuth — Google ###

###> OAuth — GitHub ###
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
###< OAuth — GitHub ###

###> reCAPTCHA ###
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
###< reCAPTCHA ###

###> Stripe (payments) ###
STRIPE_PUBLIC_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_CURRENCY="eur"
###< Stripe ###

###> Misc third-party APIs ###
EXCHANGE_RATE_API_KEY="your_exchangerate_api_key"
OPENWEATHER_API_KEY="your_openweather_api_key"
OPENAI_API_KEY="sk-proj-xxx"
OPENROUTER_API_KEY="sk-or-v1-xxx"
###< Misc third-party APIs ###

###> Debug ###
VAR_DUMPER_SERVER=127.0.0.1:9912
###< Debug ###
